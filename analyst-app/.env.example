# Required — at least one provider
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional overrides
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ANALYST_MODEL=gemini-2.0-flash

# PropEdge board feed (defaults to production prop-feed)
PROPEDGE_FEED_URL=https://propedgemasters.netlify.app/.netlify/functions/prop-feed?sheet=propedge-main
