# Kimi via OpenRouter (recommended — one key, OpenAI-compatible)
OPENROUTER_API_KEY=
# Fastest Kimi on OpenRouter in our benchmarks (~1–2s vs 60s+ for k2.5/k2.6)
KIMI_MODEL=moonshotai/kimi-k2-0905
KIMI_MAX_OUTPUT_TOKENS=8192
KIMI_TIMEOUT_MS=90000
# Alternatives: moonshotai/kimi-k2.6 (slower, richer) | moonshotai/kimi-k2.5 (slowest)

# Or Kimi direct from Moonshot (platform.kimi.ai)
# MOONSHOT_API_KEY=
# KIMI_MODEL=kimi-k2.5
# KIMI_API_URL=https://api.moonshot.ai/v1/chat/completions

# Gemini fallback
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# PropEdge board feed (defaults to production prop-feed)
PROPEDGE_FEED_URL=https://propedgemasters.netlify.app/.netlify/functions/prop-feed?sheet=propedge-main
