# Required — Kimi primary, Gemini fallback (at least one required)
MOONSHOT_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional overrides
KIMI_MODEL=kimi-k2-turbo-preview
MOONSHOT_API_BASE=https://api.moonshot.ai/v1
GEMINI_MODEL=gemini-3.5-flash

# PropEdge board feed (defaults to production prop-feed)
PROPEDGE_FEED_URL=https://propedgemasters.netlify.app/.netlify/functions/prop-feed?sheet=propedge-main
