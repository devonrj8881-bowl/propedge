# ⚠️ CRITICAL: Scraper configuration files — MUST NOT be Git-tracked
# These files are environment-specific and subject to frequent fixes
# Git checkout operations would revert critical fixes (exit code 78 prevention)
# Standalone setup scripts handle initialization — no git dependency
com.propedge.scraper.REAL_MAC.plist
com.propedge.scraper.plist
com.propedge.*.plist
run-scraper-daemon.sh
propedge-daily-audit.js
scraper-v14.js
scraper-v13.js
logs/
*.VERIFIED
