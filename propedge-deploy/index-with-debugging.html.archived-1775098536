    // Map full team name → abbreviation using existing TEAM_ALIASES
    function teamNameToAbbr(fullName) {
      if (!fullName) return '';
      const upper = fullName.toUpperCase().trim();
      if (TEAM_ALIASES[upper]) return TEAM_ALIASES[upper];
      // Try words in reverse (nickname is usually last word: "Utah Jazz" → "JAZZ")
      const words = upper.split(' ');
      for (let i = words.length - 1; i >= 0; i--) {
        if (TEAM_ALIASES[words[i]]) return TEAM_ALIASES[words[i]];
      }
      // Try last two words combined ("Golden State" → "GOLDEN STATE")
      if (words.length >= 2) {
        const twoWord = words.slice(-2).join(' ');
        if (TEAM_ALIASES[twoWord]) return TEAM_ALIASES[twoWord];
      }
      return upper;
    }

