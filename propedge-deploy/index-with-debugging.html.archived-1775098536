    function detailToggleParlay(propId) {
      const prop = state.props.find(p => p.id === propId);
      if (!prop) return;
      const existing = state.parlay.find(x => x.id === propId);
      if (existing) {
        state.parlay = state.parlay.filter(x => x.id !== propId);
      } else {
        if (state.parlay.length >= 10) { showToast('Max 10 legs in parlay'); return; }
        state.parlay.push(prop);
      }
      renderParlay();
      updateParlayBadge();
      // Update button in panel
      const btn = document.querySelector('.detail-action-btn.primary, .detail-action-btn.added');
      if (btn) {
        const inParlay = state.parlay.find(x => x.id === propId);
        btn.className = `detail-action-btn ${inParlay ? 'added' : 'primary'}`;
        btn.textContent = inParlay ? '✓ In Parlay' : '+ Add to Parlay';
      }
    }

    // ── Build sport-specific field/court SVG graphic for the live tracker card ──
    function buildLiveFieldGraphic(game) {
      const league = game.league || '';

      if (league === 'NFL') {
        // Estimate ball position from possession team (rough 50% default, redzone = 85%)
        const ballPct = game.isRedZone ? 82 : (game.possession === game.homeTeam ? 60 : 40);
        const lines = Array.from({length: 9}, (_, i) =>
          `<div class="ltf-nfl-line" style="left:${(i+1)*10}%;"></div>`).join('');
        const driveText = game.downDistanceText
          ? `CURRENT DRIVE: ${game.downDistanceText}`
          : (game.shortDetail || 'IN PROGRESS');
        return `
          <div class="ltf-nfl">
            <div class="ltf-nfl-lines">${lines}</div>
            ${game.isRedZone ? '<div class="ltf-redzone-glow"></div>' : ''}
            <div class="ltf-ball-marker" style="left:calc(${ballPct}% - 9px);">
              <div class="ltf-ball-icon"></div>
            </div>
            <div class="ltf-drive-text">${driveText}</div>
          </div>`;

      } else if (league === 'NBA') {
        const qLabel = game.period <= 4 ? `Q${game.period}` : `OT${game.period - 4}`;
        return `
          <div class="ltf-nba">
            <div class="ltf-nba-court">
              <div class="ltf-nba-3pt"></div>
              <div class="ltf-nba-lane"></div>
              <div class="ltf-nba-circle"></div>
            </div>
            <span class="ltf-nba-label">${qLabel} ${game.displayClock || ''}</span>
          </div>`;

      } else if (league === 'NHL') {
        const pLabel = game.period <= 3 ? `Period ${game.period}` : 'Overtime';
        return `
          <div class="ltf-nhl">
            <div class="ltf-nhl-rink"></div>
            <div class="ltf-nhl-center"></div>
            <div class="ltf-nhl-blueline" style="left:30%;"></div>
            <div class="ltf-nhl-blueline" style="left:70%;"></div>
            <div class="ltf-nhl-dot" style="left:25%;top:30%;"></div>
            <div class="ltf-nhl-dot" style="left:25%;bottom:30%;"></div>
            <div class="ltf-nhl-dot" style="left:75%;top:30%;"></div>
            <div class="ltf-nhl-dot" style="left:75%;bottom:30%;"></div>
            <span class="ltf-nhl-label">${pLabel} ${game.displayClock ? '· ' + game.displayClock : ''}</span>
          </div>`;

      } else if (league === 'MLB') {
        const half = game.inningHalf === 'top' ? '▲' : '▼';
        const inLbl = game.inning ? `${half} ${game.inning}` : (game.shortDetail || '');
        const outs = game.outs ?? 0;
        const outDots = [0,1,2].map(i =>
          `<div class="ltf-mlb-out-dot${i < outs ? ' filled' : ''}"></div>`).join('');
        return `
          <div class="ltf-mlb">
            <div class="ltf-mlb-grass"></div>
            <div class="ltf-mlb-inning-overlay">
              <span style="font-size:9px;color:rgba(255,255,255,0.5);letter-spacing:0.04em;">${inLbl}</span>
              <div class="ltf-mlb-outs">${outDots}</div>
            </div>
            <div class="ltf-mlb-diamond">
              <div class="ltf-mlb-base home"></div>
              <div class="ltf-mlb-base first${game.onFirst ? ' occupied' : ''}"></div>
              <div class="ltf-mlb-base second${game.onSecond ? ' occupied' : ''}"></div>
              <div class="ltf-mlb-base third${game.onThird ? ' occupied' : ''}"></div>
            </div>
          </div>`;
      }
      return '';
    }

    // ── Live box score tracker — fetches actual current game stat from ESPN ──
    async function loadLivePlayerStat(prop) {
      const body = document.getElementById('liveStatBody');
      if (!body) return; // section not shown (game not live)

      const gameInfo = getGameInfo(prop.team, prop.league);
      if (!gameInfo || gameInfo.status !== 'live') return;

      const cfg = ESPN_SPORT_MAP[prop.league];
      if (!cfg) return;

      const pid = PLAYER_IDS[prop.player];
      const propLine = prop.line || 1;
      const propLower = prop.prop.toLowerCase();

      try {
        // ESPN boxscore endpoint for this specific game
        const boxUrl = `https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/summary?event=${gameInfo.gameId}`;
        const res = await fetch(boxUrl).catch(() => null);
        if (!res || !res.ok) throw new Error('box score fetch failed');
        const data = await res.json();

        // ── Pull sport-specific live stat columns ─────────────────────────
        let liveStat = null;    // the main tracked stat value (number)
        let statLabel = prop.prop; // display name
        let extraStats = [];   // [{label, val}] additional box-score context
        let sportCtxHtml = ''; // sport-specific situation chips

        // Resolve stat label(s) we're targeting
        const comboMap = {
          NBA: {
            'pts+reb+ast': ['points','rebounds','assists'],
            'pts + reb + ast': ['points','rebounds','assists'],
            'pts+reb':     ['points','rebounds'],
            'pts + reb':   ['points','rebounds'],
            'pts+ast':     ['points','assists'],
            'pts + ast':   ['points','assists'],
            'reb+ast':     ['rebounds','assists'],
            'reb + ast':   ['rebounds','assists'],
          },
          NHL: { 'points': ['goals','assists'] },
          MLB: {},
          NFL: {},
        };
        const singleMap = {
          NBA: { 'points':'points','pts':'points','rebounds':'rebounds','reb':'rebounds','assists':'assists','ast':'assists','threes':'threePointFieldGoalsMade','3-pt made':'threePointFieldGoalsMade','3pm':'threePointFieldGoalsMade','steals':'steals','blocks':'blocks','turnovers':'turnovers' },
          NHL: { 'goals':'goals','assists':'assists','points':'points','shots on goal':'shots','shots':'shots','sog':'shots','saves':'saves','pim':'penaltyMinutes' },
          MLB: { 'strikeouts':'strikeouts','hits':'hits','total bases':'totalBases','runs':'runs','rbis':'rbi','home runs':'homeRuns','walks':'baseOnBalls','earned runs':'earnedRuns','innings pitched':'inningsPitched' },
          NFL: { 'passing yards':'passingYards','rushing yards':'rushingYards','receiving yards':'receivingYards','receptions':'receptions','touchdowns':'touchdowns','completions':'completions','passing tds':'passingTouchdowns','interceptions':'interceptions','carries':'rushingAttempts' },
        };

        const leagueCombo = comboMap[prop.league] || {};
        const leagueSingle = singleMap[prop.league] || {};
        let targetKeys = null;
        for (const [key, cols] of Object.entries(leagueCombo)) {
          if (propLower.includes(key)) { targetKeys = cols; break; }
        }
        if (!targetKeys) {
          for (const [key, col] of Object.entries(leagueSingle)) {
            if (propLower.includes(key)) { targetKeys = [col]; break; }
          }
        }
        if (!targetKeys) targetKeys = null;

        // ── Extract from boxscore JSON ────────────────────────────────────
        // ESPN boxscore has athletes[] inside boxscore.players[]
        const boxPlayers = data.boxscore?.players || [];
        let foundAthlete = null;

        for (const team of boxPlayers) {
          const stats = team.statistics || [];
          for (const statGroup of stats) {
            const athletes = statGroup.athletes || [];
            for (const ath of athletes) {
              const athId = String(ath.athlete?.id || '');
              const athName = ath.athlete?.displayName || ath.athlete?.shortName || '';
              // Match by ESPN ID first, fallback name match
              if ((pid && athId === String(pid)) ||
                  athName.toLowerCase().includes(prop.player.split(' ').pop().toLowerCase())) {
                foundAthlete = { ath, statGroup };
                break;
              }
            }
            if (foundAthlete) break;
          }
          if (foundAthlete) break;
        }

        if (foundAthlete) {
          const { ath, statGroup } = foundAthlete;
          const labels = statGroup.labels || statGroup.keys || [];
          const vals   = ath.stats || [];

          const getVal = (key) => {
            // key can be camelCase ESPN key OR short label
            // Try both label match and key name
            const lblIdx  = labels.findIndex(l => l.toLowerCase() === key.toLowerCase());
            if (lblIdx >= 0) return parseFloat(vals[lblIdx]) || 0;
            // also try statGroup.keys
            const keyList = statGroup.keys || [];
            const keyIdx  = keyList.findIndex(k => k.toLowerCase() === key.toLowerCase());
            if (keyIdx >= 0) return parseFloat(vals[keyIdx]) || 0;
            return null;
          };

          // Sum target keys
          if (targetKeys) {
            let total = 0;
            let found = false;
            for (const k of targetKeys) {
              const v = getVal(k);
              if (v !== null) { total += v; found = true; }
            }
            if (found) liveStat = Math.round(total * 10) / 10;
          }

          // Extra box-score context per league
          if (prop.league === 'NBA') {
            const pts   = getVal('points');
            const reb   = getVal('rebounds') ?? getVal('totalRebounds');
            const ast   = getVal('assists');
            const min   = getVal('minutes') ?? getVal('MIN');
            const fg    = getVal('fieldGoalsMade') !== null ? `${getVal('fieldGoalsMade')}/${getVal('fieldGoalsAttempted')}` : null;
            const tp    = getVal('threePointFieldGoalsMade') !== null ? `${getVal('threePointFieldGoalsMade')}/${getVal('threePointFieldGoalsAttempted')}` : null;
            if (pts   !== null) extraStats.push({ label: 'PTS',  val: pts });
            if (reb   !== null) extraStats.push({ label: 'REB',  val: reb });
            if (ast   !== null) extraStats.push({ label: 'AST',  val: ast });
            if (fg)             extraStats.push({ label: 'FG',   val: fg  });
            if (tp)             extraStats.push({ label: '3PM',  val: tp  });
            if (min   !== null) extraStats.push({ label: 'MIN',  val: min });
            // Sport context
            const qLabel = gameInfo.period <= 4 ? `Q${gameInfo.period}` : `OT${gameInfo.period - 4}`;
            sportCtxHtml = `<span class="detail-live-chip pace">${qLabel}</span>`;
            if (gameInfo.displayClock) sportCtxHtml += `<span class="detail-live-chip pace edge">⏱ ${gameInfo.displayClock}</span>`;
            if (gameInfo.homeTimeouts !== null) sportCtxHtml += `<span class="detail-live-chip pace edge">${gameInfo.awayTeam} ${gameInfo.awayTimeouts}TO · ${gameInfo.homeTeam} ${gameInfo.homeTimeouts}TO</span>`;

          } else if (prop.league === 'NHL') {
            const g   = getVal('goals') ?? getVal('G');
            const a   = getVal('assists') ?? getVal('A');
            const s   = getVal('shots') ?? getVal('S');
            const toi = getVal('timeOnIce') ?? getVal('TOI');
            const pim = getVal('penaltyMinutes') ?? getVal('PIM');
            if (g   !== null) extraStats.push({ label: 'G',   val: g   });
            if (a   !== null) extraStats.push({ label: 'A',   val: a   });
            if (s   !== null) extraStats.push({ label: 'SOG', val: s   });
            if (toi !== null) extraStats.push({ label: 'TOI', val: toi });
            if (pim !== null) extraStats.push({ label: 'PIM', val: pim });
            const pLabel = gameInfo.period <= 3 ? `P${gameInfo.period}` : 'OT';
            sportCtxHtml = `<span class="detail-live-chip pace">${pLabel}</span>`;
            if (gameInfo.displayClock) sportCtxHtml += `<span class="detail-live-chip pace edge">⏱ ${gameInfo.displayClock}</span>`;
            if (gameInfo.homeSog) sportCtxHtml += `<span class="detail-live-chip pace edge">SOG ${gameInfo.awaySog}–${gameInfo.homeSog}</span>`;

          } else if (prop.league === 'MLB') {
            const h   = getVal('hits')       ?? getVal('H');
            const r   = getVal('runs')       ?? getVal('R');
            const rbi = getVal('rbi')        ?? getVal('RBI');
            const hr  = getVal('homeRuns')   ?? getVal('HR');
            const bb  = getVal('baseOnBalls') ?? getVal('BB');
            const k   = getVal('strikeouts') ?? getVal('K');
            const ip  = getVal('inningsPitched') ?? getVal('IP');
            const er  = getVal('earnedRuns') ?? getVal('ER');
            if (h   !== null) extraStats.push({ label: 'H',   val: h   });
            if (r   !== null) extraStats.push({ label: 'R',   val: r   });
            if (rbi !== null) extraStats.push({ label: 'RBI', val: rbi });
            if (hr  !== null) extraStats.push({ label: 'HR',  val: hr  });
            if (bb  !== null) extraStats.push({ label: 'BB',  val: bb  });
            if (k   !== null) extraStats.push({ label: 'K',   val: k   });
            if (ip  !== null) extraStats.push({ label: 'IP',  val: ip  });
            if (er  !== null) extraStats.push({ label: 'ER',  val: er  });
            const half = gameInfo.inningHalf === 'top' ? '▲' : '▼';
            const inLbl = gameInfo.inning ? `${half} ${gameInfo.inning}` : (gameInfo.shortDetail || 'LIVE');
            sportCtxHtml = `<span class="detail-live-chip pace">${inLbl}</span>`;
            if (gameInfo.outs !== null) sportCtxHtml += `<span class="detail-live-chip pace edge">${gameInfo.outs} out${gameInfo.outs !== 1 ? 's' : ''}</span>`;
            if (gameInfo.balls !== null && gameInfo.strikes !== null) sportCtxHtml += `<span class="detail-live-chip count">${gameInfo.balls}–${gameInfo.strikes} count</span>`;

          } else if (prop.league === 'NFL') {
            const pyds = getVal('passingYards')    ?? getVal('YDS');
            const ryds = getVal('rushingYards')    ?? getVal('YDS');
            const recyds = getVal('receivingYards');
            const rec  = getVal('receptions')      ?? getVal('REC');
            const td   = getVal('touchdowns')      ?? getVal('TD');
            const cmp  = getVal('completions')     ?? getVal('CMP');
            const att  = getVal('attempts')        ?? getVal('ATT');
            const car  = getVal('rushingAttempts') ?? getVal('CAR');
            if (cmp  !== null && att !== null) extraStats.push({ label: 'CMP/ATT', val: `${cmp}/${att}` });
            if (pyds !== null) extraStats.push({ label: 'PASS YDS', val: pyds });
            if (ryds !== null) extraStats.push({ label: 'RUSH YDS', val: ryds });
            if (rec  !== null) extraStats.push({ label: 'REC',      val: rec  });
            if (recyds !== null) extraStats.push({ label: 'REC YDS', val: recyds });
            if (td   !== null) extraStats.push({ label: 'TD',       val: td   });
            if (car  !== null) extraStats.push({ label: 'CAR',      val: car  });
            const qLabel = gameInfo.period <= 4 ? `Q${gameInfo.period}` : 'OT';
            sportCtxHtml = `<span class="detail-live-chip pace">${qLabel}</span>`;
            if (gameInfo.displayClock) sportCtxHtml += `<span class="detail-live-chip pace edge">⏱ ${gameInfo.displayClock}</span>`;
            if (gameInfo.downDistanceText) sportCtxHtml += `<span class="detail-live-chip down">${gameInfo.downDistanceText}</span>`;
            if (gameInfo.isRedZone) sportCtxHtml += `<span class="detail-live-chip risk">🔴 Red Zone</span>`;
            if (gameInfo.possession) sportCtxHtml += `<span class="detail-live-chip pace edge">🏈 ${gameInfo.possession}</span>`;
          }
        }

        // ── If we still have no liveStat, fall back to l10Avg with a note ─
        const usingFallback = liveStat === null;
        if (usingFallback) liveStat = prop.l10Avg || 0;

        // ── Build the rendered HTML ───────────────────────────────────────
        const pct       = Math.min(100, Math.round((liveStat / propLine) * 100));
        const maxScale  = Math.max(liveStat, propLine) * 1.25;
        const markerLeft = Math.min(96, Math.round((propLine / maxScale) * 100));
        const valClass  = liveStat >= propLine * 1.1 ? 'ahead' : liveStat < propLine * 0.85 ? 'behind' : 'ontrack';
        const barColor  = liveStat >= propLine * 1.1 ? 'var(--accent-green)' : liveStat < propLine * 0.85 ? 'var(--accent-red)' : 'var(--accent-gold)';

        // Pace projection: linear extrapolation using L10 avg as season benchmark
        const paceProjected  = usingFallback ? (prop.l10Avg * 1.05).toFixed(1) : liveStat.toFixed(1);
        const paceClass      = parseFloat(paceProjected) >= propLine ? 'pace' : 'pace behind';
        const paceLabel      = parseFloat(paceProjected) >= propLine ? '↗ On Pace' : '↘ Below Pace';

        // Edge drift
        const pregameEdge = prop.edge || 0;
        const paceEdge    = parseFloat(((prop.l10Avg / propLine - 1) * 100 * 0.6 + pregameEdge * 0.4).toFixed(1));
        const edgeDrift   = paceEdge - pregameEdge;
        const edgeChipClass = edgeDrift > 0 ? 'pace' : 'pace edge';
        const edgeLabel   = `${edgeDrift >= 0 ? '↗ Edge +' : '↘ Edge '}${paceEdge > 0 ? '+' : ''}${paceEdge}%`;

        // Risk flags
        const riskChips = [];
        if (prop.league === 'NBA' && gameInfo.period >= 4) riskChips.push('Late game — DNP risk');
        if (prop.league === 'MLB' && gameInfo.inning >= 7)  riskChips.push('Late innings');
        if (prop.league === 'NFL' && gameInfo.isRedZone)    riskChips.push('Red Zone — RB spike');
        if (prop.league === 'NHL' && gameInfo.period >= 3)  riskChips.push(`P${gameInfo.period} — TOI watch`);

        // Update situation text
        const sitEl = document.getElementById('liveSituation');
        if (sitEl) {
          const sitParts = [];
          if (gameInfo.league === 'NFL' && gameInfo.downDistanceText) sitParts.push(gameInfo.downDistanceText);
          else if (gameInfo.league === 'MLB' && gameInfo.pitcher) sitParts.push(`P: ${gameInfo.pitcher}`);
          else if (gameInfo.league === 'NHL' && gameInfo.homeSog) sitParts.push(`SOG ${gameInfo.awaySog}–${gameInfo.homeSog}`);
          else if (gameInfo.league === 'NBA' && gameInfo.homeTimeouts !== null) sitParts.push(`${gameInfo.awayTeam} ${gameInfo.awayTimeouts}TO · ${gameInfo.homeTeam} ${gameInfo.homeTimeouts}TO`);
          sitEl.textContent = sitParts.join(' · ') || gameInfo.shortDetail || '';
        }

        body.innerHTML = `
          <div class="live-tracker-stats">
            <!-- Main stat vs line bar -->
            <div class="live-tracker-stat-row">
              <div class="live-tracker-stat-top">
                <span class="live-tracker-stat-label">${prop.prop}</span>
                <span class="live-tracker-stat-val ${valClass}">
                  ${usingFallback ? '~' : ''}${liveStat} <span style="font-size:10px;color:var(--text-muted);font-weight:400;">/ ${propLine} line</span>
                </span>
              </div>
              <div class="live-tracker-bar-bg" style="margin-top:6px;">
                <div class="live-tracker-bar-fill" style="width:${pct}%;background:${barColor};"></div>
                <div class="live-tracker-bar-marker" style="left:${markerLeft}%;"></div>
              </div>
            </div>

            <!-- Chips -->
            <div class="live-tracker-chips">
              <span class="live-tracker-chip ${parseFloat(paceProjected) >= propLine ? 'green' : 'red'}">${paceLabel}: ${paceProjected}</span>
              <span class="live-tracker-chip ${edgeDrift >= 0 ? 'green' : 'gold'}">${edgeLabel}</span>
              ${riskChips.map(r => `<span class="live-tracker-chip red">⚠ ${r}</span>`).join('')}
              ${usingFallback ? '<span class="live-tracker-chip muted" style="font-size:8px;">avg estimate</span>' : ''}
            </div>

            <!-- Full box score mini grid -->
            ${extraStats.length ? `
            <div class="live-tracker-box-row">
              ${extraStats.slice(0, 8).map(s => `
                <div class="live-tracker-box-cell">
                  <div class="live-tracker-box-val">${s.val}</div>
                  <div class="live-tracker-box-label">${s.label}</div>
                </div>`).join('')}
            </div>` : ''}
          </div>`;

      } catch (err) {
        if (body) body.innerHTML = `<div style="font-size:10px;color:var(--text-muted);padding:4px 0;">Live stat unavailable</div>`;
        console.warn('loadLivePlayerStat error:', err);
      }
    }

    async function loadDetailStats(prop) {
      const cfg = ESPN_SPORT_MAP[prop.league];
      if (!cfg) return;

      const pid = PLAYER_IDS[prop.player];
      if (!pid) {
        document.getElementById('sznStatsGrid').innerHTML = '<div class="detail-szn-loading" style="color:var(--text-muted)">Stats not available</div>';
        document.getElementById('gamelogChart').innerHTML = '<div class="detail-gamelog-loading" style="font-size:11px">Game log not available</div>';
        return;
      }

      const cacheKey = `${prop.league}-${pid}`;

      // Use cache if available
      if (detailCache[cacheKey]) {
        renderDetailStats(prop, detailCache[cacheKey]);
        return;
      }

      try {
        const [statsRes, logRes] = await Promise.all([
          fetch(`https://site.web.api.espn.com/apis/common/v3/sports/${cfg.sport}/${cfg.league}/athletes/${pid}/stats`).catch(() => null),
          fetch(`https://site.web.api.espn.com/apis/common/v3/sports/${cfg.sport}/${cfg.league}/athletes/${pid}/gamelog?season=${cfg.season}`).catch(() => null),
        ]);

        const statsData = statsRes?.ok ? await statsRes.json() : null;
        const logData   = logRes?.ok   ? await logRes.json()   : null;

        const result = { statsData, logData };
        detailCache[cacheKey] = result;
        renderDetailStats(prop, result);
      } catch (e) {
        document.getElementById('sznStatsGrid').innerHTML = '<div class="detail-szn-loading" style="color:var(--text-muted)">Could not load stats</div>';
        document.getElementById('gamelogChart').innerHTML = '<div class="detail-gamelog-loading" style="font-size:11px">Could not load game log</div>';
      }
    }

    function renderDetailStats(prop, { statsData, logData }) {
      // ── Season stats ──────────────────────────────────────
      const sznGrid = document.getElementById('sznStatsGrid');
      if (statsData) {
        try {
          const cats = statsData.categories || [];
          const avgCat = cats.find(c => c.displayName?.toLowerCase().includes('average') && c.displayName?.toLowerCase().includes('regular'));
          if (avgCat) {
            const labels = avgCat.labels || [];
            const stats  = avgCat.statistics || [];
            // Find current season (highest year)
            const sorted = [...stats].sort((a, b) => {
              const ya = a.season?.displayName?.match(/(\d{4})/)?.[1] || '0';
              const yb = b.season?.displayName?.match(/(\d{4})/)?.[1] || '0';
              return parseInt(yb) - parseInt(ya);
            });
            const current = sorted[0];
            if (current) {
              const vals = current.stats || [];
              // Pick best display stats based on league
              const wanted = {
                NBA: ['MIN','PTS','REB','AST','FG%','3P%','STL','BLK','TO'],
                NHL: ['G','A','PTS','+/-','S','SPCT','PPG','PIM'],
                MLB: ['AVG','HR','RBI','R','H','BB','K','OBP','SLG'],
                NFL: ['CMP','ATT','YDS','TD','INT','AVG','REC','LNG'],
              }[prop.league] || labels.slice(0, 8);

              const cells = wanted.map(stat => {
                const idx = labels.indexOf(stat);
                const val = idx >= 0 && vals[idx] ? vals[idx] : '—';
                // Simplify fractions (e.g. "4.5-9.3" → show as "4.5")
                const display = val.includes('-') ? val.split('-')[0] : val;
                return `<div class="detail-szn-cell">
                  <div class="detail-szn-val">${display}</div>
                  <div class="detail-szn-label">${stat}</div>
                </div>`;
              }).join('');

              sznGrid.innerHTML = cells || '<div class="detail-szn-loading">No data</div>';
            } else {
              sznGrid.innerHTML = '<div class="detail-szn-loading">No season data</div>';
            }
          } else {
            sznGrid.innerHTML = '<div class="detail-szn-loading">No avg data</div>';
          }
        } catch (e) {
          sznGrid.innerHTML = '<div class="detail-szn-loading">Parse error</div>';
        }
      } else {
        sznGrid.innerHTML = '<div class="detail-szn-loading" style="color:var(--text-muted)">Stats unavailable</div>';
      }

      // ── Game log chart ────────────────────────────────────
      const chart = document.getElementById('gamelogChart');
      if (!logData) {
        chart.innerHTML = '<div class="detail-gamelog-loading" style="font-size:11px">Game log unavailable</div>';
        return;
      }
      try {
        const labels    = logData.labels || [];
        const eventsMeta = logData.events || {};
        const seasonTypes = logData.seasonTypes || [];

        // Collect ALL games from the regular season across all monthly categories
        // ESPN splits gamelog by month — must merge them all then sort newest-first
        let games = [];
        const regularSeason = seasonTypes.find(st => st.displayName?.toLowerCase().includes('regular'));
        if (regularSeason) {
          for (const cat of (regularSeason.categories || [])) {
            games.push(...(cat.events || []));
          }
          // Sort by eventId descending (higher ID = more recent game)
          games.sort((a, b) => parseInt(b.eventId) - parseInt(a.eventId));
        }
        // Fallback: if no regular season found, use largest single category
        if (!games.length) {
          for (const st of seasonTypes) {
            for (const cat of (st.categories || [])) {
              if ((cat.events || []).length > games.length) games = cat.events || [];
            }
          }
        }

        // ── Combo prop detection ────────────────────────────────
        // Map prop type to ONE or MORE ESPN stat labels to sum together
        const propLower = prop.prop.toLowerCase();

        // Define multi-stat combos explicitly
        const COMBO_MAP = {
          NBA: {
            'pts+reb+ast':   ['PTS','REB','AST'],
            'pts + reb + ast': ['PTS','REB','AST'],
            'points + rebounds + assists': ['PTS','REB','AST'],
            'pts+reb':       ['PTS','REB'],
            'pts + reb':     ['PTS','REB'],
            'points + rebounds': ['PTS','REB'],
            'pts+ast':       ['PTS','AST'],
            'pts + ast':     ['PTS','AST'],
            'points + assists': ['PTS','AST'],
            'reb+ast':       ['REB','AST'],
            'reb + ast':     ['REB','AST'],
            'rebounds + assists': ['REB','AST'],
          },
          NHL: {
            'points':        ['G','A'],  // goals + assists = points in hockey
          },
          MLB: {},
          NFL: {
            'passing + rushing yards': ['YDS','YDS'], // not ideal but best we have
          },
        };

        // Check combo map first
        const comboMap = COMBO_MAP[prop.league] || {};
        let targetLabels = null; // array of labels to sum

        for (const [key, lbls] of Object.entries(comboMap)) {
          if (propLower.includes(key) || propLower === key) {
            targetLabels = lbls;
            break;
          }
        }

        // Fall back to single-stat map
        if (!targetLabels) {
          const statMap = PROP_STAT_MAP[prop.league] || {};
          for (const [key, lbl] of Object.entries(statMap)) {
            if (propLower.includes(key)) {
              targetLabels = [lbl];
              break;
            }
          }
        }

        // Last resort default
        if (!targetLabels) targetLabels = [labels[labels.length - 1]];

        // Resolve label indexes (deduplicate for NHL points hack)
        const statIndexes = [...new Set(targetLabels.map(lbl => labels.indexOf(lbl)).filter(i => i >= 0))];

        const chartLabel = targetLabels.join('+');

        // Take last 20 games (they come newest first) — matches L20 hit rate display
        const recent = games.slice(0, 20).reverse();

        if (!recent.length) {
          chart.innerHTML = '<div class="detail-gamelog-loading" style="font-size:11px">No recent games found</div>';
          return;
        }

        const parsed = recent.map(ev => {
          const stats = ev.stats || [];
          // Sum all relevant columns
          let val = 0;
          for (const idx of statIndexes) {
            let rawVal = idx >= 0 ? stats[idx] : null;
            // Handle "made-attempted" strings — take made side
            if (rawVal && String(rawVal).includes('-')) rawVal = String(rawVal).split('-')[0];
            val += parseFloat(rawVal) || 0;
          }
          // Round to 1 decimal for display
          val = Math.round(val * 10) / 10;
          const meta = eventsMeta[String(ev.eventId)] || {};
          const opp  = meta.opponent?.abbreviation || '?';
          const atVs = meta.atVs || '';
          const result = meta.gameResult || '';
          // Use >= to match PropFinder sheet hit rate logic (over OR equal = hit)
          const hit  = val >= prop.line ? 'hit' : 'miss';
          return { val, opp, atVs, result, hit };
        });

        const maxVal = Math.max(...parsed.map(g => g.val), prop.line * 1.5, 1);

        const bars = parsed.map(g => {
          const heightPct = Math.max((g.val / maxVal) * 100, 3);
          const linePosPct = (prop.line / maxVal) * 100;
          return `
            <div class="detail-gamelog-bar-wrap">
              <div class="detail-gamelog-val">${g.val > 0 ? g.val : '0'}</div>
              <div class="detail-gamelog-bar-container">
                <div class="detail-gamelog-bar ${g.hit}"
                  style="height:${heightPct}%;"
                  title="${g.atVs} ${g.opp} (${g.result}): ${g.val} ${chartLabel}">
                </div>
              </div>
              <div class="detail-gamelog-opp">${g.atVs}${g.opp}</div>
            </div>
          `;
        }).join('');

        // Prop line overlay — position relative to chart area
        const linePct = Math.min((prop.line / maxVal) * 100, 95);

        // ── Recalculate L5/L10/L20/Season from ESPN gamelog (newest-first order) ──
        // Arrow functions avoid function-declaration-in-block issues in strict mode
        const calcHitPct = (gameList, n) => {
          const slice = gameList.slice(0, n);
          if (!slice.length) return null;
          let hits = 0;
          for (const ev of slice) {
            const evStats = ev.stats || [];
            let v = 0;
            for (const idx of statIndexes) {
              let raw = idx >= 0 ? evStats[idx] : null;
              if (raw && String(raw).includes('-')) raw = String(raw).split('-')[0];
              v += parseFloat(raw) || 0;
            }
            if (Math.round(v * 10) / 10 >= prop.line) hits++;
          }
          return Math.round((hits / slice.length) * 100);
        };

        const calcSeasonPct = (gameList) => {
          if (!gameList.length) return null;
          let hits = 0;
          for (const ev of gameList) {
            const evStats = ev.stats || [];
            let v = 0;
            for (const idx of statIndexes) {
              let raw = idx >= 0 ? evStats[idx] : null;
              if (raw && String(raw).includes('-')) raw = String(raw).split('-')[0];
              v += parseFloat(raw) || 0;
            }
            if (Math.round(v * 10) / 10 >= prop.line) hits++;
          }
          return Math.round((hits / gameList.length) * 100);
        };

        const espnL5  = calcHitPct(games, 5);
        const espnL10 = calcHitPct(games, 10);
        const espnL20 = calcHitPct(games, 20);
        const espnSzn = calcSeasonPct(games);

        // Update the hit rate grid with ESPN-calculated values
        const hitRateGrid = document.getElementById('hitRateGrid');
        if (hitRateGrid) {
          const espnRates = [
            { label: 'Last 5',  pct: espnL5  ?? prop.l5Pct   },
            { label: 'Last 10', pct: espnL10 ?? prop.l10Pct  },
            { label: 'Last 20', pct: espnL20 ?? prop.l20Pct  },
            { label: 'Season',  pct: espnSzn ?? prop.seasonPct },
          ];
          hitRateGrid.innerHTML = espnRates.map(h => `
            <div class="detail-hitrate-item">
              <div class="detail-hitrate-top">
                <span class="detail-hitrate-label">${h.label}</span>
                <span class="detail-hitrate-pct" style="color:${barColor(h.pct)}">${h.pct.toFixed(0)}%</span>
              </div>
              <div class="detail-hitrate-bar-bg">
                <div class="detail-hitrate-bar-fill" style="width:${h.pct}%;background:${barColor(h.pct)};"></div>
              </div>
            </div>
          `).join('');
        }

        // Calculate hit count for summary label
        const hitCount20 = parsed.filter(g => g.hit === 'hit').length;
        const hitPct20 = espnL20 ?? Math.round((hitCount20 / parsed.length) * 100);
        const hitColor20 = hitPct20 >= 70 ? 'var(--accent-green)' : hitPct20 < 50 ? 'var(--accent-red)' : 'var(--accent-gold)';

        chart.style.position = 'relative';
        chart.innerHTML = `
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:10px;color:var(--text-muted);">Oldest → Most Recent</span>
            <span style="font-size:11px;font-weight:700;color:${hitColor20};">${hitCount20}/${parsed.length} hits (${hitPct20}%)</span>
          </div>
          <div style="width:100%;display:flex;flex-direction:column;gap:0;">
            <div style="position:relative;height:90px;display:flex;align-items:flex-end;gap:2px;padding-top:12px;">
              ${bars.replace(/<div class="detail-gamelog-bar-wrap">/g, '<div class="detail-gamelog-bar-wrap" style="position:relative;flex:1;">')}
              <!-- Prop line -->
              <div style="
                position:absolute;
                left:0;right:0;
                bottom:${linePct}%;
                height:1.5px;
                background: rgba(255,255,255,0.3);
                border-top: 1.5px dashed rgba(255,255,255,0.55);
                pointer-events:none;
                z-index:2;
              ">
                <span style="
                  position:absolute;right:0;top:-10px;
                  font-size:7px;
                  font-family:'JetBrains Mono',monospace;
                  color:rgba(255,255,255,0.5);
                  background:var(--bg-card);
                  padding:1px 3px;border-radius:2px;
                ">${prop.line}</span>
              </div>
            </div>
          </div>
        `;
      } catch (e) {
        chart.innerHTML = `<div class="detail-gamelog-loading" style="font-size:11px;color:var(--accent-red)">${e.message}</div>`;
        console.error('Gamelog chart error:', e);
      }
    }

    // Close on overlay click — element is defined after this script tag, so defer to DOMContentLoaded
    document.addEventListener('DOMContentLoaded', function() {
      const _ov = document.getElementById('detailOverlay');
      if (_ov) _ov.addEventListener('click', closePlayerDetail);
    });

    // ==========================================
    // APP RESUME / BACKGROUND STALE-DATA FIX
    // Handles: iOS Home Screen PWA suspend/resume,
    // tab switching, app backgrounding
    // ==========================================
    let _lastRefreshAt  = 0;
    let _isRefreshing   = false;
    const STALE_AFTER_MS = 45 * 1000; // consider data stale if unseen for 45s

    // Central refresh — calls all live data sources, then rerenders everything visible
    async function refreshAllData({ force = false } = {}) {
      const now = Date.now();
      if (_isRefreshing) return;
      // Debounce: don't fire more than once every 5s unless forced
      if (!force && now - _lastRefreshAt < 5000) return;

      _isRefreshing = true;
      try {
        // Parallel fetch: games (ESPN) + props (Sheet) + FD lines
        await Promise.all([
          fetchGames(),
          loadData(),
        ]);
        // Non-critical extras after main data
        loadFanDuelLinesFromSheet().catch(() => {});
        loadLineMovement().catch(() => {});
        _lastRefreshAt = Date.now();
        rerenderAllVisibleUI();
      } catch (err) {
        console.warn('[PropEdge] refreshAllData error:', err);
      } finally {
        _isRefreshing = false;
      }
    }

    // Rerender everything that could be open/visible right now
    function rerenderAllVisibleUI() {
      // Props list
      if (typeof renderProps === 'function') renderProps();

      // Game ticker
      const allGames = [
        ...(state.games.NBA || []),
        ...(state.games.NHL || []),
        ...(state.games.MLB || []),
        ...(state.games.NFL || []),
      ];
      if (allGames.length && typeof renderTicker === 'function') renderTicker(allGames);

      // Player detail panel — rerender from latest store so it doesn't show stale data
      if (_activeDetailPropId) {
        const fresh = state.props.find(p => p.id === _activeDetailPropId);
        if (fresh) openPlayerDetail(_activeDetailPropId);
      }

      // If a game modal is open, refresh it too
      const gameModal = document.getElementById('gameModal');
      if (gameModal && gameModal.classList.contains('open') && _modalState?.game) {
        // Re-fetch latest version of that game from state
        const lg = _modalState.game.league;
        const freshGame = (state.games[lg] || []).find(g => g.id === _modalState.game.id);
        if (freshGame) {
          // Only do a full modal rebuild when game STATUS changes (upcoming→live, live→final).
          // For same-status updates, just keep the stored reference current —
          // _refreshModalData() already handles score/clock/leaders every 10s without
          // destroying the DOM (and killing the countdown timer).
          if (freshGame.status !== _modalState.game.status) {
            openGameModal(freshGame);
          } else {
            _modalState.game = freshGame;
            // Re-seed the 1-second countdown if it stopped (0:00 end of period, or never
            // started because displayClock was empty when modal first opened).
            if (freshGame.status === 'live' &&
                freshGame.displayClock &&
                freshGame.league !== 'MLB' &&
                !_modalState.countdownTimer) {
              _startCountdown(freshGame.displayClock, freshGame.period, freshGame.league, true);
            }
          }
        }
      }

      // Update status indicators
      if (typeof updateStatus === 'function') updateStatus();
      if (typeof updateStats  === 'function') updateStats();
    }

    // Restart all background timers (they die when iOS suspends the app)
    function _restartAllTimers() {
      // Auto-refresh interval
      if (state.autoRefresh) startAutoRefresh();

      // Live ticker poll + 1-second clock countdown — restart if any live games in state
      _stopLiveTickerPoll();   // also calls _stopTickerClockCountdown
      const liveGames = [
        ...(state.games.NBA || []), ...(state.games.NHL || []),
        ...(state.games.MLB || []), ...(state.games.NFL || []),
      ].filter(g => g.status === 'live');
      if (liveGames.length) {
        _startLiveTickerPoll();  // also calls _startTickerClockCountdown
      }

      // Injury / lineup / news / ticket timers
      if (_injState) {
        if (_injState.refreshTimer) { clearInterval(_injState.refreshTimer); _injState.refreshTimer = null; }
        if (_injState.lineupTimer)  { clearInterval(_injState.lineupTimer);  _injState.lineupTimer  = null; }
        if (_injState.newsTimer)    { clearInterval(_injState.newsTimer);    _injState.newsTimer    = null; }
        if (_injState.ticketTimer)  { clearInterval(_injState.ticketTimer);  _injState.ticketTimer  = null; }

        // Only restart if the tracker panel has been opened at least once
        if (_injState.loaded) {
          _injState.refreshTimer = setInterval(refreshInjuryTracker, 15 * 60 * 1000);
          _injState.lineupTimer  = setInterval(async () => {
            await loadLineupsForLeague(_injState.lineupLeague);
            if (typeof renderProps === 'function') renderProps();
          }, 10 * 60 * 1000);
          _injState.newsTimer    = setInterval(async () => {
            await _fetchNews(_injState.lineupLeague);
          }, 30 * 60 * 1000);
          _injState.ticketTimer  = setInterval(async () => {
            await _ticketCheckStatusChanges();
          }, 90 * 1000);
        }
      }
    }

    // Called whenever the app becomes visible / focused after being away
    function handleAppResume() {
      const isStale = Date.now() - _lastRefreshAt > STALE_AFTER_MS;
      _restartAllTimers();
      if (isStale) refreshAllData({ force: true });
    }

    // visibilitychange — fires when tab or Home Screen app is foregrounded
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        handleAppResume();
      } else {
        // App going to background — stop auto-refresh to save battery / prevent stale intervals
        stopAutoRefresh();
      }
    });

    // focus — backup for desktop and some Android browsers
    window.addEventListener('focus', handleAppResume);

    // pageshow — fires when iOS restores page from bfcache (back/forward cache)
    window.addEventListener('pageshow', (event) => {
      handleAppResume();
      if (event.persisted) {
        // Page was served from bfcache — force a hard refresh
        refreshAllData({ force: true });
      }
    });

    // ==========================================
    // Close game modal on overlay click — deferred because element is defined after this script
    document.addEventListener('DOMContentLoaded', function() {
      const _go = document.getElementById('gameOverlay');
      if (_go) _go.addEventListener('click', function(e) {
        e.stopPropagation();
        closeGameModal();
      });
    });

    // Close on back button / escape; arrow keys cycle game bar
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closePlayerDetail(); closeGameModal(); return; }

      // Arrow keys navigate the game bar (left/right)
      if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        // Don't hijack arrow keys when user is typing in an input/textarea
        if (document.activeElement && (
          document.activeElement.tagName === 'INPUT' ||
          document.activeElement.tagName === 'TEXTAREA' ||
          document.activeElement.isContentEditable
        )) return;

        const ticker = document.getElementById('gamesTicker');
        if (!ticker) return;
        const cards = Array.from(ticker.querySelectorAll('.live-game-card'));
        if (!cards.length) return;

        // Find currently active card index
        const activeIdx = cards.findIndex(c => c.classList.contains('active'));

        let nextIdx;
        if (activeIdx === -1) {
          // Nothing selected yet — start at first or last depending on direction
          nextIdx = e.key === 'ArrowRight' ? 0 : cards.length - 1;
        } else {
          nextIdx = e.key === 'ArrowRight'
            ? Math.min(activeIdx + 1, cards.length - 1)
            : Math.max(activeIdx - 1, 0);
        }

        // Don't do anything if we're already at the edge
        if (nextIdx === activeIdx) return;

        e.preventDefault(); // prevent page scroll

        const nextCard = cards[nextIdx];
        const gameId = nextCard.getAttribute('data-gameid');
        // Derive league from data-league attr or fall back to state
        const leagueAttr = nextCard.getAttribute('data-league');
        const league = leagueAttr || (() => {
          // Find it in state.games
          for (const [lg, games] of Object.entries(state.games || {})) {
            if (games.some(g => String(g.id) === String(gameId))) return lg;
          }
          return 'NBA';
        })();

        selectGame(gameId, league, null);

        // Scroll the card into view within the horizontal bar
        nextCard.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
      }
    });

  </script>
  <!-- Player Detail Panel -->
  <div class="detail-overlay" id="detailOverlay"></div>
  <div class="detail-panel" id="detailPanel">
    <div class="detail-scroll" id="detailContent">
      <!-- populated by JS -->
    </div>
  </div>

  <!-- Game Modal -->
  <div class="game-overlay" id="gameOverlay"></div>
  <div class="game-modal" id="gameModal">
    <div class="game-modal-scroll" id="gameModalContent">
      <!-- populated by JS -->
    </div>
  </div>

</body>
</html>
