    function updateStatus() {
      const now = new Date();
      const hour = now.getHours();
      const isLateNight = hour >= 23 || hour < 9;
      
      // Check if all ESPN games are final (no upcoming or live games)
      const allGames = [...state.games.NBA, ...state.games.NHL, ...state.games.MLB, ...state.games.NFL];
      const hasUpcomingOrLive = allGames.some(g => g.status === 'upcoming' || g.status === 'live');
      const allGamesFinished = allGames.length > 0 && !hasUpcomingOrLive;
      
      // Calculate next update
      let nextUpdate = '11:30 AM';
      if (hour >= 11 && hour < 18) {
        nextUpdate = '6:30 PM';
      } else if (hour >= 18 && hour < 23) {
        nextUpdate = '11:30 AM';
      }
      
      const indicator = document.querySelector('.live-indicator');
      const dot = document.querySelector('.live-dot');
      
      if (isLateNight || allGamesFinished) {
        // Late night or all games done — show next update time
        document.getElementById('statusText').textContent = `NEXT: ${nextUpdate}`;
        indicator.style.background = 'var(--accent-orange-dim)';
        indicator.style.color = 'var(--accent-orange)';
        dot.style.background = 'var(--accent-orange)';
        dot.style.animation = 'none';
      } else if (allGames.some(g => g.status === 'live') && state.props.length > 0) {
        document.getElementById('statusText').textContent = 'LIVE';
        indicator.style.background = 'var(--accent-green-dim)';
        indicator.style.color = 'var(--accent-green)';
        dot.style.background = 'var(--accent-green)';
        dot.style.animation = 'pulse 2s infinite';
      } else if (state.props.length > 0) {
        document.getElementById('statusText').textContent = 'READY';
        indicator.style.background = 'var(--accent-green-dim)';
        indicator.style.color = 'var(--accent-green)';
        dot.style.background = 'var(--accent-green)';
        dot.style.animation = 'pulse 2s infinite';
      } else {
        document.getElementById('statusText').textContent = 'OFFLINE';
        indicator.style.background = 'var(--accent-red-dim)';
        indicator.style.color = 'var(--accent-red)';
        dot.style.background = 'var(--accent-red)';
        dot.style.animation = 'none';
      }
      
      if (state.lastUpdated) {
        document.getElementById('lastUpdated').textContent = state.lastUpdated.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
      }
    }

