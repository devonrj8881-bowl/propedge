    .live-game-card:hover::before {
      opacity: 1;
    }

    .live-game-card > * {
      position: relative;
      z-index: 1;
    }

    /* Action buttons that appear on selected game card */
    .game-card-actions {
      display: flex;
      gap: 6px;
