    function parseCSV(csv, league) {
      const lines = csv.split('\n');
      if (lines.length < 2) return [];

      let headers = parseCSVLine(lines[0]).map(h => h.toLowerCase().trim());
      const props = [];

      // Strip 'saved' bookmark column — PropFinder adds it but data rows omit it,
      // causing a 1-column offset that breaks every field lookup
      const savedIdx = headers.indexOf('saved');
      if (savedIdx !== -1) {
        headers = headers.filter((_, i) => i !== savedIdx);
      }

      const cols = {
        pfRating: headers.findIndex(h => h.includes('pf') && h.includes('rating')),
        team: headers.findIndex(h => h === 'team'),
        pos: headers.findIndex(h => h === 'pos' || h === 'position'),
        player: headers.findIndex(h => h === 'player' || h === 'name'),
        prop: headers.findIndex(h => h === 'prop' || h === 'market'),
        l10Avg: headers.findIndex(h => h === 'l10 avg'),
        l5Avg: headers.findIndex(h => h === 'l5 avg'),
        odds: headers.findIndex(h => h === 'odds'),
        streak: headers.findIndex(h => h === 'streak'),
        sznMatchup: headers.findIndex(h => h === 'szn matchup' || (h.includes('szn') && h.includes('matchup'))),
        // Season column: handles all PropFinder export variants
        // NBA/NHL: "'25-'26"  NHL: "'25-'26"  MLB: "2026"  NFL: "25-'26" (no leading apostrophe)
        season: headers.findIndex(h =>
          h === "25-'26"   || h === "'25-'26"  ||
          h === '25-26'    || h === "'25-26"   ||
          h === '2026'     || h === "'26"      ||
          h.includes("25-'26") || h.includes('25-26') ||
          h.includes('2026')   || h.includes('24-25') ||
          h.includes("24-'25")
        ),
        h2h: headers.findIndex(h => h === 'h2h'),
        l5: headers.findIndex(h => h === 'l5'),
        l10: headers.findIndex(h => h === 'l10'),
        l20: headers.findIndex(h => h === 'l20')
      };
      
      console.log(`${league} column mapping:`, cols);

      for (let i = 1; i < lines.length; i++) {
        const values = parseCSVLine(lines[i]);
        if (values.length < 5) continue;

        const getValue = (idx) => idx >= 0 && values[idx] ? values[idx].replace(/"/g, '').trim() : '';

        const propStr = getValue(cols.prop);
        if (!propStr) continue;

        const direction = propStr.toLowerCase().startsWith('u') ? 'UNDER' : 'OVER';
        const lineMatch = propStr.match(/[ou]?([\d.]+)/i);
        const line = lineMatch ? parseFloat(lineMatch[1]) : 0;
        const propType = propStr.replace(/^[ou]?[\d.]+\s*/i, '').trim();

        const pfRating = parseFloat(getValue(cols.pfRating)) || 0;
        const l5Avg = parseFloat(getValue(cols.l5Avg)) || 0;
        const l10Avg = parseFloat(getValue(cols.l10Avg)) || 0;
        const streak = parseInt(getValue(cols.streak)) || 0;
        const sznMatchup = parseInt(getValue(cols.sznMatchup)) || 15;

        // Parse hit rates
        const parseHitRate = (str) => {
          if (!str) return 0;
          const fracMatch = str.match(/\((\d+)\/(\d+)\)/);
          if (fracMatch) return (parseInt(fracMatch[1]) / parseInt(fracMatch[2])) * 100;
          const pctMatch = str.match(/([\d.]+)%?/);
          return pctMatch ? parseFloat(pctMatch[1]) : 0;
        };

        const l5Pct = parseHitRate(getValue(cols.l5));
        const l10Pct = parseHitRate(getValue(cols.l10));
        const l20Pct = parseHitRate(getValue(cols.l20));
        const seasonPct = parseHitRate(getValue(cols.season));

        const oddsStr = getValue(cols.odds);
        const odds = parseInt(oddsStr.replace(/[^0-9\-]/g, '')) || -110;
        const impliedProb = odds < 0 ? Math.abs(odds) / (Math.abs(odds) + 100) : 100 / (odds + 100);

        // Calculate model score with matchup bonuses
        let modelScore = pfRating;
        if (l10Pct >= 70 && l5Pct >= 65) modelScore += 5;

        // FIX 5: MLB streak bonus — 3-game streak is common in baseball, require 5 for meaningful bump
        if (league === 'MLB') {
          if (streak >= 5) modelScore += 4;
          else if (streak >= 3) modelScore += 1;
        } else {
          if (streak >= 3) modelScore += 3;
        }
        
        // Matchup bonuses
        const isGoodOverMatchup = sznMatchup >= 1 && sznMatchup <= 10;
        // FIX 4: MLB under matchup — remove under bonus for MLB (matchup rank reflects hitter vs. pitcher,
        // a high rank = weak pitcher = more hits = OVER, so under bonus doesn't apply)
        const isGoodUnderMatchup = league === 'MLB'
          ? false
          : (league === 'NFL' || league === 'NHL')
            ? sznMatchup >= 23 && sznMatchup <= 32
            : sznMatchup >= 21 && sznMatchup <= 30;
        if (direction === 'OVER' && isGoodOverMatchup) modelScore += 3;
        if (direction === 'UNDER' && isGoodUnderMatchup) modelScore += 3;

        // FIX 3: MLB true probability — weight longer samples more heavily (L20 + season)
        // because daily variance in baseball makes L5/L10 less predictive than in NBA/NHL
        const weightedHitRate = league === 'MLB'
          ? (l5Pct * 0.15 + l10Pct * 0.25 + l20Pct * 0.30 + seasonPct * 0.30) / 100
          : (l5Pct * 0.30 + l10Pct * 0.30 + l20Pct * 0.20 + seasonPct * 0.20) / 100;
        const trueProb = weightedHitRate;
        const edge = ((trueProb - impliedProb) * 100);
        
        // League-specific thresholds from Config sheet
        // FIX 2: MLB value edge threshold raised to 8 (matches NBA/NHL) — 6% was too easy to hit
        const leagueConfig = leagueThresholds[league] || { strong: 72, value: 8 };
        if (league === 'MLB' && leagueConfig.value < 8) leagueConfig.value = 8;
        const valueThreshold = leagueConfig.value;
        const strongThreshold = leagueConfig.strong;

        const isValue = edge >= valueThreshold && (trueProb - impliedProb) >= 0.10;

        // FIX 1: MLB meetsUltimate — require consistency over longer windows (L20 + season)
        // rather than just L5/L10 which can be fluky over a short baseball stretch
        const meetsUltimate = league === 'MLB'
          ? pfRating >= 80 && l10Pct >= 65 && l20Pct >= 60 && seasonPct >= 58
          : pfRating >= 82 && l10Pct >= 70 && l5Pct >= 65;

        let tier = 'spec';
        if (meetsUltimate) tier = 'ultimate';
        else if (modelScore >= THRESHOLDS.prime) tier = 'prime';
        else if (modelScore >= strongThreshold) tier = 'strong';
        else if (modelScore >= THRESHOLDS.solid) tier = 'solid';

        props.push({
          id: `${league}-${getValue(cols.player)}-${propType}-${line}-${direction}`.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9\-_.]/g, ''),
          league,
          player: getValue(cols.player),
          team: getValue(cols.team),
          pos: getValue(cols.pos),
          prop: propType,
          line,
          direction,
          odds,
          oddsStr: odds > 0 ? `+${odds}` : `${odds}`,
          impliedProb,
          trueProb,
          pfRating,
          l5Avg,
          l10Avg,
          l5Pct,
          l10Pct,
          l20Pct,
          seasonPct,
          streak,
          sznMatchup,
          modelScore: Math.round(modelScore),
          edge: parseFloat(edge.toFixed(1)),
          tier,
          isValue,
          meetsUltimate
        });
      }

      return props;
    }

    function parseCSVLine(line) {
      const values = [];
      let current = '';
      let inQuotes = false;

      for (let i = 0; i < line.length; i++) {
        const char = line[i];
        if (char === '"') {
          inQuotes = !inQuotes;
        } else if (char === ',' && !inQuotes) {
          values.push(current.trim());
          current = '';
        } else {
          current += char;
        }
      }
      values.push(current.trim());
      return values;
    }

