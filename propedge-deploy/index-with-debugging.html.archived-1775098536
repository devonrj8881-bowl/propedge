    function isOnFanDuel(prop) {
      if (Object.keys(state.fdLines).length === 0) return false;
      
      const playerLower = prop.player.toLowerCase().trim();
      const propType = (prop.prop || '').trim().toLowerCase();
      
      // Direct match
      if (state.fdLines[`${playerLower}|${propType}`]) return true;
      
      // Last name match
      const lastName = playerLower.split(' ').pop();
      for (const fdKey of Object.keys(state.fdLines)) {
        const [fdPlayer, fdPropType] = fdKey.split('|');
        const fdLastName = fdPlayer.split(' ').pop();
        
        if (lastName === fdLastName && (fdPropType.includes(propType) || propType.includes(fdPropType))) {
          return true;
        }
      }
      
      return false;
    }

    function getFanDuelLine(prop) {
      const playerLower = prop.player.toLowerCase().trim();
      const propType = (prop.prop || '').trim().toLowerCase();
      
      const direct = state.fdLines[`${playerLower}|${propType}`];
      if (direct) return direct;
      
      const lastName = playerLower.split(' ').pop();
      for (const fdKey of Object.keys(state.fdLines)) {
        const [fdPlayer, fdPropType] = fdKey.split('|');
        if (fdPlayer.split(' ').pop() === lastName && (fdPropType.includes(propType) || propType.includes(fdPropType))) {
          return state.fdLines[fdKey];
        }
      }
      
      return null;
    }

