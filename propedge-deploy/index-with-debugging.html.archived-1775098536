    function generateSuggestedParlays() {
      const container = document.getElementById('suggestedParlays');
      if (!container) return;

      if (!state.props || state.props.length < 3) {
        container.innerHTML = '<div style="color:var(--text-muted);font-size:12px;padding:16px;text-align:center;">Load props to see AI suggestions</div>';
        return;
      }

      // Helper: pick up to N props with no duplicate players and no duplicate teams
      function pickUnique(pool, n) {
        const seen = new Set();
        const result = [];
        for (const p of pool) {
          const key = p.player + '|' + p.team;
          if (!seen.has(key)) {
            seen.add(key);
            result.push(p);
            if (result.length >= n) break;
          }
        }
        return result;
      }

      // Score a prop for AI quality (higher = better suggestion)
      function propScore(p) {
        return (
          (p.pfRating   || 0) * 0.35 +
          (p.l10Pct     || 0) * 0.25 +
          (p.l5Pct      || 0) * 0.20 +
          (p.edge       || 0) * 0.10 +
          (p.modelScore || 0) * 0.10
        );
      }

      // Sorted pools
      const allSorted  = [...state.props].sort((a, b) => propScore(b) - propScore(a));
      const ultPool    = allSorted.filter(p => p.meetsUltimate);
      const primePool  = allSorted.filter(p => p.tier === 'prime' || p.tier === 'ultimate');
      const valuePool  = allSorted.filter(p => p.isValue).sort((a, b) => (b.edge||0) - (a.edge||0));

      // Fallback: if a tier is too thin, fill from top of allSorted
      function withFallback(pool, n) {
        const picks = pickUnique(pool, n);
        if (picks.length < n) {
          const extraPool = allSorted.filter(p => !picks.includes(p));
          picks.push(...pickUnique(extraPool, n - picks.length));
        }
        return picks.slice(0, n);
      }

      const suggestions = [];

      // 1. Ultimate Stack — best 3 overall
      const ultPicks = withFallback(ultPool.length >= 2 ? ultPool : allSorted, 3);
      if (ultPicks.length >= 2) {
        const avgHit = Math.round(ultPicks.reduce((s, p) => s + (p.l10Pct || 0), 0) / ultPicks.length);
        suggestions.push({
          name: '⭐ Ultimate Stack',
          picks: ultPicks,
          desc: `${avgHit}% avg L10 hit rate · highest-confidence plays`
        });
      }

      // 2. Prime Picks — high confidence, diverse legs
      const primePicks = withFallback(primePool, 3);
      if (primePicks.length >= 2) {
        const avgEdge = (primePicks.reduce((s, p) => s + (p.edge || 0), 0) / primePicks.length).toFixed(1);
        suggestions.push({
          name: '🎯 Prime Picks',
          picks: primePicks,
          desc: `+${avgEdge}% avg model edge · proven high-hit plays`
        });
      }

      // 3. Value Play — best positive-edge props
      const valuePicks = withFallback(valuePool.length >= 2 ? valuePool : allSorted, 3);
      // Exclude players already used above to maximize variety
      const usedPlayers = new Set([...ultPicks, ...primePicks].map(p => p.player));
      const freshValue  = valuePicks.filter(p => !usedPlayers.has(p.player));
      const finalValue  = freshValue.length >= 2 ? freshValue.slice(0, 3) : withFallback(valuePool, 3);
      if (finalValue.length >= 2) {
        const bestEdge = Math.max(...finalValue.map(p => p.edge || 0)).toFixed(1);
        suggestions.push({
          name: '💰 Value Play',
          picks: finalValue,
          desc: `Up to +${bestEdge}% edge · best bang-for-your-buck legs`
        });
      }

      // 4. Mixed League (if multiple leagues available)
      const leagues = [...new Set(state.props.map(p => p.league))];
      if (leagues.length >= 2) {
        const mixedPicks = [];
        const usedInMix  = new Set();
        for (const league of leagues) {
          const leagueBest = allSorted.filter(p => p.league === league && !usedInMix.has(p.player));
          if (leagueBest.length > 0) {
            mixedPicks.push(leagueBest[0]);
            usedInMix.add(leagueBest[0].player);
          }
          if (mixedPicks.length >= 4) break;
        }
        if (mixedPicks.length >= 2) {
          suggestions.push({
            name: '🌐 Cross-Sport',
            picks: mixedPicks,
            desc: `${mixedPicks.map(p => p.league).join(' + ')} · diversified multi-sport parlay`
          });
        }
      }

      // Tier color badge
      const tierColor = { ultimate: '#f59e0b', prime: '#6366f1', strong: '#10b981', solid: '#3b82f6', spec: '#8b5cf6' };

      container.innerHTML = suggestions.length ? suggestions.map(s => `
        <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:14px;margin-bottom:10px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
            <div style="font-weight:700;font-size:13px;">${s.name}</div>
            <span style="font-size:10px;background:rgba(99,102,241,0.15);color:#818cf8;border-radius:20px;padding:2px 8px;">${s.picks.length} legs</span>
          </div>
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">${s.desc}</div>
          ${s.picks.map(p => `
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
              <div style="width:6px;height:6px;border-radius:50%;background:${tierColor[p.tier]||'#64748b'};flex-shrink:0;"></div>
              <div style="font-size:12px;color:var(--text-secondary);flex:1;">${p.player} <span style="color:var(--text-muted);">· ${p.direction} ${p.line} ${p.prop}</span></div>
              <span style="font-size:11px;color:${(p.edge||0)>0?'var(--accent-green)':'var(--text-muted)'}">${(p.edge||0)>0?'+':''}${(p.edge||0).toFixed(1)}%</span>
            </div>
          `).join('')}
          <button class="parlay-btn secondary" style="width:100%;margin-top:10px;padding:9px;font-size:12px;font-weight:600;" onclick="addSuggestedParlay([${s.picks.map(p => `'${p.id}'`).join(',')}])">+ Add All to Parlay</button>
        </div>
      `).join('') : '<div style="color:var(--text-muted);font-size:12px;padding:16px;text-align:center;">No suggestions available — reload props to refresh</div>';
    }

