    function _lacTeamColor(abbr, espnHex, type) {
      // If ESPN gives a valid 6-char hex, use it
      if (espnHex && /^[0-9a-fA-F]{6}$/.test(espnHex)) return '#' + espnHex;
      // Fall back to table
      const entry = _LAC_TEAM_COLORS[abbr];
      if (entry) return '#' + (type === 'alt' ? entry[1] : entry[0]);
      return type === 'alt' ? '#333344' : '#1a2040';
    }

    function _lacApplyTeamColor(league) {
      const svg = document.querySelector('#liveCourtCanvas svg');
      if (!svg) return;
      const hc  = _lacState.homeColor  || '#1a1d24';
      const alt = _lacState.altColor   || '#333344';
      const logo = _lacState.homeLogo  || '';

      // Floor base tint — home primary color
      const floorEl = svg.querySelector('.lac-floor');
      if (floorEl) { floorEl.setAttribute('fill', hc); floorEl.setAttribute('fill-opacity', '0.22'); }

      if (league === 'NBA') {
        // Outer border in home primary color
        const border = svg.querySelector('.lac-border');
        if (border) { border.setAttribute('fill', hc); }
        // Paint (lane) in home primary color — solid like a real court
        const lane = svg.querySelector('.lac-lane');
        if (lane) { lane.setAttribute('fill', hc); lane.setAttribute('fill-opacity','0.92'); }
        // Inject center-court logo (on hardwood, good opacity)
        _lacSetCenterLogo(svg, logo, 50, 24, 10);
      }

      if (league === 'NHL') {
        // Home goal crease color
        const goalR = svg.querySelector('.lac-goal-r');
        if (goalR) { goalR.setAttribute('fill', hc); goalR.setAttribute('fill-opacity','0.45'); goalR.setAttribute('stroke', alt || hc); }
        // Center ice logo (big, on white ice)
        _lacSetCenterLogo(svg, logo, 100, 42.5, 16);
      }

      if (league === 'NFL') {
        // End zones in home primary color
        const ezL = svg.querySelector('.lac-ez-left');
        const ezR = svg.querySelector('.lac-ez-right');
        if (ezL) { ezL.setAttribute('fill', hc); }
        if (ezR) { ezR.setAttribute('fill', hc); }
        // End zone logos
        _lacSetCenterLogo(svg, logo, 5, 26.5, 5, 'lac-logo-ez-l');
        _lacSetCenterLogo(svg, logo, 115, 26.5, 5, 'lac-logo-ez-r');
        // Mid-field logo
        _lacSetCenterLogo(svg, logo, 60, 26.5, 9, 'lac-logo-mid');
      }

      if (league === 'MLB') {
        // Center field logo on the outfield grass
        _lacSetCenterLogo(svg, logo, 60, 45, 14);
      }
    }

    function _lacSetCenterLogo(svg, logoUrl, cx, cy, r, id='lac-logo-center') {
      if (!logoUrl) return;
      // Remove existing
      const existing = svg.getElementById ? svg.getElementById(id) : svg.querySelector('#'+id);
      if (existing) existing.remove();
      // Create clipPath for circular logo
      const defs = svg.querySelector('defs') || (() => { const d = document.createElementNS('http://www.w3.org/2000/svg','defs'); svg.insertBefore(d, svg.firstChild); return d; })();
      const clipId = id + '_clip';
      let cp = svg.querySelector('#'+clipId);
      if (!cp) {
        cp = document.createElementNS('http://www.w3.org/2000/svg','clipPath');
        cp.setAttribute('id', clipId);
        const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');
        circle.setAttribute('cx', cx); circle.setAttribute('cy', cy); circle.setAttribute('r', r);
        cp.appendChild(circle);
        defs.appendChild(cp);
      }
      // Logo image
      const img = document.createElementNS('http://www.w3.org/2000/svg','image');
      img.setAttribute('id', id);
      img.setAttribute('href', logoUrl);
      img.setAttribute('x', cx - r); img.setAttribute('y', cy - r);
      img.setAttribute('width', r*2); img.setAttribute('height', r*2);
      img.setAttribute('opacity', '0.55');
      img.setAttribute('clip-path', `url(#${clipId})`);
      img.setAttribute('preserveAspectRatio', 'xMidYMid meet');
      // Insert before ball element so ball renders on top
      const ball = svg.querySelector('.lac-ball');
      if (ball) svg.insertBefore(img, ball); else svg.appendChild(img);
    }

    function _lacBuildAthleteMap(data, sport) {
      // Populate _lacState.athleteMap from boxscore players
      for (const teamData of (data?.boxscore?.players || [])) {
        for (const sg of (teamData?.statistics || [])) {
          for (const ath of (sg?.athletes || [])) {
            const a = ath?.athlete || {};
            const id = String(a.id || '');
            if (id) {
              _lacState.athleteMap[id] = {
                name: a.shortName || a.displayName || '?',
                headshot: a.headshot?.href || `https://a.espncdn.com/i/headshots/${sport}/players/full/${id}.png`,
              };
            }
          }
        }
      }
    }

    function _lacGetAthleteFromPlay(play) {
      // Returns first participant's athlete data, or null
      const parts = play?.participants || play?.teamParticipants || [];
      for (const part of parts) {
        const id = String(part?.athlete?.id || '');
        if (id && _lacState.athleteMap[id]) return { id, ..._lacState.athleteMap[id] };
      }
      return null;
    }

    function _lacShowHeadshot(ballX, ballY, athlete, svgViewW, svgViewH) {
      // Renders a small circular headshot near the ball position in the SVG
      const svg = document.querySelector('#liveCourtCanvas svg');
      if (!svg || !athlete?.headshot) return;

      // Remove any existing headshot
      const existing = svg.querySelector('.lac-headshot-group');
      if (existing) existing.remove();

      const r = 7;  // radius in SVG units
      // Clamp position so headshot stays inside viewbox and above the clock bar
      // Clock bar is always the bottom 6 units; name label is r+4 below center
      // So max hy = svgViewH - 6 (clock) - r (circle) - 5 (name label) - 2 (margin)
      const hx = Math.max(r + 1, Math.min(svgViewW - r - 1, ballX));
      const hy = Math.max(r + 2, Math.min(svgViewH - 6 - r - 7, ballY - r - 4));

      // Build group
      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      g.setAttribute('class', 'lac-headshot-group');

      // Background circle (team color)
      const bg = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      bg.setAttribute('cx', hx); bg.setAttribute('cy', hy); bg.setAttribute('r', r + 0.5);
      bg.setAttribute('fill', _lacState.homeColor);
      bg.setAttribute('stroke', '#fff');
      bg.setAttribute('stroke-width', '0.8');
      bg.setAttribute('opacity', '0.95');
      g.appendChild(bg);

      // Clip path for circular headshot
      const defs = svg.querySelector('defs') || svg.insertBefore(document.createElementNS('http://www.w3.org/2000/svg','defs'), svg.firstChild);
      let cp = svg.querySelector('#lac_hs_clip');
      if (!cp) {
        cp = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
        cp.setAttribute('id', 'lac_hs_clip');
        defs.appendChild(cp);
      }
      cp.innerHTML = '';
      const cc = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      cc.setAttribute('cx', hx); cc.setAttribute('cy', hy); cc.setAttribute('r', r);
      cp.appendChild(cc);

      // Headshot image
      const img = document.createElementNS('http://www.w3.org/2000/svg', 'image');
      img.setAttribute('href', athlete.headshot);
      img.setAttribute('x', hx - r); img.setAttribute('y', hy - r);
      img.setAttribute('width', r * 2); img.setAttribute('height', r * 2);
      img.setAttribute('clip-path', 'url(#lac_hs_clip)');
      img.setAttribute('preserveAspectRatio', 'xMidYMid meet');
      g.appendChild(img);

      // Tiny name label below circle
      const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      label.setAttribute('x', hx); label.setAttribute('y', hy + r + 3.5);
      label.setAttribute('text-anchor', 'middle');
      label.setAttribute('fill', 'rgba(255,255,255,0.9)');
      label.setAttribute('font-size', '3.2');
      label.setAttribute('font-family', "'Space Grotesk',sans-serif");
      label.setAttribute('font-weight', '700');
      label.setAttribute('paint-order', 'stroke');
      label.setAttribute('stroke', 'rgba(0,0,0,0.8)');
      label.setAttribute('stroke-width', '1.2');
      label.textContent = athlete.name;
      g.appendChild(label);

      svg.appendChild(g);

      // Auto-fade after 4s
      clearTimeout(_lacState._hsTimer);
      _lacState._hsTimer = setTimeout(() => {
        const el = svg.querySelector('.lac-headshot-group');
        if (el) el.remove();
      }, 4000);
    }

    function _lacProcessPlays(data, league) {
      const svg = document.querySelector('#liveCourtCanvas svg');
      if (!svg) return;

      let plays = [];
      if (league === 'NFL') {
        // NFL plays live in drives
        const drives = data?.drives || {};
        const allDrives = [...(drives.previous || []), ...(drives.current ? [drives.current] : [])];
        for (const drv of allDrives) plays.push(...(drv.plays || []));
      } else {
        plays = data?.plays || [];
      }

      // Sort by sequenceNumber ascending, process only new ones
      plays.sort((a,b) => parseInt(a.sequenceNumber||0) - parseInt(b.sequenceNumber||0));
      const newPlays = plays.filter(p => parseInt(p.sequenceNumber||0) > _lacState.lastSeqNum);
      if (!newPlays.length) return;

      _lacState.lastSeqNum = parseInt(newPlays[newPlays.length - 1].sequenceNumber || 0);

      // Animate only the most recent meaningful play
      const meaningful = [...newPlays].reverse().find(p => {
        const tid = p?.type?.id;
        if (league === 'NBA') return p.shootingPlay || [155,156,44,45,42,97,98,99,103].includes(+tid);
        if (league === 'NHL') return [505,506,507,508,502,503,1401,1402].includes(+tid);
        if (league === 'MLB') return p?.type?.text && !['Start Batter/Pitcher','End Batter/Pitcher','Start Inning','End Inning'].includes(p.type.text);
        if (league === 'NFL') return [24,3,5,59,67,26,52,53,7,66].includes(+tid);
        return false;
      });
      if (!meaningful) return;

      if (league === 'NBA') _lacAnimateNBA(svg, meaningful);
      else if (league === 'NHL') _lacAnimateNHL(svg, meaningful);
      else if (league === 'MLB') _lacAnimateMLB(svg, meaningful);
      else if (league === 'NFL') _lacAnimateNFL(svg, meaningful);
    }

    // ── Coordinate helpers ─────────────────────────────────────────────────────
    function _lacNBAcoord(play) {
      const c = play?.coordinate || {};
      let x = c.x, y = c.y;
      if (!x || x < -1000 || !y || y < -1000) {
        // Free throw or unknown
        const tid = +(play?.type?.id || 0);
        if ([97,98,99,103].includes(tid)) return { px: 50, py: 82 };
        return null;
      }
      // ESPN: x=0-50 sideline, y=0-47 from basket
      // SVG viewBox "0 0 100 55" — basket at right side center
      const px = 95 - (y / 47) * 85;
      const py = (x / 50) * 54;
      return { px: Math.max(5, Math.min(95, px)), py: Math.max(2, Math.min(53, py)) };
    }

    function _lacNHLcoord(play) {
      const c = play?.coordinate || {};
      let x = c.x, y = c.y;
      if (typeof x !== 'number' || x < -200) return null;
      // ESPN: x=-100..100, y=-42.5..42.5
      // SVG viewBox "0 0 200 85"
      const px = ((x + 100) / 200) * 200;
      const py = ((y + 42.5) / 85) * 85;
      return { px, py };
    }

    function _lacNFLcoord(play) {
      const start = play?.start || {};
      const end   = play?.end   || {};
      const yte_s = start.yardsToEndzone;
      const yte_e = end.yardsToEndzone;
      if (!yte_s) return null;
      // SVG viewBox "0 0 120 53" (120 total yds including 10yd endzones)
      const px_s = 10 + (1 - yte_s/100) * 100;
      const px_e = yte_e != null ? 10 + (1 - yte_e/100) * 100 : px_s + 5;
      return { px_s, px_e, py: 26.5 };
    }

    // ── Reusable SVG animation helper ────────────────────────────────────────────
    function _lacMoveBall(svg, fromX, fromY, toX, toY, arcH, ms, onDone) {
      const ball = svg.querySelector('.lac-ball');
      if (!ball) return;
      const steps = Math.max(20, Math.round(ms / 16));
      let i = 0;
      if (ball._anim) cancelAnimationFrame(ball._anim);
      function step() {
        const t = i / steps;
        const ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
        const x = fromX + (toX - fromX) * ease;
        const y = fromY + (toY - fromY) * ease - arcH * Math.sin(Math.PI * t);
        ball.setAttribute('cx', x.toFixed(2));
        ball.setAttribute('cy', y.toFixed(2));
        ball.setAttribute('opacity', '1');
        i++;
        if (i <= steps) { ball._anim = requestAnimationFrame(step); }
        else { if (onDone) onDone(); }
      }
      step();
    }

    function _lacShowEvent(text, color) {
      const chip = document.querySelector('#liveCourtCanvas .lac-event-chip');
      if (!chip) return;
      chip.textContent = text;
      chip.style.borderLeft = '3px solid ' + color;
      chip.classList.add('show');
      clearTimeout(chip._t);
      chip._t = setTimeout(() => chip.classList.remove('show'), 3200);
    }

    function _lacScoreFlash(svg) {
      const overlay = svg.querySelector('.lac-score-overlay');
      if (!overlay) return;
      overlay.style.animation = 'none';
      void overlay.offsetWidth;
      overlay.style.fill = 'rgba(0,230,118,0.4)';
      overlay.style.opacity = '0';
      overlay.style.animation = 'lacScoreFlash 1s ease forwards';
    }

    // ── NBA ────────────────────────────────────────────────────────────
    function _lacAnimateNBA(svg, play) {
      const tid     = +(play?.type?.id || 0);
      const text    = play?.text || '';
      const scoring = play?.scoringPlay;
      const athlete = _lacGetAthleteFromPlay(play);
      const basket_px = 93, basket_py = 27.5;

      // Free throw
      if ([97,98,99,103].includes(tid)) {
        if (athlete) _lacShowHeadshot(65, 27.5, athlete, 100, 55);
        _lacMoveBall(svg, 65, 27.5, basket_px, basket_py, 6, 700, () => {
          if (scoring) { _lacScoreFlash(svg); _lacShowEvent(text.slice(0,45), 'var(--accent-green)'); }
          else         { _lacShowEvent(text.slice(0,45), 'var(--accent-red)'); }
        });
        return;
      }

      const coord = _lacNBAcoord(play);

      // Rebound
      if ([155,156].includes(tid)) {
        const ball = svg.querySelector('.lac-ball');
        if (ball && coord) { ball.setAttribute('cx', coord.px); ball.setAttribute('cy', coord.py); ball.setAttribute('opacity','1'); }
        if (athlete && coord) _lacShowHeadshot(coord.px, coord.py, athlete, 100, 55);
        _lacShowEvent(text.slice(0,45), tid === 156 ? 'var(--accent-gold)' : 'var(--accent-blue)');
        return;
      }

      // Foul
      if ([44,45,42].includes(tid)) {
        _lacShowEvent(text.slice(0,45), 'var(--accent-red)');
        return;
      }

      if (!coord) return;
      const { px, py } = coord;

      const isLayupDunk = [109,110,111,113,115,116,118,141,144,145,146,149,151].includes(tid);
      const is3pt = text.toLowerCase().includes('three point') || text.toLowerCase().includes('3-point') ||
                    /\b(2[5-9]|3[0-9])-foot\b/.test(text);
      const arcH = isLayupDunk ? 3 : is3pt ? 18 : 10;
      const ms   = isLayupDunk ? 400 : is3pt ? 900 : 650;

      // Show shooter headshot at origin
      if (athlete) _lacShowHeadshot(px, py, athlete, 100, 55);

      _lacMoveBall(svg, px, py, basket_px, basket_py, arcH, ms, () => {
        if (scoring) {
          _lacScoreFlash(svg);
          _lacShowEvent(text.slice(0,50), 'var(--accent-green)');
        } else {
          const ball = svg.querySelector('.lac-ball');
          if (ball) setTimeout(() => { ball.setAttribute('cx', basket_px+3); ball.setAttribute('cy', basket_py+4); ball.setAttribute('opacity','0.5'); }, 200);
          _lacShowEvent(text.slice(0,50), 'var(--accent-red)');
        }
      });
    }

    // ── NHL ────────────────────────────────────────────────────────────
    function _lacAnimateNHL(svg, play) {
      const tid     = +(play?.type?.id || 0);
      const text    = play?.text || '';
      const scoring = play?.scoringPlay;
      const athlete = _lacGetAthleteFromPlay(play);
      const coord   = _lacNHLcoord(play);
      const teamId  = play?.team?.id;
      const isHome  = String(teamId) === String(_lacState.homeTeamId);
      const targetNet_px = isHome ? 185 : 15;
      const targetNet_py = 42.5;

      if (!coord) {
        if (tid === 502) {
          const ball = svg.querySelector('.lac-ball');
          if (ball) { ball.setAttribute('cx', 100); ball.setAttribute('cy', 42.5); ball.setAttribute('opacity','1'); }
        }
        return;
      }

      const { px, py } = coord;

      if ([505,506].includes(tid)) {
        if (athlete) _lacShowHeadshot(px, py, athlete, 200, 85);
        const arcH = tid === 505 ? 6 : 3;
        _lacMoveBall(svg, px, py, targetNet_px, targetNet_py, arcH, 600, () => {
          if (scoring || tid === 505) {
            _lacScoreFlash(svg);
            _lacShowEvent(text.slice(0,50), 'var(--accent-green)');
            const goalLight = svg.querySelector(isHome ? '.lac-goal-r' : '.lac-goal-l');
            if (goalLight) {
              goalLight.setAttribute('fill', '#ff2200'); goalLight.setAttribute('fill-opacity','0.7');
              setTimeout(() => { goalLight.setAttribute('fill','rgba(74,143,255,0.12)'); goalLight.setAttribute('fill-opacity','1'); }, 2200);
            }
          } else { _lacShowEvent(text.slice(0,50), 'var(--accent-blue)'); }
        });
      } else if (tid === 507) {
        if (athlete) _lacShowHeadshot(px, py, athlete, 200, 85);
        _lacMoveBall(svg, px, py, targetNet_px+(isHome?12:-12), targetNet_py+8, 5, 500, () => {
          const ball = svg.querySelector('.lac-ball'); if (ball) ball.setAttribute('opacity','0.3');
          _lacShowEvent(text.slice(0,50), 'var(--accent-red)');
        });
      } else if (tid === 508) {
        _lacMoveBall(svg, px, py, px+(isHome?-8:8), py, 2, 300, () => { _lacShowEvent(text.slice(0,50), 'var(--accent-gold)'); });
      } else if ([503,1401,1402].includes(tid)) {
        const ball = svg.querySelector('.lac-ball');
        if (ball) { ball.setAttribute('cx', px); ball.setAttribute('cy', py); ball.setAttribute('opacity','1'); }
        _lacShowEvent(text.slice(0,50), tid===503 ? 'var(--accent-orange)' : 'var(--text-muted)');
      }
    }

    // ── MLB ────────────────────────────────────────────────────────────
    function _lacAnimateMLB(svg, play) {
      const typeText = play?.type?.text || '';
      const text     = play?.text || '';
      const scoring  = play?.scoringPlay;

      const mound_px = 60, mound_py = 30;
      const plate_px = 60, plate_py = 88;

      const ball = svg.querySelector('.lac-ball');

      if (typeText === 'Ball') {
        _lacMoveBall(svg, mound_px, mound_py, plate_px + 8, plate_py + 4, 2, 350, () => {
          _lacShowEvent('Ball', 'var(--accent-blue)');
          if (ball) ball.setAttribute('opacity','0.3');
        });
      } else if (typeText.includes('Strike')) {
        _lacMoveBall(svg, mound_px, mound_py, plate_px, plate_py, 2, 350, () => {
          _lacShowEvent('Strike', 'var(--accent-red)');
          if (ball) ball.setAttribute('opacity','0.3');
        });
      } else if (typeText.includes('Foul')) {
        _lacMoveBall(svg, mound_px, mound_py, plate_px + 20, plate_py - 20, 8, 400, () => {
          _lacShowEvent('Foul', 'var(--accent-gold)');
          if (ball) ball.setAttribute('opacity','0.3');
        });
      } else if (['Single','Double','Triple','Home Run'].includes(typeText)) {
        const dist = typeText === 'Home Run' ? 55 : typeText === 'Triple' ? 45 : typeText === 'Double' ? 35 : 20;
        const arcH = typeText === 'Home Run' ? 30 : typeText === 'Triple' ? 20 : 12;
        const angle = (Math.random() * 70 + 20) * Math.PI / 180;
        const tx = plate_px + Math.cos(angle) * dist * 0.7;
        const ty = plate_py - Math.sin(angle) * dist;
        _lacMoveBall(svg, plate_px, plate_py, tx, ty, arcH, 600, () => {
          _lacScoreFlash(svg);
          _lacShowEvent(typeText === 'Home Run' ? 'HOME RUN! ' + text.slice(0,30) : text.slice(0,45),
                        typeText === 'Home Run' ? 'var(--accent-gold)' : 'var(--accent-green)');
        });
      } else if (typeText.includes('Out') || typeText.includes('out')) {
        _lacMoveBall(svg, mound_px, mound_py, plate_px, plate_py, 2, 350, () => {
          _lacShowEvent(text.slice(0,45), 'var(--text-muted)');
          if (ball) ball.setAttribute('opacity','0.3');
        });
      } else if (typeText === 'Walk') {
        _lacShowEvent('Walk — batter takes first', 'var(--accent-blue)');
      } else if (scoring) {
        _lacScoreFlash(svg);
        _lacShowEvent('RUN SCORES! ' + text.slice(0,35), 'var(--accent-green)');
      }
    }

    // ── NFL ────────────────────────────────────────────────────────────
    function _lacAnimateNFL(svg, play) {
      const tid     = +(play?.type?.id || 0);
      const text    = play?.text || '';
      const scoring = play?.scoringPlay;
      const athlete = _lacGetAthleteFromPlay(play);
      const coord   = _lacNFLcoord(play);
      if (!coord) return;
      const { px_s, px_e, py } = coord;

      const arcH = [24,3].includes(tid) ? 8 : [67,66].includes(tid) ? 14 : [52,53].includes(tid) ? 20 : 2;
      const ms   = [52,53].includes(tid) ? 1000 : 600;

      if (athlete) _lacShowHeadshot(px_s, py, athlete, 120, 53);

      _lacMoveBall(svg, px_s, py, px_e, py, arcH, ms, () => {
        if (scoring || [67,66].includes(tid)) {
          _lacScoreFlash(svg);
          _lacShowEvent('TOUCHDOWN! ' + text.slice(0,40), 'var(--accent-green)');
        } else if (tid === 59) {
          _lacScoreFlash(svg);
          _lacShowEvent('FIELD GOAL ✓ ' + text.slice(0,35), 'var(--accent-green)');
        } else if (tid === 26) {
          _lacShowEvent('INTERCEPTION! ' + text.slice(0,35), 'var(--accent-red)');
        } else if (tid === 7) {
          _lacShowEvent('SACK — ' + text.slice(0,40), 'var(--accent-red)');
