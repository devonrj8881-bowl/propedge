    // ==========================================
    // INJURY & LINEUP TRACKER — ALL 3 PHASES
    // ==========================================

    const _injState = {
      subtab: 'injuries',   // injuries | lineups | news
      injLeague: 'ALL',
      lineupLeague: 'NBA',
      newsLeague: 'ALL',
      injuries: { NBA:[], NHL:[], MLB:[], NFL:[] },
      lineups:  { NBA:[], NHL:[], MLB:[], NFL:[] },
      news:     { NBA:[], NHL:[], MLB:[], NFL:[] },
      loaded: false,
      refreshTimer: null,
      lineupTimer:  null,
      newsTimer:    null,
      ticketTimer:  null,
    };

    const ESPN_SPORT_MAP = {
      NBA: { sport:'basketball', league:'nba', season:2026 },
      NHL: { sport:'hockey',     league:'nhl', season:2026 },
      MLB: { sport:'baseball',   league:'mlb', season:2026 },
      NFL: { sport:'football',   league:'nfl', season:2025 },
    };

    // ── Sub-tab switching ───────────────────────
    // ==============================================
    // 🎟 TICKET WATCHLIST + PUSH NOTIFICATIONS
    // ==============================================

    // ─ Persistent watchlist stored in localStorage ─
    // Each entry: { player, league, team, prop?, line?, direction?, addedAt, lastStatus }
    const _ticket = {
      players: JSON.parse(localStorage.getItem('pe_ticket') || '[]'),
      notifEnabled: localStorage.getItem('pe_notif') === 'true',
      // previous status snapshot for change detection: { playerKey: statusKey }
      prevStatuses: {},
    };

    function _ticketSave() {
      localStorage.setItem('pe_ticket', JSON.stringify(_ticket.players));
    }

    function _ticketKey(playerName) {
      return (playerName || '').toLowerCase().trim();
    }

    function _ticketHasPlayer(playerName) {
      const k = _ticketKey(playerName);
      return _ticket.players.some(p => _ticketKey(p.player) === k);
    }

    function _ticketGetEntry(playerName) {
      const k = _ticketKey(playerName);
      return _ticket.players.find(p => _ticketKey(p.player) === k) || null;
    }

    // ─ Add/remove from a prop card watch button ─
    function toggleTicketProp(btn) {
      const player    = btn.dataset.player;
      const league    = btn.dataset.league;
      const team      = btn.dataset.team;
      const prop      = btn.dataset.prop;
      const line      = btn.dataset.line;
      const direction = btn.dataset.dir;
      const k = _ticketKey(player);
      const idx = _ticket.players.findIndex(p => _ticketKey(p.player) === k);
      if (idx >= 0) {
        _ticket.players.splice(idx, 1);
        btn.classList.remove('watched');
        btn.textContent = '☆';
        showToast(`${player} removed from My Ticket`);
      } else {
        _ticket.players.push({ player, league, team, prop, line, direction, addedAt: Date.now(), lastStatus: '' });
        btn.classList.add('watched');
        btn.textContent = '★';
        showToast(`★ ${player} added to My Ticket`);
      }
      _ticketSave();
      _ticketUpdateBadge();
      // Refresh ticket panel if open
      if (_injState.subtab === 'ticket') renderTicketPanel();
    }

    // ─ Add/remove from an injury card watch button ─
    function toggleTicketInj(btn) {
      const player = btn.dataset.player;
      const league = btn.dataset.league;
      const team   = btn.dataset.team;
      const k = _ticketKey(player);
      const idx = _ticket.players.findIndex(p => _ticketKey(p.player) === k);
      if (idx >= 0) {
        _ticket.players.splice(idx, 1);
        btn.classList.remove('watched');
        btn.textContent = '☆';
        btn.title = 'Add to My Ticket';
        showToast(`${player} removed from My Ticket`);
      } else {
        _ticket.players.push({ player, league, team, addedAt: Date.now(), lastStatus: '' });
        btn.classList.add('watched');
        btn.textContent = '★';
        btn.title = 'Remove from My Ticket';
        showToast(`★ ${player} added to My Ticket`);
      }
      _ticketSave();
      _ticketUpdateBadge();
      if (_injState.subtab === 'ticket') renderTicketPanel();
    }

    // ─ Remove an entry directly from the ticket panel ─
    function removeFromTicket(playerName) {
      const k = _ticketKey(playerName);
      _ticket.players = _ticket.players.filter(p => _ticketKey(p.player) !== k);
      _ticketSave();
      _ticketUpdateBadge();
      renderTicketPanel();
      showToast(`${playerName} removed from My Ticket`);
    }

    function clearTicket() {
      _ticket.players = [];
      _ticketSave();
      _ticketUpdateBadge();
      renderTicketPanel();
      showToast('My Ticket cleared');
    }

    // ─ Badge count on the tab ─
    function _ticketUpdateBadge() {
      const cnt = _ticket.players.length;
      const el = document.getElementById('ticketBadgeCount');
      if (!el) return;
      el.textContent = cnt;
      el.style.display = cnt > 0 ? 'inline-flex' : 'none';
    }

    // ─ Render the My Ticket panel ─
    function renderTicketPanel() {
      const container = document.getElementById('ticketWatchlistContent');
      if (!container) return;

      // Notification banner logic
      const bannerEl  = document.getElementById('ticketNotifBanner');
      const enabledEl = document.getElementById('ticketNotifEnabled');
      if (bannerEl && enabledEl) {
        if (_ticket.notifEnabled) {
          bannerEl.style.display  = 'none';
          enabledEl.style.display = 'flex';
        } else {
          bannerEl.style.display  = 'block';
          enabledEl.style.display = 'none';
        }
      }

      if (_ticket.players.length === 0) {
        container.innerHTML = `
          <div class="ticket-empty">
            <div class="ticket-empty-icon">🎟</div>
            <div style="font-weight:700;margin-bottom:6px;color:var(--text-secondary);">Your Ticket is empty</div>
            <div>Tap the <strong style="color:var(--accent-green);">&#9734; Watch</strong> button on any prop card or injury card to track a player here.</div>
          </div>`;
        return;
      }

      // Merge current injury status for each watched player
      const allInj = ['NBA','NHL','MLB','NFL'].flatMap(l => _injState.injuries[l] || []);

      let html = '';
      // Sort: OUT/Questionable first, then healthy, then by name
      const sorted = [..._ticket.players].sort((a, b) => {
        const sa = _getTicketStatus(a.player, allInj);
        const sb = _getTicketStatus(b.player, allInj);
        const order = { out:0, dnp:0, q:1, gtd:1, dtd:1, prob:2, in:3, '':4 };
        return (order[sa] ?? 4) - (order[sb] ?? 4) || a.player.localeCompare(b.player);
      });

      // Group: Flagged (out/q) vs Active
      const flagged = sorted.filter(p => ['out','dnp','q','gtd','dtd'].includes(_getTicketStatus(p.player, allInj)));
      const active  = sorted.filter(p => !['out','dnp','q','gtd','dtd'].includes(_getTicketStatus(p.player, allInj)));

      if (flagged.length) {
        html += `<div class="ticket-section-label">⚠️ Flagged Players (${flagged.length})</div>`;
        html += flagged.map(p => _ticketRowHtml(p, allInj)).join('');
      }
      if (active.length) {
        html += `<div class="ticket-section-label">✅ Active (${active.length})</div>`;
        html += active.map(p => _ticketRowHtml(p, allInj)).join('');
      }

      html += `<button class="ticket-clear-btn" onclick="clearTicket()">🗑 Clear All Watched Players</button>`;
      container.innerHTML = html;
    }

    function _getTicketStatus(playerName, allInj) {
      const k = _ticketKey(playerName);
      const match = allInj.find(i => _ticketKey(i.player) === k);
      if (!match) return '';
      return _lpStatusKey(match.status);
    }

    function _ticketRowHtml(entry, allInj) {
      const k     = _ticketKey(entry.player);
      const match = allInj.find(i => _ticketKey(i.player) === k);
      const statusKey   = match ? _lpStatusKey(match.status) : 'in';
      const statusLabel = match ? _lpStatusLabel(statusKey) : 'Healthy';
      const hsUrl = (() => {
        try { return getPlayerHeadshot(entry.player, entry.league); } catch(e) { return ''; }
      })();
      const avatar = hsUrl
        ? `<img class="ticket-avatar" src="${hsUrl}" onerror="this.style.display='none'" />`
        : `<div class="ticket-avatar-ph">${(entry.player[0]||'?').toUpperCase()}</div>`;

      const propSub = entry.prop
        ? `<div class="ticket-prop-sub">${entry.direction} ${entry.line} ${entry.prop}</div>`
        : '';
      const detail = match?.detail ? `<div style="font-size:10px;color:var(--text-muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;">${match.detail}</div>` : '';

      return `
        <div class="ticket-player-row status-${statusKey}">
          ${avatar}
          <div class="ticket-player-info">
            <div class="ticket-player-name">${entry.player}</div>
            <div class="ticket-player-meta">${entry.team} · ${entry.league}</div>
            ${propSub}${detail}
          </div>
          <span class="ticket-status-pill ${statusKey}">${statusLabel}</span>
          <button class="ticket-remove-btn" onclick="removeFromTicket('${entry.player.replace(/'/g,'\\&apos;')}')" title="Remove">×</button>
        </div>`;
    }

    // ─ OneSignal: request permission + enable ─
    async function enableTicketNotifications() {
      try {
        // Step 1: Request browser notification permission directly
        // This is the most reliable path — works immediately, no SDK timing dependency
        let permission = Notification.permission;
        if (permission === 'default') {
          permission = await Notification.requestPermission();
        }

        if (permission === 'denied') {
          showToast('⛔ Notifications blocked — enable them in your browser settings, then try again');
          return;
        }

        if (permission !== 'granted') {
          showToast('Notifications not granted — please try again');
          return;
        }

        // Step 2: Also init OneSignal subscription if SDK is ready
        if (window.OneSignalDeferred) {
          window.OneSignalDeferred.push(async (OS) => {
            try {
              // v16 API — opt the user in
              if (OS.User?.PushSubscription) {
                await OS.User.PushSubscription.optIn();
              } else if (OS.Notifications?.requestPermission) {
                await OS.Notifications.requestPermission();
              }
            } catch(e) { /* SDK not fully ready, native permission is enough */ }
          });
        }

        // Step 3: Mark enabled and update UI
        _ticket.notifEnabled = true;
        localStorage.setItem('pe_notif', 'true');
        const bell = document.getElementById('notifBellBtn');
        if (bell) { bell.classList.add('enabled'); bell.textContent = '🔔'; }
        renderTicketPanel();
        showToast('🔔 Push notifications enabled — you’ll be alerted for watched players!');
      } catch(e) {
        showToast('Could not enable notifications — please check browser settings');
      }
    }

    // ─ Bell FAB toggle ─
    async function toggleNotifBell() {
      if (_ticket.notifEnabled) {
        // Go to ticket tab
        switchInjSubtab('ticket');
        document.getElementById('injTab')?.click();
      } else {
        await enableTicketNotifications();
      }
    }

    // ─ Send a push notification via OneSignal ─
    function _sendTicketPush(title, body) {
      if (!_ticket.notifEnabled) return;
      if (Notification.permission !== 'granted') return;
      try {
        // Primary path: use Service Worker showNotification (works when tab is in background)
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.ready.then(reg => {
            reg.showNotification(title, {
              body,
              icon: '/icon-192.png',
              badge: '/icon-192.png',
              tag: 'propedge-ticket',
              renotify: true,
              requireInteraction: false,
              data: { url: window.location.href },
            });
          }).catch(() => {
            // Fallback: foreground Notification API (only works when tab is open/focused)
            new Notification(title, { body, tag: 'propedge-ticket' });
          });
        } else {
          // No service worker — use foreground notification
          new Notification(title, { body, tag: 'propedge-ticket' });
        }
      } catch(e) {}
    }

    // ─ Cross-reference watchlist against latest injury data ─
    // Called after every injury poll cycle
    function _ticketCheckStatusChanges() {
      if (_ticket.players.length === 0) return;
      const allInj = ['NBA','NHL','MLB','NFL'].flatMap(l => _injState.injuries[l] || []);

      _ticket.players.forEach(entry => {
        const k         = _ticketKey(entry.player);
        const match     = allInj.find(i => _ticketKey(i.player) === k);
        const newStatus = match ? _lpStatusKey(match.status) : 'in';
        const oldStatus = _ticket.prevStatuses[k];

        // First time seeing this player — just store, don’t alert
        if (oldStatus === undefined) {
          _ticket.prevStatuses[k] = newStatus;
          return;
        }

        // Status changed — fire push
        if (newStatus !== oldStatus) {
          _ticket.prevStatuses[k] = newStatus;
          // Update entry's lastStatus
          entry.lastStatus = newStatus;
          _ticketSave();

          // Build notification
          const label = _lpStatusLabel(newStatus);
          let title = '';
          let body  = '';
          if (newStatus === 'out' || newStatus === 'dnp') {
            title = `🚨 ${entry.player} is ${label.toUpperCase()}`;
            body  = `${entry.player} (${entry.team}) status changed to ${label}${entry.prop ? ' — check your ' + entry.direction + ' ' + entry.line + ' ' + entry.prop + ' prop' : ''}`;
          } else if (newStatus === 'q' || newStatus === 'gtd' || newStatus === 'dtd') {
            title = `⚠️ ${entry.player} is ${label}`;
            body  = `${entry.player} (${entry.team}) is now ${label} — monitor closely`;
          } else if (newStatus === 'in' && (oldStatus === 'out' || oldStatus === 'q' || oldStatus === 'gtd' || oldStatus === 'dtd' || oldStatus === 'prob')) {
            title = `✅ ${entry.player} is Confirmed`;
            body  = `${entry.player} (${entry.team}) has been confirmed active`;
          } else {
            title = `📊 ${entry.player} status: ${label}`;
            body  = `${entry.player} (${entry.team}) updated to ${label}`;
          }
          _sendTicketPush(title, body);
          // Also show in-app toast
          showToast(title);
          // Re-render ticket panel if it's open
          if (_injState.subtab === 'ticket') renderTicketPanel();
        }
      });
    }

    // Show the bell FAB whenever user has notification permission or watched players
    function _ticketUpdateBellVisibility() {
      const bell = document.getElementById('notifBellBtn');
      if (!bell) return;
      const hasWatched = _ticket.players.length > 0;
      bell.style.display = hasWatched ? 'flex' : 'none';
      bell.classList.toggle('enabled', _ticket.notifEnabled);
    }

    function switchInjSubtab(tab) {
      _injState.subtab = tab;
      document.querySelectorAll('.inj-subtab').forEach(el =>
        el.classList.toggle('active', el.dataset.subtab === tab));
      ['injuries','lineups','news','ticket'].forEach(t => {
