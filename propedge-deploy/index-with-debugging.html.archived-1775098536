    // ── Main refresh ────────────────────────────
    async function refreshInjuryTracker() {
      const btn = document.getElementById('injRefreshBtn');
      const icon = document.getElementById('injRefreshIcon');
      btn.classList.add('spinning');
      // Parallel fetch all leagues
      await Promise.all(['NBA','NHL','MLB','NFL'].map(lg => Promise.all([
        _fetchInjuries(lg),
        _fetchLineups(lg),
        _fetchNews(lg),
      ])));
      _syncInjuriesToLineups();
      btn.classList.remove('spinning');
      _injState.loaded = true;
      const now = new Date();
      document.getElementById('injLastUpdated').textContent =
        'Updated ' + now.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      renderInjuryPanel();
      renderLineupsPanel();
      renderNewsPanel();
      // Re-render props so Intel badges (Opportunity, Lineup Lock, Line Moving) update
      if (typeof renderProps === 'function') renderProps();
      // Auto-refresh every 15 min (full)
      if (_injState.refreshTimer) clearInterval(_injState.refreshTimer);
      _injState.refreshTimer = setInterval(refreshInjuryTracker, 15 * 60 * 1000);

      // Lineup-only poll every 5 min — keeps status pills current as games approach tip
      if (_injState.lineupTimer) clearInterval(_injState.lineupTimer);
      _injState.lineupTimer = setInterval(async () => {
        await Promise.all(['NBA','NHL','MLB','NFL'].map(lg => _fetchLineups(lg)));
        renderLineupsPanel();
        // Also re-render props so Lineup Lock badges update
        if (typeof renderProps === 'function') renderProps();
      }, 5 * 60 * 1000);

      // Injury feed poll every 2 min — near real-time status updates
      if (_injState.newsTimer) clearInterval(_injState.newsTimer);
      _injState.newsTimer = setInterval(async () => {
        await Promise.all(['NBA','NHL','MLB','NFL'].map(lg => _fetchNews(lg)));
        renderNewsPanel();
        renderLineupsPanel(); // refresh game strips
      }, 2 * 60 * 1000);

      // Ticket injury poll every 90s — fastest possible status change detection
      if (_injState.ticketTimer) clearInterval(_injState.ticketTimer);
      _injState.ticketTimer = setInterval(async () => {
        await Promise.all(['NBA','NHL','MLB','NFL'].map(lg => _fetchInjuries(lg)));
        _syncInjuriesToLineups();
        renderLineupsPanel();
        _ticketCheckStatusChanges();
        _ticketUpdateBellVisibility();
        if (_injState.subtab === 'ticket') renderTicketPanel();
      }, 90 * 1000);

      showToast('Tracker updated — Intel signals active');

      // 🎟 Ticket: check for status changes on watched players + update bell
      _ticketCheckStatusChanges();
      _ticketUpdateBellVisibility();
      if (_injState.subtab === 'ticket') renderTicketPanel();
    }

    // ── Phase 1: Injuries ───────────────────────
    async function _fetchInjuries(league) {
      try {
        const { sport, league: lg } = ESPN_SPORT_MAP[league];
        const url = `https://site.api.espn.com/apis/site/v2/sports/${sport}/${lg}/injuries`;
        const d = await fetch(url, { cache: 'no-store' }).then(r => r.json());
        const list = [];
        (d.items || []).forEach(item => {
          const ath = item.athlete || {};
          const statusRaw = (item.status || item.type?.name || 'Unknown');
          list.push({
            league,
            player:    ath.displayName || 'Unknown',
            playerId:  ath.id || '',
            position:  ath.position?.abbreviation || '',
            team:      item.team?.abbreviation || item.team?.displayName || '',
            teamFull:  item.team?.displayName || '',
            status:    statusRaw,
            detail:    item.longComment || item.shortComment || item.type?.text || '',
            returnDate: item.returnDate || '',
            isStarter: ath.starter || false,
          });
        });
        // Sort: Out first, then doubtful, questionable, probable
        const order = {'out':0,'doubtful':1,'questionable':2,'probable':3};
        list.sort((a,b) => (order[getInjuryClass(a.status)]||4) - (order[getInjuryClass(b.status)]||4));
        _injState.injuries[league] = list;
      } catch(e) { _injState.injuries[league] = []; }
    }

    function renderInjuryPanel() {
      const q = (document.getElementById('injSearchInput')?.value || '').toLowerCase();
      const lg = _injState.injLeague;
      const leagues = lg === 'ALL' ? ['NBA','NHL','MLB','NFL'] : [lg];
      let all = leagues.flatMap(l => _injState.injuries[l]);
      if (q) all = all.filter(i =>
        i.player.toLowerCase().includes(q) || i.team.toLowerCase().includes(q));

      const container = document.getElementById('injCardsOut');
      if (!_injState.loaded) {
        container.innerHTML = '<div class="inj-empty"><div class="inj-empty-icon">🩹</div>Tap Refresh to load injury data</div>';
        return;
      }
      if (!all.length) {
        container.innerHTML = '<div class="inj-empty"><div class="inj-empty-icon">✅</div>No injuries found' + (q ? ' for "'+q+'"' : '') + '</div>';
        return;
      }

      // ══ Intel Summary Banner ═══════════════════════════════════
      {
        const banner = document.getElementById('intelSummaryBanner');
        if (banner) {
          // Count OUT+Doubtful players that have props to benefit from
          const outOrDoubtful = all.filter(i => getInjuryClass(i.status) === 'out' || getInjuryClass(i.status) === 'doubtful');
          const affectedTeams = new Set(outOrDoubtful.map(i => i.team.toUpperCase().trim() + '_' + i.league));
          let affectedProps = 0;
          affectedTeams.forEach(key => {
            const [t, l] = key.split('_');
            affectedProps += state.props.filter(p =>
              p.league === l && (p.team||'').toUpperCase().trim() === t).length;
          });
          // Count line-moving opportunities (game within 60 min)
          let lineMovingCount = 0;
          outOrDoubtful.forEach(inj => {
            const gameStart = _findPropGameStart((inj.team||'').toUpperCase().trim(), inj.league);
            if (gameStart !== null) {
              const mins = (gameStart - Date.now()) / 60000;
              if (mins >= -5 && mins <= 60) lineMovingCount++;
            }
          });

          if (outOrDoubtful.length > 0) {
            banner.style.display = '';
            banner.innerHTML = `
              <div style="background:linear-gradient(135deg,rgba(255,165,0,0.1),rgba(176,108,255,0.1));border:1px solid rgba(255,165,0,0.25);border-radius:10px;padding:10px 14px;">
                <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.6px;color:#ffaa33;margin-bottom:8px;">⚡ PropEdge Intel Active</div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                  <span style="font-size:11px;background:rgba(255,68,68,0.1);color:#ff6666;border:1px solid rgba(255,68,68,0.3);border-radius:5px;padding:3px 9px;">
                    ${outOrDoubtful.length} player${outOrDoubtful.length!==1?'s':''} OUT/Doubtful
                  </span>
                  ${affectedProps > 0 ? `<span style="font-size:11px;background:rgba(255,165,0,0.1);color:#ffaa33;border:1px solid rgba(255,165,0,0.3);border-radius:5px;padding:3px 9px;">
                    🔥 ${affectedProps} prop${affectedProps!==1?'s':''} affected
                  </span>` : ''}
                  ${lineMovingCount > 0 ? `<span style="font-size:11px;background:rgba(176,108,255,0.1);color:var(--accent-purple);border:1px solid rgba(176,108,255,0.3);border-radius:5px;padding:3px 9px;">
                    📈 ${lineMovingCount} line${lineMovingCount!==1?'s':''} moving
                  </span>` : ''}
                </div>
              </div>`;
          } else {
            banner.style.display = 'none';
          }
        }
      }

      // Group by status
      const groups = { out:[], doubtful:[], questionable:[], probable:[] };
      all.forEach(i => { const c = getInjuryClass(i.status); (groups[c] = groups[c]||[]).push(i); });
      const labelMap = { out:'Out', doubtful:'Doubtful', questionable:'Questionable', probable:'Probable / GTD' };
      const leagueEmoji = { NBA:'🏀', NHL:'🏒', MLB:'⚾', NFL:'🏈' };

      let html = '';
      ['out','doubtful','questionable','probable'].forEach(g => {
        if (!groups[g]?.length) return;
        html += `<div class="inj-section-label">${labelMap[g]} <span style="color:var(--text-muted);font-weight:400;font-size:10px;">(${groups[g].length})</span></div>`;
        html += '<div class="inj-cards-grid">';
        groups[g].forEach((inj, injIdx) => {
          const cls = getInjuryClass(inj.status);
          const hsUrl = inj.playerId ? `https://a.espncdn.com/i/headshots/${ESPN_SPORT_MAP[inj.league]?.sport}/players/full/${inj.playerId}.png` : '';
          const avatar = hsUrl
            ? `<img class="inj-avatar" src="${hsUrl}" onerror="this.style.display='none'" alt="">`
            : `<div class="inj-avatar-placeholder">${leagueEmoji[inj.league]||'🏅'}</div>`;
          const starter = inj.isStarter ? '<span class="inj-starter-badge">STARTER</span>' : '';
          const lgBadge = lg === 'ALL' ? `<span style="font-size:9px;color:var(--text-muted);">${inj.league}</span>` : '';
          const returnTxt = inj.returnDate ? `<div class="inj-return">📅 Est. return: ${inj.returnDate}</div>` : '';

          // ══ INTEL signals in Injury card ══════════════════════════════

          // Feature 3: Line Moving signal — does this injury affect any prop within 60min?
          let lineMovingHtml = '';
          if (cls === 'out' || cls === 'doubtful') {
            const teamNorm = (inj.team||'').toUpperCase().trim();
            const gameStart = _findPropGameStart(teamNorm, inj.league);
            if (gameStart !== null) {
              const minsToTip = (gameStart - Date.now()) / 60000;
              if (minsToTip >= -5 && minsToTip <= 60) {
                lineMovingHtml = `<div class="intel-signals-row" style="margin-top:6px;">
                  <span class="prop-badge line-moving" style="font-size:9px;">📈 LINE MOVING — game in ${Math.max(0,Math.round(minsToTip))} min</span>
                </div>`;
              }
            }
          }

          // Feature 4: Who Benefits — only show for OUT or Doubtful players
          let whoBenefitsHtml = '';
          if (cls === 'out' || cls === 'doubtful') {
            const beneficiaries = _whobenefits(inj.player, inj.team, inj.league);
            const panelId = `wb-panel-${g}-${injIdx}`;
            if (beneficiaries.length > 0) {
              const rows = beneficiaries.map((bp, bi) => {
                const bpHs = getPlayerHeadshot ? getPlayerHeadshot(bp.player, bp.league) : '';
                const avatarImg = bpHs
                  ? `<img class="wb-avatar" src="${bpHs}" onerror="this.src=''" alt="">`
                  : `<div class="wb-avatar" style="display:flex;align-items:center;justify-content:center;font-size:14px;">${leagueEmoji[bp.league]||'📊'}</div>`;
                return `<div class="wb-row">
                  <span class="wb-rank">#${bi+1}</span>
                  ${avatarImg}
                  <div class="wb-info">
                    <div class="wb-name">${bp.player}</div>
                    <div class="wb-prop">${bp.direction} ${bp.line} ${bp.prop} · ${bp.oddsStr||''}</div>
                  </div>
                  <div>
                    <div class="wb-score">${bp.modelScore}</div>
                    <div class="wb-score-label">Score</div>
                  </div>
                </div>`;
              }).join('');
              whoBenefitsHtml = `
                <div class="who-benefits-panel" id="${panelId}">
                  <div class="who-benefits-toggle" onclick="toggleWhoBenefits('${panelId}')">
                    ⚡ WHO BENEFITS (${beneficiaries.length})
                    <span class="wb-arrow">▼</span>
                  </div>
                  <div class="who-benefits-body">${rows}</div>
                </div>`;
            } else {
              whoBenefitsHtml = `
                <div class="who-benefits-panel">
                  <div class="who-benefits-toggle" style="cursor:default;opacity:0.6;">⚡ NO PROPS FOUND FOR TEAMMATES</div>
                </div>`;
            }
          }

          const injWatched = _ticketHasPlayer(inj.player);
          html += `
            <div class="injury-card status-${cls}">
              ${avatar}
              <div class="inj-card-body">
                <div class="inj-card-row1">
                  <span class="injury-player">${inj.player}</span>
                  ${starter}${lgBadge}
                </div>
                <div class="injury-team">${inj.team}${inj.position ? ' · ' + inj.position : ''}</div>
                ${inj.detail ? `<div class="inj-detail">${inj.detail}</div>` : ''}
                ${returnTxt}
                ${lineMovingHtml}
                ${whoBenefitsHtml}
              </div>
              <span class="injury-status ${cls}">${inj.status}</span>
              <button class="inj-watch-btn ${injWatched ? 'watched' : ''}"
                data-player="${inj.player}" data-league="${inj.league}" data-team="${inj.team}"
                onclick="toggleTicketInj(this)"
                title="${injWatched ? 'Remove from My Ticket' : 'Add to My Ticket'}">
                ${injWatched ? '★' : '☆'}
              </button>
            </div>`;
        });
        html += '</div>';
      });
      container.innerHTML = html;
    }

    // ── Phase 2: Lineups ────────────────────────

    /**
     * Normalize a raw ESPN injury/status string into a canonical key.
     * Returns: 'out' | 'dnp' | 'q' | 'gtd' | 'dtd' | 'prob' | 'in' | ''
     */
    function _lpStatusKey(raw) {
      const s = (raw || '').toLowerCase().trim();
      if (!s) return '';
      if (s.includes('out') || s === 'inactive' || s === 'did not play') return 'out';
      if (s === 'dnp' || s.includes('did not play') || s.includes('not with team')) return 'dnp';
      if (s.includes('doubtful')) return 'q';           // doubtful → yellow Q
      if (s.includes('questionable') || s === 'q') return 'q';
      if (s.includes('day-to-day') || s === 'dtd') return 'dtd';
      if (s.includes('game time') || s === 'gtd') return 'gtd';
      if (s.includes('probable') || s === 'p') return 'prob';
      if (s === 'active' || s === 'playing' || s === 'in' || s === 'available') return 'in';
      // Anything else with content treat as questionable
      return 'q';
    }

    /** Human-readable label for a status key */
    function _lpStatusLabel(key) {
      return { out:'Out', dnp:'DNP', q:'Questionable', gtd:'Game-Time', dtd:'Day-To-Day', prob:'Probable', in:'Confirmed' }[key] || key.toUpperCase();
    }

    async function _fetchLineups(league) {
      try {
        const { sport, league: lg } = ESPN_SPORT_MAP[league];
        // Get today's scoreboard for all games
        const sb = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${sport}/${lg}/scoreboard`).then(r=>r.json());
        const events = sb.events || [];
        const results = [];
        const fetchedAt = Date.now();

        // Fetch summary for each game (up to 8) in parallel to get rosters
        await Promise.all(events.slice(0,8).map(async ev => {
          try {
            const sum = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${sport}/${lg}/summary?event=${ev.id}`).then(r=>r.json());
            const comp = ev.competitions?.[0];
            const homeComp = comp?.competitors?.find(c=>c.homeAway==='home');
            const awayComp = comp?.competitors?.find(c=>c.homeAway==='away');
            const isLive  = ev.status?.type?.state === 'in';
            const isFinal = ev.status?.type?.completed;
            const gameDate = comp?.date ? new Date(comp.date) : null;
            const statusTxt = isFinal ? 'Final' : isLive
              ? (ev.status?.type?.shortDetail || 'Live')
              : (gameDate ? gameDate.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) : 'TBD');

            // Cross-ref the ESPN injury list for this team to get richer status
            const leagueInj = _injState.injuries[league] || [];
            const injByName = {};
            leagueInj.forEach(inj => {
              injByName[inj.player.toLowerCase().trim()] = inj.status;
            });

            /**
             * Build a rich roster for one team.
             * Priority: boxscore athletes (game-day active list) → rosters fallback.
             * For each player we resolve:
             *   name, pos, starter, statusKey, statusLabel, active, playerId
             */
            const buildRoster = (teamAbbr) => {
              const players = [];
              const seen = new Set();

              // ── Source A: boxscore.players (confirmed game-day list) ────
              const teamPlayers = sum.boxscore?.players?.find(tp =>
                tp.team?.abbreviation?.toUpperCase() === teamAbbr?.toUpperCase());

              if (teamPlayers) {
                const allAthletes = (teamPlayers.statistics || []).flatMap(sg =>
                  (sg.athletes || []).map(a => {
                    const ath = a.athlete || {};
                    // ESPN gives didNotPlay + reason for players who were in the active pool but didn't play
                    const dnp = a.didNotPlay || false;
                    const dnpReason = a.reason || '';
                    // Raw injury status from athlete object
                    const rawStatus = ath.injured
                      ? (ath.injuryStatus || 'Q')
                      : (dnp ? (dnpReason || 'DNP') : '');
                    // Cross-check against today's ESPN injury feed for latest status
                    const injFeedStatus = injByName[ath.displayName?.toLowerCase().trim() || ''] ||
                                         injByName[ath.shortName?.toLowerCase().trim() || ''] || '';
                    const resolvedRaw = injFeedStatus || rawStatus;
                    const statusKey = _lpStatusKey(resolvedRaw);
                    return {
                      name:        ath.shortName || ath.displayName || '',
                      fullName:    ath.displayName || '',
                      playerId:    ath.id || '',
                      pos:         ath.position?.abbreviation || '',
                      starter:     a.starter || false,
                      active:      !dnp && !ath.injured,
                      statusKey,                           // 'in'|'out'|'q'|'gtd'|'dnp'|'prob'|'dtd'|''
                      statusLabel: _lpStatusLabel(statusKey),
                      rawStatus:   resolvedRaw,
                    };
                  })
                );
                allAthletes.forEach(p => {
                  if (p.name && !seen.has(p.name)) { seen.add(p.name); players.push(p); }
                });
              }

              // ── Source B: summary.rosters (sometimes populated pre-game) ────
              if (!players.length) {
                const rosterTeam = sum.rosters?.find(r =>
                  r.team?.abbreviation?.toUpperCase() === teamAbbr?.toUpperCase());
                (rosterTeam?.roster || []).slice(0, 18).forEach((r, i) => {
                  const ath = r.athlete || {};
                  const injFeedStatus = injByName[ath.displayName?.toLowerCase().trim() || ''] ||
                                        injByName[ath.shortName?.toLowerCase().trim() || ''] || '';
                  const rawStatus = injFeedStatus || ath.injuryStatus || '';
                  const statusKey = _lpStatusKey(rawStatus);
                  const defaultStarter = i < (league==='NBA'?5:league==='NHL'?6:league==='MLB'?9:11);
                  players.push({
                    name:        ath.shortName || ath.displayName || '',
                    fullName:    ath.displayName || '',
                    playerId:    ath.id || '',
                    pos:         ath.position?.abbreviation || '',
                    starter:     r.starter ?? defaultStarter,
                    active:      statusKey !== 'out' && statusKey !== 'dnp',
                    statusKey,
                    statusLabel: _lpStatusLabel(statusKey),
                    rawStatus,
                  });
                });
              }
              // stored for async roster fetch below
              return players;
            };

            // ── Source C: ESPN /roster API (async, pre-game fallback) ────
            // Fetch team roster directly when no boxscore/rosters data came back.
            // Uses competitor team IDs from scoreboard.
            const fetchRosterForTeam = async (teamId, teamAbbr) => {
              try {
                const r = await fetch(
                  `https://site.api.espn.com/apis/site/v2/sports/${sport}/${lg}/teams/${teamId}/roster`
                ).then(r => r.json());
                // ESPN /teams/{id}/roster returns a flat array of athletes (NOT grouped under 'items')
                const athletes = (r.athletes || []).map((ath) => {
                    const injFeedStatus = injByName[ath.displayName?.toLowerCase().trim() || ''] ||
                                          injByName[ath.shortName?.toLowerCase().trim() || ''] || '';
                    // Status: prefer injury feed cross-ref, then ath.injuries[0].status, then ath.status.type
                    const espnInjStatus  = ath.injuries?.[0]?.status || '';
                    const espnStatusType = (ath.status?.type === 'active' || ath.status?.type === 'Active')
                                           ? '' : (ath.status?.type || '');
                    const rawStatus = injFeedStatus || espnInjStatus || espnStatusType;
                    const statusKey = _lpStatusKey(rawStatus);
                    return {
                      name:        ath.shortName || ath.displayName || '',
                      fullName:    ath.displayName || '',
                      playerId:    ath.id || '',
                      pos:         ath.position?.abbreviation || '',
                      starter:     false,   // pre-game roster, starters unknown
                      active:      statusKey !== 'out' && statusKey !== 'dnp',
                      statusKey,
                      statusLabel: _lpStatusLabel(statusKey),
                      rawStatus,
                    };
                });
                // Sort: healthy first, then Q/GTD, then OUT — alphabetical within group
                athletes.sort((a, b) => {
                  const aOut = a.statusKey === 'out' || a.statusKey === 'dnp';
                  const bOut = b.statusKey === 'out' || b.statusKey === 'dnp';
                  if (aOut !== bOut) return aOut ? 1 : -1;
                  const aQ = a.statusKey === 'q' || a.statusKey === 'gtd' || a.statusKey === 'dtd';
                  const bQ = b.statusKey === 'q' || b.statusKey === 'gtd' || b.statusKey === 'dtd';
                  if (aQ !== bQ) return aQ ? 1 : -1;
                  return a.name.localeCompare(b.name);
                });
                return athletes.slice(0, 18);
              } catch(e) { return []; }
            };

            const homeAbbr = homeComp?.team?.abbreviation || '';
            const awayAbbr = awayComp?.team?.abbreviation || '';
            const homeTeamId = homeComp?.team?.id || homeAbbr;
            const awayTeamId = awayComp?.team?.id || awayAbbr;
            const homeLogo = getTeamLogoUrl(homeAbbr, league);
            const awayLogo = getTeamLogoUrl(awayAbbr, league);

            let homeRoster = buildRoster(homeAbbr);
            let awayRoster = buildRoster(awayAbbr);

            // ── Source C: ESPN /roster API for pre-game PROJECTED lineups ────────
            // Only run when boxscore + summary.rosters both came back empty
            // (i.e., game hasn't started yet). Shows full team roster with
            // injury status from the ESPN injury feed cross-ref.
            if (!isLive && !isFinal) {
              if (!homeRoster.length) {
                homeRoster = await fetchRosterForTeam(homeTeamId, homeAbbr);
              }
              if (!awayRoster.length) {
                awayRoster = await fetchRosterForTeam(awayTeamId, awayAbbr);
              }
            }

            results.push({
              gameId: ev.id, league,
              homeAbbr, awayAbbr, homeLogo, awayLogo,
              homeRoster, awayRoster,
              isLive, isFinal, statusTxt,
              gameTime: gameDate ? gameDate.getTime() : null,
              confirmed: isLive || isFinal,   // true = ESPN has real boxscore data
              fetchedAt,                      // timestamp of this fetch
            });
          } catch(e) {}
        }));
        _injState.lineups[league] = results;
      } catch(e) { _injState.lineups[league] = []; }
    }

    function getTeamLogoUrl(abbr, league) {
      const a = (abbr||'').toUpperCase();
      const byLeague = TEAM_LOGOS_BY_LEAGUE[league];
      if (byLeague?.[a]) return byLeague[a];
      return TEAM_LOGOS[a] || '';
    }

    function renderLineupsPanel() {
      const lg = _injState.lineupLeague;
      const raw = _injState.lineups[lg] || [];
      const container = document.getElementById('injLineupCards');
      if (!_injState.loaded) {
        container.innerHTML = '<div class="inj-empty"><div class="inj-empty-icon">📋</div>Tap Refresh to load lineups</div>';
        return;
      }
      if (!raw.length) {
        container.innerHTML = '<div class="inj-empty"><div class="inj-empty-icon">🗓</div>No games scheduled today for ' + lg + '</div>';
        return;
      }

      // Sort games chronologically: LIVE first, then upcoming by tip-off time, then FINAL
      const games = [...raw].sort((a, b) => {
        // LIVE games always first
        if (a.isLive && !b.isLive) return -1;
        if (!a.isLive && b.isLive) return 1;
        // FINAL games always last
        if (a.isFinal && !b.isFinal) return 1;
        if (!a.isFinal && b.isFinal) return -1;
        // Otherwise sort by game start time ascending
        const ta = a.gameTime || 0;
        const tb = b.gameTime || 0;
        return ta - tb;
      });

      const maxPlayers = { NBA:10, NHL:14, MLB:9, NFL:13 };
      const max = maxPlayers[lg] || 12;
      const now = Date.now();

      container.innerHTML = games.map((g, gi) => {
        // ── Status badge ──────────────────────────────────────────────────
        const badge = g.isFinal
          ? '<span class="lineup-confirmed-badge" style="opacity:0.6;">FINAL</span>'
          : g.isLive
          ? '<span class="lineup-confirmed-badge" style="background:rgba(255,82,82,0.15);color:var(--accent-red);border:1px solid rgba(255,82,82,0.3);">LIVE ●</span>'
          : g.confirmed
          ? '<span class="lineup-confirmed-badge">🔒 CONFIRMED</span>'
          : '<span class="lineup-projected-badge">📋 PROJECTED</span>';

        // ── Freshness ─────────────────────────────────────────────────────
        const ageMs = g.fetchedAt ? now - g.fetchedAt : null;
        const ageMins = ageMs !== null ? Math.floor(ageMs / 60000) : null;
        const freshnessTxt = ageMins !== null
          ? (ageMins < 1 ? 'Just updated' : `Updated ${ageMins}m ago`)
          : '';
        const isStaleData = ageMins !== null && ageMins > 10;

        // ── Build one team column ─────────────────────────────────────────
        const buildTeamCol = (roster, abbr, logo) => {
          const rows = roster.slice(0, max);
          const logoImg = logo ? `<img src="${logo}" onerror="this.src=''">` : '';
          if (!rows.length) {
            return `<div class="lineup-team-col">
              <h4>${logoImg}${abbr}</h4>
              <div style="color:var(--text-muted);font-size:11px;">Lineup TBD</div>
            </div>`;
          }

          // Summary count pills
          const sc = {};
          rows.forEach(p => { if (p.statusKey) sc[p.statusKey] = (sc[p.statusKey]||0) + 1; });
          const qCount = (sc.q||0) + (sc.gtd||0) + (sc.dtd||0);
          const summaryPills = [
            sc.out  ? `<span class="lineup-summary-pill" style="background:rgba(255,68,68,0.12);color:var(--accent-red);">${sc.out} Out</span>` : '',
            sc.dnp  ? `<span class="lineup-summary-pill" style="background:rgba(255,255,255,0.05);color:var(--text-muted);">${sc.dnp} DNP</span>` : '',
            qCount  ? `<span class="lineup-summary-pill" style="background:rgba(245,197,24,0.12);color:var(--accent-gold);">${qCount} Questionable</span>` : '',
            sc.prob ? `<span class="lineup-summary-pill" style="background:rgba(68,136,255,0.12);color:var(--accent-blue);">${sc.prob} Probable</span>` : '',
            sc.in   ? `<span class="lineup-summary-pill" style="background:rgba(0,230,118,0.1);color:var(--accent-green);">${sc.in} Confirmed</span>` : '',
          ].filter(Boolean).join('');

          return `<div class="lineup-team-col">
            <h4>${logoImg}${abbr}</h4>
            ${summaryPills ? `<div class="lineup-status-summary">${summaryPills}</div>` : ''}
            ${rows.map((p, i) => lineupRow(p, i+1, g.confirmed)).join('')}
          </div>`;
        };

        const awayCol = buildTeamCol(g.awayRoster, g.awayAbbr, g.awayLogo);
        const homeCol = buildTeamCol(g.homeRoster, g.homeAbbr, g.homeLogo);
        const hasRosters = (g.homeRoster.length + g.awayRoster.length) > 0;

        const awayLogoSm = g.awayLogo ? `<img src="${g.awayLogo}" onerror="this.src=''">` : '';
        const homeLogoSm = g.homeLogo ? `<img src="${g.homeLogo}" onerror="this.src=''">` : '';

        const cardClass = g.isFinal ? 'lineup-game-card lineup-final'
                        : g.isLive  ? 'lineup-game-card lineup-live'
                        : 'lineup-game-card';

        return `
          <div class="${cardClass}">
            <div class="lineup-game-header" onclick="toggleLineupBody('lineup-body-${gi}')">
              <div>
                <div class="lineup-game-teams">${awayLogoSm}${g.awayAbbr} <span style="color:var(--text-muted)">@</span> ${homeLogoSm}${g.homeAbbr}</div>
                <div class="lineup-game-meta">${g.statusTxt}${freshnessTxt ? ' · ' + freshnessTxt : ''}</div>
              </div>
              <div style="display:flex;align-items:center;gap:8px;">
                ${badge}
                <span style="color:var(--text-muted);font-size:14px;">›</span>
              </div>
            </div>
            <div class="lineup-body" id="lineup-body-${gi}">
              ${hasRosters
                ? `<div class="lineup-teams-grid">${awayCol}${homeCol}</div>`
                : '<div style="color:var(--text-muted);font-size:12px;text-align:center;padding:12px 0;">Lineups not yet available</div>'}
              ${_buildGameFeedStrip(g.homeAbbr, g.awayAbbr, g.league)}
            </div>
          </div>`;
      }).join('');
    }

    function _syncInjuriesToLineups() {
      try {
        ['NBA', 'NHL', 'MLB', 'NFL'].forEach(league => {
          const games = _injState.lineups[league] || [];
          const leagueInj = _injState.injuries[league] || [];
          const injByName = {};
          leagueInj.forEach(inj => {
            injByName[inj.player.toLowerCase().trim()] = inj.status;
          });
          games.forEach(game => {
            if (game.homeRoster && Array.isArray(game.homeRoster)) {
              game.homeRoster.forEach(player => {
                const injStatus = injByName[player.shortName?.toLowerCase().trim()] ||
                                 injByName[player.name?.toLowerCase().trim()] ||
                                 injByName[player.fullName?.toLowerCase().trim()];
                if (injStatus) {
                  const newStatusKey = _lpStatusKey(injStatus);
                  if (newStatusKey && newStatusKey !== player.statusKey) {
                    player.statusKey = newStatusKey;
                    player.statusLabel = _lpStatusLabel(newStatusKey);
                    player.rawStatus = injStatus;
                  }
                }
              });
            }
            if (game.awayRoster && Array.isArray(game.awayRoster)) {
              game.awayRoster.forEach(player => {
                const injStatus = injByName[player.shortName?.toLowerCase().trim()] ||
                                 injByName[player.name?.toLowerCase().trim()] ||
                                 injByName[player.fullName?.toLowerCase().trim()];
                if (injStatus) {
                  const newStatusKey = _lpStatusKey(injStatus);
                  if (newStatusKey && newStatusKey !== player.statusKey) {
                    player.statusKey = newStatusKey;
                    player.statusLabel = _lpStatusLabel(newStatusKey);
                    player.rawStatus = injStatus;
                  }
                }
              });
            }
          });
        });
      } catch(e) {
        console.warn('[PropEdge] _syncInjuriesToLineups error:', e);
      }
    }

    /**
     * Render one player row in the lineup panel.
     * Shows rich status pills: IN / OUT / Q / GTD / DTD / PROB / DNP
     * Strikethrough + dimming for OUT/DNP rows.
     * ✓ for confirmed starters, ★ for projected starters.
     */
    function lineupRow(p, num, confirmed) {
      const isOut = p.statusKey === 'out' || p.statusKey === 'dnp';

      // ── Status pill — always shown, reflects real-time status ──────────────
      // Priority: explicit injury status > confirmed/projected default
      let statusPill = '';
      if (p.statusKey === 'out') {
        // OUT — red, strikethrough row
        statusPill = `<span class="lp-status out">Out</span>`;
      } else if (p.statusKey === 'dnp') {
        statusPill = `<span class="lp-status dnp">DNP</span>`;
      } else if (p.statusKey === 'q') {
        statusPill = `<span class="lp-status q">Questionable</span>`;
      } else if (p.statusKey === 'dtd') {
        statusPill = `<span class="lp-status dtd">Day-To-Day</span>`;
      } else if (p.statusKey === 'gtd') {
        statusPill = `<span class="lp-status gtd">Game-Time</span>`;
      } else if (p.statusKey === 'prob') {
        statusPill = `<span class="lp-status prob">Probable</span>`;
      } else {
        // No injury flag — show Confirmed (green ✓) if lineup is locked, else Probable (blue)
        if (confirmed) {
          statusPill = `<span class="lp-status in">✓ Confirmed</span>`;
        } else {
          statusPill = `<span class="lp-status prob">Probable</span>`;
        }
      }

      // Starter dot — small indicator left of name
      const starterDot = (!isOut && p.starter)
        ? `<span class="lp-starter-dot${confirmed ? ' confirmed' : ''}"></span>` : '';

      return `<div class="lineup-player-row${isOut ? ' lp-out' : ''}">
        <span class="lineup-num">${num}</span>
        ${starterDot}
        ${p.pos ? `<span class="lineup-pos">${p.pos}</span>` : ''}
        <span class="lineup-pname">${p.name}</span>
        ${statusPill}
      </div>`;
    }

    function toggleLineupBody(id) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('open');
    }

    // ── Phase 3: Real-Time Injury Feed (Underdog-style) ───────────────────
    // Pulls from ESPN /injuries API — has shortComment (breaking line),
    // longComment (analyst blurb), timestamp, status, headshot.
    // Auto-polls every 2 min. Also feeds inline strips on lineup game cards.

    async function _fetchNews(league) {
      try {
        const { sport, league: lg } = ESPN_SPORT_MAP[league];
        const d = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${sport}/${lg}/injuries`).then(r=>r.json());
        const teams = d.injuries || [];
        const items = [];
        teams.forEach(team => {
          (team.injuries || []).forEach(inj => {
            const ath  = inj.athlete || {};
            const status = inj.status || '';
            items.push({
              league,
              player:       ath.displayName || ath.shortName || '',
              shortName:    ath.shortName   || '',
              playerId:     ath.id           || '',
              headshot:     ath.headshot?.href || '',
              team:         ath.team?.abbreviation || team.displayName || '',
              teamFull:     team.displayName || '',
              pos:          ath.position?.abbreviation || '',
              status,
              statusKey:    _lpStatusKey(status),
              shortComment: inj.shortComment || '',
              longComment:  inj.longComment  || '',
              injType:      inj.details?.type || '',
              injLocation:  inj.details?.location || '',
              injDetail:    inj.details?.detail || '',
              returnDate:   inj.details?.returnDate || '',
              date:         inj.date || '',
              ts:           inj.date ? new Date(inj.date).getTime() : 0,
            });
          });
        });
        // Sort newest-first
        items.sort((a,b) => b.ts - a.ts);
        _injState.news[league] = items;
      } catch(e) { _injState.news[league] = []; }
    }

    /** Time-ago helper — "2m ago", "1h ago", "Just now" */
    function _timeAgo(ts) {
      if (!ts) return '';
      const diff = Math.floor((Date.now() - ts) / 1000);
      if (diff < 60)  return 'Just now';
      if (diff < 3600) return Math.floor(diff/60) + 'm ago';
      if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
      return Math.floor(diff/86400) + 'd ago';
    }

    /** Status color class for feed items */
    function _feedStatusClass(key) {
      return { out:'feed-status-out', dnp:'feed-status-out', q:'feed-status-q',
               gtd:'feed-status-q', dtd:'feed-status-q', prob:'feed-status-prob',
               in:'feed-status-in' }[key] || 'feed-status-q';
    }

    /** Render one feed item row */
    function _feedItemHtml(item, showLeague) {
      const sClass = _feedStatusClass(item.statusKey);
      const label  = { out:'OUT', dnp:'DNP', q:'QUESTIONABLE', gtd:'GAME-TIME',
                       dtd:'DAY-TO-DAY', prob:'PROBABLE', in:'ACTIVE' }[item.statusKey] || item.status.toUpperCase();
      const avatar = item.headshot
        ? `<img class="feed-avatar" src="${item.headshot}" onerror="this.src=''"/>`
        : `<div class="feed-avatar feed-avatar-placeholder">${(item.player[0]||'?')}</div>`;
      const injBadge = item.injType
        ? `<span class="feed-inj-type">${item.injType}${item.injLocation ? ' · ' + item.injLocation : ''}</span>` : '';
      const returnBadge = item.returnDate
        ? `<span class="feed-return">Return: ${item.returnDate}</span>` : '';
      const leagueBadge = showLeague
        ? `<span class="feed-league-tag feed-league-${item.league.toLowerCase()}">${item.league}</span>` : '';
      const teamBadge = `<span class="feed-team-tag">${item.team}</span>`;
      const timeStr = _timeAgo(item.ts);
      const blurb = item.shortComment || item.longComment || '';
      // Truncate long blurbs to ~180 chars for feed view; full shown on expand
      const short = blurb.length > 200 ? blurb.slice(0,197) + '…' : blurb;
      const hasLong = item.longComment && item.longComment.length > 200;
      const itemId = 'fi_' + item.league + '_' + (item.playerId || item.player.replace(/\s/g,''));
      return `
        <div class="feed-item feed-item-${item.statusKey}">
          <div class="feed-item-left">${avatar}</div>
          <div class="feed-item-body">
            <div class="feed-item-header">
              <span class="feed-player-name">${item.player}</span>
              ${leagueBadge}${teamBadge}
              ${item.pos ? `<span class="feed-pos">${item.pos}</span>` : ''}
              <span class="feed-time">${timeStr}</span>
            </div>
            <div class="feed-status-line">
              <span class="feed-status-badge ${sClass}">${label}</span>
              ${injBadge}${returnBadge}
            </div>
            ${short ? `<div class="feed-blurb">${short}</div>` : ''}
            ${hasLong ? `<button class="feed-expand-btn" onclick="_toggleFeedExpand('${itemId}')">Read more</button>
              <div class="feed-long-blurb" id="${itemId}" style="display:none">${item.longComment}</div>` : ''}
          </div>
        </div>`;
    }

    function _toggleFeedExpand(id) {
      const el = document.getElementById(id);
      const btn = el?.previousElementSibling;
      if (!el) return;
      const open = el.style.display !== 'none';
      el.style.display = open ? 'none' : '';
      if (btn) btn.textContent = open ? 'Read more' : 'Show less';
    }

    function renderNewsPanel() {
      const lg = _injState.newsLeague;
      const leagues = lg === 'ALL' ? ['NBA','NHL','MLB','NFL'] : [lg];
      const all = leagues.flatMap(l => _injState.news[l]);
      const container = document.getElementById('injNewsCards');
      if (!_injState.loaded) {
        container.innerHTML = '<div class="inj-empty"><div class="inj-empty-icon">🏥</div>Tap Refresh to load injury feed</div>';
        return;
      }
      if (!all.length) {
        container.innerHTML = '<div class="inj-empty"><div class="inj-empty-icon">✅</div>No injury updates right now</div>';
        return;
      }
      // Sort newest-first across leagues
      const sorted = [...all].sort((a,b) => b.ts - a.ts);
      const showLeague = lg === 'ALL';
      const outFirst = [...sorted.filter(i=>i.statusKey==='out'||i.statusKey==='dnp'),
                        ...sorted.filter(i=>i.statusKey!=='out'&&i.statusKey!=='dnp')];
      container.innerHTML =
        `<div class="feed-meta-bar">` +
        `<span class="feed-meta-count">${outFirst.length} updates</span>` +
        `<span class="feed-meta-live">● Live · refreshes every 2m</span>` +
        `</div>` +
        `<div class="inj-feed-list">` +
        outFirst.map(item => _feedItemHtml(item, showLeague)).join('') +
        `</div>`;
    }

    /**
     * Build inline injury feed strip for a lineup game card.
     * Shows last N updates for players on homeTeam or awayTeam.
     */
    function _buildGameFeedStrip(homeAbbr, awayAbbr, league, maxItems=4) {
      const feed = _injState.news[league] || [];
      const teams = new Set([homeAbbr.toUpperCase(), awayAbbr.toUpperCase()]);
      const relevant = feed.filter(f => teams.has(f.team?.toUpperCase())).slice(0, maxItems);
      if (!relevant.length) return '';
      const rows = relevant.map(item => {
        const sClass = _feedStatusClass(item.statusKey);
        const label  = { out:'OUT', dnp:'DNP', q:'Q', gtd:'GTD', dtd:'DTD', prob:'PROB', in:'IN' }[item.statusKey] || item.status;
        const avatar = item.headshot
          ? `<img class="gf-avatar" src="${item.headshot}" onerror="this.src=''"/>`
          : `<div class="gf-avatar gf-avatar-ph">${(item.player[0]||'?')}</div>`;
        const blurb = item.shortComment || '';
        const short = blurb.length > 120 ? blurb.slice(0,117)+'…' : blurb;
        return `<div class="gf-row">
          ${avatar}
          <div class="gf-body">
            <div class="gf-header">
              <span class="gf-name">${item.player}</span>
              <span class="gf-status ${sClass}">${label}</span>
              <span class="gf-time">${_timeAgo(item.ts)}</span>
            </div>
            ${short ? `<div class="gf-blurb">${short}</div>` : ''}
          </div>
        </div>`;
      }).join('');
      return `<div class="game-feed-strip"><div class="gf-label">🏥 Injury Updates</div>${rows}</div>`;
    }

    function getInjuryClass(status) {
      const s = (status||'').toLowerCase();
      if (s.includes('out')) return 'out';
      if (s.includes('doubtful')) return 'doubtful';
      if (s.includes('questionable') || s.includes('gtd') || s.includes('day-to-day')) return 'questionable';
      return 'probable';
    }

    // Legacy shim so old code doesn't break
    function fetchAllInjuries() { refreshInjuryTracker(); }

    // ==========================================
    // PROPEDGE INTEL ENGINE
    // ==========================================

    /**
     * _intel(prop) — returns an object with all 4 Intel signals for a given prop:
     *   { opportunityAlert, lineupStatus, lineMoving, lineMoveReason }
     *
     * Called once per prop card render — lightweight since it only scans small arrays.
     */
    function _intel(prop) {
      const result = {
        opportunityAlert:  null,   // { injuredPlayer, status }
        lineupStatus:      null,   // 'locked' | 'projected' | 'out' | null
        lineMoving:        false,
        lineMoveReason:    '',
      };

      if (!_injState.loaded) return result;

      const playerNameNorm = (prop.player || '').toLowerCase().trim();
      const propTeamNorm   = (prop.team   || '').toUpperCase().trim();
      const league         = prop.league;

      // ── Feature 1: Opportunity Alert ─────────────────────────────────
      // If a teammate (same team, same league) is OUT or Doubtful, flag it.
      const teamInjuries = (_injState.injuries[league] || []).filter(inj => {
        const injTeam = (inj.team || '').toUpperCase().trim();
        // Same team, but NOT the prop player themselves
        return injTeam === propTeamNorm &&
               inj.player.toLowerCase().trim() !== playerNameNorm &&
               (getInjuryClass(inj.status) === 'out' || getInjuryClass(inj.status) === 'doubtful');
      });
      if (teamInjuries.length > 0) {
        // Pick the most severe (out > doubtful)
        teamInjuries.sort((a,b) => (getInjuryClass(a.status)==='out'?0:1) - (getInjuryClass(b.status)==='out'?0:1));
        result.opportunityAlert = {
          injuredPlayer: teamInjuries[0].player,
          status: teamInjuries[0].status,
          count: teamInjuries.length,
        };
      }

      // ── Feature 2: Lineup Status ──────────────────────────────────────
      // Find this player in the lineups for their team's game today.
      const leagueLineups = _injState.lineups[league] || [];
      lineupSearch:
      for (const game of leagueLineups) {
        const rosters = [game.homeRoster, game.awayRoster];
        for (const roster of rosters) {
          for (const rp of (roster || [])) {
            if (!rp.name) continue;
            // Fuzzy match: check if prop player name contains or is contained in lineup name
            const rpNorm = rp.name.toLowerCase().trim();
            if (playerNameNorm.includes(rpNorm) || rpNorm.includes(playerNameNorm) ||
                _nameSimilar(playerNameNorm, rpNorm)) {
              if (rp.injStatus && getInjuryClass(rp.injStatus) === 'out') {
                result.lineupStatus = 'out';
              } else if (game.confirmed) {
                result.lineupStatus = 'locked';
              } else {
                result.lineupStatus = 'projected';
              }
              break lineupSearch;
            }
          }
        }
      }

      // ── Feature 3: Line Moving (lineup-driven) ────────────────────────
      // If a teammate is OUT/Doubtful AND the game starts within 60 minutes → LINE MOVING
      if (result.opportunityAlert) {
        const gameStart = _findPropGameStart(propTeamNorm, league);
        if (gameStart !== null) {
          const minsToTip = (gameStart - Date.now()) / 60000;
          if (minsToTip >= -5 && minsToTip <= 60) {
            result.lineMoving = true;
            const injName = result.opportunityAlert.injuredPlayer.split(' ').pop(); // last name
            result.lineMoveReason = `${injName} ${result.opportunityAlert.status} — usage shift expected`;
          }
        }
      }

      return result;
    }

    /** Rough last-name similarity (handles "LeBron James" vs "L. James" etc.) */
    function _nameSimilar(a, b) {
      const lastA = a.split(' ').pop();
      const lastB = b.split(' ').pop();
      return lastA.length > 2 && lastB.length > 2 && lastA === lastB;
    }

    /** Returns the game start timestamp (ms) for a team, or null */
    function _findPropGameStart(teamAbbr, league) {
      const leagueLineups = _injState.lineups[league] || [];
      for (const g of leagueLineups) {
        const norm = t => (t||'').toUpperCase().trim();
        if (norm(g.homeAbbr) === teamAbbr || norm(g.awayAbbr) === teamAbbr) {
          // statusTxt may be a time string like "7:30 PM" — parse it
          if (g.isLive || g.isFinal) return null; // game already started
          if (g.statusTxt && g.statusTxt.match(/\d+:\d+/)) {
            const today = new Date();
            const [time, ampm] = g.statusTxt.split(' ');
            if (!time) return null;
            let [h, m] = time.split(':').map(Number);
            if (ampm && ampm.toLowerCase() === 'pm' && h < 12) h += 12;
            if (ampm && ampm.toLowerCase() === 'am' && h === 12) h = 0;
            const gameDate = new Date(today.getFullYear(), today.getMonth(), today.getDate(), h, m, 0);
            return gameDate.getTime();
          }
        }
      }
      // Fall back to ESPN games state
      const allGames = [...(state.games[league] || [])];
      for (const g of allGames) {
        if ((g.homeTeam||'').toUpperCase() === teamAbbr || (g.awayTeam||'').toUpperCase() === teamAbbr) {
          if (g.gameTime) return new Date(g.gameTime).getTime();
        }
      }
      return null;
    }

    /**
     * Feature 4: Who Benefits Engine
     * Given an injured player (OUT), return top 3 teammates by model score
     * who have props in state.props.
     */
    function _whobenefits(injuredPlayer, team, league) {
      const propTeamNorm = (team || '').toUpperCase().trim();
      // Get all active props for this team excluding the injured player
      const injNorm = (injuredPlayer || '').toLowerCase().trim();
      const candidates = state.props.filter(p => {
        if (p.league !== league) return false;
        if ((p.team||'').toUpperCase().trim() !== propTeamNorm) return false;
        if ((p.player||'').toLowerCase().trim() === injNorm) return false;
        return true;
      });
      // Group by player — take highest modelScore prop per player
      const byPlayer = {};
      candidates.forEach(p => {
        const key = p.player;
        if (!byPlayer[key] || p.modelScore > byPlayer[key].modelScore) {
          byPlayer[key] = p;
        }
      });
      // Sort by modelScore desc, take top 3
      return Object.values(byPlayer)
        .sort((a,b) => b.modelScore - a.modelScore)
        .slice(0, 3);
    }

    /** Toggle who-benefits accordion */
    function toggleWhoBenefits(panelId) {
      const el = document.getElementById(panelId);
      if (el) el.classList.toggle('open');
    }

    // ==========================================
    // RENDER PROPS
    // ==========================================
    function renderProps() {
      const container = document.getElementById('propsContainer');
      let props = [...state.props];

      // Filter by live/final games using multiple data sources
      const allGames = [...state.games.NBA, ...state.games.NHL, ...state.games.MLB, ...state.games.NFL];
      
      // Time-based checks
      const now = new Date();
      const hour = now.getHours();
      const isLateNight = hour >= 23 || hour < 9; // 11 PM to 9 AM
      const isBeforeGames = hour >= 9 && hour < 11; // 9 AM to 11 AM (before first games)
      
      // Calculate next update time
      let nextUpdate = '';
      if (hour >= 23 || hour < 11) {
        nextUpdate = '11:30 AM';
      } else if (hour >= 11 && hour < 18) {
        nextUpdate = '6:30 PM';
      } else {
        nextUpdate = '11:30 AM tomorrow';
      }
      
      // Only show "no data" empty state if the sheet truly returned nothing
      // (never show it just because ESPN games are all final or late night)
      const sheetIsEmpty = state.props.length === 0;
      const waitingForData = sheetIsEmpty && isBeforeGames;
      const noSheetDataLateNight = sheetIsEmpty && isLateNight;
      
      if (sheetIsEmpty && (waitingForData || noSheetDataLateNight)) {
        container.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">🌙</div>
            <div class="empty-title">${isLateNight ? 'Games Completed' : 'Waiting for Today\'s Props'}</div>
            <div class="empty-text">
              ${isLateNight 
                ? 'Today\'s games have finished. Fresh props will load at <strong>11:30 AM</strong> when tomorrow\'s lines are available.'
                : `Props are being prepared. Next update at <strong>${nextUpdate}</strong>.`
              }
            </div>
            <div style="margin-top: 20px; padding: 16px; background: var(--bg-tertiary); border-radius: var(--radius-md); text-align: left;">
              <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 8px;">⏰ Daily Schedule</div>
              <div style="font-size: 11px; color: var(--text-muted); line-height: 1.8;">
                <strong>11:30 AM</strong> — Morning props loaded<br>
                <strong>6:30 PM</strong> — Evening refresh<br>
                <strong>2:00 AM</strong> — Data reset for new day
              </div>
            </div>
          </div>
        `;
        
        // Update stats to show zeros
        document.getElementById('statTotal').textContent = '0';
        document.getElementById('statPrime').textContent = '0';
        document.getElementById('statValue').textContent = '0';
        document.getElementById('propCount').textContent = '0 props';
        return;
      }
      
      // ── Auto-clear game filter if its game is now final ───────────────
      if (state.gameFilter) {
        const liveVersion = allGames.find(g => g.id === state.gameFilter.id);
        if (liveVersion && (liveVersion.isCompleted || liveVersion.status === 'final')) {
          state.gameFilter = null;
          document.querySelectorAll('.live-game-card').forEach(el => el.classList.remove('active'));
        }
      }

      // ── PHASE 1: Hard game-state cleanup ──────────────────────────────
      // Rule: keep props for pregame, warmup, delayed, halftime/intermission, in-progress.
      // Suppress props when status.type.completed===true (hard final) and the game
      // started TODAY (prevents wiping tomorrow’s same-team props loaded overnight).
      const nowMs   = Date.now();
      const todayStart = new Date(); todayStart.setHours(0,0,0,0);
      const STALE_LIVE_MS = 8 * 60 * 1000; // 8 min without update = mark unavailable

      props = props.filter(p => {
        const propTeam = normalizeTeam(p.team);

        // Method 1: ESPN live data
        const game = allGames.find(g => {
          if (g.league !== p.league) return false;
          return normalizeTeam(g.homeTeam) === propTeam || normalizeTeam(g.awayTeam) === propTeam;
        });

        if (game) {
          // Remove if game is completed or final — regardless of what day it was
          if (game.isCompleted || game.status === 'final') return false;

          // Stale-data failsafe: live game with no update for 8+ min
          if (game.status === 'live' && game.lastUpdate && (nowMs - game.lastUpdate) > STALE_LIVE_MS) {
            p._stale = true;
          }
        } else {
          // No ESPN game found for this team — only remove if ESPN successfully loaded games for this league
          const leagueGames = allGames.filter(g => g.league === p.league);
          if (leagueGames.length > 0) return false;

          // Method 2: Game_Status sheet — ONLY as fallback when ESPN has NO data for this league.
          // Do NOT apply when ESPN has games (even for other teams) — stale sheet entries from
          // yesterday would otherwise incorrectly filter today's upcoming props.
          if (state.teamStatus) {
            const key = `${p.league}_${propTeam}`;
            const s   = state.teamStatus[key];
            if (s === 'live' || s === 'final') return false;
          }
        }

        return true;
      });
      // ───────────────────────────────────────────────────────────────────

      // Filter by game (from ticker click)
      if (state.gameFilter) {
        const homeTeam = normalizeTeam(state.gameFilter.homeTeam);
        const awayTeam = normalizeTeam(state.gameFilter.awayTeam);
        props = props.filter(p => {
          const propTeam = normalizeTeam(p.team);
          return p.league === state.gameFilter.league && 
            (propTeam === homeTeam || propTeam === awayTeam);
        });
      }

      // Filter by league
      if (state.league !== 'ALL') {
        props = props.filter(p => p.league === state.league);
      }

      // Filter by type
      switch (state.filter) {
        case 'ultimate': props = props.filter(p => p.meetsUltimate); break;
        case 'prime': props = props.filter(p => p.tier === 'prime' || p.tier === 'ultimate'); break;
        case 'strong': props = props.filter(p => ['prime', 'strong', 'ultimate'].includes(p.tier)); break;
        case 'value': props = props.filter(p => p.isValue); break;
        case 'hot': props = props.filter(p => p.streak >= 3); break;
        case 'overs': props = props.filter(p => p.direction === 'OVER'); break;
        case 'unders': props = props.filter(p => p.direction === 'UNDER'); break;
      }

      // ============================================
      // DEVON'S QUALITY FILTERS - Always applied
      // ============================================
      props = props.filter(p => {
        // PF Rating > 70
        if (p.pfRating <= 70) return false;
        
        // FIX 4 (quality gate): MLB uses line-relative avg check instead of fixed >6
        // e.g. O3.5 Ks with a 4.5 avg is still valid — avg must be ≥70% of the line
        if (p.league === 'MLB') {
          if (p.line > 0 && p.l10Avg < p.line * 0.70) return false;
        } else {
          // L10 Avg > 6 (non-MLB)
          if (p.l10Avg <= 6) return false;
          // L5 Avg > 5.5 (non-MLB)
          if (p.l5Avg <= 5.5) return false;
        }
        
        // Odds between -500 and +200
        if (p.odds < -500 || p.odds > 200) return false;
        
        return true;
      });
      // ============================================

      // Sort
      switch (state.sort) {
        case 'model': props.sort((a, b) => b.modelScore - a.modelScore); break;
        case 'edge': props.sort((a, b) => b.edge - a.edge); break;
        case 'l10': props.sort((a, b) => b.l10Pct - a.l10Pct); break;
        case 'streak': props.sort((a, b) => b.streak - a.streak); break;
        case 'odds': props.sort((a, b) => b.odds - a.odds); break;
      }

      state.filteredProps = props;
      
      const countText = state.gameFilter 
        ? `${props.length} props • ${state.gameFilter.awayTeam} @ ${state.gameFilter.homeTeam}`
        : `${props.length} props`;
      document.getElementById('propCount').textContent = countText;

      if (props.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">🔍</div>
            <div class="empty-title">No Props Found</div>
            <div class="empty-text">${state.gameFilter ? 'No props for this game. Click game again to clear.' : 'Try adjusting your filters'}</div>
          </div>
        `;
        return;
      }

      const currentLimit = state.propDisplayLimit || 100;
      const displayProps = props.slice(0, currentLimit);
      const hasMore = props.length > currentLimit;

      console.log(`Rendering ${displayProps.length} props out of ${props.length}`);

      let cardsHtml = '';
      try {
        cardsHtml = displayProps.map(p => {
        const gameInfo = getGameInfo(p.team, p.league);
        const inParlay = state.parlay.find(x => x.id === p.id);
        const fdLine   = getFanDuelLine(p);
        const movement = state.lineMovements[normalizeTeam(p.team)];
        const isLiveGame = gameInfo?.status === 'live';
        const isStale    = p._stale === true;

        // ══ PROPEDGE INTEL ════════════════════════════
        const intel = _intel(p);

        // Feature 1: Opportunity Alert badge
        const opptyBadge = intel.opportunityAlert ? (() => {
          const { injuredPlayer, status, count } = intel.opportunityAlert;
          const tip = count > 1
            ? `${injuredPlayer} (${status}) + ${count-1} more OUT — usage spike expected`
            : `${injuredPlayer} is ${status} — usage spike expected`;
          return `<span class="intel-badge-wrap"><span class="prop-badge opportunity">🔥 OPPORTUNITY</span><span class="intel-tip">${tip}</span></span>`;
        })() : '';

        // Feature 2: Lineup Lock badge
        const lineupBadge = (() => {
          if (intel.lineupStatus === 'locked')    return `<span class="intel-badge-wrap"><span class="prop-badge lineup-locked">🔒 LOCKED</span><span class="intel-tip">Lineup confirmed by ESPN</span></span>`;
          if (intel.lineupStatus === 'projected') return `<span class="intel-badge-wrap"><span class="prop-badge lineup-projected">📋 PROJECTED</span><span class="intel-tip">Lineup not yet official</span></span>`;
          if (intel.lineupStatus === 'out')       return `<span class="intel-badge-wrap"><span class="prop-badge lineup-out">❌ OUT</span><span class="intel-tip">Listed as OUT in lineup data</span></span>`;
          return '';
        })();

        // Feature 3: Line Moving badge
        const lineMoveBadge = intel.lineMoving
          ? `<span class="intel-badge-wrap"><span class="prop-badge line-moving">📈 LINE MOVING</span><span class="intel-tip">${intel.lineMoveReason}</span></span>`
          : '';

        const moveBadge = movement
          ? movement.type === 'steam'
            ? `<span class="prop-badge steam">🔥 STEAM +${movement.moveAmt}</span>`
            : movement.type === 'split'
            ? `<span class="prop-badge steam">📈 SHARP SPLIT</span>`
            : `<span class="prop-badge moving">📈 MOVING +${movement.moveAmt}</span>`
          : '';

        // PHASE 2: Compact live context strip on card
        const liveStrip = isLiveGame ? buildLiveContextHTML(gameInfo, true) : '';

        // PHASE 5: Value drift — compare pregame edge vs pace-adjusted current
        // Pregame edge stored in p.edge; pace edge estimated from avg vs line with game time weight
        let valueDriftHtml = '';
        if (isLiveGame && gameInfo && p.l10Avg && p.line) {
          const pregameEdge = p.edge;
          // Simple pace model: if player is averaging well above line, drift is positive
          const paceEdge = parseFloat(((p.l10Avg / p.line - 1) * 100 * 0.6 + pregameEdge * 0.4).toFixed(1));
          const drift = paceEdge - pregameEdge;
          const driftColor = drift > 1 ? 'var(--accent-green)' : drift < -2 ? 'var(--accent-red)' : 'var(--text-muted)';
          const driftIcon  = drift > 1 ? '↗' : drift < -2 ? '↘' : '→';
          // Risk flags
          const riskFlags = [];
          if (p.league === 'NBA' && gameInfo.period >= 4) riskFlags.push('Late game — DNP risk');
          if (p.league === 'MLB' && gameInfo.outs !== null && gameInfo.inning >= 7) riskFlags.push('Late innings');
          if (p.league === 'NFL' && gameInfo.isRedZone) riskFlags.push('Red zone — RB spike risk');
          valueDriftHtml = `
            <div class="value-drift-row">
              <span class="drift-label">Pregame</span>
              <span class="drift-val" style="color:${pregameEdge>0?'var(--accent-green)':'var(--accent-red)'}">${pregameEdge>0?'+':''}${pregameEdge}%</span>
              <span class="drift-arrow" style="color:${driftColor}">${driftIcon}</span>
              <span class="drift-label">Pace</span>
              <span class="drift-val" style="color:${driftColor}">${paceEdge>0?'+':''}${paceEdge}%</span>
              ${riskFlags.length ? `<span class="drift-flag">⚠ ${riskFlags[0]}</span>` : ''}
            </div>`;
        }

        return `
          <div class="prop-card ${p.tier}${isStale ? ' stale' : ''}">
            <div class="prop-card-clickable" data-pid="${p.id}" onclick="openPlayerDetail(this.dataset.pid)" style="cursor:pointer;">
            <div class="prop-header">
              ${(() => { const _hs = getPlayerHeadshot(p.player, p.league); return _hs ? `<div class="prop-headshot-wrap"><img class="prop-headshot ${p.tier}" src="${_hs}" onerror="this.style.display='none'" /></div>` : ''; })()}
              <div class="prop-player">
                <div class="prop-player-name">${p.player}${isStale ? ' <span style="font-size:9px;color:var(--text-muted);">(updating…)</span>' : ''}</div>
                <div class="prop-player-meta">
                  <span class="prop-team" style="font-size: 16px; margin-right: 4px;display:inline-flex;align-items:center;">${getTeamLogo(p.team, p.league)}</span>
                  <span class="prop-team">${p.team}</span>
                  <span>${p.pos || 'N/A'}</span>
                  <span>${p.league}</span>
                </div>
                ${gameInfo && !isLiveGame ? `
                  <div class="prop-game-info">
                    <span class="game-info-badge">${gameInfo.matchup}</span>
                    <span class="game-info-badge">${gameInfo.time}</span>
                    ${gameInfo.status === 'final' ? '<span class="game-info-badge final">FINAL</span>' : ''}
                  </div>
                ` : ''}
                <div class="prop-badges">
                  ${isLiveGame ? '<span class="prop-badge live-badge">● LIVE</span>' : ''}
                  ${p.meetsUltimate ? '<span class="prop-badge ultimate">⭐ ULTIMATE</span>' : ''}
                  ${p.tier === 'prime' && !p.meetsUltimate ? '<span class="prop-badge prime">🎯 PRIME</span>' : ''}
                  ${p.tier === 'strong' ? '<span class="prop-badge strong">✅ STRONG</span>' : ''}
                  ${p.isValue ? '<span class="prop-badge value">💰 VALUE</span>' : ''}
                  ${p.streak >= 3 ? `<span class="prop-badge hot">🔥 ${p.streak}</span>` : ''}
                  ${p.edge > 5 ? `<span class="prop-badge edge">+${p.edge}%</span>` : ''}
                  ${fdLine ? `<span class="prop-badge fd">FD ${fdLine.line}</span>` : ''}
                  ${moveBadge}
                  ${opptyBadge}
                  ${lineupBadge}
                  ${lineMoveBadge}
                </div>
              </div>
              <div class="prop-score ${p.tier}">${p.modelScore}</div>
            </div>
            ${liveStrip}
            ${valueDriftHtml}

            <div class="prop-line">
              <span class="prop-direction ${p.direction.toLowerCase()}">${p.direction}</span>
              <span class="prop-value">${p.line}</span>
              <span class="prop-type">${p.prop}</span>
              <span class="prop-odds">${p.oddsStr}</span>
            </div>

            <div class="prop-stats">
              <div class="prop-stat">
                <div class="prop-stat-value ${p.l5Pct >= 70 ? 'green' : p.l5Pct < 50 ? 'red' : ''}">${p.l5Pct.toFixed(0)}%</div>
                <div class="prop-stat-label">L5</div>
              </div>
              <div class="prop-stat">
                <div class="prop-stat-value ${p.l10Pct >= 70 ? 'green' : p.l10Pct < 50 ? 'red' : ''}">${p.l10Pct.toFixed(0)}%</div>
                <div class="prop-stat-label">L10</div>
              </div>
              <div class="prop-stat">
                <div class="prop-stat-value">${p.l5Avg}</div>
                <div class="prop-stat-label">L5 Avg</div>
              </div>
              <div class="prop-stat">
                <div class="prop-stat-value">${p.l10Avg}</div>
                <div class="prop-stat-label">L10 Avg</div>
              </div>
              <div class="prop-stat">
                <div class="prop-stat-value ${(() => {
                  const isGoodMatch = (p.direction === 'OVER' && p.sznMatchup >= 1 && p.sznMatchup <= 10) ||
                    (p.direction === 'UNDER' && ((p.league === 'NFL' || p.league === 'NHL') ? p.sznMatchup >= 23 && p.sznMatchup <= 32 : p.sznMatchup >= 21 && p.sznMatchup <= 30));
                  return isGoodMatch ? 'green' : '';
                })()}">#${p.sznMatchup}</div>
                <div class="prop-stat-label">SZN MU</div>
              </div>
              <div class="prop-stat">
                <div class="prop-stat-value ${p.edge > 5 ? 'green' : p.edge < 0 ? 'red' : ''}">${p.edge > 0 ? '+' : ''}${p.edge}%</div>
                <div class="prop-stat-label">Edge</div>
              </div>
            </div>

            </div><!-- end prop-card-clickable -->
            <div class="prop-footer">
              <div class="prop-probs">
                <div class="prop-prob">
                  <div class="prop-prob-value">${(p.impliedProb * 100).toFixed(0)}%</div>
                  <div class="prop-prob-label">Implied</div>
                </div>
                <div class="prop-prob">
                  <div class="prop-prob-value" style="color:var(--accent-green)">${(p.trueProb * 100).toFixed(0)}%</div>
                  <div class="prop-prob-label">True</div>
                </div>
              </div>
              <div class="prop-actions">
                <button class="prop-action-btn ${inParlay ? 'added' : ''}" 
                  data-pid="${p.id}" onclick="toggleParlay(this.dataset.pid)" 
                  title="Add to Parlay">
                  ${inParlay ? '✓' : '+'}
                </button>
                <button class="prop-action-btn ${fdLine ? 'fd' : ''}" 
                  data-pid="${p.id}" onclick="openFanDuelDirect(this.dataset.pid)" 
                  title="Open in FanDuel">
                  🔗
                </button>
                <button class="prop-watch-btn ${_ticketHasPlayer(p.player) ? 'watched' : ''}" 
                  data-player="${p.player}" data-league="${p.league}" data-team="${p.team}" data-prop="${p.prop}" data-line="${p.line}" data-dir="${p.direction}"
                  onclick="toggleTicketProp(this)" 
                  title="Watch this player">
                  ${_ticketHasPlayer(p.player) ? '★' : '☆'}
                </button>
              </div>
            </div>
          </div>
        `;
        }).join('');
      } catch (err) {
        console.error('Error rendering prop cards:', err);
        cardsHtml = `<div style="color: red; padding: 20px;">Error rendering props: ${err.message}</div>`;
      }

      console.log(`Setting container with ${cardsHtml.length} chars of HTML`);
      container.innerHTML = `
        <div class="props-grid">
          ${cardsHtml}
        </div>
        ${hasMore ? `
          <div class="load-more">
            <button class="load-more-btn" onclick="loadMoreProps()">
              Load More (${currentLimit} of ${props.length})
            </button>
          </div>
        ` : ''}
      `;
    }

    function loadMoreProps() {
      state.propDisplayLimit = (state.propDisplayLimit || 100) + 100;
      renderProps();
    }

    function getGameInfo(team, league) {
      const games = state.games[league] || [];
      const normTeam = normalizeTeam(team);
      const game = games.find(g =>
        normalizeTeam(g.homeTeam) === normTeam || normalizeTeam(g.awayTeam) === normTeam
      );
      if (!game) return null;
      return { ...game, matchup: `${game.awayTeam} @ ${game.homeTeam}`, time: game.gameTimeDisplay };
    }

    // ── Build sport-specific live context strip HTML ───────────────────
    function buildLiveContextHTML(game, compact = false) {
      if (!game || game.status !== 'live') return '';
      const { league } = game;

      // Base: score header — always shown
      const scoreHtml = `
        <div class="live-ctx-score">
          <span class="live-ctx-team">${game.awayTeam}</span>
          <span class="live-ctx-num">${game.awayScore}</span>
          <span class="live-ctx-sep">–</span>
          <span class="live-ctx-num">${game.homeScore}</span>
          <span class="live-ctx-team">${game.homeTeam}</span>
          <span class="live-ctx-clock">${game.shortDetail || game.displayClock}</span>
        </div>`;

      let sportHtml = '';

      if (league === 'NBA') {
        // Q1–Q4 + clock + possession indicator
        const qLabel = game.period <= 4 ? `Q${game.period}` : `OT${game.period - 4}`;
        const clock  = game.displayClock || '';
        sportHtml = `<div class="live-ctx-chips">`;
        sportHtml += `<span class="live-ctx-chip period">${qLabel}</span>`;
        if (clock) sportHtml += `<span class="live-ctx-chip clock">⏱ ${clock}</span>`;
        if (game.homeTimeouts !== null) sportHtml += `<span class="live-ctx-chip timeouts" title="Timeouts">${game.awayTeam} ${game.awayTimeouts}TO · ${game.homeTeam} ${game.homeTimeouts}TO</span>`;
        sportHtml += `</div>`;

      } else if (league === 'NHL') {
        const pLabel = game.period <= 3 ? `P${game.period}` : 'OT';
        sportHtml = `<div class="live-ctx-chips">`;
        sportHtml += `<span class="live-ctx-chip period">${pLabel}</span>`;
        if (game.displayClock) sportHtml += `<span class="live-ctx-chip clock">⏱ ${game.displayClock}</span>`;
        if (game.homeSog) sportHtml += `<span class="live-ctx-chip sog">SOG ${game.awaySog}–${game.homeSog}</span>`;
        sportHtml += `</div>`;

      } else if (league === 'MLB') {
        const half = game.inningHalf === 'top' ? '▲' : game.inningHalf === 'bottom' ? '▼' : '';
        const inningLabel = game.inning ? `${half} ${game.inning}` : game.shortDetail;
        // Base state diamond
        const b1 = game.onFirst  ? '#f59e0b' : 'rgba(255,255,255,0.12)';
        const b2 = game.onSecond ? '#f59e0b' : 'rgba(255,255,255,0.12)';
        const b3 = game.onThird  ? '#f59e0b' : 'rgba(255,255,255,0.12)';
        const baseDiamond = compact ? '' : `
          <span class="live-ctx-bases" title="Base state">
            <svg width="22" height="22" viewBox="0 0 22 22">
              <rect x="10" y="2"  width="7" height="7" rx="1" transform="rotate(45 13.5 5.5)"  fill="${b2}"/>
              <rect x="2"  y="10" width="7" height="7" rx="1" transform="rotate(45 5.5 13.5)"  fill="${b3}"/>
              <rect x="14" y="10" width="7" height="7" rx="1" transform="rotate(45 17.5 13.5)" fill="${b1}"/>
            </svg>
          </span>`;
        const outsHtml = game.outs !== null
          ? `<span class="live-ctx-chip outs">${game.outs} out${game.outs !== 1 ? 's' : ''}</span>` : '';
        const countHtml = (game.balls !== null && game.strikes !== null)
          ? `<span class="live-ctx-chip count">${game.balls}–${game.strikes}</span>` : '';
        sportHtml = `<div class="live-ctx-chips">`;
        if (inningLabel) sportHtml += `<span class="live-ctx-chip period">${inningLabel}</span>`;
        sportHtml += outsHtml + countHtml + baseDiamond;
        if (!compact && game.pitcher) sportHtml += `<span class="live-ctx-chip pitcher">P: ${game.pitcher}</span>`;
        sportHtml += `</div>`;

      } else if (league === 'NFL') {
        const qLabel = game.period <= 4 ? `Q${game.period}` : 'OT';
        sportHtml = `<div class="live-ctx-chips">`;
        sportHtml += `<span class="live-ctx-chip period">${qLabel}</span>`;
        if (game.displayClock) sportHtml += `<span class="live-ctx-chip clock">⏱ ${game.displayClock}</span>`;
        if (game.downDistanceText) sportHtml += `<span class="live-ctx-chip down">${game.downDistanceText}</span>`;
        if (game.isRedZone) sportHtml += `<span class="live-ctx-chip redzone">🔴 Red Zone</span>`;
        sportHtml += `</div>`;
      }

      return `<div class="live-ctx-strip">${scoreHtml}${sportHtml}</div>`;
    }

    // ==========================================
    // PARLAY
    // ==========================================
    function toggleParlay(id) {
      const prop = state.props.find(p => p.id === id);
      if (!prop) return;

      const idx = state.parlay.findIndex(p => p.id === id);
      if (idx >= 0) {
        state.parlay.splice(idx, 1);
        showToast('Removed from parlay');
      } else {
        state.parlay.push(prop);
        showToast('Added to parlay');
      }
      
      renderProps();
      renderParlay();
    }

    function renderParlay() {
      const legsContainer = document.getElementById('parlayLegs');
      const summary = document.getElementById('parlaySummary');

      if (state.parlay.length === 0) {
        legsContainer.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-muted);">Add props to build your parlay</div>';
        summary.style.display = 'none';
      } else {
        legsContainer.innerHTML = state.parlay.map(p => `
          <div class="parlay-leg">
            <div class="parlay-leg-info">
              <div class="parlay-leg-player">${p.player}</div>
              <div class="parlay-leg-prop">${p.direction} ${p.line} ${p.prop} • ${p.team}</div>
            </div>
            <span class="parlay-leg-odds">${p.oddsStr}</span>
            <button class="parlay-leg-remove" onclick="removeFromParlay('${p.id}')">×</button>
          </div>
        `).join('');
        summary.style.display = 'block';
        updateParlayCalcs();
      }

      // Always refresh AI suggestions when parlay view is rendered
      generateSuggestedParlays();
    }

    function updateParlayCalcs() {
      if (state.parlay.length === 0) return;
      
      const wager = parseFloat(document.getElementById('wagerAmount')?.value) || 10;
      
      // Calculate combined decimal odds
      let totalDecimal = 1;
      state.parlay.forEach(p => {
        const decimal = p.odds > 0 ? (p.odds / 100) + 1 : (100 / Math.abs(p.odds)) + 1;
        totalDecimal *= decimal;
      });

      // Calculate American odds
      const americanOdds = totalDecimal >= 2 
        ? Math.round((totalDecimal - 1) * 100) 
        : Math.round(-100 / (totalDecimal - 1));

      // Calculate payouts
      const profit = wager * (totalDecimal - 1);
      const totalPayout = wager * totalDecimal;

      // Calculate combined implied probability (from book odds)
      let combinedImpliedProb = 1;
      state.parlay.forEach(p => {
        combinedImpliedProb *= p.impliedProb;
      });

      // Calculate combined true probability (from model)
      let combinedTrueProb = 1;
      state.parlay.forEach(p => {
        combinedTrueProb *= p.trueProb;
      });

      // Calculate combined edge
      const combinedEdge = ((combinedTrueProb * totalDecimal) - 1) * 100;

      // Calculate Expected Value
      const ev = (combinedTrueProb * profit) - ((1 - combinedTrueProb) * wager);

      // Update display
      document.getElementById('parlayLegCount').textContent = state.parlay.length;
      document.getElementById('parlayOdds').textContent = americanOdds > 0 ? `+${americanOdds}` : americanOdds;
      document.getElementById('parlayPayout').textContent = `$${profit.toFixed(2)}`;
      document.getElementById('parlayTotalPayout').textContent = `$${totalPayout.toFixed(2)}`;
      document.getElementById('parlayImpliedProb').textContent = `${(combinedImpliedProb * 100).toFixed(1)}%`;
      document.getElementById('parlayTrueProb').textContent = `${(combinedTrueProb * 100).toFixed(1)}%`;
      
      const edgeEl = document.getElementById('parlayEdge');
      edgeEl.textContent = `${combinedEdge > 0 ? '+' : ''}${combinedEdge.toFixed(1)}%`;
      edgeEl.style.color = combinedEdge > 0 ? 'var(--accent-green)' : 'var(--accent-red)';

      const evEl = document.getElementById('parlayEV');
      evEl.textContent = `${ev >= 0 ? '+' : ''}$${ev.toFixed(2)}`;
      evEl.style.color = ev >= 0 ? 'var(--accent-green)' : 'var(--accent-red)';
    }

    function removeFromParlay(id) {
      state.parlay = state.parlay.filter(p => p.id !== id);
      renderParlay();
      renderProps();
    }

    function clearParlay() {
      state.parlay = [];
      renderParlay();
      renderProps();
      showToast('Parlay cleared');
    }

    function copyParlay() {
      const text = state.parlay.map(p => 
        `${p.player} ${p.direction} ${p.line} ${p.prop} (${p.oddsStr})`
      ).join('\n');
      
      navigator.clipboard.writeText(text);
      showToast('Parlay copied!');
    }

    function sharePicksLink() {
      const picks = state.parlay.map(p => 
        `${p.player} ${p.direction} ${p.line} ${p.prop}`
      ).join(' | ');
      
      const text = `🎯 My PropEdge Picks:\n${picks}`;
      
      if (navigator.share) {
        navigator.share({ text });
      } else {
        navigator.clipboard.writeText(text);
        showToast('Link copied!');
      }
    }

    function openGamblyBot() {
      if (state.parlay.length === 0) {
        showToast('Add props to your parlay first');
        return;
      }
      
      // Format picks for Gambly - natural language format works best
      const picks = state.parlay.map(p => 
        `${p.player} ${p.direction} ${p.line} ${p.prop}`
      ).join(', ');
      
      // Copy to clipboard first
      navigator.clipboard.writeText(picks).then(() => {
        showToast('Picks copied! Paste in Gambly chat');
        // Open Gambly bot page
        window.open('https://gambly.com/gambly-bot', '_blank');
      }).catch(() => {
        // If clipboard fails, just open Gambly
        window.open('https://gambly.com/', '_blank');
        showToast('Opening Gambly...');
      });
    }

    // Gambly bot numbers:
    //  iOS (iMessage):   646-567-9746
    //  Android (SMS):    305-857-2288
    const GAMBLY_IOS     = '16465679746';
    const GAMBLY_ANDROID = '13058572288';

    function textPicks(platform) {
      if (state.parlay.length === 0) {
        showToast('Add props to your parlay first');
        return;
      }

      const picks = state.parlay.map(p =>
        `${p.player} ${p.direction} ${p.line} ${p.prop}`
      ).join(', ');

      const message = `PropEdge picks: ${picks}`;

      // Auto-detect if no platform passed
      if (!platform) {
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
        platform = isIOS ? 'ios' : 'android';
