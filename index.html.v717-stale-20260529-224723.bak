    function openFanDuelSearch(playerName) {
      const url = `https://sportsbook.fanduel.com/search?q=${encodeURIComponent(playerName)}`;
      const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
      if (isMobile) {
        // Direct redirect on mobile to prevent empty tabs behind app handoff
        window.location.assign(url);
      } else {
        window.open(url, '_blank');
      }
      showToast(`Searching FanDuel for ${playerName}...`);
    }

