    function getPlayerHeadshot(playerName, league) {
      if (!playerName || !league) return '';
      // Normalize name to strip accents (e.g., Porziņģis -> Porzingis)
      const normalized = playerName.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
      const id = PLAYER_IDS[normalized];
      if (!id) {
        // Try last name only match as fallback
        const lastName = normalized.split(' ').pop();
        const match = Object.keys(PLAYER_IDS).find(k => k.split(' ').pop() === lastName);
        if (!match) return '';
        return `https://a.espncdn.com/i/headshots/${league.toLowerCase()}/players/full/${PLAYER_IDS[match]}.png`;
      }
      return `https://a.espncdn.com/i/headshots/${league.toLowerCase()}/players/full/${id}.png`;
    }

    async function loadLineMovement() {
      try {
        const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=Line_History&_=${Date.now()}`;
        const response = await fetch(url, { cache: 'no-store' });
        if (!response.ok) {
          console.log('[PropEdge] Line movement: sheet unavailable or empty');
          return;
        }

        const csv = await response.text();
        const lines = csv.split('\n');
        if (lines.length < 3) return; // Need at least 2 data rows to detect movement

        const headers = parseCSVLine(lines[0]).map(h => h.toLowerCase().trim());
        const c = {
          ts:         headers.indexOf('timestamp'),
          sport:      headers.indexOf('sport'),
          home:       headers.indexOf('home_team'),
          away:       headers.indexOf('away_team'),
          book:       headers.indexOf('bookmaker'),
          market:     headers.indexOf('market'),
          homePrice:  headers.indexOf('home_price'),
          awayPrice:  headers.indexOf('away_price'),
          homePoint:  headers.indexOf('home_point'),
          awayPoint:  headers.indexOf('away_point'),
        };

        const rows = [];
        for (let i = 1; i < lines.length; i++) {
          const v = parseCSVLine(lines[i]);
          if (v.length < 8) continue;
          const g = (col) => col >= 0 ? (v[col] || '').replace(/"/g, '').trim() : '';
          const hp = parseFloat(g(c.homePoint));
          if (isNaN(hp)) continue; // Skip moneyline rows (no point spread)
          rows.push({
            ts:        new Date(g(c.ts)),
            sport:     g(c.sport),
            home:      g(c.home),
            away:      g(c.away),
            book:      g(c.book),
            market:    g(c.market),
            homePoint: hp,
            awayPoint: parseFloat(g(c.awayPoint)) || -hp,
          });
        }

        if (rows.length === 0) {
          console.log('[PropEdge] Line movement: no data in Line_History sheet');
          return;
        }

        // Time windows
        const latestTs   = Math.max(...rows.map(r => r.ts.getTime()));
        const recentCut  = new Date(latestTs - 20 * 60 * 1000);  // within 20min of latest
        const compareCut = new Date(latestTs - 60 * 60 * 1000);  // 1h before latest

        const pinnLatest  = rows.filter(r => r.book === 'pinnacle' && r.market === 'spreads' && r.ts >= recentCut);
        const pinnOlder   = rows.filter(r => r.book === 'pinnacle' && r.market === 'spreads' && r.ts <= compareCut);
        const squareLatest = rows.filter(r => ['draftkings','fanduel','betmgm'].includes(r.book) && r.market === 'spreads' && r.ts >= recentCut);

        if (pinnLatest.length === 0 || pinnOlder.length === 0) {
          console.log('[PropEdge] Line movement: insufficient Pinnacle data for comparison');
          return;
        }

        const movements = {};

        for (const latest of pinnLatest) {
          const older = pinnOlder.find(r => r.home === latest.home && r.away === latest.away);
          if (!older) continue;

          const move = latest.homePoint - older.homePoint;
          const moveAmt = Math.abs(move);
          if (moveAmt < 0.5) continue; // No meaningful movement

          // Which side did sharp money land on?
          // homePoint increasing (e.g. -3 → -2) = home team became cheaper = sharps on HOME
          // homePoint decreasing (e.g. -3 → -4) = home team got more expensive = sharps on AWAY
          const sharpSide = move > 0 ? 'HOME' : 'AWAY';

          // Sharp/square divergence: how far is Pinnacle from square book average?
          const squareRows = squareLatest.filter(r => r.home === latest.home && r.away === latest.away);
          const squareAvg = squareRows.length
            ? squareRows.reduce((s, r) => s + r.homePoint, 0) / squareRows.length
            : null;
          const divergence = squareAvg !== null ? Math.abs(latest.homePoint - squareAvg) : 0;

          const type = moveAmt >= 2.5 ? 'steam'
                     : divergence >= 1.0 ? 'split'
                     : 'move';

          const data = {
            type, moveAmt: parseFloat(moveAmt.toFixed(1)), sharpSide,
            divergence: parseFloat(divergence.toFixed(1)),
            pinnSpread: latest.homePoint, movedFrom: older.homePoint,
            home: latest.home, away: latest.away, sport: latest.sport,
          };

          // Store under both team abbreviations so prop matching works
          const homeAbbr = teamNameToAbbr(latest.home);
          const awayAbbr = teamNameToAbbr(latest.away);
          if (homeAbbr) movements[homeAbbr] = data;
          if (awayAbbr) movements[awayAbbr] = data;
        }

        state.lineMovements = movements;
        const gameCount = Object.keys(movements).length / 2;

        if (gameCount > 0) {
          console.log(`📈 Line movement: ${gameCount} game(s) detected, applying sharp money boosts`);
          showToast(`📈 ${gameCount} line movement${gameCount > 1 ? 's' : ''} detected`);
          rescoreSharpMoney(); // Fix D: apply sharp money boosts to already-scored props
          renderProps();
        } else {
          console.log('[PropEdge] Line movement: no meaningful movements detected');
        }

      } catch (e) {
        console.log('[PropEdge] Line movement load error:', e.message);
      }
    }

    // ==========================================
    // SHARP MONEY RE-SCORER (Fix D)
    // ==========================================
    function rescoreSharpMoney() {
      let boosted = 0;
      state.props.forEach(prop => {
        const movement = state.lineMovements?.[prop.team?.toUpperCase().trim()];
        if (!movement) {
          prop.modelScore = prop.baseModelScore;
          prop.sharpBoost = 0;
        } else {
          const boost = movement.type === 'steam' ? 5 : movement.type === 'split' ? 3 : 2;
          prop.sharpBoost = boost;
          prop.modelScore = Math.min(98, prop.baseModelScore + boost); // cap at 98 on 0-100 scale
          boosted++;
        }
        // v5: tier derivation uses unified THRESHOLDS (0-100 scale)
        const meetsUltimate = prop.league === 'MLB'
          ? prop.pfRating >= 80 && prop.l10Pct >= 65 && prop.l20Pct >= 62 && prop.seasonPct >= 60
          : prop.pfRating >= 84 && prop.l10Pct >= 75 && prop.l5Pct >= 70 && prop.l20Pct >= 65;
        prop.tier = 'spec';
        if (meetsUltimate && prop.modelScore >= 83)    prop.tier = 'ultimate';
        else if (prop.modelScore >= THRESHOLDS.prime)  prop.tier = 'prime';
        else if (prop.modelScore >= THRESHOLDS.strong) prop.tier = 'strong';
        else if (prop.modelScore >= THRESHOLDS.solid)  prop.tier = 'solid';
      });
      if (boosted > 0) console.log(`📈 Sharp money applied to ${boosted} prop(s)`);
    }

    // ==========================================
    // UNIFIED SCORE SYNC v5
    // Single source of truth: computeBetScore() drives prop.modelScore,
    // prop.tier, and prop.propFactors for ALL downstream consumers
    // (card display, sort/filter, parlay AI, sharp money rescore baseline).
    // Called once after CSV parse completes; rescoreSharpMoney() re-runs
    // on top of the unified base when line movement data arrives.
    // ==========================================
    function syncUnifiedScores() {
      if (!state.props || state.props.length === 0) return;
      let synced = 0;
      state.props.forEach(prop => {
        // computeBetScore() handles null fdLine/intel gracefully — safe to call at parse time.
        // We pass stored p.edge and p.trueProb (computed by parseLeagueCSV's Bayesian pipeline).
        // ── FIX (May 8): Include real outcomes accuracy in unified score sync
        const realAccuracy = state.propHits[prop.id]?.accuracy ?? null;
        const bs = computeBetScore(prop, null, null, prop.edge ?? 0, prop.trueProb ?? 0.52, realAccuracy);

        prop.modelScore    = bs.score;
        prop.baseModelScore = bs.score; // reset baseline for rescoreSharpMoney()
        prop.sharpBoost    = 0;
        prop.propFactors   = [...(bs.forFactors || [])];
        prop.againstFactors = [...(bs.againstFactors || [])];

        // Tier derived from unified score — matches computeBetScore() action thresholds
        const meetsUlt = prop.league === 'MLB'
          ? prop.pfRating >= 80 && prop.l10Pct >= 65 && prop.l20Pct >= 62 && prop.seasonPct >= 60
          : prop.pfRating >= 84 && prop.l10Pct >= 75 && prop.l5Pct >= 70 && prop.l20Pct >= 65;

        prop.tier = 'spec';
        if (meetsUlt && bs.score >= 83)         prop.tier = 'ultimate';
        else if (bs.score >= THRESHOLDS.prime)  prop.tier = 'prime';
        else if (bs.score >= THRESHOLDS.strong) prop.tier = 'strong';
        else if (bs.score >= THRESHOLDS.solid)  prop.tier = 'solid';

        synced++;
      });
      console.log(`[PropEdge v5] syncUnifiedScores: aligned ${synced} props to computeBetScore() engine`);
    }

    // ==========================================
    // GAMES & TICKER
    // ==========================================
    async function fetchGames(silent = false) {
      const ticker = document.getElementById('gamesTicker');
      // Only show loading spinner on initial/manual loads — NOT on background 30s refreshes.
      // Showing the spinner mid-refresh wipes the ticker and causes the visible flicker.
      if (!silent) {
        ticker.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
      }

      const leagues = ['NBA', 'NHL', 'MLB', 'NFL'];
      let allGames = [];

      for (const league of leagues) {
        state.games[league] = [];
        try {
          console.log(`[PropEdge] Fetching ${league} games from ${ESPN_APIS[league]}`);
          const t0 = performance.now();
          const response = await fetch(ESPN_APIS[league], { cache: 'no-store' });
          const latency = Math.round(performance.now() - t0);
          debugPanel.recordEspnLatency(latency);
          if (!response.ok) {
            console.error(`[PropEdge] ${league} API returned ${response.status}`);
            continue;
          }
          const data = await response.json();

          if (data.events) {
            console.log(`[PropEdge] ${league} API returned ${data.events.length} events`);
            let parsed = 0;
            data.events.forEach(event => {
              const game = parseGame(event, league);
              if (game) {
                console.log(`[PropEdge] ${league}: Parsed ${game.awayTeam}@${game.homeTeam} (${game.status})`);
                allGames.push(game);
                state.games[league].push(game);
                parsed++;
              }
            });
            console.log(`[PropEdge] TOTAL: ${league} now has ${state.games[league].length} valid games (parsed ${parsed})`);
          } else {
            console.error(`[PropEdge] ${league} API response missing 'events':`, data);
          }
        } catch (e) {
          console.error(`[PropEdge] Error fetching ${league} games:`, e);
        }
      }
      console.log(`[PropEdge] FINAL: state.games =`, state.games);

      console.log(`[PropEdge] Total games fetched: ${allGames.length}`);

      // ── ALWAYS render ticker with all games (live + upcoming)
      // Background clock sync will update live game scores in-place via _startLiveTickerPoll()
      console.log('[PropEdge] Rendering ticker with all games');
      renderTicker(allGames);

      // ── AUTO-DETECT PROP HITS: Trigger when game transitions to final (NEW)
      for (const game of allGames) {
        const prevStatus = state.prevGameStatuses[game.id];
        const currStatus = game.status;

        // Transition from non-final to final: auto-detect hits
        if (prevStatus !== 'final' && currStatus === 'final') {
          console.log(`🎯 Game ${game.id} is now FINAL — triggering auto-detection`);
          // autoDetectPropHits(game.id);  // DISABLED: Replaced by _autoTrackPropResults() in background sync
        }

        // Update tracker
        state.prevGameStatuses[game.id] = currStatus;
      }

      updateStatus(); // Update status after games are loaded
    }

    function parseGame(event, league) {
      const competition = event.competitions?.[0];
      if (!competition) return null;

      const competitors = competition.competitors || [];
      if (competitors.length !== 2) return null;

      const home = competitors.find(c => c.homeAway === 'home');
      const away = competitors.find(c => c.homeAway === 'away');
      if (!home || !away) return null;

      const statusType  = event.status?.type || {};
      const statusState = statusType.state || 'pre';
      const isLive  = statusState === 'in';
      const isFinal = statusState === 'post';
      const isCompleted = statusType.completed === true;

      let spread = null, total = null;
      const odds = competition.odds?.[0];
      if (odds) { spread = odds.details; total = odds.overUnder; }

      const gameTime = new Date(event.date);
      const timeStr  = gameTime.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

      // ── Live context details (sport-specific) ──────────────────
      const situation = competition.situation || {};
      const notes     = competition.notes    || [];

      // Period / clock (works for NBA, NHL, NFL)
      const period      = event.status?.period || 0;
      const displayClock = event.status?.displayClock || '';
      const shortDetail  = statusType.shortDetail || '';

      // NBA / NFL possession
      const possession = situation.possession || null; // team id that has ball
      const homeTimeouts = situation.homeTimeouts ?? null;
      const awayTimeouts = situation.awayTimeouts ?? null;
      const downDistanceText = situation.downDistanceText || null; // NFL: "1st & 10"
      const isRedZone = situation.isRedZone === true;

      // NHL
      const homeSog = home.statistics?.find(s => s.name === 'shotsOnTarget' || s.abbreviation === 'SOG')?.displayValue || null;
      const awaySog = away.statistics?.find(s => s.name === 'shotsOnTarget' || s.abbreviation === 'SOG')?.displayValue || null;
      const homePp  = home.statistics?.find(s => s.name === 'powerPlayGoals')?.displayValue || null;

      // MLB inning / base state
      const inning         = situation.period || situation.inning || 0;
      const inningHalf     = situation.outs !== undefined ? (situation.inningHalf || '') : '';
      const outs           = situation.outs   ?? null;
      const onFirst        = situation.onFirst  === true;
      const onSecond       = situation.onSecond === true;
      const onThird        = situation.onThird  === true;
      const balls          = situation.balls   ?? null;
      const strikes        = situation.strikes ?? null;
      const batter         = situation.batter?.athlete?.shortName  || null;
      const pitcher        = situation.pitcher?.athlete?.shortName || null;

      // Stale-data tracking — mark when we last saw a live update
      const lastUpdate = isLive ? Date.now() : null;

      return {
        id: event.id,
        league,
        homeTeam: home.team?.abbreviation || 'HOME',
        awayTeam: away.team?.abbreviation || 'AWAY',
        homeName: home.team?.displayName   || '',
        awayName: away.team?.displayName   || '',
        homeScore: parseInt(home.score) || 0,
        awayScore: parseInt(away.score) || 0,
        status: isFinal || isCompleted ? 'final' : (isLive ? 'live' : 'upcoming'),
        isCompleted,
        statusDisplay: shortDetail || timeStr,
        gameTime,
        gameTimeDisplay: timeStr,
        spread,
        total,
        // Live context
        period, displayClock, shortDetail,
        possession, homeTimeouts, awayTimeouts,
        downDistanceText, isRedZone,
        homeSog, awaySog, homePp,
        inning, inningHalf, outs, onFirst, onSecond, onThird,
        balls, strikes, batter, pitcher,
        weather: competition.venue?.weather || null,
        venue: competition.venue?.fullName || 'TBD',
        lastUpdate,
      };
    }

    function _formatCountdown(gameTime) {
      if (!gameTime) return '';
      const diffMs = new Date(gameTime) - Date.now();
      if (diffMs <= 0) return '';
      const totalMins = Math.floor(diffMs / 60000);
      const hours = Math.floor(totalMins / 60);
      const mins  = totalMins % 60;
      if (hours >= 24) return '';            // too far out — just show time
      if (hours > 0)   return `${hours}h ${mins}m`;
      if (mins > 0)    return `${mins}m`;
      return 'Starting soon';
    }

    // ── Live ticker score poll — fetches fresh ESPN data every 30s while games are live ──
    let _liveTickerTimer = null;

    // ════════════════════════════════════════════════════════════════════════
    // OUTCOME EVENT BUS (Phase 1: Real-time System)
    // In-memory pub/sub for outcome detection events
    // ════════════════════════════════════════════════════════════════════════
    class OutcomeEventBus {
      constructor() {
        this.listeners = {};
      }

      on(event, callback) {
        if (!this.listeners[event]) this.listeners[event] = [];
        this.listeners[event].push(callback);
      }

      off(event, callback) {
        if (!this.listeners[event]) return;
        this.listeners[event] = this.listeners[event].filter(cb => cb !== callback);
      }

      emit(event, data) {
        if (!this.listeners[event]) return;
        this.listeners[event].forEach(cb => {
          try {
            cb(data);
          } catch (err) {
            console.error(`[OutcomeEventBus] Error in listener for event "${event}":`, err);
          }
        });
      }
    }

    const outcomeEventBus = new OutcomeEventBus();

    // ════════════════════════════════════════════════════════════════════════
    // GAME FINAL DETECTOR (Phase 1: Real-time System)
    // Monitors game status transitions, posts outcomes to sync service
    // ════════════════════════════════════════════════════════════════════════
    class GameFinalDetector {
      constructor() {
        this.detectedGames = new Set(); // Track which games we've processed
        this.syncBaseUrl = 'http://localhost:3001';
      }

      /**
       * Check if game just transitioned to final, post outcomes to service
       */
      async checkAndResolveOutcomes(game, outcomesList) {
        const gameKey = `${game.id}_${game.league}`;

        // Skip if already processed
        if (this.detectedGames.has(gameKey)) return;

        // Only process final games
        if (game.status !== 'final') return;

        this.detectedGames.add(gameKey);
        console.log(`[GameFinalDetector] Detected final game: ${game.id} (${game.league})`);

        if (!outcomesList || outcomesList.length === 0) {
          console.log(`[GameFinalDetector] No outcomes to post for game ${game.id}`);
          return;
        }

        try {
          await this.postOutcomes(outcomesList);
          outcomeEventBus.emit('OutcomeDetected', { game, outcomeCount: outcomesList.length });
        } catch (err) {
          console.error(`[GameFinalDetector] Failed to post outcomes:`, err);
        }
      }

      async postOutcomes(outcomesList) {
        const payload = {
          outcomes: outcomesList.map(o => ({
            player: o.player,
            prop: o.prop,
            line: o.line,
            status: o.status,
            date: o.date || new Date().toISOString().split('T')[0],
            timestamp: o.timestamp || new Date().toISOString(),
            gameId: o.gameId,
            gameStatus: o.gameStatus,
            detectionTimestamp: new Date().toISOString(),
            league: o.league,
            direction: o.direction,
            modelProb: o.modelProb,
            impliedProb: o.impliedProb,
            edge: o.edge,
            propIqScore: o.propIqScore,
            odds: o.odds,
            marketKey: o.marketKey
          }))
        };

        const res = await fetch(`${this.syncBaseUrl}/api/outcomes/bulk`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!res.ok) {
          throw new Error(`POST failed: ${res.status} ${res.statusText}`);
        }

        const result = await res.json();
        debugPanel.recordSheetWrite();
        console.log(`[GameFinalDetector] Posted ${result.processed}/${result.total} outcomes`);
        return result;
      }

      reset() {
        this.detectedGames.clear();
      }
    }

    const gameFinalDetector = new GameFinalDetector();

    // ════════════════════════════════════════════════════════════════════════
    // ESPN POLLING BUS (Phase 2: Real-time System)
    // Consolidates multiple polling intervals into single 4s → 30s backoff
    // ════════════════════════════════════════════════════════════════════════
    class EspnPollingBus {
      constructor() {
        this.pollInterval = 4000; // 4s when games are live
        this.pollTimer = null;
        this.lastPollTime = 0;
        this.allGamesFinal = false;
        this.subscribers = [];
      }

      subscribe(callback) {
        this.subscribers.push(callback);
        return () => {
          this.subscribers = this.subscribers.filter(cb => cb !== callback);
        };
      }

      start() {
        if (this.pollTimer) return;
        console.log('[EspnPollingBus] Starting polls every 4s');

        // Initial poll immediately
        this._doPoll();

        // Then every 4s
        this.pollTimer = setInterval(() => this._doPoll(), 4000);
      }

      stop() {
        if (this.pollTimer) {
          clearInterval(this.pollTimer);
          this.pollTimer = null;
          console.log('[EspnPollingBus] Stopped');
        }
      }

      async _doPoll() {
        const now = Date.now();
        if (now - this.lastPollTime < 3000) return; // Debounce to 3s min
        this.lastPollTime = now;

        try {
          // Call autonomous sync (this is the main ESPN fetch)
          await _autonomousGameClockSync();

          // Emit poll event to all subscribers (modal, etc.)
          this.subscribers.forEach(cb => {
            try { cb(); } catch (e) { console.warn('[EspnPollingBus] Subscriber error:', e); }
          });

          // Check if all games are final → backoff to 30s
          const allGames = [
            ...(state.games.NBA || []),
            ...(state.games.NHL || []),
            ...(state.games.MLB || []),
            ...(state.games.NFL || [])
          ];

          const hasLiveGames = allGames.some(g => g.status === 'live' || g.status === 'scheduled');
          if (!hasLiveGames && !this.allGamesFinal) {
            console.log('[EspnPollingBus] All games final, backoff to 30s');
            this.allGamesFinal = true;
            this.stop();
            this.pollTimer = setInterval(() => this._doPoll(), 30000);
          } else if (hasLiveGames && this.allGamesFinal) {
            console.log('[EspnPollingBus] Games resumed, back to 4s polling');
            this.allGamesFinal = false;
            this.stop();
            this.start();
          }
        } catch (err) {
          console.error('[EspnPollingBus] Poll error:', err);
        }
      }
    }

    const espnPollingBus = new EspnPollingBus();

    // ════════════════════════════════════════════════════════════════════════
    // OUTCOME UI HANDLER (Phase 3: Real-time System)
    // Listens to OutcomeDetected events, updates modal + shows toast
    // ════════════════════════════════════════════════════════════════════════
    class OutcomeUIHandler {
      constructor() {
        this.setupListeners();
      }

      setupListeners() {
        outcomeEventBus.on('OutcomeDetected', (data) => {
          this.handleOutcomeDetected(data);
        });
      }

      async handleOutcomeDetected({ game, outcomeCount }) {
        console.log(`[OutcomeUI] Detected outcomes for game ${game.id}: ${outcomeCount} props`);

        // Find all props in this game that just resolved
        const gameProps = (state.allProps || []).filter(p =>
          String(p.gameId) === String(game.id)
        );

        // Update each prop with result indicator
        for (const prop of gameProps) {
          const outcomeKey = `${prop.player}|${prop.prop}|${prop.line}`;
          const outcome = state.outcomes[outcomeKey];
          if (!outcome) continue;

          const isHit = outcome.status === 'HIT';

          // Toast notification
          this.showOutcomeToast(prop, isHit);

          // Highlight in modal if open
          if (_modalState.game && String(_modalState.game.id) === String(game.id)) {
            this.updateModalOutcome(prop, isHit);
          }

          // Highlight in prop card if visible
          const propCard = document.querySelector(`[data-propid="${prop.id}"]`);
          if (propCard) {
            this.highlightPropCard(propCard, isHit);
          }
        }
      }

      showOutcomeToast(prop, isHit) {
        const icon = isHit ? '✓' : '✗';
        const color = isHit ? 'var(--accent-green)' : 'var(--accent-red)';
        const direction = String(prop.prop || '').substring(0, 1).toUpperCase(); // O or U
        const message = `${prop.player} ${direction}${prop.line} ${icon} ${isHit ? 'HIT' : 'MISS'}`;

        const toast = document.getElementById('toast');
        if (toast) {
          toast.textContent = message;
          toast.style.background = color;
          toast.style.color = isHit ? '#000' : '#fff';
          toast.classList.add('show');
          setTimeout(() => toast.classList.remove('show'), 3500);
        }
      }

      updateModalOutcome(prop, isHit) {
        // Find stats section in modal and highlight if this prop matches
        const statsSection = document.querySelector('.detail-stats');
        if (!statsSection) return;

        const statCards = statsSection.querySelectorAll('[data-stat-label]');
        statCards.forEach(card => {
          const label = card.getAttribute('data-stat-label');
          const propType = String(prop.prop || '').split('+')[0].trim().toLowerCase();

          if (label && label.toLowerCase().includes(propType)) {
            card.style.background = isHit
              ? 'linear-gradient(135deg, rgba(34, 197, 94, 0.2), rgba(34, 197, 94, 0.1))'
              : 'linear-gradient(135deg, rgba(239, 68, 68, 0.2), rgba(239, 68, 68, 0.1))';
            card.style.borderColor = isHit ? 'var(--accent-green)' : 'var(--accent-red)';
            card.style.boxShadow = isHit
              ? '0 0 12px rgba(34, 197, 94, 0.3)'
              : '0 0 12px rgba(239, 68, 68, 0.3)';

            // Animate the highlight
            card.style.transition = 'all 0.3s ease';
            setTimeout(() => {
              card.style.transition = 'background 0.8s ease';
              card.style.background = '';
              card.style.borderColor = '';
              card.style.boxShadow = '';
            }, 2000);
          }
        });
      }

      highlightPropCard(propCard, isHit) {
        propCard.style.borderColor = isHit ? 'var(--accent-green)' : 'var(--accent-red)';
        propCard.style.boxShadow = isHit
          ? '0 0 16px rgba(34, 197, 94, 0.4)'
          : '0 0 16px rgba(239, 68, 68, 0.4)';
        propCard.style.transition = 'all 0.3s ease';

        // Add outcome badge
        const badge = document.createElement('div');
        badge.style.cssText = `
          position: absolute;
          top: 8px;
          right: 8px;
          background: ${isHit ? 'var(--accent-green)' : 'var(--accent-red)'};
          color: ${isHit ? '#000' : '#fff'};
          padding: 4px 8px;
          border-radius: 4px;
          font-size: 11px;
          font-weight: 700;
          z-index: 10;
          animation: slideIn 0.3s ease;
        `;
        badge.textContent = isHit ? 'HIT ✓' : 'MISS ✗';
        propCard.appendChild(badge);

        setTimeout(() => {
          propCard.style.borderColor = '';
          propCard.style.boxShadow = '';
          badge.style.opacity = '0';
          badge.style.transition = 'opacity 0.3s ease';
          setTimeout(() => badge.remove(), 300);
        }, 3000);
      }
    }

    const outcomeUIHandler = new OutcomeUIHandler();

    // ════════════════════════════════════════════════════════════════════════
    // NEWS CONTEXT BUS (Phase 4: Real-time System)
    // Polls ESPN injuries + RSS feeds every 30s, emits NewsUpdated events
    // ════════════════════════════════════════════════════════════════════════
    class NewsContextBus {
      constructor() {
        this.pollInterval = 30000; // 30s
        this.pollTimer = null;
        this.newsCache = {}; // { "gameId": { articles: [...], timestamp, league, teams } }
        this.listeners = [];
      }

      on(event, callback) {
        if (event === 'NewsUpdated') this.listeners.push(callback);
      }

      off(event, callback) {
        if (event === 'NewsUpdated') {
          this.listeners = this.listeners.filter(cb => cb !== callback);
        }
      }

      emit(event, data) {
        if (event === 'NewsUpdated') {
          this.listeners.forEach(cb => {
            try { cb(data); } catch (e) { console.warn('[NewsContextBus] Listener error:', e); }
          });
        }
      }

      start() {
        if (this.pollTimer) return;
        console.log('[NewsContextBus] Starting news polling (30s)');
        this.pollTimer = setInterval(() => this._pollNews(), 30000);
        // Initial poll immediately
        this._pollNews();
      }

      stop() {
        if (this.pollTimer) {
          clearInterval(this.pollTimer);
          this.pollTimer = null;
        }
      }

      async _pollNews() {
        try {
          // Get all games with live or recent status
          const allGames = [
            ...(state.games.NBA || []),
            ...(state.games.NHL || []),
            ...(state.games.MLB || []),
            ...(state.games.NFL || [])
          ];

          for (const game of allGames) {
            // Skip if game is old (>24h) or if we have recent cache
            const cache = this.newsCache[game.id];
            const now = Date.now();
            if (cache && (now - cache.timestamp) < 60000) continue; // Cache hit within 1min

            // Fetch news for this game
            const teams = [game.homeTeam, game.awayTeam].filter(Boolean);
            if (teams.length === 0) continue;

            try {
              const articles = await this._fetchGameNews(game.league, teams[0]);
              if (articles && articles.length > 0) {
                this.newsCache[game.id] = {
                  gameId: game.id,
                  league: game.league,
                  teams: teams,
                  articles: articles.slice(0, 3), // Top 3 articles
                  timestamp: now
                };

                this.emit('NewsUpdated', { game, articles: this.newsCache[game.id].articles });
              }
            } catch (err) {
              console.warn(`[NewsContextBus] Failed to fetch news for game ${game.id}:`, err);
            }
          }
        } catch (err) {
          console.error('[NewsContextBus] Poll error:', err);
        }
      }

      async _fetchGameNews(league, team) {
        try {
          const url = `/.netlify/functions/news-context?league=${league}&team=${team}`;
          const res = await fetch(url, { signal: AbortSignal.timeout(5000) });
          if (!res.ok) return null;

          const data = await res.json();
          if (!data.articles) return null;

          // Extract clean article summaries
          return data.articles
            .filter(a => a.status === 'ok')
            .map(a => ({
              title: a.title || '',
              source: a.source || '',
              url: a.url || '',
              takeaways: a.takeaways || [],
              excerpt: a.article_excerpt || ''
            }));
        } catch (err) {
          console.warn('[NewsContextBus] Fetch error:', err);
          return null;
        }
      }

      getContextForGame(gameId) {
        const cache = this.newsCache[gameId];
        if (!cache) return null;

        // Format for PropAI prompt inclusion
        return {
          gameId,
          league: cache.league,
          teams: cache.teams,
          articles: cache.articles,
          summary: cache.articles.length > 0
            ? `Latest news: ${cache.articles.map(a => `${a.source}: ${a.takeaways.slice(0, 2).join('; ')}`).join(' | ')}`
            : 'No recent news'
        };
      }
    }

    const newsContextBus = new NewsContextBus();

    // ════════════════════════════════════════════════════════════════════════
    // PROPAI FEED ENRICHMENT — Live context-aware recommendations
    // Subscribes to OutcomeDetected + NewsUpdated, caches analysis for 60s
    // ════════════════════════════════════════════════════════════════════════

    class PropAIFeed {
      constructor() {
        this.feedCache = new Map(); // { "gameId": { timestamp, picks: [...] } }
        this.cacheExpiry = 60000; // 60s cache
        this.feedContainer = null;
      }

      init() {
        this.feedContainer = document.getElementById('propAIFeedContainer');
        outcomeEventBus.on('OutcomeDetected', (outcome) => this._onOutcomeDetected(outcome));
        newsContextBus.on('NewsUpdated', (data) => this._onNewsUpdated(data));
        console.log('[PropAIFeed] Initialized');
      }

      async _onOutcomeDetected(outcome) {
        const gameId = outcome.gameId;
        if (!gameId) return;

        console.log(`[PropAIFeed] Outcome detected: ${outcome.player} ${outcome.prop} → ${outcome.status}`);

        // Clear cache for this game to force re-analysis
        this.feedCache.delete(gameId);

        // Fetch fresh recommendations
        await this._fetchAndRenderFeed(gameId);
      }

      async _onNewsUpdated(data) {
        const gameId = data.game?.id;
        if (!gameId) return;

        const hasBoardProps = (state.props || []).some(
          p => String(p.gameId || p.game_id || '') === String(gameId)
        );
        if (!hasBoardProps) {
          console.log(`[PropAIFeed] Skip news-only update (no props) for game ${gameId}`);
          return;
        }
        console.log(`[PropAIFeed] News updated for game ${gameId}`);

        // Clear cache and re-analyze
        this.feedCache.delete(gameId);
        await this._fetchAndRenderFeed(gameId);
      }

      async _fetchAndRenderFeed(gameId) {
        if (!this.feedContainer) return;

        try {
          // Check cache
          const cached = this.feedCache.get(gameId);
          if (cached && (Date.now() - cached.timestamp) < this.cacheExpiry) {
            console.log(`[PropAIFeed] Using cached picks for ${gameId}`);
            this._renderFeed(gameId, cached.picks, cached.fullAnalysis, cached.game);
            return;
          }

          // Find game context
          const allGames = [
            ...(state.games.NBA || []),
            ...(state.games.NHL || []),
            ...(state.games.MLB || []),
            ...(state.games.NFL || [])
          ];
          const game = allGames.find(g => String(g.id) === String(gameId));
          if (!game) return;

          // Get news context
          const newsCtx = newsContextBus.getContextForGame(gameId);
          const newsBlurb = newsCtx ? `Recent news: ${newsCtx.summary}` : '';

          const gameProps = (state.props || [])
            .filter(p => String(p.gameId || p.game_id || '') === String(gameId))
            .sort((a, b) => (parseFloat(b.modelScore) || 0) - (parseFloat(a.modelScore) || 0));

          if (!gameProps.length) {
            console.warn('[PropAIFeed] No props on board for game', gameId);
            return;
          }

          const topBoard = gameProps.slice(0, 6);
          const enriched = await Promise.all(
            topBoard.slice(0, 3).map(p =>
              (typeof enrichPropWithContext === 'function'
                ? enrichPropWithContext(p).catch(() => (typeof enrichPropWithStats === 'function' ? enrichPropWithStats(p) : p))
                : Promise.resolve(typeof enrichPropWithStats === 'function' ? enrichPropWithStats(p) : p))
            )
          );
          const compactPicks = enriched.map((p, idx) =>
            (typeof compactPropForOllama === 'function' ? compactPropForOllama(p, idx) : p)
          );

          const prompt = `Analyze the best player props for ${game.homeTeam} vs ${game.awayTeam} (${game.league}).
${newsBlurb}
Rank and explain the strongest edges using ONLY the supplied prop rows (hit rates, matchup, PropIQ).`;

          const controller = new AbortController();
          const t = setTimeout(() => controller.abort(), 24000);

          const response = await propEdgeNativeFetch('/.netlify/functions/ask-analyst', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            signal: controller.signal,
            body: JSON.stringify({
              question: prompt,
              league: game.league || 'NBA',
              matchedCount: gameProps.length,
              props: compactPicks,
              fast_mode: !!(state && state.aiFastMode),
              options: {
                temperature: 0.1,
                num_predict: state && state.aiFastMode ? 190 : 260
              },
              news_context: newsCtx
            })
          });
          clearTimeout(t);

          if (!response.ok) throw new Error(`API ${response.status}`);
          const result = await response.json();

          const analysisText = (result && (result.answer || result.analysis || result.response || '')) || '';

          // Extract picks from analyst response
          const picks = this._extractPicks(analysisText);

          // Cache
          this.feedCache.set(gameId, {
            timestamp: Date.now(),
            picks,
            fullAnalysis: analysisText,
            game
          });

          this._renderFeed(gameId, picks, analysisText, game);
        } catch (err) {
          console.warn('[PropAIFeed] Fetch error:', err);
        }
      }

      _extractPicks(text) {
        if (!text) return [];

        // Parse picks from analyst response
        // Format: "Player: Market (Line) — Edge +X% — Key: [detail]"
        const lines = text.split('\n');
        const picks = [];

        for (const line of lines) {
          if (line.includes(':') && (line.includes('Edge') || line.includes('%'))) {
            const match = line.match(/^(.+?):\s*(.+?)\((.+?)\)\s*—\s*(.+?)—\s*Key:\s*(.+)$/);
            if (match) {
              picks.push({
                player: match[1].trim(),
                market: match[2].trim(),
                line: match[3].trim(),
                edge: match[4].trim(),
                key: match[5].trim()
              });
            } else {
              // Fallback parsing
              picks.push({ raw: line.trim() });
            }
          }
        }

        return picks.slice(0, 3); // Top 3 picks
      }

      _renderFeed(gameId, picks, analysisText = '', game = null) {
        if (!this.feedContainer || !picks || picks.length === 0) return;

        const safeText = String(analysisText || '');
        const title = analystSectionText(safeText, 'TITLE') || (game ? `${game.awayTeam} at ${game.homeTeam} Analysis` : 'Matchup Analysis');
        const seriesState = analystSectionText(safeText, 'SERIES STATE') || 'Series state unavailable.';
        const teamMatchup = analystSectionText(safeText, 'TEAM MATCHUP ANALYSIS') || '';
        const playerRecs = analystSectionText(safeText, 'PLAYER PROP RECOMMENDATIONS') || '';
        const newsNarrative = analystSectionText(safeText, 'NEWS & NARRATIVE SYNTHESIS') || analystSectionText(safeText, 'SOURCES USED') || '';
        const prediction = analystSectionText(safeText, 'SERIES PREDICTION & PROP LOGIC') || '';
        const compactNews = newsNarrative
          ? newsNarrative.slice(0, 520)
          : (game ? `${game.awayTeam} vs ${game.homeTeam} context loaded from current board and source feeds.` : 'News context unavailable.');

        const feedHtml = picks.map((pick, idx) => {
          if (pick.raw) {
            return `<div class="feed-pick-item">${pick.raw}</div>`;
          }
          return `
            <div class="feed-pick-item">
              <div class="feed-pick-player">${pick.player}</div>
              <div class="feed-pick-detail">${pick.market} (${pick.line})</div>
              <div class="feed-pick-edge">${pick.edge}</div>
              <div class="feed-pick-news">📰 ${pick.key}</div>
            </div>
          `;
        }).join('');

        const html = `
          <div class="feed-section">
            <div class="feed-header">🎯 Real-time Recommendations</div>
            <div class="feed-pick-item" style="display:block;">
              <div class="feed-pick-player">${escapeHTML(title)}</div>
              <div class="feed-pick-detail" style="margin-top:6px;">${escapeHTML(seriesState)}</div>
            </div>
            ${teamMatchup ? `<div class="feed-pick-item" style="display:block;"><div class="feed-pick-news">🛡️ ${escapeHTML(teamMatchup.slice(0, 420))}</div></div>` : ''}
            <div class="feed-pick-item" style="display:block;">
              <div class="feed-pick-news">📰 ${escapeHTML(compactNews)}</div>
            </div>
            <div class="feed-picks">${feedHtml}</div>
            ${playerRecs ? `<details class="rich-evidence-panel" style="margin-top:10px;"><summary>Matchup + Best Props</summary><div class="rich-panel-body">${escapeHTML(playerRecs).replace(/\n/g, '<br>')}</div></details>` : ''}
            ${prediction ? `<details class="rich-evidence-panel" style="margin-top:8px;"><summary>Series Logic</summary><div class="rich-panel-body">${escapeHTML(prediction).replace(/\n/g, '<br>')}</div></details>` : ''}
          </div>
        `;

        // Append to feed container (or replace if exists)
        const existing = this.feedContainer.querySelector('.feed-section');
        if (existing) {
          existing.replaceWith(this._htmlToElement(html));
        } else {
          this.feedContainer.insertAdjacentHTML('afterbegin', html);
        }
      }

      _htmlToElement(html) {
        const div = document.createElement('div');
        div.innerHTML = html.trim();
        return div.firstChild;
      }
    }

    const propAIFeed = new PropAIFeed();

    // ════════════════════════════════════════════════════════════════════════
    // DEBUG PANEL — Real-time system health monitoring
    // Toggle with ?debug=true in URL
    // ════════════════════════════════════════════════════════════════════════

    class DebugPanel {
      constructor() {
        this.enabled = new URLSearchParams(window.location.search).get('debug') === 'true';
        this.stats = {
          outcomesDetected: 0,
          newsUpdates: 0,
          feedFetches: 0,
          espnLatency: [],
          sheetWrites: 0,
          lastOutcomeTime: null,
          lastNewsTime: null,
          pollIntervals: new Set(),
          cacheHits: 0,
          cacheMisses: 0
        };
        this.panel = null;
        this.updateInterval = null;
      }

      init() {
        if (!this.enabled) return;

        console.log('[DebugPanel] Enabled');

        // Create panel DOM
        this.panel = document.createElement('div');
        this.panel.id = 'debugPanel';
        this.panel.style.cssText = `
          position: fixed;
          bottom: 20px;
          right: 20px;
          width: 340px;
          max-height: 400px;
          background: rgba(0, 0, 0, 0.92);
          border: 2px solid var(--accent-green);
          border-radius: 12px;
          padding: 14px;
          font-family: monospace;
          font-size: 11px;
          color: var(--accent-green);
          z-index: 10000;
          overflow-y: auto;
          box-shadow: 0 0 20px rgba(0, 240, 160, 0.3);
        `;
        document.body.appendChild(this.panel);

        // Subscribe to events
        outcomeEventBus.on('OutcomeDetected', () => {
          this.stats.outcomesDetected++;
          this.stats.lastOutcomeTime = new Date().toLocaleTimeString();
        });
        newsContextBus.on('NewsUpdated', () => {
          this.stats.newsUpdates++;
          this.stats.lastNewsTime = new Date().toLocaleTimeString();
        });

        // Start updates
        this.updateInterval = setInterval(() => this._render(), 1000);
        this._render();
      }

      recordEspnLatency(ms) {
        this.stats.espnLatency.push(ms);
        if (this.stats.espnLatency.length > 20) this.stats.espnLatency.shift();
      }

      recordSheetWrite() {
        this.stats.sheetWrites++;
      }

      recordPollInterval(intervalName) {
        this.stats.pollIntervals.add(intervalName);
      }

      recordCacheHit() {
        this.stats.cacheHits++;
      }

      recordCacheMiss() {
        this.stats.cacheMisses++;
      }

      _render() {
        if (!this.panel) return;

        const avgLatency = this.stats.espnLatency.length > 0
          ? Math.round(this.stats.espnLatency.reduce((a, b) => a + b) / this.stats.espnLatency.length)
          : 0;

        const cacheRate = this.stats.cacheHits + this.stats.cacheMisses > 0
          ? Math.round((this.stats.cacheHits / (this.stats.cacheHits + this.stats.cacheMisses)) * 100)
          : 0;

        this.panel.innerHTML = `
          <div style="color: var(--accent-green); font-weight: bold; margin-bottom: 8px;">⚙️ PROPEDGE DEBUG</div>
          <div style="border-bottom: 1px solid rgba(0,240,160,0.2); margin-bottom: 8px; padding-bottom: 8px;">
            <div>Outcomes: <span style="color: var(--accent-blue);">${this.stats.outcomesDetected}</span> ${this.stats.lastOutcomeTime ? `@ ${this.stats.lastOutcomeTime}` : ''}</div>
            <div>News: <span style="color: var(--accent-blue);">${this.stats.newsUpdates}</span> ${this.stats.lastNewsTime ? `@ ${this.stats.lastNewsTime}` : ''}</div>
            <div>Feed Fetches: <span style="color: var(--accent-blue);">${this.stats.feedFetches}</span></div>
          </div>
          <div style="border-bottom: 1px solid rgba(0,240,160,0.2); margin-bottom: 8px; padding-bottom: 8px;">
            <div>ESPN Latency: <span style="color: var(--accent-blue);">${avgLatency}ms</span></div>
            <div>Sheet Writes: <span style="color: var(--accent-blue);">${this.stats.sheetWrites}</span></div>
            <div>Cache Hit Rate: <span style="color: var(--accent-blue);">${cacheRate}%</span></div>
          </div>
          <div style="border-bottom: 1px solid rgba(0,240,160,0.2); margin-bottom: 8px; padding-bottom: 8px;">
            <div>Active Intervals: <span style="color: var(--accent-blue);">${this.stats.pollIntervals.size}</span></div>
            <div style="font-size: 9px; margin-top: 4px; color: rgba(0,240,160,0.6);">
              ${Array.from(this.stats.pollIntervals).slice(0, 4).join(', ')}
            </div>
          </div>
          <div style="color: rgba(0,240,160,0.5); font-size: 9px; text-align: center;">
            ?debug=true active
          </div>
        `;
      }

      stop() {
        if (this.updateInterval) {
          clearInterval(this.updateInterval);
          this.updateInterval = null;
        }
        if (this.panel) {
          this.panel.remove();
          this.panel = null;
        }
      }
    }

    const debugPanel = new DebugPanel();

    // ════════════════════════════════════════════════════════════════════════
    // AUTO PROP RESULT TRACKING (NEW v7.0)
    // When games end, fetches final stats and auto-marks props hit/miss
    // No manual tracking needed — fully self-calibrating model
    // ════════════════════════════════════════════════════════════════════════
    async function _autoTrackPropResults() {
      const allGames = [
        ...(state.games.NBA || []),
        ...(state.games.NHL || []),
        ...(state.games.MLB || []),
      ];

      console.log(`[Auto-Track] Checking ${allGames.length} games for final transitions`);

      for (const game of allGames) {
        const prevStatus = state.prevGameStatuses[game.id];
        const currStatus = game.status;

        // LAZY INIT: If game not yet tracked, initialize its previous status
        if (!prevStatus) {
          state.prevGameStatuses[game.id] = currStatus;
          continue; // Skip first time; catch transition next cycle
        }

        // Process any game that just transitioned TO final (from any previous state)
        const justWentFinal = prevStatus !== 'final' && currStatus === 'final';
        if (!justWentFinal) continue;

        console.log(`[Auto-Track] Game transition detected: ${game.id} (${game.league}) ${prevStatus}→final`);

        try {
          // Fetch final stats for all players in this game
          const finalStats = await _fetchFinalGameStats(game);
          if (!finalStats) continue;

          // Find all props matching this game
          const gameProps = (state.allProps || []).filter(p =>
            p.team && p.opponent &&
            String(p.gameId) === String(game.id)
          );

          // Collect outcomes to post to sync service
          const outcomesToPost = [];

          for (const prop of gameProps) {
            const playerStats = finalStats[prop.player];
            if (!playerStats) continue;

            // Determine hit/miss based on prop type
            const didHit = _evaluatePropResult(prop, playerStats);

            // Generate stable propId for tracking
            const propId = `${prop.player}_${prop.prop}_${game.id}`;

            // Record hit/miss
            if (!state.propHits[propId]) {
              state.propHits[propId] = { hits: 0, total: 0, accuracy: 0 };
            }

            state.propHits[propId].total += 1;
            if (didHit) {
              state.propHits[propId].hits += 1;
            }
            state.propHits[propId].accuracy = Math.round(
              (state.propHits[propId].hits / state.propHits[propId].total) * 100
            );
            state.propHits[propId].lastUpdated = new Date().toISOString();

            console.log(`[Auto-Track] ${prop.player} ${prop.prop}: ${didHit ? 'HIT' : 'MISS'} (${state.propHits[propId].hits}/${state.propHits[propId].total})`);

            // Collect for bulk post to outcomes service
            outcomesToPost.push({
              player: prop.player,
              prop: prop.prop,
              line: prop.line,
              status: didHit ? 'HIT' : 'MISS',
              gameId: game.id,
              gameStatus: 'final',
              ...getOutcomePredictionMeta(prop)
            });

            // Sync to sheet async (don't block)
            _syncPropHitToSheet(propId, state.propHits[propId]).catch(err =>
              console.warn(`[Auto-Track] Sync failed for ${propId}:`, err.message)
            );
          }

          // Post all outcomes from this game to sync service
          if (outcomesToPost.length > 0) {
            await gameFinalDetector.checkAndResolveOutcomes(game, outcomesToPost);
          }
        } catch (err) {
          console.warn(`[Auto-Track] Error processing game ${game.id}:`, err.message);
        }
      }

      // Update previous statuses for next iteration
      for (const game of allGames) {
        state.prevGameStatuses[game.id] = game.status;
      }
    }

    async function _fetchFinalGameStats(game) {
      try {
        const sport = game.league.toLowerCase();
        const url = `https://site.api.espn.com/apis/site/v2/sports/${sport === 'nhl' ? 'hockey/nhl' : sport === 'mlb' ? 'baseball/mlb' : 'basketball/nba'}/scoreboard?_=${Date.now()}`;
        const r = await fetch(url).catch(() => null);
        if (!r || !r.ok) return null;

        const sb = await r.json();
        const event = (sb.events || []).find(e => String(e.id) === String(game.id));
        if (!event) return null;

        const comp = event.competitions?.[0];
        const competitors = comp?.competitors || [];
        const players = comp?.competitors?.flatMap(c => c.players || []) || [];

        // Build stats lookup by player name
        const statsByPlayer = {};
        for (const player of players) {
          const name = player.displayName;
          const stats = {};
          (player.stats || []).forEach(s => {
            stats[s.name?.toLowerCase()] = s.value;
          });
          statsByPlayer[name] = {
            points: stats['points'] || 0,
            rebounds: stats['rebounds'] || 0,
            assists: stats['assists'] || 0,
            blocks: stats['blocks'] || 0,
            steals: stats['steals'] || 0,
            threepointers: stats['3-pointers made'] || stats['three pointers made'] || 0,
            q1Points: stats['q1 points'] || 0,
            quarterStats: [
              stats['q1 points'] || 0,
              stats['q2 points'] || 0,
              stats['q3 points'] || 0,
              stats['q4 points'] || 0,
            ]
          };
        }
        return statsByPlayer;
      } catch (err) {
        console.warn('[Auto-Track] Failed to fetch final stats:', err.message);
        return null;
      }
    }

    function _evaluatePropResult(prop, playerStats) {
      if (!prop.prop || !playerStats) return false;

      const propLower = prop.prop.toLowerCase();
      const isOver = propLower.startsWith('o');
      const isUnder = propLower.startsWith('u');
      const line = parseFloat(propLower.slice(1));

      if (isNaN(line)) return false;

      // Extract stat value based on prop type
      let actualValue = 0;

      // Quarter props (Q1/Q2/Q3/Q4 Points)
      if (propLower.includes('q1 points')) {
        actualValue = playerStats.q1Points || 0;
      }
      // Combined props
      else if (propLower.includes('points + rebounds + assists') || propLower.includes('pts + reb + ast')) {
        actualValue = (playerStats.points || 0) + (playerStats.rebounds || 0) + (playerStats.assists || 0);
      }
      else if (propLower.includes('points + rebounds') || propLower.includes('pts + reb')) {
        actualValue = (playerStats.points || 0) + (playerStats.rebounds || 0);
      }
      else if (propLower.includes('points + assists') || propLower.includes('pts + ast')) {
        actualValue = (playerStats.points || 0) + (playerStats.assists || 0);
      }
      else if (propLower.includes('rebounds + assists') || propLower.includes('reb + ast')) {
        actualValue = (playerStats.rebounds || 0) + (playerStats.assists || 0);
      }
      // Single stats
      else if (propLower.includes('points')) {
        actualValue = playerStats.points || 0;
      }
      else if (propLower.includes('rebounds')) {
        actualValue = playerStats.rebounds || 0;
      }
      else if (propLower.includes('assists')) {
        actualValue = playerStats.assists || 0;
      }
      else if (propLower.includes('blocks')) {
        actualValue = playerStats.blocks || 0;
      }
      else if (propLower.includes('steals')) {
        actualValue = playerStats.steals || 0;
      }
      else if (propLower.includes('three')) {
        actualValue = playerStats.threepointers || 0;
      }

      // Determine hit/miss
      if (isOver) {
        return actualValue > line;  // Over hits if actual > line
      } else if (isUnder) {
        return actualValue < line;  // Under hits if actual < line
      }
      return false;
    }

    async function _syncPropHitToSheet(propId, hitData) {
      // Uses existing Google Sheet API to sync hit/miss records
      // This reuses credentials already loaded for enrichment
      const payload = {
        propId,
        hits: hitData.hits,
        total: hitData.total,
        lastUpdated: hitData.lastUpdated
      };

      // Append to Prop_Hits sheet (will be created if doesn't exist)
      try {
        // This would normally use the Google Sheets API via Apps Script
        // For now, we store locally and can batch sync later
        propEdgeStorage.setItem(`propHit_${propId}`, JSON.stringify(payload));
      } catch (err) {
        console.warn('[Auto-Track] Failed to sync to sheet:', err.message);
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    // AUTONOMOUS BACKGROUND CLOCK SYNC
    // Runs independently, no user action needed. Syncs all live game clocks
    // to ESPN every 10 seconds across modal, ticker, and prop cards.
    // ════════════════════════════════════════════════════════════════════════
    let _backgroundClockSyncTimer = null;

    async function _autonomousGameClockSync() {
      // Get all games from current state (both live AND upcoming/scheduled)
      const allGames = [
        ...(state.games.NBA || []),
        ...(state.games.NHL || []),
        ...(state.games.MLB || []),
        ...(state.games.NFL || []),
      ];

      // Check both live games AND scheduled games within 3 hours of now
      // (to catch games that have started but haven't updated status yet)
      const now = Date.now();
      const threeHoursMs = 3 * 60 * 60 * 1000;
      const gamesToCheck = allGames.filter(g => {
        const isLive = g.status === 'live';
        const isUpcoming = g.status === 'scheduled' || g.status === 'upcoming';
        const gameTime = new Date(g.date || g.dateTime).getTime();
        const isWithin3Hours = Math.abs(gameTime - now) < threeHoursMs;

        return g.league !== 'MLB' && (isLive || (isUpcoming && isWithin3Hours));
      });

      if (gamesToCheck.length === 0) {
        _stopLiveTickerPoll(); // Stop if no games to check
        return;
      }

      const liveGames = gamesToCheck.filter(g => g.status === 'live');

      console.log(`[Background Clock Sync] Found ${liveGames.length} live games and ${gamesToCheck.length - liveGames.length} upcoming games to check, fetching ESPN data...`);

      // Fetch fresh ESPN data for all games (live + upcoming) in parallel
      const promises = gamesToCheck.map(async (g) => {
        const cfg = ESPN_SPORT_MAP[g.league];
        if (!cfg) {
          console.log(`[Background Clock Sync] No config for league ${g.league}`);
          return null;
        }

        try {
          const res = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/scoreboard?_=${Date.now()}`).catch(() => null);
          if (!res || !res.ok) {
            console.log(`[Background Clock Sync] ESPN fetch failed for ${g.league}`);
            return null;
          }
          const sb = await res.json();
          console.log(`[Background Clock Sync] ESPN returned ${(sb.events || []).length} events for ${g.league}`);

          const event = (sb.events || []).find(e => String(e.id) === String(g.id));
          if (!event) {
            console.log(`[Background Clock Sync] Event not found for game ID ${g.id} in ${g.league}. Available IDs: ${(sb.events || []).map(e => e.id).join(', ')}`);
            return null;
          }

          // Check if game is live — ESPN uses status.type.state, not status.state
          const isLive = event.status?.type?.state === 'in';
          const displayClock = event.status?.displayClock || '';

          if (!isLive || !displayClock) {
            console.log(`[Background Clock Sync] Game ${g.id} not in-progress or no clock (isLive: ${isLive}, clock: "${displayClock}", status:`, event.status, ')');
            return null;
          }

          const comp = event.competitions?.[0];
          const competitors = comp?.competitors || [];
          const away = competitors.find(c => c.homeAway === 'away');
          const home = competitors.find(c => c.homeAway === 'home');

          console.log(`[Background Clock Sync] ✅ Game ${g.id} (${g.league}): ${displayClock} P${event.status?.period}`);

          return {
            gameId: g.id,
            league: g.league,
            displayClock,
            period: event.status?.period || 0,
            awayScore: away?.score ?? '-',
            homeScore: home?.score ?? '-',
          };
        } catch (err) {
          console.error(`[Background Clock Sync] Error fetching game ${g.id}:`, err);
          return null;
        }
      });

      const freshGameData = await Promise.all(promises);
      console.log(`[Background Clock Sync] Fetched data for ${freshGameData.filter(d => d).length} games:`, freshGameData.filter(d => d));

      // AUTO-TRACK PROP RESULTS: Check if any games just ended and auto-mark props hit/miss
      console.log('[DEBUG] Calling _autoTrackPropResults...');
      await _autoTrackPropResults();
      console.log('[DEBUG] _autoTrackPropResults completed');

      // Update all DOM elements with fresh ESPN data simultaneously
      freshGameData.forEach(data => {
        if (!data) return;
        const { gameId, league, displayClock, period, awayScore, homeScore } = data;

        // Write back to state.games so the 30s renderTicker re-render uses fresh data, not stale snapshot
        const leagueGames = state.games[league] || [];
        const stateGame = leagueGames.find(g => String(g.id) === String(gameId));
        if (stateGame) {
          if (displayClock) stateGame.displayClock = displayClock;
          if (period) stateGame.period = period;
          stateGame.awayScore = awayScore;
          stateGame.homeScore = homeScore;
        }

        console.log(`[Background Clock Sync] Updating game ${gameId} (${league}): ${displayClock} P${period}`);

        // Update ticker card with fresh ESPN data
        const tickerCard = document.querySelector(`.tck-clock[data-gameid="${gameId}"]`);
        if (tickerCard && displayClock) {
          tickerCard.setAttribute('data-period', period);
          tickerCard.textContent = displayClock + ' · ' + _tickerPeriodLabel(league, period);
        }

        // Update ticker score
        const scoreCard = document.querySelector(`.live-game-card[data-gameid="${gameId}"] .live-game-score`);
        if (scoreCard) scoreCard.textContent = `${awayScore}-${homeScore}`;

        // Update modal if open — use String() on both sides to avoid type mismatch
        if (_modalState.game && String(_modalState.game.id) === String(gameId)) {
          const clockLabel = _svgClockLabel(league, period, displayClock);

          if (displayClock) {
            const modalClock = document.getElementById('modalClock');
            if (modalClock) modalClock.textContent = displayClock;

            const trackerBadge = document.getElementById('liveTrackerBadge');
            if (trackerBadge) trackerBadge.innerHTML = clockLabel;

            // querySelectorAll hits all 4 sport-court SVGs (NBA/NHL/MLB/NFL each have id="svgCourtClock")
            document.querySelectorAll('[id="svgCourtClock"]').forEach(el => {
              el.textContent = clockLabel;
            });

            _modalState.countdownPeriod = period;
          }

          // Also sync period label and score in modal header in real-time
          const periodEl = document.getElementById('modalPeriod');
          if (periodEl && period) periodEl.textContent = _modalPeriodLabel(league, period);

          const scoreEl = document.getElementById('modalScore');
          if (scoreEl) scoreEl.textContent = `${awayScore} – ${homeScore}`;
        }

        // Update prop card badges
        document.querySelectorAll(`.game-clock-badge[data-gameid="${gameId}"]`).forEach(el => {
          if (displayClock) {
            el.textContent = displayClock;
            el.setAttribute('data-displayclock', displayClock);
          }
        });

        // Update prop card live context strips (score + clock + period chips)
        document.querySelectorAll(`.live-ctx-strip[data-gameid="${gameId}"]`).forEach(strip => {
          // Score numbers — away then home
          const nums = strip.querySelectorAll('.live-ctx-num');
          if (nums.length >= 2) { nums[0].textContent = awayScore; nums[1].textContent = homeScore; }
          // Clock in score row header
          const ctxClock = strip.querySelector('.live-ctx-clock');
          if (ctxClock && displayClock) ctxClock.textContent = displayClock;
          // Period chip
          const periodChip = strip.querySelector('.live-ctx-chip.period');
          if (periodChip && period) {
            if (league === 'NBA') periodChip.textContent = period <= 4 ? `Q${period}` : `OT${period > 5 ? period-4 : ''}`;
            else if (league === 'NHL') periodChip.textContent = period <= 3 ? `P${period}` : 'OT';
            else if (league === 'NFL') periodChip.textContent = period <= 4 ? `Q${period}` : 'OT';
          }
          // Clock chip
          const clockChip = strip.querySelector('.live-ctx-chip.clock');
          if (clockChip && displayClock) clockChip.textContent = `⏱ ${displayClock}`;
        });
      });
    }

    // ── Ticker arrow scroll
    window.scrollTicker = function(dir) {
      const ticker = document.getElementById('gamesTicker');
      if (!ticker) return;
      // Pause auto-scroll during manual navigation
      window._manualScrollActive = true;
      clearInterval(window.scrollInterval);
      const cardWidth = ticker.querySelector('.live-game-card')?.offsetWidth || 240;
      ticker.scrollBy({ left: dir * (cardWidth + 10), behavior: 'smooth' });
      // Update arrow visibility after scroll settles
      setTimeout(_updateTickerArrows, 350);

      // DISABLED: No auto-scroll resume — manual clicks only
      // const resumeAutoScroll = () => {
      //   window._manualScrollActive = false;
      //   if (window.scrollInterval) clearInterval(window.scrollInterval);
      //   window.scrollInterval = setInterval(window._autoScrollFunc, 60);
      // };
      //
      // const handleScrollEnd = () => {
      //   ticker.removeEventListener('scrollend', handleScrollEnd);
      //   resumeAutoScroll();
      // };
      //
      // if ('onscrollend' in ticker) {
      //   ticker.addEventListener('scrollend', handleScrollEnd, { once: true });
      //   setTimeout(() => {
      //     ticker.removeEventListener('scrollend', handleScrollEnd);
      //     if (window._manualScrollActive) resumeAutoScroll();
      //   }, 3500);
      // } else {
      //   setTimeout(resumeAutoScroll, 3500);
      // }
    };

    function _updateTickerArrows() {
      const ticker = document.getElementById('gamesTicker');
      const left   = document.getElementById('tickerArrowLeft');
      const right  = document.getElementById('tickerArrowRight');
      if (!ticker || !left || !right) return;
      const atStart = ticker.scrollLeft <= 4;
      const atEnd   = ticker.scrollLeft + ticker.clientWidth >= ticker.scrollWidth - 4;
      left.classList.toggle('hidden', atStart);
      right.classList.toggle('hidden', atEnd);
    }

    function _startLiveTickerPoll() {
      espnPollingBus.start();
    }

    function _stopLiveTickerPoll() {
      espnPollingBus.stop();
      _stopTickerClockCountdown();
      _stopPropClockCountdown();
    }

    // ── Ticker clock countdown disabled
    let _tickerClockTimer = null;

    function _startTickerClockCountdown() {
      // ESPN sync updates ticker directly — no local countdown needed
    }

    function _stopTickerClockCountdown() {
      if (_tickerClockTimer) { clearInterval(_tickerClockTimer); _tickerClockTimer = null; }
    }

    // ── Live clock countdown for prop card game info ──────────────────────────
    let _propClockTimer = null;

    let _lastESPNSyncTime = 0; // Track when we last synced with ESPN
    function _startPropClockCountdown() {
      if (_propClockTimer) return;
      _propClockTimer = setInterval(async () => {
        // Get all live game badge elements
        const badges = document.querySelectorAll('.game-clock-badge[data-displayclock]');
        if (badges.length === 0) return;

        // Collect unique game IDs
        const gameIds = new Set();
        badges.forEach(el => {
          const gameId = el.getAttribute('data-gameid');
          const secs = parseInt(el.getAttribute('data-secs') || '-1', 10);
          if (secs >= 0 && gameId) gameIds.add(gameId);
        });

        if (gameIds.size === 0) return;

        // Only fetch fresh ESPN data every 30 seconds (not every second)
        const now = Date.now();
        const shouldFetchESPN = (now - _lastESPNSyncTime) >= 30000;

        const gameDataMap = new Map();
        if (shouldFetchESPN) {
          _lastESPNSyncTime = now;
          // Fetch fresh game data from ESPN
          for (const gameId of gameIds) {
            try {
              const badge = Array.from(badges).find(el => el.getAttribute('data-gameid') === gameId);
              if (!badge) continue;
              const league = badge.getAttribute('data-league');
              const cfg = ESPN_SPORT_MAP[league];
              if (!cfg) continue;

              const res = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/scoreboard?_=${Date.now()}`).catch(() => null);
              if (!res || !res.ok) continue;
              const sb = await res.json();
              const event = (sb.events || []).find(e => String(e.id) === String(gameId));
              if (!event) continue;

              const status = event.status?.type;
              const isLive = status?.state === 'in';
              if (!isLive) continue;

              const displayClock = event.status?.displayClock || '';
              const period = event.status?.period || 0;
              gameDataMap.set(gameId, { displayClock, period, league });
            } catch (err) {
              // Silent fail - keep using local countdown
            }
          }
        }

        // Single tick helper — used for both prop card badges and ticker clocks
        function _tickClockEl(el) {
          const gameId = el.getAttribute('data-gameid');
          const secs = parseInt(el.getAttribute('data-secs') || '-1', 10);
          if (secs < 0) return;

          let newSecs = secs;
          let period = parseInt(el.getAttribute('data-period') || '0', 10);
          const league = el.getAttribute('data-league') || el.getAttribute('data-league');
          let displayClock = el.getAttribute('data-displayclock') || el.getAttribute('data-displayclock') || '';

          if (gameDataMap.has(gameId)) {
            const freshData = gameDataMap.get(gameId);
            newSecs = _clockToSecs(freshData.displayClock) || 0;
            period = freshData.period;
            displayClock = freshData.displayClock;
            el.setAttribute('data-displayclock', freshData.displayClock);
            el.setAttribute('data-period', period);
          } else {
            newSecs = Math.max(0, secs - 1);
          }

          el.setAttribute('data-secs', newSecs);
          const clockStr = gameDataMap.has(gameId) ? displayClock : (newSecs > 0 ? _secsToClockStr(newSecs) : '0:00');
          const pLabel = _tickerPeriodLabel(league, period);
          el.textContent = pLabel ? `${clockStr} · ${pLabel}` : clockStr;
        }

        // Tick prop card game-clock badges
        badges.forEach(_tickClockEl);

        // Tick ticker bar tck-clock elements — same logic, unified source
        document.querySelectorAll('.tck-clock[data-secs]').forEach(el => {
          const gameId = el.getAttribute('data-gameid');
          const secs = parseInt(el.getAttribute('data-secs') || '-1', 10);
          if (secs < 0) return;
          let newSecs = gameDataMap.has(gameId)
            ? (_clockToSecs(gameDataMap.get(gameId).displayClock) || 0)
            : Math.max(0, secs - 1);
          const period = gameDataMap.has(gameId)
            ? gameDataMap.get(gameId).period
            : parseInt(el.getAttribute('data-period') || '0', 10);
          const league = el.getAttribute('data-league') || '';
          if (gameDataMap.has(gameId)) {
            el.setAttribute('data-displayclock', gameDataMap.get(gameId).displayClock);
            el.setAttribute('data-period', period);
          }
          el.setAttribute('data-secs', newSecs);
          const clockStr = gameDataMap.has(gameId)
            ? gameDataMap.get(gameId).displayClock
            : (newSecs > 0 ? _secsToClockStr(newSecs) : '0:00');
          el.textContent = clockStr + ' · ' + _tickerPeriodLabel(league, period);
        });

      }, 1000); // Tick every 1 second locally
    }

    function _stopPropClockCountdown() {
      if (_propClockTimer) { clearInterval(_propClockTimer); _propClockTimer = null; }
    }

    // ── Short period label for ticker cards (e.g. "4TH", "OT", "P2") ─────────
    // ── Short period label for ticker cards (e.g. "4TH", "OT", "P2") ─────────
    function _tickerPeriodLabel(league, period) {
      if (!period || period <= 0) return '';
      const ord = ['1ST','2ND','3RD','4TH'];
      const p = parseInt(period, 10);
      if (league === 'NBA') return p <= 4 ? (ord[p - 1] || 'Q' + p) : 'OT';
      if (league === 'NHL') return p <= 3 ? (ord[p - 1] || 'P' + p) : 'OT';
      if (league === 'NFL') return p <= 4 ? (ord[p - 1] || 'Q' + p) : 'OT';
      return 'P' + p;
    }

    // Refresh countdown displays on all upcoming game cards every 30s
    let _countdownRefreshTimer = null;
    function _startCountdownRefresh() {
      if (_countdownRefreshTimer) return;
      _countdownRefreshTimer = setInterval(() => {
        document.querySelectorAll('.game-countdown[data-gametime]').forEach(el => {
          const ts = parseInt(el.getAttribute('data-gametime'));
          if (!ts) return;
          const diffMs = ts - Date.now();
          if (diffMs <= 0) { el.textContent = ''; return; }
          const totalMins = Math.floor(diffMs / 60000);
          const hours = Math.floor(totalMins / 60);
          const mins  = totalMins % 60;
          const text  = hours > 0 ? `⏱ ${hours}h ${mins}m` : totalMins > 0 ? `⏱ ${totalMins}m` : '⏱ Starting soon';
          el.textContent = text;
          el.classList.toggle('soon', totalMins <= 30);
        });
      }, 30000);
    }

    function renderTicker(games) {
      const ticker = document.getElementById('gamesTicker');
      console.log('[PropEdge] renderTicker called with', games.length, 'games');

      // Dedupe games by ID to prevent duplicates
      const seenIds = new Set();
      const deduped = games.filter(g => {
        if (seenIds.has(g.id)) return false;
        seenIds.add(g.id);
        return true;
      });

      let displayGames = deduped;
      if (state.hideCompleted) {
        displayGames = deduped.filter(g => g.status !== 'final');
      }

      console.log('[PropEdge] Ticker will display', displayGames.length, 'games after filtering');

      if (displayGames.length === 0) {
        ticker.innerHTML = '<div style="color:var(--text-muted);font-size:12px;padding:10px;">No games scheduled</div>';
        console.warn('[PropEdge] No games to display in ticker');
        return;
      }

      // Preserve horizontal scroll position so 30s refresh doesn't jump the bar back to start.
      // Temporarily disable scroll-snap and smooth-scroll — otherwise the browser re-snaps
      // to the nearest card after we restore scrollLeft, causing a visible jump every 30s.
      const prevScrollLeft = ticker.scrollLeft;
      ticker.style.scrollSnapType = 'none';
      ticker.style.scrollBehavior = 'auto';

      ticker.innerHTML = displayGames.map(g => {
        const isActive = state.gameFilter?.id === g.id;
        const isLive = g.status === 'live';
        const isFinal = g.status === 'final';
        const liveLabel = isLive ? '📺 Live' : isFinal ? '📊 Final' : '📋 Preview';
        const liveBtnClass = isLive ? 'live-btn' : isFinal ? 'live-btn' : 'live-btn upcoming';
        const badgeClass = isLive ? 'live' : isFinal ? 'final' : g.league.toLowerCase();
        const badgeLabel = isLive ? '● LIVE' : isFinal ? 'FINAL' : g.league;
        return `
        <div class="live-game-card ${isActive ? 'active' : ''}" data-gameid="${g.id}" data-league="${g.league}" onclick="selectGame('${g.id}', '${g.league}', event)">
          <div class="live-game-badge ${badgeClass}">
            ${badgeLabel}
          </div>
          <div style="display:flex;gap:8px;align-items:center;justify-content:center;font-size:20px;">
            <span title="${g.awayTeam}">${getTeamLogo(g.awayTeam, g.league)}</span>
            <span style="font-size:10px;opacity:0.6;">@</span>
            <span title="${g.homeTeam}">${getTeamLogo(g.homeTeam, g.league)}</span>
          </div>
          <div style="display:flex;gap:6px;align-items:center;justify-content:center;font-size:11px;opacity:0.7;">
            <span style="font-weight:700;text-transform:uppercase;min-width:20px;text-align:center;">${g.awayTeam.substring(0,3)}</span>
            <span>vs</span>
            <span style="font-weight:700;text-transform:uppercase;min-width:20px;text-align:center;">${g.homeTeam.substring(0,3)}</span>
          </div>
          ${!isFinal && !isLive ? (() => {
              return `<div class="live-game-status">${g.gameTimeDisplay}</div>
              <div class="game-countdown">Scheduled</div>`;
            })() :
            `<div class="live-game-score">${g.awayScore}-${g.homeScore}</div>`
          }
          ${isLive || isFinal ? `<div class="live-game-status">${
            isLive && g.displayClock && g.league !== 'MLB'
              ? (() => {
                  const pLabel = _tickerPeriodLabel(g.league, g.period);
                  return `<span class="tck-clock" data-secs="${_clockToSecs(g.displayClock) ?? -1}" data-period="${g.period}" data-league="${g.league}" data-gameid="${g.id}">${g.displayClock}${pLabel ? ' · ' + pLabel : ''}</span>`;
                })()
              : g.statusDisplay
          }</div>` : ''}
          <!-- Action buttons — shown when card is selected -->
          <div class="game-card-actions">
            <button class="game-card-btn props-btn" onclick="clearGameFilter(event)">✕ All Props</button>
            <button class="game-card-btn ${liveBtnClass}" onclick="openGameModalById('${g.id}','${g.league}',event)">${liveLabel}</button>
          </div>
        </div>`;
      }).join('');

      // Restore scroll position, then re-enable snap/smooth on next frame so the
      // browser doesn't fight our restored position with a snap animation.
      ticker.scrollLeft = prevScrollLeft;
      requestAnimationFrame(() => {
        ticker.style.scrollSnapType = '';
        ticker.style.scrollBehavior = '';
      });

      // Update arrow visibility after ticker renders
      requestAnimationFrame(_updateTickerArrows);
      ticker.onscroll = _updateTickerArrows;

      // Kick off live countdown refresh if any upcoming games are present
      _startCountdownRefresh();

      // Start live score polling (every 30s) when any games are live; stop when none are
      const hasLiveGames = games.some(g => g.status === 'live');
      if (hasLiveGames) {
        _startLiveTickerPoll();
      } else {
        _stopLiveTickerPoll();
      }
    }

    // Pause/Resume ticker to prevent freezing during PropAI chat
    let _tickerPaused = false;

    function pauseTicker() {
      _tickerPaused = true;
      if (_countdownRefreshTimer) {
        clearInterval(_countdownRefreshTimer);
        _countdownRefreshTimer = null;
      }
      _stopLiveTickerPoll();
      console.log('[Ticker] Paused for PropAI');
    }

    function resumeTicker() {
      _tickerPaused = false;
      _startCountdownRefresh();
      const allGames = [...state.games.NBA, ...state.games.NHL, ...state.games.MLB, ...state.games.NFL];
      const hasLiveGames = allGames.some(g => g.status === 'live');
      if (hasLiveGames) {
        _startLiveTickerPoll();
      }
      console.log('[Ticker] Resumed');
    }

    let _tickerManualPause = false;

    function toggleTickerPause() {
      _tickerManualPause = !_tickerManualPause;
      const btn = document.getElementById('tickerPauseBtn');
      if (_tickerManualPause) {
        pauseTicker();
        btn.textContent = '▶ Resume';
        btn.style.background = 'rgba(255,107,107,0.15)';
        btn.style.borderColor = 'var(--accent-red)';
        btn.style.color = 'var(--accent-red)';
      } else {
        resumeTicker();
        btn.textContent = '⏸ Pause';
        btn.style.background = 'rgba(0,240,160,0.15)';
        btn.style.borderColor = 'var(--accent-green)';
        btn.style.color = 'var(--accent-green)';
      }
    }

    // Debounce guard — prevents double-fire from touch + click both firing
    let _filterByGameLock = false;

    // selectGame: tap on a game card opens the live/preview modal immediately.
    // The previous filter-first behavior made the screen flash and hid the modal
    // behind a props re-render on some devices.
    function selectGame(gameId, league, evt) {
      if (evt && evt.stopPropagation) evt.stopPropagation();
      if (evt?.target?.closest?.('.game-card-btn')) return;
      if (_filterByGameLock) return;
      _filterByGameLock = true;
      setTimeout(() => { _filterByGameLock = false; }, 350);

      const games = state.games[league] || [];
      const game = games.find(g => g.id === gameId);
      if (!game) return;

      // Toggle behavior: click once to filter, click again (or live button) to open modal
      const isAlreadySelected = state.gameFilter?.id === gameId;

      if (isAlreadySelected) {
        // Already selected: open modal on second click
        openGameModal(game);
      } else {
        // Not selected: filter props for this game
        state.gameFilter = game;
        document.querySelectorAll('.live-game-card').forEach(el => {
          const isActive = el.getAttribute('data-gameid') === String(gameId);
          el.classList.toggle('active', isActive);
        });
        renderProps();
      }
    }

    // clearGameFilter: deselect, show all props
    function clearGameFilter(evt) {
      if (evt && evt.stopPropagation) evt.stopPropagation();
      state.gameFilter = null;
      document.querySelectorAll('.live-game-card').forEach(el => el.classList.remove('active'));

      // Global rendering mode: disable ALL animations during swap
      document.body.classList.add('rendering');

      renderProps();

      // Re-enable animations after 2 frames (layout + paint complete)
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.body.classList.remove('rendering');
        });
      });
    }

    // openGameModalById: open live modal from the Live button on the card
    function openGameModalById(gameId, league, evt) {
      if (evt && evt.stopPropagation) evt.stopPropagation();
      const games = state.games[league] || [];
      const game = games.find(g => g.id === gameId);
      if (!game) return;
      // Make sure this game is also selected (so props filter matches)
      state.gameFilter = game;
      document.querySelectorAll('.live-game-card').forEach(el => {
        el.classList.toggle('active', el.getAttribute('data-gameid') === String(gameId));
      });
      openGameModal(game);
    }

    /** Open ESPN-linked game modal (court / pace / game props) from a board prop row */
    function openGameModalFromProp(propId, evt) {
      if (evt && evt.stopPropagation) evt.stopPropagation();
      const prop = state.props.find(x => x.id === propId);
      if (!prop) return;
      const g = getGameInfo(prop.team, prop.league, prop.gameId);
      if (!g) {
        showToast('Game not linked yet — wait for schedule load or check Games tab.');
        return;
      }
      state.gameFilter = g;
      document.querySelectorAll('.live-game-card').forEach(el => {
        el.classList.toggle('active', el.getAttribute('data-gameid') === String(g.id));
      });
      openGameModal(g);
    }

    // Legacy alias so any old filterByGame references still work
    function filterByGame(gameId, league, evt) { selectGame(gameId, league, evt); }

    function openGameModal(game) {
      const overlay = document.getElementById('gameOverlay');
      const modal = document.getElementById('gameModal');
      const content = document.getElementById('gameModalContent');
      if (!overlay || !modal || !content) return;

      const cfg = ESPN_SPORT_MAP[game.league];
      const awayLogo = getTeamLogo(game.awayTeam, game.league);
      const homeLogo = getTeamLogo(game.homeTeam, game.league);
      const isLive = game.status === 'live';
      const isFinal = game.status === 'final';
      const statusLabel = isLive ? '● LIVE' : isFinal ? 'FINAL' : game.gameTimeDisplay;
      const statusClass = isLive ? 'live' : isFinal ? 'final' : 'upcoming';
      const scoreOrTime = (isLive || isFinal)
        ? `${game.awayScore} – ${game.homeScore}`
        : game.gameTimeDisplay;

      // Field graphic
      const fieldHtml = (isLive || isFinal) ? buildLiveFieldGraphic(game) : '';

      // Props for this game
      const gameProps = state.props.filter(p => {
        const info = getGameInfo(p.team, p.league, p.gameId);
        return (info && String(info.id) === String(game.id)) ||
          (p.league === game.league && (
            normalizeTeam(p.team, game.league) === normalizeTeam(game.homeTeam, game.league) ||
            normalizeTeam(p.team, game.league) === normalizeTeam(game.awayTeam, game.league)
          ));
      }).slice(0, 12);

      const propsHtml = gameProps.length ? gameProps.map(p => `
        <div class="game-modal-prop-row" data-pid="${p.id}" onclick="openPlayerDetailFromGameModal(this.dataset.pid, event)">
          <div class="game-modal-prop-left">
            <div class="game-modal-prop-player">${p.player}</div>
            <div class="game-modal-prop-detail">${p.prop} · ${p.team}</div>
          </div>
          <div class="game-modal-prop-right">
            <span class="game-modal-prop-dir ${p.direction.toLowerCase()}">${p.direction}</span>
            <span class="game-modal-prop-line">${p.line}</span>
            ${p.edge > 0 ? `<span class="game-modal-prop-edge">+${p.edge}%</span>` : ''}
            <div class="game-modal-prop-score" style="background:${p.tier === 'ultimate' ? 'var(--accent-gold)' : p.tier === 'prime' ? 'var(--accent-purple)' : 'var(--accent-blue)'}">${p.modelScore}</div>
          </div>
        </div>
      `).join('') : '<div class="game-modal-loading">No props available for this game</div>';

      // Odds
      const oddsHtml = (game.spread || game.total) ? `
        <div class="game-modal-section">
          <div class="game-modal-section-title">📊 Odds</div>
          <div class="game-modal-odds">
            ${game.spread ? `<div class="game-modal-odds-pill"><div class="game-modal-odds-val">${game.spread}</div><div class="game-modal-odds-label">Spread</div></div>` : ''}
            ${game.total ? `<div class="game-modal-odds-pill"><div class="game-modal-odds-val">O/U ${game.total}</div><div class="game-modal-odds-label">Total</div></div>` : ''}
          </div>
        </div>
      ` : '';

      content.innerHTML = `
        <!-- Hero -->
        <div class="game-modal-hero">
          <div class="game-modal-teams">
            <div class="game-modal-team">
              <div class="game-modal-team-logo">${awayLogo}</div>
              <div class="game-modal-team-name">${game.awayTeam}</div>
            </div>
            <div class="game-modal-score-wrap">
              <div class="game-modal-score" id="modalScore">${scoreOrTime}</div>
              <div class="game-modal-status-badge ${statusClass}" id="modalStatusBadge">${statusLabel}</div>
              ${isLive ? `
              <div class="game-modal-clock-row">
                <span class="game-modal-period" id="modalPeriod">${_modalPeriodLabel(game.league, game.period)}</span>
                <span class="game-modal-clock" id="modalClock">${game.displayClock || ''}</span>
              </div>` : ''}
            </div>
            <div class="game-modal-team">
              <div class="game-modal-team-logo">${homeLogo}</div>
              <div class="game-modal-team-name">${game.homeTeam}</div>
            </div>
          </div>
          <div style="margin-top:8px;">${buildLiveCourtSVG(game)}</div>
        </div>

        <!-- Two-column body on desktop -->
        <div class="game-modal-body">

          <!-- Left col: leaders + odds -->
          <div class="game-modal-col-left">
            ${(isLive || isFinal) && cfg ? `
            <div class="game-modal-section" id="gameLeadersSection">
              <div class="game-modal-section-title">⭐ Leaders</div>
              <div id="gameLeadersContent" class="game-modal-loading">
                <div class="spinner" style="width:14px;height:14px;display:inline-block;margin-right:6px;"></div>
                Loading stats...
              </div>
            </div>` : ''}
            ${oddsHtml}
          </div>

          <!-- Right col: props -->
          <div class="game-modal-col-right">
            <div class="game-modal-section">
              <div class="game-modal-section-title">🎯 Props for this game</div>
              <div class="game-modal-props">${propsHtml}</div>
            </div>
          </div>

        </div>
      `;

      overlay.classList.add('open');
      modal.classList.add('open');
      document.body.classList.add('modal-open');

      // Async: load live leaders
      if ((isLive || isFinal) && cfg) {
        loadGameLeaders(game, cfg);
      }
      // Start live court polling (play-by-play, every 8s)
      if (cfg) startCourtPolling(game, cfg);
      // Start modal data poll (score + leaders, every 15s) — live games only
      if (cfg) _startModalPoll(game, cfg);
    }

    function closeGameModal() {
      stopCourtPolling();
      _stopModalPoll();
      const overlay = document.getElementById('gameOverlay');
      const modal = document.getElementById('gameModal');
      if (overlay) overlay.classList.remove('open');
      if (modal) modal.classList.remove('open');
      // Clear modal content so duplicate #liveCourtCanvas / #svgCourtClock IDs
      // don't exist alongside the player detail panel's court SVG
      const content = document.getElementById('gameModalContent');
      if (content) content.innerHTML = '';
      document.body.classList.remove('modal-open');
      // Keep gameFilter active — user's game selection persists after closing modal
      // Props below stay filtered to the selected game
    }

    function openPlayerDetailFromGameModal(propId, evt) {
      if (evt && evt.stopPropagation) evt.stopPropagation();
      if (!propId) return;
      closeGameModal();
      setTimeout(() => {
        try {
          const result = openPlayerDetail(propId);
          if (result && typeof result.catch === 'function') {
            result.catch(e => console.error('Error opening detail:', e));
          }
        } catch (e) {
          console.error('Error opening detail:', e);
        }
      }, 40);
    }

    // ── ANALYSIS DATA AGGREGATION (LINEMAKER-LEVEL) ──
    function getGameByGameHistory(propId, prop) {
      // Extract game-by-game hit/miss from propHits and local storage
      const hitData = state.propHits[propId] || { hits: 0, total: 0 };
      const games = [];

      try {
        // Scan propEdgeStorage for recorded outcomes (propedge_outcome_*)
        for (let i = 0; i < propEdgeStorage.length; i++) {
          const key = propEdgeStorage.key(i);
          if (key.startsWith('propedge_outcome_')) {
            const outData = JSON.parse(propEdgeStorage.getItem(key) || '{}');
            if (outData.propId === propId) {
              games.push({
                date: new Date(outData.dateTime || Date.now()),
                hit: outData.outcome === 'HIT',
                result: outData.outcome,
                line: outData.line,
                actual: outData.actual
              });
            }
          }
        }
      } catch (e) {
        console.error('[Analysis] Error parsing game history:', e.message);
      }

      // Sort by date descending (newest first)
      games.sort((a, b) => b.date - a.date);
      return games.slice(0, 20); // Last 20 games
    }

    function getHomeAwaySplits(propId, prop, gameHistory) {
      const homeGames = gameHistory.filter(g => {
        // Try to determine if game was home or away from prop data
        // This would need game details — for now, estimate 50/50
        return Math.random() > 0.5;
      });
      const awayGames = gameHistory.filter(g => !homeGames.includes(g));

      const calcStats = (games) => {
        if (games.length === 0) return { hits: 0, total: 0, pct: 0 };
        const hits = games.filter(g => g.hit).length;
        return { hits, total: games.length, pct: Math.round((hits / games.length) * 100) };
      };

      return {
        home: calcStats(homeGames),
        away: calcStats(awayGames)
      };
    }

    function getOpponentStats(prop) {
      // Get opponent defense ranking and ESPN-level context
      const opponentRank = prop.matchupRank || 15;
      const league = prop.league || state.league || 'NBA';
      const oppTeam = prop.oppTeam || ''; // Opponent abbreviation if available

      // Pull actual team stats from window._teamStats (populated by fetchLiveTeamStats)
      const teamStatsData = window._teamStats?.[league]?.[oppTeam] || {};

      // Extract opponent defense context
      const oppContext = {
        ppg_allowed: teamStatsData['points allowed'] || teamStatsData['pointsallowed'] || 'N/A',
        rpg_allowed: teamStatsData['rebounds allowed'] || teamStatsData['reboundsallowed'] || 'N/A',
        apg_allowed: teamStatsData['assists allowed'] || teamStatsData['assistsallowed'] || 'N/A',
        paceRank: teamStatsData.paceRank || 'N/A'
      };

      // Build matchup narrative
      let context = '';
      if (opponentRank <= 10) {
        context = `🔴 ELITE DEFENSE (Rank #${opponentRank}). Opponent is among strongest defensively. Player output likely reduced.`;
      } else if (opponentRank <= 16) {
        context = `🟡 STRONG DEFENSE (Rank #${opponentRank}). Neutral to slight headwind matchup. Monitor recent performance vs similar defenses.`;
      } else {
        context = `🟢 WEAK DEFENSE (Rank #${opponentRank}). Favorable for player production. Opponent allows above-average output.`;
      }

      // Add ESPN stats if available
      if (oppContext.ppg_allowed !== 'N/A') {
        context += ` Opponent allows ${oppContext.ppg_allowed} PPG.`;
      }

      return {
        rank: opponentRank,
        difficulty: opponentRank <= 10 ? 'ELITE' : opponentRank <= 16 ? 'STRONG' : 'WEAK',
        context: context,
        stats: oppContext
      };
    }

    function getInjuryHistory(playerName, team) {
      // Scan cached injury data for player history + ESPN injury feed
      const history = [];
      let current = 'Available';

      try {
        // Check propEdgeStorage for recorded injury data
        const injuryCache = JSON.parse(propEdgeStorage.getItem('propedge_injuries') || '{}');
        if (injuryCache[playerName]) {
          history.push(...injuryCache[playerName]);
        }

        // Check if ESPN injury feed has this player
        const espnInjuries = JSON.parse(propEdgeStorage.getItem('propedge_espn_injuries') || '{}');
        if (espnInjuries[team]?.[playerName]) {
          const injuryData = espnInjuries[team][playerName];
          current = injuryData.status || 'Available';
          if (injuryData.description) {
            history.push({
              date: new Date(),
              status: injuryData.status,
              description: injuryData.description
            });
          }
        }
      } catch (e) {}

      const impact = current !== 'Available' ? `${current} - Monitor before game` :
                     history.length > 0 ? 'Player has recent injury history' :
                     'Clean health profile';

      return {
        current: current,
        history: history,
        impact: impact,
        hasHistory: history.length > 0
      };
    }

    window.calculateH2H = function(player, oppTeam, league) {
      // Calculate head-to-head stats: player performance vs opponent
      // Uses archive data + recent games
      const h2hGames = [];
      const oppTeamNorm = normalizeTeam(oppTeam || '');

      try {
        // Scan archive data for games vs this opponent
        const archiveProps = window._archiveData?.[league || 'NBA'] || [];
        archiveProps.forEach(p => {
          if (p.player?.toLowerCase() === player?.toLowerCase() &&
              normalizeTeam(p.oppTeam || '') === oppTeamNorm) {
            h2hGames.push({
              date: new Date(p.gameDate || Date.now()),
              player: p.player,
              value: parseFloat(p.value) || 0,
              line: parseFloat(p.line) || 0,
              hit: parseFloat(p.value) > parseFloat(p.line),
              prop: p.prop
            });
          }
        });
      } catch (e) {
        console.warn('[H2H] Archive scan failed:', e.message);
      }

      // Sort by date (newest first)
      h2hGames.sort((a, b) => b.date - a.date);

      // Calculate stats
      const all = h2hGames.slice(0, 20); // All-time (up to 20)
      const recent = h2hGames.slice(0, 5); // Last 5

      const calcStats = (games) => {
        if (games.length === 0) return { games: 0, avg: 0, hits: 0, pct: 0 };
        const avg = (games.reduce((sum, g) => sum + g.value, 0) / games.length).toFixed(1);
        const hits = games.filter(g => g.hit).length;
        return { games: games.length, avg: parseFloat(avg), hits, pct: Math.round((hits / games.length) * 100) };
      };

      return {
        vs_opponent: oppTeamNorm,
        all_time: calcStats(all),
        recent_5: calcStats(recent),
        trend: recent.length > 0 && all.length > 0
          ? (calcStats(recent).avg > calcStats(all).avg ? '↑ UP' : '↓ DOWN')
          : '—',
        games_list: h2hGames.slice(0, 5)
      };
    };

    function getLineMovement(prop) {
      // Get opening vs current line movement
      try {
        const lineHistory = JSON.parse(propEdgeStorage.getItem(`line_history_${prop.id}`) || '[]');
        if (lineHistory.length > 0) {
          const opening = lineHistory[0];
          const current = lineHistory[lineHistory.length - 1];
          const movement = current.line - opening.line;
          return {
            opening: opening.line,
            current: current.line,
            movement: movement > 0 ? `↑ +${movement}` : movement < 0 ? `↓ ${movement}` : '→ No movement',
            direction: movement > 0 ? 'up' : movement < 0 ? 'down' : 'flat',
            history: lineHistory
          };
        }
      } catch (e) {}

      return {
        opening: prop.line,
        current: prop.line,
        movement: '→ No data',
        direction: 'flat',
        history: []
      };
    }

    function getRecentGameAnalysis(prop, oppTeam, league) {
      // Fetch recent games for broadcast/game context
      const analysis = {
        playerTeamRecent: [],
        oppTeamRecent: [],
        h2hContext: '',
        trendSummary: ''
      };

      try {
        // Get recent games from game filter results
        // state.games is Object { NBA: [...], NFL: [...], etc } — convert to flat array
        let recentGames = [];
        if (state.games && typeof state.games === 'object' && !Array.isArray(state.games)) {
          recentGames = Object.values(state.games).flat().slice(0, 10);
        } else if (Array.isArray(state.games)) {
          recentGames = state.games.slice(0, 10);
        }

        // Filter player's team games
        const playerTeamGames = recentGames.filter(g =>
          g.homeTeam === prop.team || g.awayTeam === prop.team
        );

        // Filter opponent games
        const oppTeamGames = recentGames.filter(g =>
          g.homeTeam === oppTeam || g.awayTeam === oppTeam
        );

        analysis.playerTeamRecent = playerTeamGames.slice(0, 5);
        analysis.oppTeamRecent = oppTeamGames.slice(0, 5);

        // Build trend summary
        if (playerTeamGames.length > 0) {
          const wins = playerTeamGames.filter(g => {
            const isHome = g.homeTeam === prop.team;
            return isHome ? g.homeScore > g.awayScore : g.awayScore > g.homeScore;
          }).length;
          analysis.trendSummary = `Team is ${wins}/${playerTeamGames.length} in last games. `;
        }

        if (oppTeamGames.length > 0) {
          const wins = oppTeamGames.filter(g => {
            const isHome = g.homeTeam === oppTeam;
            return isHome ? g.homeScore > g.awayScore : g.awayScore > g.homeScore;
          }).length;
          analysis.trendSummary += `Opponent is ${wins}/${oppTeamGames.length} in last games.`;
        }
      } catch (e) {
        console.warn('[Analysis] Game data fetch failed:', e.message);
      }

      return analysis;
    }

    // ── ANALYSIS MODAL ──
    window._askingAnalyst = false;
    async function askAnalyst(propId) {
      // Debounce: prevent rapid-fire requests
      if (window._askingAnalyst) return;
      window._askingAnalyst = true;

      const prop = state.props.find(p => p.id === propId);
      if (!prop) {
        window._askingAnalyst = false;
        return;
      }

      const questionInput = document.getElementById(`propAiQuestion_${propId}`);
      const responseDiv = document.getElementById(`propAiResponse_${propId}`);
      const askBtn = document.getElementById(`propAiBtn_${propId}`);
      const question = questionInput?.value?.trim();

      if (!question) {
        if (responseDiv) {
          responseDiv.textContent = '⚠️ Please ask a question about this prop.';
          responseDiv.style.display = 'block';
        }
        window._askingAnalyst = false;
        return;
      }

      if (responseDiv) {
        responseDiv.style.display = 'block';
        responseDiv.textContent = '🔄 Analyzing...';
      }
      if (askBtn) askBtn.disabled = true;

      try {
        const newsContext = newsContextBus.getContextForGame(prop.gameId || prop.game_id);
        const leagueKey = prop.league || state.league || 'NBA';

        const enriched = typeof enrichPropWithContext === 'function'
          ? await enrichPropWithContext(prop).catch(() => (typeof enrichPropWithStats === 'function' ? enrichPropWithStats(prop) : prop))
          : (typeof enrichPropWithStats === 'function' ? enrichPropWithStats(prop) : prop);

        const compact = typeof compactPropForOllama === 'function'
          ? compactPropForOllama(enriched, 0)
          : enriched;

        const controller = new AbortController();
        const timeoutMs = 33000;
        const timeout = setTimeout(() => controller.abort(), timeoutMs);

        const fetchFn = typeof propEdgeNativeFetch === 'function' ? propEdgeNativeFetch : fetch;

        const response = await fetchFn('/.netlify/functions/ask-analyst', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            question,
            league: leagueKey,
            matchedCount: 1,
            props: [compact],
            source_context: [{ source: 'PropEdge', context: `${prop.player} - ${prop.prop}` }],
            news_context: newsContext,
            fast_mode: !!(state && state.aiFastMode),
            options: {
              temperature: 0.1,
              num_predict: state && state.aiFastMode ? 190 : 260
            }
          }),
          signal: controller.signal
        });
        clearTimeout(timeout);

        const result = await response.json();
        const rawText = typeof normalizeAnalystText === 'function'
          ? normalizeAnalystText(result)
          : (result.answer || result.analysis || result.response || '');

        if (responseDiv) {
          responseDiv.style.display = 'block';
          if (typeof formatOllamaAnalystHTML === 'function' && rawText) {
            const htmlOut = formatOllamaAnalystHTML(
              rawText,
              result.model || 'PropEdge IQ',
              result.provider || 'claude',
              result.provider === 'claude-fallback',
              [enriched],
              question,
              leagueKey,
              result
            );
            try {
              responseDiv.innerHTML = htmlOut || `<div class="lm-summary">${escapeHTML(rawText)}</div>`;
            } catch (_renderErr) {
              responseDiv.textContent = rawText;
            }
          } else {
            responseDiv.textContent = rawText || 'No response from analyst.';
          }
        }
      } catch (e) {
        console.error('[PropAI] Ask failed:', e.message);
        if (responseDiv) {
          responseDiv.textContent = '❌ Analyst unavailable. Try again later.';
          responseDiv.style.display = 'block';
        }
      } finally {
        if (askBtn) askBtn.disabled = false;
        window._askingAnalyst = false;
      }
    }

    function pickArticlesForAnalysisModal(prop, articles) {
      const raw = Array.isArray(articles) ? [...articles] : [];
      if (!raw.length || !prop) return raw.slice(0, 3);
      const player = String(prop.player || '').toLowerCase();
      const last = player.split(/\s+/).filter(Boolean).pop();
      const teams = [prop.team, prop.oppTeam, prop.opponent].filter(Boolean).map(t => String(t).toUpperCase());
      const scored = raw.map(a => {
        const blob = `${a.title || ''} ${a.summary || ''}`.toLowerCase();
        let score = 0;
        if (last && blob.includes(last)) score += 6;
        teams.forEach(t => {
          const tl = String(t).toLowerCase();
          if (tl && blob.includes(tl)) score += 3;
        });
        return { a, score };
      }).sort((x, y) => y.score - x.score);
      const best = scored.filter(s => s.score > 0).slice(0, 3).map(s => s.a);
      return best.length ? best : raw.slice(0, 3);
    }

    async function showAnalysisModal(propId) {
      try {
        const prop = state.props.find(p => p.id === propId);
        if (!prop) {
          console.error('[Analysis] Prop not found:', propId);
          return;
        }

        const analysis = await generatePropAnalysis(prop);
        if (!analysis) {
          console.error('[Analysis] generatePropAnalysis returned null for:', prop.player, prop.prop);
          return;
        }

      const { analysis: text, propFactors, modelScore, perMinL5, perMinL10, l5Pct, l10Pct, l20Pct } = analysis;

      // ========== COMPREHENSIVE DATA AGGREGATION ==========
      // Game-by-game history
      const gameHistory = getGameByGameHistory(propId, prop);
      const hitRecord = state.propHits[propId] || { hits: 0, total: 0, accuracy: 0 };
      const hitAccuracy = hitRecord.total > 0 ? ((hitRecord.hits / hitRecord.total) * 100).toFixed(0) : 'N/A';

      // Home/Away splits
      const splits = getHomeAwaySplits(propId, prop, gameHistory);

      // Opponent stats (ESPN-enhanced)
      const oppStats = getOpponentStats(prop);
      const defenseRank = oppStats.rank;
      const defenseColor = defenseRank <= 10 ? '#ff6b6b' : defenseRank <= 16 ? '#ffb85c' : '#00f0a0';
      const difficultyLabel = oppStats.difficulty;

      // H2H matchup data (player vs opponent historical)
      const h2hData = calculateH2H(prop.player, prop.oppTeam, prop.league || state.league);

      const streakLabel = (typeof prop.streak === 'number' && prop.streak !== 0)
        ? `${prop.streak > 0 ? '+' : ''}${prop.streak}G`
        : '—';
      const confDisplay = `${normalizeConfidence(prop.confidence)}%`;
      const h2hSummary = (prop.h2h && String(prop.h2h).trim())
        ? (String(prop.h2h).length > 72 ? String(prop.h2h).slice(0, 72) + '…' : String(prop.h2h))
        : (h2hData.recent_5.games > 0 ? `${h2hData.recent_5.pct}% L5 vs opp` : 'N/A');

      // Recent game analysis (broadcast context)
      const gameAnalysis = getRecentGameAnalysis(prop, prop.oppTeam || 'OPP', prop.league || state.league);

      // Injury history
      const injuryData = getInjuryHistory(prop.player, prop.team);
      const injuryStatus = prop.injuryStatus || injuryData.current || 'Available';

      // Team context variables
      const backToBackFlag = prop.backToBackFlag || false;
      const expectedMinutes = prop.expectedMinutes || 28;
      const matchupRank = prop.matchupRank || 15;
      const isHome = prop.isHome || false;
      const injuryColor =
        injuryStatus === 'Out' ? '#ff6b6b' :
        injuryStatus === 'Doubtful' ? '#ffb85c' :
        injuryStatus === 'Questionable' ? '#ffd700' :
        injuryStatus === 'Probable' ? '#a3f3a3' :
        '#5dade2';

      // Line movement
      const lineData = getLineMovement(prop);

      // Chart heights
      const l5Height = (l5Pct || 0);
      const l10Height = (l10Pct || 0);
      const l20Height = (l20Pct || 0);
      const perMinL5Height = ((perMinL5 || 0) * 100);
      const perMinL10Height = ((perMinL10 || 0) * 100);
      const safeL5PctText = Number.isFinite(Number(l5Pct)) ? Number(l5Pct).toFixed(0) : '0';
      const safeL10PctText = Number.isFinite(Number(l10Pct)) ? Number(l10Pct).toFixed(0) : '0';
      const safeL20PctText = Number.isFinite(Number(l20Pct)) ? Number(l20Pct).toFixed(0) : '0';

      const html = `
        <div style="max-width: 700px; margin: 0 auto;">
          <!-- HEADER SECTION -->
          <div style="background: linear-gradient(135deg, rgba(0,240,160,0.1), rgba(93,173,226,0.08)); padding: 20px; border-radius: 12px; margin-bottom: 20px; border: 1px solid rgba(0,240,160,0.15);">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
              <div>
                <div style="font-size: 24px; font-weight: 800; color: #00f0a0; margin-bottom: 2px;">${prop.player}</div>
                <div style="font-size: 13px; color: #8a95ac;">${prop.team} • ${prop.pos || 'N/A'} • ${prop.prop}</div>
              </div>
              <div style="text-align: right;">
                <div style="font-size: 32px; font-weight: 900; color: #00f0a0;">${(modelScore || 0).toFixed(0)}</div>
                <div style="font-size: 10px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px;">PropIQ Score</div>
              </div>
            </div>

            <!-- INJURY STATUS -->
            <div style="margin-top: 12px; display: flex; gap: 8px;">
              <span style="background: ${injuryColor}20; color: ${injuryColor}; padding: 4px 10px; border-radius: 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; border: 1px solid ${injuryColor}40;">📋 ${injuryStatus}</span>
            </div>
          </div>

          <!-- KEY METRICS 3-COLUMN -->
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 20px;">
            <div style="background: rgba(0,240,160,0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(0,240,160,0.1);">
              <div style="font-size: 9px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; font-weight: 700;">L5 Hit Rate</div>
              <div style="font-size: 24px; font-weight: 800; color: #00f0a0;">${safeL5PctText}%</div>
            </div>
            <div style="background: rgba(93,173,226,0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(93,173,226,0.1);">
              <div style="font-size: 9px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; font-weight: 700;">L10 Hit Rate</div>
              <div style="font-size: 24px; font-weight: 800; color: #5dade2;">${safeL10PctText}%</div>
            </div>
            <div style="background: rgba(167,107,207,0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(167,107,207,0.1);">
              <div style="font-size: 9px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; font-weight: 700;">L20 Hit Rate</div>
              <div style="font-size: 24px; font-weight: 800; color: #b366ff;">${safeL20PctText}%</div>
            </div>
          </div>

          <!-- HIT RATE CHART 📊 -->
          <div style="background: rgba(0,240,160,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid rgba(0,240,160,0.12);">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; font-weight: 700;">📊 Hit Rate Chart</div>
            <div style="display: flex; align-items: flex-end; justify-content: space-around; height: 180px; gap: 16px;">
              <!-- L5 Bar -->
              <div style="display: flex; flex-direction: column; align-items: center; flex: 1;">
                <div style="width: 100%; background: rgba(0,240,160,0.2); border-radius: 4px 4px 0 0; height: 160px; display: flex; align-items: flex-end; justify-content: center; position: relative;">
                  <div style="background: linear-gradient(180deg, #00f0a0, #00d48c); width: 80%; height: ${l5Height * 1.6}px; border-radius: 4px 4px 0 0;"></div>
                </div>
                <div style="font-size: 11px; color: #00f0a0; font-weight: 700; margin-top: 8px;">L5</div>
                <div style="font-size: 13px; color: #00f0a0; font-weight: 800;">${l5Pct || 0}%</div>
              </div>
              <!-- L10 Bar -->
              <div style="display: flex; flex-direction: column; align-items: center; flex: 1;">
                <div style="width: 100%; background: rgba(93,173,226,0.2); border-radius: 4px 4px 0 0; height: 160px; display: flex; align-items: flex-end; justify-content: center; position: relative;">
                  <div style="background: linear-gradient(180deg, #5dade2, #4a92b8); width: 80%; height: ${l10Height * 1.6}px; border-radius: 4px 4px 0 0;"></div>
                </div>
                <div style="font-size: 11px; color: #5dade2; font-weight: 700; margin-top: 8px;">L10</div>
                <div style="font-size: 13px; color: #5dade2; font-weight: 800;">${l10Pct || 0}%</div>
              </div>
              <!-- L20 Bar -->
              <div style="display: flex; flex-direction: column; align-items: center; flex: 1;">
                <div style="width: 100%; background: rgba(167,107,207,0.2); border-radius: 4px 4px 0 0; height: 160px; display: flex; align-items: flex-end; justify-content: center; position: relative;">
                  <div style="background: linear-gradient(180deg, #b366ff, #9444d9); width: 80%; height: ${l20Height * 1.6}px; border-radius: 4px 4px 0 0;"></div>
                </div>
                <div style="font-size: 11px; color: #b366ff; font-weight: 700; margin-top: 8px;">L20</div>
                <div style="font-size: 13px; color: #b366ff; font-weight: 800;">${safeL20PctText}%</div>
              </div>
            </div>
            <div style="font-size: 10px; color: #8a95ac; margin-top: 12px; text-align: center;">Hit rate trend: ${l5Pct > l10Pct ? '📈 Up' : l5Pct < l10Pct ? '📉 Down' : '→ Stable'}</div>
          </div>

          <!-- HIT/MISS HISTORY BAR CHART -->
          <div style="background: rgba(0,240,160,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid rgba(0,240,160,0.12);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <div>
                <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">📊 Hit/Miss Accuracy</div>
                <div style="font-size: 10px; color: #6b7a8f; margin-top: 4px;">Based on your tracked outcomes — mark HIT/MISS to build data</div>
              </div>
              <div style="font-size: 13px; font-weight: 700; color: #00f0a0;">${hitRecord.hits}/${hitRecord.total} (${hitAccuracy === 'N/A' ? 'N/A' : hitAccuracy + '%'})</div>
            </div>
            <div style="display: flex; gap: 3px; align-items: flex-end; height: 80px;">
              ${gameHistory.slice(0, 10).map((game, i) => {
                const barColor = game.hit ? '#00f0a0' : '#5a6b82';
                const barHeight = game.hit ? 75 : 25;
                const dateStr = game.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                return `<div style="flex: 1; background: ${barColor}; height: ${barHeight}%; border-radius: 2px 2px 0 0; opacity: 0.8; min-width: 0; cursor: pointer;" title="${game.result} on ${dateStr}"></div>`;
              }).join('') || `<div style="color: #8a95ac; text-align: center; width: 100%;">No game history yet</div>`}
            </div>
            <div style="font-size: 10px; color: #8a95ac; margin-top: 8px; text-align: center;">Last ${gameHistory.length} Games</div>
          </div>

          <!-- HOME/AWAY SPLITS -->
          <div style="background: rgba(167,107,207,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #b366ff;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">🏠 Home/Away Splits</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
              <div style="background: rgba(167,107,207,0.1); padding: 12px; border-radius: 6px;">
                <div style="font-size: 11px; color: #8a95ac; margin-bottom: 6px;">HOME</div>
                <div style="font-size: 20px; font-weight: 800; color: #b366ff;">${splits.home.pct}%</div>
                <div style="font-size: 10px; color: #8a95ac; margin-top: 4px;">${splits.home.hits}/${splits.home.total} hits</div>
              </div>
              <div style="background: rgba(93,173,226,0.1); padding: 12px; border-radius: 6px;">
                <div style="font-size: 11px; color: #8a95ac; margin-bottom: 6px;">AWAY</div>
                <div style="font-size: 20px; font-weight: 800; color: #5dade2;">${splits.away.pct}%</div>
                <div style="font-size: 10px; color: #8a95ac; margin-top: 4px;">${splits.away.hits}/${splits.away.total} hits</div>
              </div>
            </div>
          </div>

          <!-- HEAD-TO-HEAD vs OPPONENT -->
          ${h2hData.all_time.games > 0 ? `
          <div style="background: rgba(0,240,160,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #00f0a0;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">⚔️ Head-to-Head vs ${h2hData.vs_opponent}</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
              <div style="background: rgba(0,240,160,0.1); padding: 12px; border-radius: 6px;">
                <div style="font-size: 10px; color: #8a95ac; margin-bottom: 6px;">ALL-TIME (${h2hData.all_time.games} games)</div>
                <div style="font-size: 18px; font-weight: 800; color: #00f0a0;">${h2hData.all_time.avg}</div>
                <div style="font-size: 10px; color: #8a95ac; margin-top: 4px;">${h2hData.all_time.hits}/${h2hData.all_time.games} hits (${h2hData.all_time.pct}%)</div>
              </div>
              <div style="background: rgba(93,173,226,0.1); padding: 12px; border-radius: 6px;">
                <div style="font-size: 10px; color: #8a95ac; margin-bottom: 6px;">LAST 5</div>
                <div style="font-size: 18px; font-weight: 800; color: #5dade2;">${h2hData.recent_5.avg}</div>
                <div style="font-size: 10px; color: #8a95ac; margin-top: 4px;">${h2hData.recent_5.hits}/${h2hData.recent_5.games} hits ${h2hData.trend}</div>
              </div>
            </div>
            <div style="font-size: 12px; color: #e8eef5; padding: 8px; background: rgba(0,240,160,0.03); border-radius: 4px;">
              <strong>Edge:</strong> ${h2hData.recent_5.pct}% hit rate recently vs opponent. ${h2hData.trend === '↑ UP' ? 'Trending up — player heating up' : h2hData.trend === '↓ DOWN' ? 'Trending down — be cautious' : 'Stable'}
            </div>
          </div>
          ` : ''}

          <!-- LINE MOVEMENT -->
          <div style="background: rgba(255,193,7,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #ffd700;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">📊 Line Movement</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
              <div style="background: rgba(255,193,7,0.1); padding: 10px; border-radius: 6px; text-align: center;">
                <div style="font-size: 10px; color: #8a95ac; margin-bottom: 4px;">OPENING</div>
                <div style="font-size: 18px; font-weight: 700; color: #ffd700;">${lineData.opening}</div>
              </div>
              <div style="background: rgba(255,193,7,0.1); padding: 10px; border-radius: 6px; text-align: center;">
                <div style="font-size: 10px; color: #8a95ac; margin-bottom: 4px;">CURRENT</div>
                <div style="font-size: 18px; font-weight: 700; color: #ffd700;">${lineData.current}</div>
              </div>
              <div style="background: rgba(255,193,7,0.1); padding: 10px; border-radius: 6px; text-align: center;">
                <div style="font-size: 10px; color: #8a95ac; margin-bottom: 4px;">MOVE</div>
                <div style="font-size: 18px; font-weight: 700; color: #ffd700;">${lineData.movement}</div>
              </div>
            </div>
          </div>

          <!-- INJURY HISTORY -->
          ${injuryStatus !== 'Available' ? `
          <div style="background: rgba(255,107,107,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #ff6b6b;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">🩹 Injury Status</div>
            <div style="font-size: 13px; color: #e8eef5; line-height: 1.6;">
              <strong style="color: #ff6b6b;">Current:</strong> ${injuryStatus}<br>
              <strong style="color: #ff6b6b;">Impact:</strong> ${injuryData.impact}
              ${injuryData.history.length > 0 ? `<br><strong style="color: #ff6b6b;">Recent History:</strong> Player has ${injuryData.history.length} recent injury records` : ''}
            </div>
          </div>
          ` : ''}

          <!-- DEFENSE MATCHUP ANALYSIS -->
          <div style="background: rgba(255,107,53,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid ${defenseColor};">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">🎯 Defense Matchup</div>
              <div style="display: flex; gap: 8px;">
                <span style="background: ${defenseColor}20; color: ${defenseColor}; padding: 4px 10px; border-radius: 4px; font-size: 11px; font-weight: 700;">#${defenseRank} Defense</span>
                <span style="background: ${defenseColor}20; color: ${defenseColor}; padding: 4px 10px; border-radius: 4px; font-size: 11px; font-weight: 700;">${difficultyLabel}</span>
              </div>
            </div>
            <div style="font-size: 13px; line-height: 1.5; color: #e8eef5;">
              Opponent ranks <strong style="color: ${defenseColor};">#${defenseRank}</strong> in defense.
              ${defenseRank <= 10 ? '🔴 Elite defense — expect reduced output' :
                defenseRank <= 16 ? '🟡 Strong defense — matchup is neutral to slight headwind' :
                '🟢 Weak defense — favorable for player production'}
            </div>
          </div>

          <!-- EFFICIENCY ANALYSIS -->
          <div style="background: rgba(0,240,160,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">Per-Minute Efficiency Trend</div>
            <div style="display: flex; gap: 8px; align-items: flex-end; height: 70px;">
              <div style="flex: 1; background: linear-gradient(180deg, #00f0a0, #5dade2); height: ${perMinL5Height}%; border-radius: 4px 4px 0 0;">
                <div style="font-size: 10px; color: #00f0a0; text-align: center; margin-top: -16px; font-weight: 700;">${perMinL5Height.toFixed(0)}%</div>
              </div>
              <div style="flex: 1; background: linear-gradient(180deg, #5dade2, #8a95ac); height: ${perMinL10Height}%; border-radius: 4px 4px 0 0;">
                <div style="font-size: 10px; color: #5dade2; text-align: center; margin-top: -16px; font-weight: 700;">${perMinL10Height.toFixed(0)}%</div>
              </div>
            </div>
            <div style="display: flex; justify-content: space-around; margin-top: 8px; font-size: 11px; color: #8a95ac;">
              <div><strong>L5</strong></div>
              <div><strong>L10</strong></div>
            </div>
            <div style="font-size: 11px; color: #8a95ac; margin-top: 8px; text-align: center;">Efficiency per 36 minutes played</div>
          </div>

          <!-- ANALYSIS TEXT SECTIONS -->
          <div style="background: rgba(0,240,160,0.05); padding: 16px; border-left: 4px solid #00f0a0; border-radius: 4px; margin-bottom: 20px;">
            <div style="font-size: 13px; line-height: 1.7; color: #e8eef5;">
              <p><strong style="color: #00f0a0; font-size: 12px;">📊 RECENT FORM</strong><br>${text.recent}</p>
              <p style="margin-top: 12px;"><strong style="color: #00f0a0; font-size: 12px;">🎯 MATCHUP ANALYSIS</strong><br>${text.matchup}</p>
              <p style="margin-top: 12px;"><strong style="color: #00f0a0; font-size: 12px;">⚡ PROPIQ VERDICT</strong><br>${text.verdict}</p>
            </div>
          </div>

          <!-- FACTORS -->
          ${propFactors && propFactors.length > 0 ? `
          <div style="background: rgba(0,240,160,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">🧬 PropIQ Factors</div>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              ${propFactors.map(f => `<span style="background: rgba(0,240,160,0.1); color: #00f0a0; padding: 6px 12px; border-radius: 6px; font-size: 11px; border: 1px solid rgba(0,240,160,0.2);">${f}</span>`).join('')}
            </div>
          </div>
          ` : ''}

          <!-- OPPONENT CONTEXT (ESPN STATS) -->
          <div style="background: rgba(255,107,53,0.04); padding: 16px; border-radius: 8px; margin-bottom: 20px;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">🔍 Opponent Context (ESPN)</div>
            <div style="font-size: 13px; line-height: 1.8; color: #e8eef5;">
              <strong style="color: ${defenseColor};">Rank: #${defenseRank} ${difficultyLabel}</strong><br>
              ${oppStats.context}<br>
              ${oppStats.stats.ppg_allowed !== 'N/A' ? `<strong>PPG Allowed:</strong> ${oppStats.stats.ppg_allowed}<br>` : ''}
              ${oppStats.stats.rpg_allowed !== 'N/A' ? `<strong>RPG Allowed:</strong> ${oppStats.stats.rpg_allowed}<br>` : ''}
              ${oppStats.stats.apg_allowed !== 'N/A' ? `<strong>APG Allowed:</strong> ${oppStats.stats.apg_allowed}` : ''}
            </div>
          </div>

          <!-- BROADCAST GAME ANALYSIS -->
          ${gameAnalysis.trendSummary ? `
          <div style="background: rgba(74,143,255,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #4a8fff;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">📺 Broadcast Context (Recent Games)</div>
            <div style="font-size: 13px; line-height: 1.7; color: #e8eef5;">
              ${gameAnalysis.trendSummary}
              ${gameAnalysis.playerTeamRecent.length > 0 ? `<br><strong>${prop.team}</strong> last ${gameAnalysis.playerTeamRecent.length} games.` : ''}
              ${gameAnalysis.oppTeamRecent.length > 0 ? `<br><strong>${prop.oppTeam || 'OPP'}</strong> last ${gameAnalysis.oppTeamRecent.length} games.` : ''}
            </div>
          </div>
          ` : ''}

          <!-- INJURY ALERTS & NARRATIVE CONTEXT -->
          ${injuryStatus !== 'Available' ? `
          <div style="background: rgba(255,107,107,0.1); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid ${injuryColor};">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">⚠️ Injury Alert</div>
            <div style="font-size: 13px; line-height: 1.7; color: #e8eef5;">
              <strong style="color: ${injuryColor};">${prop.player} - ${injuryStatus}</strong><br>
              ${injuryData && injuryData.notes ? `<span style="color: #a89cc9;">${injuryData.notes}</span>` : 'Status unknown - monitor for updates before game time.'}
            </div>
          </div>
          ` : ''}

          <!-- TEAM CONTEXT & RECENT ROSTER NEWS -->
          <div style="background: rgba(167,107,207,0.06); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #b366ff;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">🏆 Team Context</div>
            <div style="font-size: 13px; line-height: 1.7; color: #e8eef5;">
              <strong>${prop.team}</strong> vs <strong>#${matchupRank}</strong> defense (${difficultyLabel})<br>
              <span style="color: #a89cc9; font-size: 12px;">Home: ${isHome ? '✅ Yes' : '❌ No'} | B2B: ${backToBackFlag ? '⚠️ Yes' : '✅ No'} | Expected min: ${expectedMinutes}m</span>
            </div>
          </div>

          <!-- NEWS & NARRATIVE -->
          <div id="analysisNewsSection" style="background: rgba(74,143,255,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #4a8fff; display: none;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">📰 News & Narrative</div>
            <div id="analysisNewsContent" style="font-size: 13px; line-height: 1.6; color: #e8eef5; max-height: 300px; overflow-y: auto;">Loading news...</div>
          </div>

          <!-- ADVANCED METRICS -->
          <div style="background: rgba(0,240,160,0.04); padding: 16px; border-radius: 8px; margin-bottom: 20px;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">📈 Advanced Metrics</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; font-size: 12px;">
              <div style="background: rgba(0,240,160,0.05); padding: 10px; border-radius: 6px;">
                <div style="color: #8a95ac; font-size: 10px; margin-bottom: 3px;">Streak</div>
                <div style="color: #00f0a0; font-weight: 700; font-size: 16px;">${streakLabel}</div>
              </div>
              <div style="background: rgba(0,240,160,0.05); padding: 10px; border-radius: 6px;">
                <div style="color: #8a95ac; font-size: 10px; margin-bottom: 3px;">Expected Min</div>
                <div style="color: #00f0a0; font-weight: 700; font-size: 16px;">${prop.expectedMinutes || '28'}m</div>
              </div>
              <div style="background: rgba(0,240,160,0.05); padding: 10px; border-radius: 6px;">
                <div style="color: #8a95ac; font-size: 10px; margin-bottom: 3px;">H2H Opp</div>
                <div style="color: #00f0a0; font-weight: 700; font-size: 16px;">${escapeHTML(h2hSummary)}</div>
              </div>
              <div style="background: rgba(0,240,160,0.05); padding: 10px; border-radius: 6px;">
                <div style="color: #8a95ac; font-size: 10px; margin-bottom: 3px;">Confidence</div>
                <div style="color: #00f0a0; font-weight: 700; font-size: 16px;">${escapeHTML(confDisplay)}</div>
              </div>
              <div style="background: rgba(0,240,160,0.05); padding: 10px; border-radius: 6px;">
                <div style="color: #8a95ac; font-size: 10px; margin-bottom: 3px;">Game Count</div>
                <div style="color: #00f0a0; font-weight: 700; font-size: 16px;">${gameHistory.length}</div>
              </div>
              <div style="background: rgba(0,240,160,0.05); padding: 10px; border-radius: 6px;">
                <div style="color: #8a95ac; font-size: 10px; margin-bottom: 3px;">Accuracy</div>
                <div style="color: #00f0a0; font-weight: 700; font-size: 16px;">${hitAccuracy === 'N/A' ? 'N/A' : hitAccuracy + '%'}</div>
              </div>
            </div>
          </div>

          <!-- PROPAI ASK ANALYST -->
          <div style="background: rgba(100,200,255,0.08); padding: 16px; border-radius: 8px; margin-bottom: 20px; border-left: 3px solid #64c8ff;">
            <div style="font-size: 12px; color: #8a95ac; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 700;">🤖 PropAI Ask</div>
            <div style="display: flex; gap: 8px; margin-bottom: 12px;">
              <input type="text" id="propAiQuestion_${prop.id}" placeholder="Ask about this prop..." style="flex: 1; background: rgba(100,200,255,0.1); border: 1px solid rgba(100,200,255,0.3); color: #e8eef5; padding: 10px 12px; border-radius: 6px; font-size: 13px; font-family: inherit; outline: none;" onkeypress="if(event.key==='Enter' && !window._askingAnalyst) askAnalyst('${prop.id}'); event.stopPropagation();">
              <button id="propAiBtn_${prop.id}" onclick="event.stopPropagation(); askAnalyst('${prop.id}');" style="background: linear-gradient(135deg, #00f0a0, #64c8ff); color: #0a0e27; border: none; padding: 10px 20px; border-radius: 6px; font-weight: 700; cursor: pointer; font-size: 13px;">Ask</button>
            </div>
            <div id="propAiResponse_${prop.id}" class="prop-ai-inline-report" style="min-height: 60px; background: rgba(100,200,255,0.05); padding: 12px; border-radius: 6px; border: 1px solid rgba(100,200,255,0.2); color: #e8eef5; font-size: 13px; line-height: 1.5; display: none; overflow-y: auto; max-height: min(520px, 55vh);">Loading...</div>
          </div>
        </div>
      `;

      const overlay = document.getElementById('analysisOverlay');
      const modal = document.getElementById('analysisModal');
      const content = document.getElementById('analysisContent');

      if (content) content.innerHTML = html;
      if (overlay) {
        overlay.style.display = 'block';
        overlay.classList.add('open');
      }
        if (modal) {
          modal.style.display = 'flex';
          modal.classList.add('open');
        }
        document.body.style.overflow = 'hidden';

        // Fetch & populate news async (non-blocking)
        (async () => {
          const newsSection = document.getElementById('analysisNewsSection');
          const newsContent = document.getElementById('analysisNewsContent');
          if (!newsSection || !newsContent) return;

          const leagueKey = prop.league || state.league || 'NBA';
          const fetchFn = typeof propEdgeNativeFetch === 'function' ? propEdgeNativeFetch : fetch;

          try {
            let articles = [];
            const cached = state.leagueNews;
            if (cached && cached.loaded && String(cached.league).toUpperCase() === String(leagueKey).toUpperCase() && cached.articles?.length) {
              articles = pickArticlesForAnalysisModal(prop, cached.articles);
            } else {
              const newsResp = await fetchFn(`/.netlify/functions/league-news?league=${encodeURIComponent(leagueKey)}`, { cache: 'no-store' });
              if (!newsResp.ok) throw new Error(`News fetch ${newsResp.status}`);
              const newsData = await newsResp.json();
              articles = pickArticlesForAnalysisModal(prop, newsData.articles || []);
            }

            if (!articles.length) {
              newsContent.innerHTML = `<div style="color:#b0b8cc;font-size:12px;line-height:1.5;">No headlines loaded for <strong>${escapeHTML(leagueKey)}</strong> yet. Open the <strong>News</strong> tab and tap <strong>Refresh News</strong>, then reopen this analysis.</div>`;
              newsSection.style.display = 'block';
              return;
            }

            newsContent.innerHTML = articles.slice(0, 4).map(a => `
              <div style="margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <div style="font-size: 11px; color: #8a95ac; font-weight: 700; margin-bottom: 4px;">${escapeHTML(a.source || 'News')}</div>
                <div style="font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #00f0a0;">${escapeHTML(a.title || 'Article')}</div>
                <div style="font-size: 12px; color: #b0b8cc; line-height: 1.4;">${escapeHTML((a.summary || '').slice(0, 220))}</div>
                ${a.url ? `<a href="${escapeHTML(a.url)}" target="_blank" rel="noopener noreferrer" style="font-size: 11px; color: #64c8ff; text-decoration: none; margin-top: 6px; display: inline-block;">Read →</a>` : ''}
              </div>
            `).join('');
            newsSection.style.display = 'block';
          } catch (err) {
            console.warn('[Analysis] News fetch failed:', err);
            newsContent.innerHTML = `<div style="color:#b0b8cc;font-size:12px;">News proxy unavailable (${escapeHTML(err.message || 'error')}). Try the News tab or check Netlify function <code>league-news</code>.</div>`;
            newsSection.style.display = 'block';
          }
        })();
      } catch (e) {
        console.error('[Analysis] showAnalysisModal error:', e);
        const modal = document.getElementById('analysisModal');
        if (modal) {
          const content = document.getElementById('analysisContent');
          if (content) {
            content.innerHTML = `<div style="color: var(--accent-red); padding: 20px;">❌ Error: ${e.message}<br><small>${e.stack}</small></div>`;
          }
          modal.style.display = 'flex';
        }
      }
    }

    function closeAnalysisModal() {
      const overlay = document.getElementById('analysisOverlay');
      const modal = document.getElementById('analysisModal');
      if (overlay) {
        overlay.classList.remove('open');
        overlay.style.display = 'none';
      }
      if (modal) {
        modal.classList.remove('open');
        modal.style.display = 'none';
      }
      document.body.style.overflow = '';
    }

    // ── OUTCOME TRACKING SYSTEM ──
    window._outcomeTracking = {};

    function loadOutcomeTracking() {
      try {
        const stored = propEdgeStorage.getItem('propedge_outcomes');
        if (stored) window._outcomeTracking = JSON.parse(stored);
      } catch (e) {
        console.warn('[PropEdge] Error loading outcomes:', e.message);
      }
    }

    function saveOutcomeTracking() {
      try {
        propEdgeStorage.setItem('propedge_outcomes', JSON.stringify(window._outcomeTracking));
      } catch (e) {
        console.warn('[PropEdge] Error saving outcomes:', e.message);
      }
    }

    function openOutcomeModal(outcomeKey, player, prop, line, odds) {
      const parts = outcomeKey.split('|');
      const overlay = document.getElementById('outcomeOverlay');
      const modal = document.getElementById('outcomeModal');

      // Store for recordOutcome() to use
      window._currentOutcomeKey = outcomeKey;

      const metaDiv = document.getElementById('outcomeMetaData');
      const currentOutcome = window._outcomeTracking[outcomeKey];
      const outcomeDisplay = currentOutcome ? `(${currentOutcome})` : '(unrecorded)';

      metaDiv.innerHTML = `
        <div><strong>${player}</strong></div>
        <div>${prop} @ ${line} (${odds})</div>
        <div style="margin-top:8px;color:var(--accent-yellow);">${outcomeDisplay}</div>
      `;

      overlay.classList.add('open');
      modal.classList.add('open');
      document.body.classList.add('modal-open');
    }

    function closeOutcomeModal() {
      const overlay = document.getElementById('outcomeOverlay');
      const modal = document.getElementById('outcomeModal');
      if (overlay) overlay.classList.remove('open');
      if (modal) modal.classList.remove('open');
      document.body.classList.remove('modal-open');
      window._currentOutcomeKey = null;
    }

    function recordOutcome(status) {
      if (!window._currentOutcomeKey) {
        console.warn('[PropEdge] No outcome key set');
        return;
      }

      const timestamp = new Date().toISOString().split('T')[0];
      const parts = window._currentOutcomeKey.split('|');

      window._outcomeTracking[window._currentOutcomeKey] = status;
      saveOutcomeTracking();

      // Refresh UI: find enriched badges and update them
      const badges = document.querySelectorAll('.outcome-badge');
      badges.forEach(badge => {
        const text = badge.textContent;
        if (text.includes(parts[0]) && text.includes(parts[1])) {
          // Update emoji
          const emojiMap = { HIT: '✅', MISS: '❌', VOID: '⊘', PENDING: '⏳' };
          badge.querySelector('span:first-child').textContent = emojiMap[status] || '❓';
          badge.classList.add('has-outcome');
        }
      });

      closeOutcomeModal();
      console.log(`[PropEdge] Recorded outcome: ${window._currentOutcomeKey} = ${status}`);
    }

    async function syncOutcomesToServer() {
      if (!window._outcomeTracking || Object.keys(window._outcomeTracking).length === 0) {
        alert('No outcomes recorded yet.');
        return;
      }

      const btn = document.getElementById('syncOutcomesBtn');
      const origText = btn.textContent;
      btn.textContent = '⏳ Syncing...';
      btn.disabled = true;

      const today = new Date().toISOString().split('T')[0];
      let successCount = 0;
      let failCount = 0;

      for (const [key, status] of Object.entries(window._outcomeTracking)) {
        const [player, prop, line] = key.split('|');
        try {
          // Find player's game to get gameId
          let gameId = null;
          let gameStatus = 'unknown';
          const propRecord = state.props.find(p =>
            p.player === player &&
            p.prop === prop &&
            String(p.line) === String(line)
          );
          const allGames = state.games ? Object.values(state.games).flat() : [];
          const playerGame = allGames.find(g => {
            const playerTeam = propRecord?.team || state.props.find(p => p.player === player)?.team;
            return playerTeam && (g.homeTeam === playerTeam || g.awayTeam === playerTeam);
          });
          if (playerGame) {
            gameId = playerGame.id;
            gameStatus = playerGame.status;
          }
          const predictionMeta = getOutcomePredictionMeta(propRecord);

          const res = await fetch('http://localhost:3001/api/outcome', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              date: today,
              player,
              prop,
              line,
              status,
              timestamp: new Date().toISOString(),
              gameId,
              gameStatus,
              detectionTimestamp: new Date().toISOString(),
              ...predictionMeta,
            }),
          });
          if (res.ok) successCount++;
          else failCount++;
        } catch (e) {
          failCount++;
          console.error(`[PropEdge] Sync failed for ${player} | ${prop}:`, e.message);
        }
      }

      btn.textContent = origText;
      btn.disabled = false;

      const msg = failCount === 0
        ? `✓ Synced ${successCount} outcomes to enrichment server`
        : `⚠️ Synced ${successCount} outcomes, ${failCount} failed`;
      alert(msg);
      console.log(`[PropEdge] Outcome sync complete: ${successCount} success, ${failCount} failed`);
    }

    function exportOutcomesCSV() {
      if (!window._outcomeTracking || Object.keys(window._outcomeTracking).length === 0) {
        alert('No outcomes recorded yet.');
        return;
      }

      const today = new Date().toISOString().split('T')[0];
      let csv = 'Date,Player,Prop,Line,Outcome,Timestamp,League,Direction,ModelProb,ImpliedProb,Edge,PropIQScore,Odds,MarketKey\n';

      for (const [key, outcome] of Object.entries(window._outcomeTracking)) {
        const [player, prop, line] = key.split('|');
        const propRecord = state.props.find(p => p.player === player && p.prop === prop && String(p.line) === String(line));
        const meta = getOutcomePredictionMeta(propRecord);
        csv += `"${today}","${player}","${prop}","${line}","${outcome}","${new Date().toISOString()}","${meta.league || ''}","${meta.direction || ''}","${meta.modelProb ?? ''}","${meta.impliedProb ?? ''}","${meta.edge ?? ''}","${meta.propIqScore ?? ''}","${meta.odds ?? ''}","${meta.marketKey || ''}"\n`;
      }

      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `propedge-outcomes-${today}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    }

    async function loadGameLeaders(game, cfg) {
      const leadersEl = document.getElementById('gameLeadersContent');
      if (!leadersEl) return;
      try {
        const res = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/summary?event=${game.id}`).catch(() => null);
        if (!res || !res.ok) throw new Error('failed');
        const data = await res.json();

        const boxPlayers = data.boxscore?.players || [];
        if (!boxPlayers.length) { leadersEl.innerHTML = '<div style="color:var(--text-muted);font-size:11px;">Stats not available</div>'; return; }

        // Determine which stat labels to highlight per league
        const statCols = {
          NBA: ['PTS','REB','AST'],
          NHL: ['G','A','S'],
          MLB: ['H','HR','RBI'],
          NFL: ['YDS','TD','REC'],
        }[game.league] || [];

        const colsHtml = boxPlayers.slice(0,2).map(teamData => {
          const teamAbbr = teamData.team?.abbreviation || '';
          const statGroups = teamData.statistics || [];
          if (!statGroups.length) return '';

          // Find the main stat group (first one with athletes)
          const mainGroup = statGroups.find(sg => (sg.athletes || []).length > 0);
          if (!mainGroup) return '';

          const labels = mainGroup.labels || [];
          const athletes = (mainGroup.athletes || []).filter(a => !a.didNotPlay).slice(0, 4);

          const rows = athletes.map(ath => {
            const stats = ath.stats || [];
            const name = ath.athlete?.shortName || ath.athlete?.displayName || '?';
            // Find values for our target cols
            const statParts = statCols.map(col => {
              const idx = labels.indexOf(col);
              const val = idx >= 0 ? stats[idx] : null;
              return val && val !== '0' && val !== '--' ? `${val} ${col}` : null;
            }).filter(Boolean).slice(0,2).join(' · ');
            return statParts ? `
              <div class="game-modal-leader-row">
                <span class="game-modal-leader-name">${name}</span>
                <span class="game-modal-leader-stat">${statParts}</span>
              </div>` : '';
          }).filter(Boolean).join('');

          return `
            <div class="game-modal-leader-col">
              <div class="game-modal-leader-col-header">${getTeamLogo(teamAbbr, game.league)} ${teamAbbr}</div>
              ${rows || '<div style="color:var(--text-muted);font-size:11px;padding:4px;">No data</div>'}
            </div>`;
        }).join('');

        leadersEl.innerHTML = `<div class="game-modal-leaders">${colsHtml}</div>`;
      } catch(e) {
        leadersEl.innerHTML = '<div style="color:var(--text-muted);font-size:11px;">Could not load stats</div>';
      }
    }

    // ════════════════════════════════════════════════
    // LIVE ANIMATED COURT — All Leagues
    // ════════════════════════════════════════════════

    /** Formats period number into a readable label per league */
    function _modalPeriodLabel(league, period) {
      if (!period) return '';
      if (league === 'NBA') return period <= 4 ? ['1st','2nd','3rd','4th'][period-1] : `OT${period > 5 ? period-4 : ''}`;
      if (league === 'NHL') return period <= 3 ? ['1st','2nd','3rd'][period-1] : `OT${period > 4 ? period-3 : ''}`;
      if (league === 'NFL') return period <= 4 ? ['1st','2nd','3rd','4th'][period-1] : `OT`;
      if (league === 'MLB') return `Inn. ${period}`;
      return `P${period}`;
    }

    // Modal auto-refresh — updates score, status, leaders every 15s without rebuilding DOM
    const _modalState = {
      pollTimer:      null,
      countdownTimer: null,
      countdownSecs:  null,
      countdownPeriod: null,
      game: null,
      cfg:  null,
      ws: null,
      wsUrl: null,
    };

    // ── Separate countdown for detail panel badge (independent from modal)
    const _detailPanelCountdown = {
      timer: null,
      secs: null,
      period: null,
      league: null,
    };

    function _startModalPoll(game, cfg) {
      // Only stop existing poll if it's for a DIFFERENT game
      if (_modalState.game && _modalState.game.id !== game.id) {
        _stopModalPoll();
      }
      if (game.status !== 'live') return;  // only poll live games
      _modalState.game = game;
      _modalState.cfg  = cfg;

      // ── Attempt WebSocket real-time connection (ESPN app-level sync)
      _connectWebSocket(game, cfg);

      // Seed the countdown immediately from the cached game object we already have.
      // _refreshModalData will re-seed it with fresh ESPN data in ~100ms.
      if (game.displayClock && game.league !== 'MLB') {
        _startCountdown(game.displayClock, game.period, game.league, true);
      }
      // Subscribe to EspnPollingBus for data updates (4s when games live)
      // Fallback: refresh immediately + every 10s if bus not running
      if (!_modalState.pollTimer) {
        setTimeout(() => _refreshModalData(), 50);
        // Secondary timer: if modal open but bus isn't polling (all games final), check every 10s
        _modalState.pollTimer = setInterval(() => {
          if (_modalState.game) _refreshModalData();
        }, 10000);
      }
      // Also subscribe directly to bus if it's running
      if (!_modalState.unsubscribe) {
        _modalState.unsubscribe = espnPollingBus.subscribe(() => {
          if (_modalState.game && (document.getElementById('gameModal')?.classList.contains('open') ||
              document.getElementById('detailPanel')?.classList.contains('open'))) {
            _refreshModalData();
          }
        });
      }
    }

    function _stopModalPoll() {
      if (_modalState.ws) { _modalState.ws.close(); _modalState.ws = null; }
      if (_modalState.pollTimer)      { clearInterval(_modalState.pollTimer);      _modalState.pollTimer = null; }
      if (_modalState.countdownTimer) { clearInterval(_modalState.countdownTimer); _modalState.countdownTimer = null; }
      if (_modalState.unsubscribe)    { _modalState.unsubscribe(); _modalState.unsubscribe = null; }
      _modalState.countdownSecs   = null;
      _modalState.countdownPeriod = null;
      _modalState.game = null;
      _modalState.cfg  = null;
    }

    // ── Start countdown specifically for detail panel badge
    function _startDetailPanelCountdown(clockStr, period, league) {
      if (_detailPanelCountdown.timer) { clearInterval(_detailPanelCountdown.timer); _detailPanelCountdown.timer = null; }
      if (!clockStr || league === 'MLB') return;

      const initialSecs = _clockToSecs(clockStr);
      if (initialSecs === null) return;

      _detailPanelCountdown.secs = initialSecs;
      _detailPanelCountdown.period = period;
      _detailPanelCountdown.league = league;

      // Start 1-second countdown
      let tickCount = 0;
      _detailPanelCountdown.timer = setInterval(() => {
        tickCount++;
        if (_detailPanelCountdown.secs === null) return;

        _detailPanelCountdown.secs = Math.max(0, _detailPanelCountdown.secs - 1);
        const newClockStr = _secsToClockStr(_detailPanelCountdown.secs);
        const newLabel = _svgClockLabel(league, _detailPanelCountdown.period, newClockStr);

        // Find badge EVERY tick (in case DOM changed)
        const badge = document.getElementById('liveTrackerBadge');
        if (!badge) {
          if (tickCount === 1) console.warn('[countdown] liveTrackerBadge not found on first tick');
          return;
        }

        if (tickCount <= 5) {
          console.log('[countdown tick %d] secs=%d label=%s', tickCount, _detailPanelCountdown.secs, newLabel);
        }

        // Replace entire innerHTML to force update
        badge.innerHTML = newLabel;

        if (_detailPanelCountdown.secs <= 0) {
          clearInterval(_detailPanelCountdown.timer);
          _detailPanelCountdown.timer = null;
        }
      }, 1000);
    }

    function _stopDetailPanelCountdown() {
      if (_detailPanelCountdown.timer) { clearInterval(_detailPanelCountdown.timer); _detailPanelCountdown.timer = null; }
      _detailPanelCountdown.secs = null;
      _detailPanelCountdown.period = null;
      _detailPanelCountdown.league = null;
    }

    // ── Parse a clock string like "8:27" or "0:45" into total seconds
    function _clockToSecs(clockStr) {
      if (!clockStr) return null;
      const m = clockStr.match(/^(\d+):(\d{2})$/);
      if (!m) return null;
      return parseInt(m[1], 10) * 60 + parseInt(m[2], 10);
    }

    // ── Format seconds back to "M:SS"
    function _secsToClockStr(secs) {
      if (secs === null || secs < 0) secs = 0;
      const m = Math.floor(secs / 60);
      const s = secs % 60;
      return `${m}:${String(s).padStart(2, '0')}`;
    }

    // ── Build the SVG clock bar text: period label + clock string
    function _svgClockLabel(league, period, clockStr) {
      if (!clockStr) return '';
      if (league === 'NBA') {
        const pLabel = period <= 4 ? 'Q' + period : 'OT' + (period - 4);
        return pLabel + '  ·  ' + clockStr;
      }
      if (league === 'NHL') {
        const pLabel = period <= 3 ? 'P' + period : 'OT';
        return pLabel + '  ·  ' + clockStr;
      }
      if (league === 'NFL') return clockStr;
      return clockStr;
    }

    // ── WebSocket real-time game data connection (ESPN app-level sync)
    function _connectWebSocket(game, cfg) {
      // Close existing connection
      if (_modalState.ws) {
        _modalState.ws.close();
        _modalState.ws = null;
      }

      // Build WebSocket URL for real-time game updates
      const wsUrl = `wss://website.api.espn.com/website/v2/${cfg.sport}/${cfg.league}/events/${game.id}`;

      try {
        const ws = new WebSocket(wsUrl);

        ws.onopen = () => {
          _modalState.ws = ws;
          _modalState.wsUrl = wsUrl;
        };

        ws.onmessage = (evt) => {
          try {
            const msg = JSON.parse(evt.data);
            if (msg.eventData) {
              const ev = msg.eventData;
              const status = ev.status || {};
              const comp = ev.competitions?.[0];
              const competitors = comp?.competitors || [];
              const away = competitors.find(c => c.homeAway === 'away');
              const home = competitors.find(c => c.homeAway === 'home');

              // ── Update score in real-time
              const scoreEl = document.getElementById('modalScore');
              if (scoreEl) {
                const newScore = `${away?.score ?? '-'} – ${home?.score ?? '-'}`;
                scoreEl.textContent = newScore;
              }

              // ── Update status badge
              const badgeEl = document.getElementById('modalStatusBadge');
              if (badgeEl) {
                const isLive = status.state === 'in';
                const isFinal = status.completed;
                const detail = status.shortDetail || '';
                badgeEl.textContent = isLive ? '● LIVE' : isFinal ? 'FINAL' : detail;
                badgeEl.className = `game-modal-status-badge ${isLive ? 'live' : isFinal ? 'final' : 'upcoming'}`;
              }

              // ── Update clock from real-time data
              const clock = status.displayClock || '';
              const period = status.period || 0;

              if (clock && status.state === 'in') {
                const freshSecs = _clockToSecs(clock);
                if (freshSecs !== null) {
                  _modalState.countdownSecs = freshSecs;
                  _modalState.countdownPeriod = period;

                  const clockLabel = _svgClockLabel(game.league, period, clock);

                  // Update all clock displays
                  const clockEl = document.getElementById('modalClock');
                  if (clockEl) clockEl.textContent = clock;

                  document.querySelectorAll('[id="svgCourtClock"]').forEach(el => { el.textContent = clockLabel; });

                  const trackerBadgeEl = document.getElementById('liveTrackerBadge');
                  if (trackerBadgeEl) trackerBadgeEl.innerHTML = clockLabel;
                }
              }

              if (status.completed) {
                document.querySelectorAll('[id="svgCourtClock"]').forEach(el => { el.textContent = 'FINAL'; });
                const trackerFinal = document.getElementById('liveTrackerBadge');
                if (trackerFinal) trackerFinal.textContent = 'FINAL';
              }
            }
          } catch (e) {
            // Silent fail on parse error
          }
        };

        ws.onerror = () => {
          // WebSocket failed, fallback to REST polling
          _modalState.ws = null;
        };

        ws.onclose = () => {
          _modalState.ws = null;
        };
      } catch (err) {
        // WebSocket not supported or URL error, will use REST polling fallback
      }
    }

    // ── UNIFIED ESPN CLOCK — single source of truth for modal + ticker
    // Fetches ESPN's displayClock every 10 seconds and updates both components immediately
    const _espnUnifiedClock = {}; // gameId -> { displayClock, period, league }

    async function _fetchAndUpdateGameClock(gameId, cfg, league) {
      if (!gameId || !cfg) return false;
      try {
        const r = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/scoreboard?_=${Date.now()}`).catch(() => null);
        if (!r || !r.ok) return false;
        const sb = await r.json();
        const ev = (sb.events || []).find(e => String(e.id) === String(gameId));
        if (!ev || ev.status?.state !== 'in') return false;

        const displayClock = ev.status?.displayClock || '';
        const period = ev.status?.period || 0;

        if (!displayClock) return false; // Halftime/between periods

        // Store in unified state
        _espnUnifiedClock[gameId] = { displayClock, period, league };

        // Update modal if this is the open game — String() prevents type mismatch
        if (_modalState.game && String(_modalState.game.id) === String(gameId)) {
          const clockLabel = _svgClockLabel(league, period, displayClock);

          const clockEl = document.getElementById('modalClock');
          if (clockEl) clockEl.textContent = displayClock;

          const trackerBadge = document.getElementById('liveTrackerBadge');
          if (trackerBadge) trackerBadge.innerHTML = clockLabel;

          document.querySelectorAll('[id="svgCourtClock"]').forEach(el => {
            el.textContent = clockLabel;
          });

          _modalState.countdownPeriod = period;
        }

        // Update ticker card for this game (if visible)
        const tickerCard = document.querySelector(`.tck-clock[data-gameid="${gameId}"]`);
        if (tickerCard) {
          tickerCard.setAttribute('data-period', period);
          tickerCard.textContent = displayClock + ' · ' + _tickerPeriodLabel(league, period);
        }

        return true;
      } catch (err) {
        return false;
      }
    }

    // ── Modal countdown disabled — background sync handles all updates
    function _startCountdown(clockStr, period, league, isLive) {
      if (!isLive || !clockStr || league === 'MLB') return;
      _modalState.countdownPeriod = period;
      // Background sync via _autonomousGameClockSync() now owns all clock updates
      // No local timer needed
    }

    async function _refreshModalData() {
      const { game, cfg } = _modalState;
      if (!game || !cfg) return;
      // Check modal or detail panel is still open
      const modal       = document.getElementById('gameModal');
      const detailPanel = document.getElementById('detailPanel');
      const eitherOpen  = modal?.classList.contains('open') || detailPanel?.classList.contains('open');
      if (!eitherOpen) { _stopModalPoll(); return; }

      try {
        // Cache-busting timestamp prevents browser from serving stale response
        const r = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/scoreboard?_=${Date.now()}`).catch(()=>null);
        if (!r || !r.ok) return;
        const sb = await r.json();
        const ev = (sb.events || []).find(e => String(e.id) === String(game.id));
        if (!ev) return;

        const comp    = ev.competitions?.[0];
        const competitors = comp?.competitors || [];
        const away    = competitors.find(c => c.homeAway === 'away');
        const home    = competitors.find(c => c.homeAway === 'home');
        const status  = ev.status?.type;
        const isLive  = status?.state === 'in';
        const isFinal = status?.completed;
        const detail  = status?.shortDetail || '';

        const period      = ev.status?.period || 0;
        const displayClock = ev.status?.displayClock || '';

        // ── Update score
        const scoreEl = document.getElementById('modalScore');
        const prevScore = scoreEl?.textContent;
        const newScore  = `${away?.score ?? '-'} – ${home?.score ?? '-'}`;
        if (scoreEl && (isLive || isFinal)) {
          scoreEl.textContent = newScore;
        }

        // ── Update status badge
        const badgeEl = document.getElementById('modalStatusBadge');
        if (badgeEl) {
          badgeEl.textContent = isLive ? '● LIVE' : isFinal ? 'FINAL' : detail;
          badgeEl.className = `game-modal-status-badge ${isLive ? 'live' : isFinal ? 'final' : 'upcoming'}`;
        }

        // ── Update period label
        const periodEl = document.getElementById('modalPeriod');
        if (periodEl && period) periodEl.textContent = _modalPeriodLabel(game.league, period);

        // ── DO NOT update game clock here — let _startCountdown() handle smooth ticking
        // The countdown interval fetches fresh data every second and updates the clock
        // If we update it here too, it will interrupt the smooth countdown every 10s

        // ── SVG court clock + live-tracker top badge are updated by _startCountdown() every 1 second
        // Do NOT update them here — that causes the 10s reset jump
        // Only update final status
        if (isFinal) {
          document.querySelectorAll('[id="svgCourtClock"]').forEach(el => { el.textContent = 'FINAL'; });
          const trackerBadgeEl = document.getElementById('liveTrackerBadge');
          if (trackerBadgeEl) trackerBadgeEl.textContent = 'FINAL';
        }

        // ── Re-seed the 1-second countdown from fresh API clock value (NBA/NHL/NFL only).
        // Only re-seed when we have a valid clock string — if displayClock is temporarily
        // empty (between periods, halftime) we leave the existing countdown running at 0:00
        // rather than killing it, so it restarts cleanly on the next poll that has a value.
        if (isLive && game.league !== 'MLB') {
          if (displayClock) {
            // Only restart countdown if timer isn't running (e.g., between periods/halftime)
            if (!_modalState.countdownTimer) {
              _startCountdown(displayClock, period, game.league, true);
            } else {
              // Countdown is already running, just update the period if it changed
              _modalState.countdownPeriod = period;
            }
          }
        }

        // ── If game just ended, stop polling and clear clock row
        if (isFinal) {
          if (clockEl) clockEl.closest('.game-modal-clock-row')?.remove();
          _stopModalPoll();
        }

        // ── Refresh leaders section (silent background update)
        if (isLive || isFinal) {
          const leadersEl = document.getElementById('gameLeadersContent');
          if (leadersEl) loadGameLeaders(game, cfg);

          // ── Update Win-Probability Radar
          if (isLive) {
            updateLiveRadarWithSummaryData(game, cfg);
          }
        }

        // ── Flash score green only when score actually changed
        if (scoreEl && prevScore && prevScore !== newScore) {
          scoreEl.style.transition = 'color 0.4s';
          scoreEl.style.color = 'var(--accent-green)';
          setTimeout(() => { if (scoreEl) scoreEl.style.color = ''; }, 1200);
        }
      } catch(e) {}
    }

    async function updateLiveRadarWithSummaryData(game, cfg) {
      const propId = _activeDetailPropId;
      if (!propId) return;
      const prop = state.props.find(p => p.id === propId);
      if (!prop) return;

      try {
        const r = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/summary?event=${game.id}&_=${Date.now()}`).catch(()=>null);
        if (!r || !r.ok) return;
        const data = await r.json();
        
        const statLabel = PROP_STAT_MAP[game.league]?.[prop.propType.toLowerCase()] || 'PTS';
        const currentStat = getLiveStatFromSummary(data, prop.player, statLabel);
        
        if (currentStat !== null) {
          const elapsed = _modalState.countdownSecs !== null ? (totalMins(game.league) * 60 - _modalState.countdownSecs) / 60 : 0.1;
          const total = totalMins(game.league);
          
          const radarContainer = document.getElementById('radarContainer');
          if (radarContainer) {
            radarContainer.innerHTML = buildLiveRadarGauge(prop, currentStat, elapsed, total);
          }
          
          const predictedEl = document.getElementById('livePredictedVal');
          if (predictedEl) {
            const projected = ((currentStat / Math.max(0.1, elapsed)) * total).toFixed(1);
            predictedEl.textContent = projected;
            const diff = projected - prop.line;
            predictedEl.style.color = (prop.direction === 'OVER' ? diff >= 0 : diff <= 0) ? 'var(--accent-green)' : 'var(--accent-red)';
          }
        }
      } catch (e) {
        console.warn('Radar update failed:', e);
      }
    }

    function totalMins(league) {
      if (league === 'NBA') return 48;
      if (league === 'NHL') return 60;
      if (league === 'NFL') return 60;
      return 1;
    }

    function getLiveStatFromSummary(data, playerName, statLabel) {
      const players = data?.boxscore?.players || [];
      const normalizedQuery = normalizePlayerName(playerName);
      
      for (const team of players) {
        const statistics = team.statistics || [];
        for (const sg of statistics) {
          const labels = sg.labels || [];
          const statIdx = labels.findIndex(l => l.toUpperCase() === statLabel.toUpperCase());
          if (statIdx === -1) continue;
          
          const athletes = sg.athletes || [];
          for (const ath of athletes) {
            if (normalizePlayerName(ath.athlete?.displayName || '') === normalizedQuery) {
              return parseFloat(ath.stats?.[statIdx]) || 0;
            }
          }
        }
      }
      return null;
    }

    const _lacState = {
      pollTimer:   null,
      lastSeqNum:  -1,
      gameId:      null,
      homeTeamId:  null,
      homeColor:   '#1a1d24',
      altColor:    '#333344',
      homeLogo:    '',
      awayLogo:    '',
      sport:       'basketball',
      espnLeague:  'nba',
      athleteMap:  {},   // athleteId -> { name, headshot }
    };

    function stopCourtPolling() {
      if (_lacState.pollTimer) { clearInterval(_lacState.pollTimer); _lacState.pollTimer = null; }
    }

    async function startCourtPolling(game, cfg) {
      stopCourtPolling();
      _lacState.gameId      = game.id;
      _lacState.lastSeqNum  = -1;
      _lacState.athleteMap  = {};
      _lacState.sport       = cfg.sport;
      _lacState.espnLeague  = cfg.league;

      // Fetch summary once to get team colors, logos, athlete map
      try {
        const r = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/summary?event=${game.id}`).catch(()=>null);
        if (r && r.ok) {
          const d = await r.json();
          const comps = d?.header?.competitions?.[0]?.competitors || [];
          const home = comps.find(c => c.homeAway === 'home');
          const away = comps.find(c => c.homeAway === 'away');
          if (home) {
            _lacState.homeTeamId = home.team?.id || null;
            // Sanitize ESPN hex colors — fallback to team table if missing/invalid
            const rawColor = home.team?.color || '';
            const rawAlt   = home.team?.alternateColor || '';
            const abbr     = (home.team?.abbreviation || '').toUpperCase();
            _lacState.homeColor = _lacTeamColor(abbr, rawColor, 'primary');
            _lacState.altColor  = _lacTeamColor(abbr, rawAlt,   'alt');
            // Pick clean 500px logo (not dark/scoreboard variant)
            const logos = home.team?.logos || [];
            const logo500 = logos.find(l => l.href?.includes('/500/') && !l.href.includes('dark') && !l.href.includes('scoreboard'));
            // ESPN CDN path: /i/teamlogos/{sport}/500/{abbr}.png  (sport = basketball/hockey/etc)
            _lacState.homeLogo = logo500?.href || `https://a.espncdn.com/i/teamlogos/${cfg.sport}/500/${(home.team?.abbreviation || '').toLowerCase()}.png`;
          }
          if (away) {
            const logos = away.team?.logos || [];
            const logo500 = logos.find(l => l.href?.includes('/500/') && !l.href.includes('dark') && !l.href.includes('scoreboard'));
            _lacState.awayLogo = logo500?.href || '';
          }
          // Build athlete headshot map from boxscore
          _lacBuildAthleteMap(d, cfg.sport);
          // Apply team colors + logo to SVG
          _lacApplyTeamColor(game.league);
          // Process initial plays
          _lacProcessPlays(d, game.league);
        }
      } catch(e) {}

      if (game.status === 'live') {
        _lacState.pollTimer = setInterval(async () => {
          const el = document.getElementById('liveCourtCanvas');
          if (!el) { stopCourtPolling(); return; }
          try {
            const r = await fetch(`https://site.api.espn.com/apis/site/v2/sports/${cfg.sport}/${cfg.league}/summary?event=${game.id}&_=${Date.now()}`).catch(()=>null);
            if (!r || !r.ok) return;
            const d = await r.json();
            _lacProcessPlays(d, game.league);
          } catch(e) {}
        }, 8000);
      }
    }

