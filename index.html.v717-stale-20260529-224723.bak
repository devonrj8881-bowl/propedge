<!DOCTYPE html>
<!-- PropEdge v7.17 — Player detail: whole-card tap + id coercion + safe modelScore in handlers — 2026-05-16 LIVE DEPLOY -->
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="PropEdge">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" type="image/png" href="/favicon-32.png" sizes="32x32">
