<!-- === PropEdge May 2026 Fix Pack: runtime integration START === -->
<script>
(function () {
  'use strict';

  function peUpper(value) {
    return String(value || '').trim().toUpperCase();
  }

  function peTeam(value, league) {
    if (!value) return '';
    try {
      if (typeof normalizeTeam === 'function') {
        var normalized = normalizeTeam(value, league);
        if (normalized) return peUpper(normalized);
      }
    } catch (_) {}
    if (window.PropEdgeResolver) {
      var resolved = window.PropEdgeResolver.resolveTeam(String(value), league);
      if (resolved) return resolved.abbr;
    }
    return peUpper(value).replace(/[^A-Z0-9]/g, '').slice(0, 4);
  }

  function peState() {
    try {
      if (typeof state !== 'undefined' && state) return state;
    } catch (_) {}
    return window.state || {};
  }

  function peAllGames() {
    var out = [];
    var gamesState = (peState() && peState().games) || {};
    ['NBA', 'NHL', 'MLB', 'NFL'].forEach(function (league) {
      (gamesState[league] || []).forEach(function (g) {
        var home = peTeam(g.home || g.homeTeam || g.homeAbbr || g.home_team || g.home_name, league);
        var away = peTeam(g.away || g.awayTeam || g.awayAbbr || g.away_team || g.away_name, league);
        if (!home || !away) return;
        out.push({
          id: g.id || g.gameId || [league, away, home, g.date || g.startTime || g.startsAt].join(':'),
          league: league,
          home: home,
          away: away,
          status: g.status || g.statusType || g.gameStatus || '',
          startsAt: g.startsAt || g.startTime || g.date || g.gameTime || g.isoDate || Date.now(),
          raw: g
        });
      });
    });
    return out;
  }

  function peRosterFromProps() {
    var seen = new Set();
    var rows = [];
    ((peState() && peState().props) || []).forEach(function (p) {
      var league = peUpper(p.league || 'NBA');
      var team = peTeam(p.team || p.teamAbbr || p.Team, league);
      var name = p.player || p.playerName || p.name || p.Player;
      if (!team || !name) return;
      var key = league + '|' + team + '|' + name;
      if (seen.has(key)) return;
      seen.add(key);
      rows.push({ name: name, team: team, league: league, position: p.pos || p.position || p.Position || '' });
    });
    return rows;
  }

  function peOpponentMap() {
    var map = {};
    peAllGames().forEach(function (g) {
      map[g.league + '|' + g.home] = g.away;
      map[g.league + '|' + g.away] = g.home;
    });
    return map;
  }

  function peFirstNumber(obj, keys) {
    for (var i = 0; i < keys.length; i++) {
      var n = Number(obj && obj[keys[i]]);
      if (Number.isFinite(n) && n > 0) return n;
    }
    return null;
  }

  function peSyncTeamPace() {
    window.PropEdgePace = window.PropEdgePace || { teamPace: {} };
    window.PropEdgePace.teamPace = window.PropEdgePace.teamPace || {};
    var totals = { NBA: 30, NHL: 32, MLB: 30, NFL: 32 };
    var statKeys = {
      NBA: ['pace', 'possessionspergame', 'avgpossessions', 'pointspergame'],
      NHL: ['shotspergame', 'shotsforpergame', 'goalspergame', 'pointspergame'],
      MLB: ['runspergame', 'runs', 'pointspergame'],
      NFL: ['playspergame', 'plays', 'pointspergame']
    };
    Object.keys((window._teamStats || {})).forEach(function (league) {
      window.PropEdgePace.teamPace[league] = window.PropEdgePace.teamPace[league] || {};
      var leagueStats = window._teamStats[league] || {};
      Object.keys(leagueStats).forEach(function (abbr) {
        var s = leagueStats[abbr] || {};
        var paceFor = peFirstNumber(s, statKeys[league] || statKeys.NBA);
        var paceAgainst = peFirstNumber(s, [
          'paceAgainst', 'oppPace', 'opponentpace', 'oppPossessionsPerGame',
          'shotsagainstpergame', 'goalsagainstpergame', 'runsallowedpergame',
          'playsallowedpergame', 'pointsallowedpergame'
        ]);
        if (paceAgainst == null) paceAgainst = paceFor;
        window.PropEdgePace.teamPace[league][peUpper(abbr)] = {
          paceFor: paceFor,
          paceAgainst: paceAgainst,
          rankFor: Number.isFinite(Number(s.paceRank)) ? Number(s.paceRank) : null,
          rankAgainst: Number.isFinite(Number(s.defPtsRank)) ? Number(s.defPtsRank) : null,
          total: totals[league] || 30,
          source: Object.keys(s).length ? 'ESPN Live / PropEdge stats' : 'PropEdge cache'
        };
      });
    });
    return window.PropEdgePace.teamPace;
  }

  function peBuildPacePlayers() {
    var opp = peOpponentMap();
    var search = String(document.getElementById('paceSearchInput')?.value || '').toLowerCase();
    var leagueFilter = peUpper((window.paceState && window.paceState.league) || 'ALL');
    var seen = new Set();
    var players = [];
    ((peState() && peState().props) || []).forEach(function (p) {
      var league = peUpper(p.league || 'NBA');
      if (leagueFilter !== 'ALL' && league !== leagueFilter) return;
      var team = peTeam(p.team || p.teamAbbr || p.Team, league);
      var name = p.player || p.playerName || p.name || p.Player;
      if (!team || !name) return;
      if (search && !(String(name).toLowerCase().includes(search) || team.toLowerCase().includes(search))) return;
      var key = league + '|' + team + '|' + name;
      if (seen.has(key)) return;
      seen.add(key);
      players.push({ name: name, team: team, opponent: opp[league + '|' + team] || '', position: p.pos || p.position || '', league: league });
    });
    return players;
  }

  function peEscapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function peMetricShortLabel(team) {
    var lg = peUpper(team && team.league);
    if (lg === 'NBA') return 'Poss/G';
    if (lg === 'NHL') return 'Shots/G';
    if (lg === 'MLB') return 'Runs/G';
    if (lg === 'NFL') return 'Plays/G';
    return 'Pace';
  }

  function peRank(rank, total) {
    var r = Number(rank);
    var t = Number(total) || 30;
    return Number.isFinite(r) && r > 0 ? '#' + r + '/' + t : '#—/' + t;
  }

  function peNumber(value, digits) {
    var n = Number(value);
    return Number.isFinite(n) ? n.toFixed(digits == null ? 1 : digits) : '—';
  }

  function pePaceEdge(team) {
    var rankFor = Number(team && team.rankFor);
    var rankAgainst = Number(team && team.rankAgainst);
    if (!Number.isFinite(rankFor) || !Number.isFinite(rankAgainst)) return null;
    // Lower offensive rank is faster/better. Higher opponent allowed-rank means softer/faster context.
    return Math.round(((team.total || 30) + 1 - rankFor) * 0.55 + (rankAgainst - ((team.total || 30) / 2)) * 0.45);
  }

  function pePaceApiLeagues() {
    var selected = peUpper((window.paceState && window.paceState.league) || 'ALL');
    return selected === 'ALL' ? ['NBA', 'NHL', 'MLB', 'NFL'] : [selected];
  }

  async function peFetchPaceTeams() {
    window.PropEdgePace = window.PropEdgePace || {};
    window.PropEdgePace.apiCache = window.PropEdgePace.apiCache || {};
    var leagues = pePaceApiLeagues();
    var rows = [];
    await Promise.all(leagues.map(async function (league) {
      var cache = window.PropEdgePace.apiCache[league];
      if (cache && Date.now() - cache.loadedAt < 5 * 60 * 1000) {
        rows = rows.concat(cache.teams || []);
        return;
      }
      var url = '/.netlify/functions/pace-data?league=' + encodeURIComponent(league);
      var fetcher = window.propEdgeNativeFetch || window.fetch;
      var res = await fetcher(url, { cache: 'no-store' });
      if (!res.ok) throw new Error('Pace data HTTP ' + res.status + ' for ' + league);
      var data = await res.json();
      var teams = Array.isArray(data.teams) ? data.teams : (Array.isArray(data) ? data : []);
      window.PropEdgePace.apiCache[league] = { loadedAt: Date.now(), teams: teams };
      rows = rows.concat(teams);
    }));
    return rows;
  }

  function peFilterAndSortPaceTeams(teams) {
    var search = String(document.getElementById('paceSearchInput')?.value || '').toLowerCase().trim();
    var sortType = document.getElementById('paceSortSelect')?.value || 'edge';
    var filtered = (teams || []).filter(function (team) {
      if (!team) return false;
      if (!search) return true;
      return String(team.name || '').toLowerCase().includes(search) ||
        String(team.team || team.abbr || '').toLowerCase().includes(search) ||
        String(team.league || '').toLowerCase().includes(search);
    });
    filtered.sort(function (a, b) {
      if (sortType === 'player-pace') return Number(b.paceFor || b.value || 0) - Number(a.paceFor || a.value || 0);
      if (sortType === 'opponent-pace') return Number(b.paceAgainst || 0) - Number(a.paceAgainst || 0);
      return (pePaceEdge(b) || -999) - (pePaceEdge(a) || -999);
    });
    return filtered;
  }

  function peRenderPaceTeamCards(container, teams, compact) {
    if (!container) return;
    var selected = peUpper((window.paceState && window.paceState.league) || 'ALL');
    var rows = peFilterAndSortPaceTeams(teams);
    if (!rows.length) {
      container.innerHTML = '<div class="pace-empty">No ' + peEscapeHtml(selected) + ' pace data matched the current filters.</div>';
      return;
    }
    container.innerHTML = rows.map(function (team) {
      var edge = pePaceEdge(team);
      var edgeClass = edge == null ? 'is-na' : edge >= 9 ? 'is-good' : edge <= 0 ? 'is-flat' : '';
      var edgeText = edge == null ? 'Context Ready' : (edge > 0 ? '+' : '') + edge + ' tempo edge';
      var metric = peMetricShortLabel(team);
      var source = team.source || 'PropEdge pace data';
      return `
        <div class="pace-card ${edgeClass}">
          <div class="pace-card__header">
            <div class="pace-card__name">${peEscapeHtml(team.name || team.team || team.abbr || 'Team')}</div>
            <div class="pace-card__meta">${peEscapeHtml(team.league || '')} · ${peEscapeHtml(team.team || team.abbr || '')}</div>
          </div>
          <div class="pace-card__row">${peEscapeHtml(metric)} (For) — ${peEscapeHtml(peNumber(team.paceFor ?? team.value, team.league === 'MLB' ? 2 : 1))} · ${peEscapeHtml(peRank(team.rankFor, team.total))}</div>
          <div class="pace-card__row">${peEscapeHtml(metric)} (Allowed/Opp) — ${peEscapeHtml(peNumber(team.paceAgainst, team.league === 'MLB' ? 2 : 1))} · ${peEscapeHtml(peRank(team.rankAgainst, team.total))}</div>
          <div class="pace-card__edge ${edgeClass}">Matchup / Tempo Context: ${peEscapeHtml(edgeText)}</div>
          <div class="pace-card__source">Source: ${peEscapeHtml(source)}</div>
        </div>
      `;
    }).join('');
  }

  async function peRenderPaceFromApi() {
    var section = document.getElementById('paceTrendsSection');
    var trendsContainer = document.getElementById('paceTrendsContainer');
    var cardsContainer = document.getElementById('paceCardsContainer');
    if (section) section.style.display = 'block';
    var loading = '<div class="pace-empty">Loading live pace data...</div>';
    if (trendsContainer) trendsContainer.innerHTML = loading;
    if (cardsContainer) cardsContainer.innerHTML = loading;
    try {
      var teams = await peFetchPaceTeams();
      window.fileData = window.fileData || {};
      window.fileData.paceTeams = teams;
      window.latestPredictions = teams;
      peRenderPaceTeamCards(trendsContainer, teams, true);
      peRenderPaceTeamCards(cardsContainer, teams, false);
    } catch (error) {
      console.error('[PropEdge] pace API render failed:', error);
      var msg = '<div class="pace-empty">Pace data is temporarily unavailable. Try refresh after deploy completes.</div>';
      if (trendsContainer) trendsContainer.innerHTML = msg;
      if (cardsContainer) cardsContainer.innerHTML = msg;
    }
  }

  window.loadPaceTrends = async function loadPaceTrendsFixed() {
    return peRenderPaceFromApi();
  };

  window.displayPaceData = function displayPaceDataFixed() {
    return peRenderPaceFromApi();
  };

  window.filterPaceData = function filterPaceDataFixed() {
    if (window.paceState) window.paceState.searchTerm = document.getElementById('paceSearchInput')?.value || '';
    return peRenderPaceFromApi();
  };

  window.sortPaceData = function sortPaceDataFixed() {
    return peRenderPaceFromApi();
  };

  window.filterPaceByLeague = function filterPaceByLeagueFixed(league) {
    window.paceState = window.paceState || {};
    window.paceState.league = league || 'all';
    document.querySelectorAll('.pace-filter-btn').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.league === league);
    });
    window.filterPaceData();
  };

  var oldFilterPropsByQuery = window.filterPropsByQuery;
  window.filterPropsByQuery = function filterPropsByQueryFixed(question, allProps) {
    allProps = allProps || [];
    var resolver = window.PropEdgeResolver;
    var parsed = resolver && resolver.parseAnalystIntent(question || '');
    var team = parsed && parsed.team;
    if (team) {
      var game = resolver.resolveGameForTeam(team.abbr, peAllGames(), {
        preferCompleted: parsed.intent === 'recent',
        league: team.league
      });
      var teams = new Set([team.abbr]);
      if (game) teams.add(game.home === team.abbr ? game.away : game.home);
      var locked = allProps.filter(function (p) {
        var league = peUpper(p.league || team.league);
        return league === team.league && teams.has(peTeam(p.team || p.teamAbbr || p.Team, league));
      });
      if (locked.length || parsed.intent === 'upcoming' || parsed.intent === 'live') return locked;
    }
    return typeof oldFilterPropsByQuery === 'function' ? oldFilterPropsByQuery(question, allProps) : allProps;
  };

  async function peEnsureNewsIndex() {
    if (window.__PE_NEWS_IDX instanceof Map && window.__PE_NEWS_IDX.size) return window.__PE_NEWS_IDX;
    if (!window.PropEdgeNews || !window.PropEdgeNews.indexNewsByTeam) return new Map();
    try {
      window.__PE_NEWS_IDX = await window.PropEdgeNews.indexNewsByTeam(['NBA', 'NHL', 'MLB', 'NFL']);
      return window.__PE_NEWS_IDX;
    } catch (err) {
      console.warn('[PropEdge Fix] News index unavailable:', err && err.message ? err.message : err);
      return window.__PE_NEWS_IDX || new Map();
    }
  }

  var oldGetAnalystHTML = window.getAnalystHTML;
  window.getAnalystHTML = async function getAnalystHTMLFixed(question, picks, matchedCount, league) {
    var resolver = window.PropEdgeResolver;
    var parsed = resolver && resolver.parseAnalystIntent(question || '');
    if (!parsed || !parsed.team) {
      return typeof oldGetAnalystHTML === 'function' ? oldGetAnalystHTML(question, picks, matchedCount, league) : null;
    }
    if (typeof getServerlessAnalystHTML === 'function') {
      try {
        var serverless = await getServerlessAnalystHTML(question, picks || [], matchedCount || 0, (parsed.team && parsed.team.league) || league || 'ALL');
        if (serverless) return serverless;
      } catch (serverlessErr) {
        console.warn('[Ask an Analyst] Serverless team report failed, falling back to resolver:', serverlessErr && serverlessErr.message ? serverlessErr.message : serverlessErr);
      }
    }
    var newsIdx = await peEnsureNewsIndex();
    var result = await window.PropEdgeAnalyst.askAnalyst(question, {
      schedule: peAllGames(),
      roster: peRosterFromProps(),
      newsByTeam: newsIdx,
      injuriesByTeam: window.__PE_INJURIES || new Map(),
      ollamaModel: typeof PROPEDGE_OLLAMA_MODEL !== 'undefined' ? PROPEDGE_OLLAMA_MODEL : 'gemma4:e4b',
      callOllama: async function (prompt) {
        if (typeof propEdgeCallOllama !== 'function') throw new Error('Ollama unavailable');
        return propEdgeCallOllama(prompt.user, {
          source: 'PropEdge authoritative analyst context',
          system: prompt.system,
          league: parsed.team.league,
          matchedCount: matchedCount,
          canonical_team: parsed.team,
          props: (picks || []).slice(0, 6).map(function (p, idx) {
            return typeof compactPropForOllama === 'function' ? compactPropForOllama(p, idx) : p;
          })
        });
      }
    });
    if (!result.ok) {
      return typeof formatOllamaAnalystHTML === 'function'
        ? formatOllamaAnalystHTML('MATCHUP ANALYSIS\n' + result.message + '\n\nNO-BET / RISK NOTES\nNo current or upcoming game was found in the loaded PropEdge schedule, so no matchup was invented.\n\nSOURCES USED\nPropEdge resolver and loaded schedule.', 'PropEdge Resolver')
        : '<div class="linemaker-response">' + result.message + '</div>';
    }
    return typeof formatOllamaAnalystHTML === 'function'
      ? formatOllamaAnalystHTML(result.response, (typeof PROPEDGE_OLLAMA_MODEL !== 'undefined' ? PROPEDGE_OLLAMA_MODEL : 'PropAI')).replace('Local AI prop analysis', 'PropEdge IQ Analysis')
      : '<div class="linemaker-response">' + result.response + '</div>';
  };

  window.addEventListener('load', function () {
    peEnsureNewsIndex();
    peSyncTeamPace();
    loadCachedNarratives();
  });

  async function loadCachedNarratives() {
    try {
      // Try to load cached narratives from Netlify function
      const resp = await fetch('/.netlify/functions/batch-narratives', { method: 'GET' });
      if (resp.ok) {
        const data = await resp.json();
        if (data.narratives) {
          window._cachedNarratives = data.narratives;
          console.log('[Narratives] Loaded', Object.keys(data.narratives).length, 'cached narratives');
        }
      }
    } catch (e) {
      // Silently fail — analyst will use template fallback
      console.warn('[Narratives] Cache load failed:', e.message);
    }
  }
})();
</script>
