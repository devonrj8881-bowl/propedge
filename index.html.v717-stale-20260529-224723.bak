      const url = `https://sportsbook.draftkings.com/search?q=${encodeURIComponent(playerName)}`;
      const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
      if (isMobile) {
        window.location.assign(url);
      } else {
        window.open(url, '_blank');
      }
      showToast(`Searching DraftKings for ${playerName}...`);
    }

    // ============ SPRINT APRIL 4: SPORTSBOOK + ALERTS ============

    // Track bet clicks for ROI analysis
    function trackBetClick(prop) {
      const roiTracker = JSON.parse(propEdgeStorage.getItem('propEdgeROI') || '[]');
      roiTracker.push({
        playerName: prop.player,
        sport: prop.league,
        propType: 'pace-based',
        sportsbook: 'fanduel',
        clickedAt: new Date().toISOString(),
        line: prop.line,
        direction: prop.direction,
        expectedValue: prop.edge || 0
      });
      saveROI(roiTracker);
      console.log('[PropEdge ROI] Tracked click:', prop.player, prop.league);
    }

    // Track Pace Bet Click (Pace Trends cards)
    function trackPaceBet(playerName, league, sportsbook, edge) {
      const roiTracker = JSON.parse(propEdgeStorage.getItem('propEdgeROI') || '[]');
      roiTracker.push({
        player: playerName,
        league: league,
        propType: 'pace',
        sportsbook: sportsbook,
        timestamp: new Date().toISOString(),
        edge: edge || 0
      });
      saveROI(roiTracker);
      showToast(`✅ ${playerName} logged (${league} - ${edge > 0 ? '+' : ''}${edge}%)`);

      // Refresh portfolio if it's open
      if (state.view === 'portfolio') {
        renderPortfolio();
      }

      console.log('[PropEdge ROI] Tracked Pace bet:', playerName, league, sportsbook, edge);
    }

    // Track Prop Click (Players tab cards)
    function trackPropLog(btn) {
      const player = btn.dataset.player;
      const league = btn.dataset.league;
      const edge = parseFloat(btn.dataset.edge) || 0;
      const direction = btn.dataset.direction;
      const line = btn.dataset.line;
      const prop = btn.dataset.prop;

      // Check if wager amount was already provided (from promptPropAction)
      let wagerAmount = parseFloat(btn.dataset.wagerAmount);

      // If not provided, ask for wager amount
      if (isNaN(wagerAmount)) {
        const wagerInput = prompt(`Wager amount for ${player} ${direction} ${line}?`, '10');
        if (wagerInput === null) return; // User cancelled
        wagerAmount = parseFloat(wagerInput) || 10;
      } else {
        // Clear the custom wager data after use
        delete btn.dataset.wagerAmount;
      }

      // Snapshot player injury status at log time
      const pacePlayer = window.fileData?.players?.find(x => x.name.toLowerCase() === player.toLowerCase());
      const injuryStatus = pacePlayer?.status || 'Active';

      const roiTracker = JSON.parse(propEdgeStorage.getItem('propEdgeROI') || '[]');
      roiTracker.push({
        player: player,
        league: league,
        prop: prop,
        direction: direction,
        line: parseFloat(line),
        edge: edge,
        wager: wagerAmount,
        timestamp: new Date().toISOString(),
        status: 'tracked', // not yet resolved
        injuryAtLog: injuryStatus, // snapshot injury status when logged
        injuryFlagged: injuryStatus && injuryStatus.toLowerCase() !== 'active' // flag if injured at log
      });
      saveROI(roiTracker);

      const injuryNote = injuryStatus && injuryStatus.toLowerCase() !== 'active' ? ` ⚠️ ${injuryStatus}` : '';
      showToast(`📌 ${player} ${direction} ${line} tracked - $${wagerAmount.toFixed(2)} (${edge > 0 ? '+' : ''}${edge}%)${injuryNote}`);

      // Refresh portfolio if it's open
      if (state.view === 'portfolio') {
        renderPortfolio();
      }

      console.log('[PropEdge ROI] Tracked prop:', player, direction, line, prop, edge, wagerAmount, injuryStatus);
    }

    // Open DraftKings (without pre-fill — auth required)
    function openDraftKingsDirect() {
      window.open('https://www.draftkings.com/sportsbook', '_blank');
      showToast('Opening DraftKings...');
    }

    // Send OneSignal push notification
    function sendPaceAlert(playerName, trend, confidence) {
      if (typeof OneSignal === 'undefined' || !OneSignal) {
        console.warn('[PropEdge Alert] OneSignal not available');
        return;
      }

      const trendEmoji = trend === 'UP' ? '📈' : trend === 'DOWN' ? '📉' : '→';
      const confPercent = Math.round(confidence * 100);

      OneSignal.push(() => {
        OneSignal.sendSelfPushNotification({
          headings: { en: `${playerName} Pace ${trendEmoji}` },
          contents: { en: `${trend} trend detected (${confPercent}% confidence) — Check Pace Trends now` },
          url: window.location.href + '#pace',
          bigImage: null,
          ios_attachments: {},
        });
      });
      console.log('[PropEdge Alert] Sent:', playerName, trend);
    }

    // Initialize OneSignal alert triggers for pace data
    // ==========================================
    // EMAIL / ONBOARDING
    // ==========================================
    function _updateEmailPill() {
      const btn = document.getElementById('emailPillBtn');
      if (!btn) return;
      const email = propEdgeStorage.getItem('pe_email') || '';
      if (email) {
        btn.textContent = '✓';
        btn.title = email;
        btn.style.width = '28px';
        btn.style.height = '28px';
        btn.style.padding = '0';
        btn.style.borderRadius = '50%';
        btn.style.color = 'var(--accent-green)';
        btn.style.borderColor = 'rgba(0,230,118,0.35)';
        btn.style.maxWidth = '28px';
        btn.style.lineHeight = '26px';
        btn.style.textAlign = 'center';
      } else {
        btn.textContent = 'Sign In';
        btn.title = '';
        btn.style.width = '';
        btn.style.height = '';
        btn.style.padding = '3px 10px';
        btn.style.borderRadius = '20px';
        btn.style.color = 'var(--text-secondary)';
        btn.style.borderColor = 'rgba(255,255,255,0.15)';
        btn.style.maxWidth = '150px';
        btn.style.lineHeight = '';
        btn.style.textAlign = '';
      }
    }
    function checkOnboarding() {
      try {
        // Preview/iframe-safe mode uses in-memory storage, so a blocking first-run
        // modal can reappear on every load and make the prop feed look empty.
        // Keep sign-in available through the header, but do not block the app.
        propEdgeStorage.setItem('pe_onboarded', '1');
        const el = document.getElementById('onboardingOverlay');
        if (el) el.style.display = 'none';
      } catch(e) {}
    }
    function dismissOnboarding() {
      try {
        const emailVal = document.getElementById('onboardEmailInput')?.value?.trim();
        if (emailVal && emailVal.includes('@')) {
          propEdgeStorage.setItem('pe_email', emailVal);
          _updateEmailPill();
        }
        propEdgeStorage.setItem('pe_onboarded', '1');
      } catch(e) {}
      const el = document.getElementById('onboardingOverlay');
      if (el) el.style.display = 'none';
    }
    function showEmailModal() {
      const modal = document.getElementById('emailModal');
      if (modal) { modal.style.display = 'flex'; document.getElementById('emailModalInput')?.focus(); }
    }
    function closeEmailModal() {
      const modal = document.getElementById('emailModal');
      if (modal) modal.style.display = 'none';
    }
    function saveEmailFromModal() {
      const val = document.getElementById('emailModalInput')?.value?.trim();
      if (val && val.includes('@')) {
        propEdgeStorage.setItem('pe_email', val);
        _updateEmailPill();
      }
      closeEmailModal();
    }
    function requestPushAlerts() {
      const btn = document.getElementById('getAlertsBtn');
      if (btn) btn.style.display = 'none';
    }

    function initOneSignalAlerts() {
      if (typeof OneSignal === 'undefined' || !OneSignal) {
        console.log('[PropEdge] OneSignal disabled in standalone HTML build');
        return;
      }

      console.log('[PropEdge] OneSignal alerts initialized');

      // Alert Trigger 1: Pace trending UP with confidence >75%
      function checkPaceUP() {
        if (!state.paceFiltered || state.paceFiltered.length === 0) return;

        const upTrend = state.paceFiltered.filter(p => {
          const pred = window.latestPredictions?.find(x => x.playerId === p.id);
          return pred && pred.trend === 'UP' && pred.confidence > 0.75;
        });

        upTrend.forEach(p => {
          const pred = window.latestPredictions.find(x => x.playerId === p.id);
          if (pred && !window.sentAlerts) window.sentAlerts = new Set();
          if (window.sentAlerts && !window.sentAlerts.has(p.id + '_UP')) {
            sendPaceAlert(`${p.player} (${p.team})`, 'UP', pred.confidence);
            window.sentAlerts.add(p.id + '_UP');
          }
        });
      }

      // Alert Trigger 2: Player status changed
      function checkStatusChanged() {
        const current = JSON.parse(propEdgeStorage.getItem('propEdgeLastStatus') || '{}');
        const changes = [];

        if (state.players) {
          state.players.forEach(p => {
            if (current[p.id] && current[p.id] !== p.status) {
              changes.push({ player: p.name, from: current[p.id], to: p.status });
            }
          });
        }

        changes.forEach(c => {
          const alert = `${c.player}: ${c.from} → ${c.to}`;
          OneSignal.push(() => {
            OneSignal.sendSelfPushNotification({
              headings: { en: '⚠️ Status Alert' },
              contents: { en: alert },
              url: window.location.href + '#players',
            });
          });
        });

        // Store current status for next check
        const newStatus = {};
        if (state.players) {
          state.players.forEach(p => {
            newStatus[p.id] = p.status;
          });
        }
        propEdgeStorage.setItem('propEdgeLastStatus', JSON.stringify(newStatus));
      }

      // Alert Trigger 3: Odds improved >5% since yesterday
      function checkOddsImproved() {
        const oddsSnapshot = JSON.parse(propEdgeStorage.getItem('propEdgeOddsSnapshot') || '{}');
        const today = new Date().toISOString().split('T')[0];

        if (!oddsSnapshot[today]) {
          oddsSnapshot[today] = {};
          propEdgeStorage.setItem('propEdgeOddsSnapshot', JSON.stringify(oddsSnapshot));
          return;
        }

        const improved = [];
        if (state.props) {
          state.props.forEach(p => {
            const yesterday = oddsSnapshot[today][p.id];
            if (yesterday && Math.abs(p.edge - yesterday) > 5) {
              improved.push({ player: p.player, oldEdge: yesterday, newEdge: p.edge });
            }
          });
        }

        improved.forEach(p => {
          const delta = (p.newEdge - p.oldEdge).toFixed(1);
          const direction = p.newEdge > p.oldEdge ? '⬆️ Better' : '⬇️ Worse';
          OneSignal.push(() => {
            OneSignal.sendSelfPushNotification({
              headings: { en: `${p.player} ${direction}` },
              contents: { en: `EV changed ${delta}% (${p.oldEdge.toFixed(1)} → ${p.newEdge.toFixed(1)})` },
              url: window.location.href + '#players',
            });
          });
        });
      }

      // Check every 60 seconds during day
      setInterval(checkPaceUP, 60000);
      setInterval(checkStatusChanged, 120000);
      setInterval(checkOddsImproved, 180000);

      // Initial checks
      checkPaceUP();
      checkStatusChanged();
      checkOddsImproved();
    }

    // ============ END SPRINT APRIL 4 ============

    function viewAllProps(propId, playerName) {
      const prop = state.props.find(p => p.id === propId);
      if (!prop) return;

      // Get all props for this player across all books/leagues
      const playerProps = state.props.filter(p =>
        p.player.toLowerCase() === playerName.toLowerCase()
      );

      if (playerProps.length === 0) {
        showToast('No props found for this player');
        return;
      }

      // Create modal with all props
      let propsHtml = '<table style="width:100%;border-collapse:collapse;">';
      propsHtml += '<thead><tr style="background:var(--bg-secondary);"><th style="padding:10px;text-align:left;border-bottom:1px solid var(--border-color);">League</th><th style="padding:10px;text-align:left;border-bottom:1px solid var(--border-color);">Prop</th><th style="padding:10px;text-align:left;border-bottom:1px solid var(--border-color);">Line</th><th style="padding:10px;text-align:center;border-bottom:1px solid var(--border-color);">Edge</th></tr></thead>';
      propsHtml += '<tbody>';

      playerProps.forEach(p => {
        const edgeColor = p.edge > 5 ? 'var(--accent-green)' : p.edge < 0 ? 'var(--accent-red)' : 'var(--text-default)';
        propsHtml += `<tr style="border-bottom:1px solid var(--border-color);">
          <td style="padding:10px;">${p.league}</td>
          <td style="padding:10px;">${p.prop}</td>
          <td style="padding:10px;font-weight:600;">${p.line} ${p.direction}</td>
          <td style="padding:10px;text-align:center;color:${edgeColor};font-weight:600;">${p.edge > 0 ? '+' : ''}${p.edge}%</td>
        </tr>`;
      });

      propsHtml += '</tbody></table>';

      // Show modal
      const modal = document.createElement('div');
      modal.id = 'propsModal_' + Math.random().toString(36).substr(2, 9);
      modal.style.cssText = `
        position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);
        display:flex;align-items:center;justify-content:center;z-index:10000;
      `;

      const closeModal = () => {
        modal.style.display = 'none';
        setTimeout(() => modal.remove(), 100);
      };

      modal.innerHTML = `
        <div style="background:var(--bg-primary);border:1px solid var(--border-color);border-radius:12px;padding:20px;max-width:600px;width:90%;max-height:80vh;overflow-y:auto;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
            <h3 style="margin:0;color:white;">All Props - ${playerName}</h3>
            <button id="closePropsBtn" style="background:none;border:none;color:var(--text-muted);font-size:24px;cursor:pointer;padding:0;line-height:1;">✕</button>
          </div>
          ${propsHtml}
          <div style="margin-top:15px;text-align:center;font-size:12px;color:var(--text-muted);">
            ${playerProps.length} prop${playerProps.length > 1 ? 's' : ''} found
          </div>
        </div>
      `;

      document.body.appendChild(modal);

      // Close button handler
      const closeBtn = modal.querySelector('#closePropsBtn');
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          closeModal();
        });
      }

      // Click outside modal to close
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });

      // Escape key to close
      const escapeHandler = (e) => {
        if (e.key === 'Escape') {
          closeModal();
          document.removeEventListener('keydown', escapeHandler);
        }
      };
      document.addEventListener('keydown', escapeHandler);

      showToast(`Showing ${playerProps.length} prop${playerProps.length > 1 ? 's' : ''} for ${playerName}`);
    }

    function generateSuggestedParlays() {
      const container = document.getElementById('suggestedParlays');
      if (!container) return;

      if (!state.props || state.props.length < 3) {
        container.innerHTML = '<div style="color:var(--text-muted);font-size:12px;padding:16px;text-align:center;">Load props to see AI suggestions</div>';
        return;
      }

      // Helper: pick up to N props with no duplicate players and no duplicate teams
      function pickUnique(pool, n) {
        const seen = new Set();
        const result = [];
        for (const p of pool) {
          const key = p.player + '|' + p.team;
          if (!seen.has(key)) {
            seen.add(key);
            result.push(p);
            if (result.length >= n) break;
          }
        }
        return result;
      }

      // Score a prop for AI quality — v5: unified score is the single source of truth
      function propScore(p) {
        return p.modelScore || 0;
      }

      // Sorted pools
      const allSorted  = [...state.props].sort((a, b) => propScore(b) - propScore(a));
      const ultPool    = allSorted.filter(p => p.meetsUltimate);
      const primePool  = allSorted.filter(p => p.tier === 'prime' || p.tier === 'ultimate');
      const valuePool  = allSorted.filter(p => p.isValue).sort((a, b) => (b.edge||0) - (a.edge||0));

      // Fallback: if a tier is too thin, fill from top of allSorted
      function withFallback(pool, n) {
        const picks = pickUnique(pool, n);
        if (picks.length < n) {
          const extraPool = allSorted.filter(p => !picks.includes(p));
          picks.push(...pickUnique(extraPool, n - picks.length));
        }
        return picks.slice(0, n);
      }

      const suggestions = [];

      // 1. Ultimate Stack — best 3 overall
      const ultPicks = withFallback(ultPool.length >= 2 ? ultPool : allSorted, 3);
      if (ultPicks.length >= 2) {
        const avgHit = Math.round(ultPicks.reduce((s, p) => s + (p.l10Pct || 0), 0) / ultPicks.length);
        suggestions.push({
          name: '⭐ Ultimate Stack',
          picks: ultPicks,
          desc: `${avgHit}% avg L10 hit rate · highest-confidence plays`
        });
      }

      // 2. Prime Picks — high confidence, diverse legs
      const primePicks = withFallback(primePool, 3);
      if (primePicks.length >= 2) {
        const avgEdge = (primePicks.reduce((s, p) => s + (p.edge || 0), 0) / primePicks.length).toFixed(1);
        suggestions.push({
          name: '🎯 Prime Picks',
          picks: primePicks,
          desc: `+${avgEdge}% avg model edge · proven high-hit plays`
        });
      }

      // 3. Value Play — best positive-edge props
      const valuePicks = withFallback(valuePool.length >= 2 ? valuePool : allSorted, 3);
      // Exclude players already used above to maximize variety
      const usedPlayers = new Set([...ultPicks, ...primePicks].map(p => p.player));
      const freshValue  = valuePicks.filter(p => !usedPlayers.has(p.player));
      const finalValue  = freshValue.length >= 2 ? freshValue.slice(0, 3) : withFallback(valuePool, 3);
      if (finalValue.length >= 2) {
        const bestEdge = Math.max(...finalValue.map(p => p.edge || 0)).toFixed(1);
        suggestions.push({
          name: '💰 Value Play',
          picks: finalValue,
          desc: `Up to +${bestEdge}% edge · best bang-for-your-buck legs`
        });
      }

      // 4. Mixed League (if multiple leagues available)
      const leagues = [...new Set(state.props.map(p => p.league))];
      if (leagues.length >= 2) {
        const mixedPicks = [];
        const usedInMix  = new Set();
        for (const league of leagues) {
          const leagueBest = allSorted.filter(p => p.league === league && !usedInMix.has(p.player));
          if (leagueBest.length > 0) {
            mixedPicks.push(leagueBest[0]);
            usedInMix.add(leagueBest[0].player);
          }
          if (mixedPicks.length >= 4) break;
        }
        if (mixedPicks.length >= 2) {
          suggestions.push({
            name: '🌐 Cross-Sport',
            picks: mixedPicks,
            desc: `${mixedPicks.map(p => p.league).join(' + ')} · diversified multi-sport parlay`
          });
        }
      }

      // Tier color badge
      const tierColor = { ultimate: '#f59e0b', prime: '#6366f1', strong: '#10b981', solid: '#3b82f6', spec: '#8b5cf6' };

      container.innerHTML = suggestions.length ? suggestions.map(s => `
        <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:14px;margin-bottom:10px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
            <div style="font-weight:700;font-size:13px;">${s.name}</div>
            <span style="font-size:10px;background:rgba(99,102,241,0.15);color:#818cf8;border-radius:20px;padding:2px 8px;">${s.picks.length} legs</span>
          </div>
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">${s.desc}</div>
          ${s.picks.map(p => `
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
              <div style="width:6px;height:6px;border-radius:50%;background:${tierColor[p.tier]||'#64748b'};flex-shrink:0;"></div>
              <div style="font-size:12px;color:var(--text-secondary);flex:1;">${p.player} <span style="color:var(--text-muted);">· ${p.direction} ${p.line} ${p.prop}</span></div>
              <span style="font-size:11px;color:${(p.edge||0)>0?'var(--accent-green)':'var(--text-muted)'}">${(p.edge||0)>0?'+':''}${(p.edge||0).toFixed(1)}%</span>
            </div>
          `).join('')}
          <button class="parlay-btn secondary" style="width:100%;margin-top:10px;padding:9px;font-size:12px;font-weight:600;" onclick="addSuggestedParlay([${s.picks.map(p => `'${p.id}'`).join(',')}])">+ Add All to Parlay</button>
        </div>
      `).join('') : '<div style="color:var(--text-muted);font-size:12px;padding:16px;text-align:center;">No suggestions available — reload props to refresh</div>';
    }

    function addSuggestedParlay(ids) {
      ids.forEach(id => {
        const prop = state.props.find(p => p.id === id);
        if (prop && !state.parlay.find(p => p.id === id)) {
          state.parlay.push(prop);
        }
      });
      renderParlay();
      renderProps();
      showToast('Added to parlay!');
    }

    // ==========================================
    // STRATEGY
    // ==========================================
    function renderStrategy() {
      // Ultimate picks
      const ultimateProps = state.props.filter(p => p.meetsUltimate).sort((a, b) => b.modelScore - a.modelScore).slice(0, 5);
      const ulEl = document.getElementById('ultimatePicks');
      if (ulEl) ulEl.innerHTML = ultimateProps.length ?
        ultimateProps.map(p => renderStrategyPick(p, 'ultimate')).join('') :
        '<div style="color:var(--text-muted);padding:12px;font-size:12px;">No ultimate picks found</div>';

      // Prime picks
      const primeProps = state.props.filter(p => p.tier === 'prime' && !p.meetsUltimate).sort((a, b) => b.modelScore - a.modelScore).slice(0, 5);
      const prEl = document.getElementById('primePicks');
      if (prEl) prEl.innerHTML = primeProps.length ?
        primeProps.map(p => renderStrategyPick(p, 'prime')).join('') :
        '<div style="color:var(--text-muted);padding:12px;font-size:12px;">No prime picks found</div>';

      // Hot streaks
      const hotProps = state.props.filter(p => p.streak >= 3).sort((a, b) => b.streak - a.streak).slice(0, 5);
      const hsEl = document.getElementById('hotStreaks');
      if (hsEl) hsEl.innerHTML = hotProps.length ? 
        hotProps.map(p => `
          <div class="strategy-pick" onclick="toggleParlay('${p.id}')">
            <div>
              <div class="strategy-pick-player">${p.player}</div>
              <div class="strategy-pick-prop">${p.direction} ${p.line} ${p.prop} • ${p.team}</div>
            </div>
            <div class="strategy-pick-score" style="color:var(--accent-red)">🔥 ${p.streak}</div>
          </div>
        `).join('') :
        '<div style="color:var(--text-muted);padding:12px;font-size:12px;">No hot streaks found</div>';

      // Best value
      const valueProps = state.props.filter(p => p.edge > 5).sort((a, b) => b.edge - a.edge).slice(0, 5);
      const bvEl = document.getElementById('bestValue');
      if (bvEl) bvEl.innerHTML = valueProps.length ? 
        valueProps.map(p => `
          <div class="strategy-pick" onclick="toggleParlay('${p.id}')">
            <div>
              <div class="strategy-pick-player">${p.player}</div>
              <div class="strategy-pick-prop">${p.direction} ${p.line} ${p.prop} • ${p.team}</div>
            </div>
            <div class="strategy-pick-score" style="color:var(--accent-blue)">+${p.edge}%</div>
          </div>
        `).join('') :
        '<div style="color:var(--text-muted);padding:12px;font-size:12px;">No value plays found</div>';
    }

    function renderStrategyPick(p, tier) {
      const color = tier === 'ultimate' ? 'var(--accent-gold)' : 'var(--accent-purple)';
      return `
        <div class="strategy-pick" onclick="toggleParlay('${p.id}')">
          <div>
            <div class="strategy-pick-player">${p.player}</div>
            <div class="strategy-pick-prop">${p.direction} ${p.line} ${p.prop} • ${p.team}</div>
          </div>
          <div class="strategy-pick-score" style="color:${color}">${p.modelScore}</div>
        </div>
      `;
    }

    // ==========================================
    // PACE MATCHUP DATABASE & FUNCTIONS (GLOBAL SCOPE)
    // ==========================================
    const paceDatabase = [
      {
        player: 'Luka Doncic',
        team: 'DAL',
        league: 'NBA',
        playerPace: 98,
        opponentPace: 92,
        edge: 6.5
      },
      {
        player: 'Shai Gilgeous-Alexander',
        team: 'OKC',
        league: 'NBA',
        playerPace: 95,
        opponentPace: 88,
        edge: 7.2
      },
      {
        player: 'Jayson Tatum',
        team: 'BOS',
        league: 'NBA',
        playerPace: 91,
        opponentPace: 94,
        edge: -3.1
      },
      {
        player: 'Kevin Durant',
        team: 'PHX',
        league: 'NBA',
        playerPace: 87,
        opponentPace: 87,
        edge: 0
      },
      {
        player: 'Stephen Curry',
        team: 'GSW',
        league: 'NBA',
        playerPace: 96,
        opponentPace: 85,
        edge: 11
      }
    ];

    let paceState = {
      league: 'all',
      sortBy: 'edge',
      searchTerm: '',
      filteredData: [...paceDatabase]
    };

    function filterPaceByLeague(league) {
      paceState.league = league;
      document.querySelectorAll('.pace-filter-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.league === league);
      });
      filterPaceData();
      loadPaceTrends();
    }

    function filterPaceData() {
      paceState.searchTerm = document.getElementById('paceSearchInput')?.value || '';
      const leagueFiltered = paceState.league === 'all'
        ? paceDatabase
        : paceDatabase.filter(p => p.league === paceState.league);

      paceState.filteredData = leagueFiltered.filter(player =>
        player.player.toLowerCase().includes(paceState.searchTerm.toLowerCase()) ||
        player.team.toLowerCase().includes(paceState.searchTerm.toLowerCase())
      );

      sortPaceData();
    }

    function sortPaceData() {
      const sortType = document.getElementById('paceSortSelect')?.value || 'edge';

      paceState.filteredData.sort((a, b) => {
        switch(sortType) {
          case 'player-pace':
            return b.playerPace - a.playerPace;
          case 'opponent-pace':
            return b.opponentPace - a.opponentPace;
          case 'edge':
          default:
            return b.edge - a.edge;
        }
      });

      displayPaceData();
    }

    function displayPaceData() {
      const container = document.getElementById('paceCardsContainer');
      if (!container) return;

      container.innerHTML = '';

      if (paceState.filteredData.length === 0) {
        container.innerHTML = '<div class="empty-state"><div class="empty-icon">🏀</div><div class="empty-title">No players found</div></div>';
        return;
      }

      paceState.filteredData.forEach(player => {
        const favorability = player.edge > 5 ? 'favorable' : (player.edge < 0 ? 'unfavorable' : 'neutral');
        const favorabilityLabel = player.edge > 5 ? '✅ Favorable' : (player.edge < 0 ? '❌ Unfavorable' : '⚠️ Neutral');

        const card = document.createElement('div');
        card.className = 'pace-card';
        card.innerHTML = `
          <div class="pace-card-header">
            <div class="pace-card-player">
              <div class="pace-card-name">${player.player}</div>
              <div class="pace-card-team">${player.team}</div>
            </div>
            <div class="pace-card-league">${player.league}</div>
          </div>
          <div class="pace-card-metrics">
            <div class="pace-metric">
              <div class="pace-metric-label">Player Pace</div>
              <div class="pace-metric-value">${player.playerPace}</div>
            </div>
            <div class="pace-metric">
              <div class="pace-metric-label">Opponent Pace</div>
              <div class="pace-metric-value">${player.opponentPace}</div>
            </div>
          </div>
          <div class="pace-card-edge">
            <div class="pace-edge-label">Matchup Edge</div>
            <div class="pace-edge-value ${player.edge < 0 ? 'negative' : ''}">${player.edge > 0 ? '+' : ''}${player.edge.toFixed(1)}%</div>
          </div>
          <div class="pace-card-favorability ${favorability}">${favorabilityLabel}</div>
          <div style="display: flex; gap: 8px; margin-top: 12px;">
            <button class="pace-bet-btn pace-bet-dk" data-player="${player.player.replace(/"/g, '&quot;')}" data-league="${player.league}" data-edge="${player.edge}" style="flex: 1; background: rgba(138,43,226,0.18); color: #a82be7; border: 1px solid rgba(138,43,226,0.35); padding: 8px; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer; transition: all 0.2s;">🎲 DK</button>
            <button class="pace-bet-btn pace-bet-fd" data-player="${player.player.replace(/"/g, '&quot;')}" data-league="${player.league}" data-edge="${player.edge}" style="flex: 1; background: rgba(74,143,255,0.18); color: var(--accent-blue); border: 1px solid rgba(74,143,255,0.35); padding: 8px; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer; transition: all 0.2s;">🎯 FD</button>
          </div>
        `;
        container.appendChild(card);
      });

    }

    // Attach event delegation for pace bet buttons
    document.addEventListener('click', (e) => {
      if (e.target.closest('.pace-bet-btn')) {
        e.preventDefault();
        e.stopPropagation();

        const btn = e.target.closest('.pace-bet-btn');
        const player = btn.dataset.player;
        const league = btn.dataset.league;
        const edge = parseFloat(btn.dataset.edge);
        const sportsbook = btn.classList.contains('pace-bet-dk') ? 'DraftKings' : 'FanDuel';

        console.log('[Pace Bet] Clicked:', player, league, sportsbook, edge);
        trackPaceBet(player, league, sportsbook, edge);
      }
    });

    // PACE TRENDS — LIVE (sourced from state.props + ESPN team stats)
    // ==========================================
    async function loadPaceTrends() {
      try {
        // ── Pull players from today's actual prop sheet ────────────────
        // state.props is already loaded from the Google Sheet scraper.
        // De-dupe by player+team so each player appears once per league.
        const propPlayers = state.props || [];
        const seen = new Set();
        const livePlayers = [];
        propPlayers.forEach(p => {
          const key = `${p.player}|${p.team}|${p.league}`;
          if (!seen.has(key)) {
            seen.add(key);
            livePlayers.push({ name: p.player, team: normalizeTeam(p.team)?.toUpperCase() || p.team, position: p.pos || '', league: (p.league || 'NBA').toUpperCase(), status: 'Active' });
          }
        });

        // ── Build per-player pace context from live ESPN team stats ────
        // window._teamStats[league][abbr] populated by fetchLiveTeamStats()
        function getTeamPaceContext(teamAbbr, league) {
          const ts = window._teamStats?.[league]?.[teamAbbr];
          if (!ts) return { paceRank: null, paceVal: null };
          // Get the primary pace/scoring value
          const paceVal = ts.pace || ts.possessionspergame || ts.avgpossessions || ts.pointspergame || ts.goalspergame || ts.runspergame || null;
          return { paceRank: ts.paceRank || null, paceVal };
        }

        // ── Build today's game opponent map ─────────────────────────
        const gameOpponentMap = {}; // teamAbbr → oppAbbr
        const allGames = [...(state.games.NBA||[]),...(state.games.NHL||[]),...(state.games.MLB||[]),...(state.games.NFL||[])];
        allGames.forEach(g => {
          const h = normalizeTeam(g.homeTeam)?.toUpperCase();
          const a = normalizeTeam(g.awayTeam)?.toUpperCase();
          if (h && a) { gameOpponentMap[h] = a; gameOpponentMap[a] = h; }
        });

        // ── Filter by selected league ──────────────────────────────
        const leagueFilter = (paceState.league || 'all').toUpperCase();
        let filteredPlayers = leagueFilter === 'ALL' ? livePlayers : livePlayers.filter(p => p.league === leagueFilter);

        // ── Build trend objects ────────────────────────────────────
        const trendData = filteredPlayers.map(player => {
          const myCtx  = getTeamPaceContext(player.team, player.league);
          const oppAbbr = gameOpponentMap[player.team];
          const oppCtx = oppAbbr ? getTeamPaceContext(oppAbbr, player.league) : { paceRank: null, paceVal: null };

          // Derive trend from relative pace rank
          let trend = 'STABLE';
          if (myCtx.paceRank != null) {
            if (myCtx.paceRank <= 8)       trend = 'UP';
            else if (myCtx.paceRank >= 23)  trend = 'DOWN';
          }

          // Edge = how favorable is today's matchup (negative paceRank diff = faster opp)
          let matchupEdge = 0;
          if (myCtx.paceRank != null && oppCtx.paceRank != null) {
            // Opponent faster than average = more possessions = positive edge for volume
            matchupEdge = Math.round((15 - oppCtx.paceRank) * 0.7);
          }

          const dataSource = Object.keys(window._teamStats?.[player.league] || {}).length > 0
            ? 'ESPN Live' : 'Pending';

          return {
            name:       player.name,
            team:       player.team,
            position:   player.position,
            league:     player.league,
            oppTeam:    oppAbbr || '—',
            paceRank:   myCtx.paceRank,
            paceVal:    myCtx.paceVal != null ? +myCtx.paceVal.toFixed(1) : null,
            oppPaceRank:oppCtx.paceRank,
            oppPaceVal: oppCtx.paceVal != null ? +oppCtx.paceVal.toFixed(1) : null,
            trend,
            matchupEdge,
            dataSource
          };
        }).sort((a, b) => b.matchupEdge - a.matchupEdge);

        // Keep global references for alerts system
        window.fileData = { players: filteredPlayers, predictions: trendData };
        window.latestPredictions = trendData;
        if (!window.sentAlerts) window.sentAlerts = new Set();

        // ── Render ────────────────────────────────────────────────
        const trendsSection   = document.getElementById('paceTrendsSection');
        const trendsContainer = document.getElementById('paceTrendsContainer');

        if (!trendsContainer || trendData.length === 0) {
          if (trendsSection) trendsSection.style.display = 'none';
          return;
        }
        if (trendsSection) trendsSection.style.display = 'block';
        trendsContainer.innerHTML = '';

        trendData.forEach(player => {
          const trendArrow = player.trend === 'UP' ? '📈' : player.trend === 'DOWN' ? '📉' : '→';
          const trendColor = player.trend === 'UP' ? 'var(--accent-green)' : player.trend === 'DOWN' ? 'var(--accent-red)' : 'var(--text-muted)';
          const lg = player.league;
          const metricLabel = lg === 'NHL' ? 'SOG/G' : lg === 'MLB' ? 'Runs/G' : 'Possessions/G';

          const paceDisplay = player.paceVal != null ? player.paceVal : '—';
          const oppPaceDisplay = player.oppPaceVal != null ? player.oppPaceVal : '—';
          const rankDisplay = player.paceRank != null ? `#${player.paceRank}/30` : '—';
          const oppRankDisplay = player.oppPaceRank != null ? `#${player.oppPaceRank}/30` : '—';

          const edgeClass = player.matchupEdge > 5 ? 'var(--accent-green)' : player.matchupEdge < 0 ? 'var(--accent-red)' : 'var(--accent-gold)';
          const edgeLabel = player.matchupEdge > 5 ? '✅ Favorable' : player.matchupEdge < 0 ? '❌ Unfavorable' : '→ Neutral';

          const card = document.createElement('div');
          card.style.cssText = 'background:var(--bg-tertiary);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:12px;display:flex;flex-direction:column;gap:10px;';
          card.innerHTML = `
            <div style="display:flex;justify-content:space-between;align-items:start;">
              <div>
                <div style="font-weight:600;color:var(--text-primary);">${player.name}</div>
                <div style="font-size:12px;color:var(--text-muted);">${player.team} · ${player.position || lg} · vs ${player.oppTeam}</div>
              </div>
              <div style="text-align:right;">
                <div style="font-size:22px;">${trendArrow}</div>
                <div style="font-size:10px;color:${trendColor};font-weight:600;">${player.trend}</div>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:12px;">
              <div><div style="color:var(--text-muted);">${metricLabel} (Team)</div><div style="color:var(--accent-blue);font-weight:600;">${paceDisplay} <span style="font-size:10px;opacity:0.7;">${rankDisplay}</span></div></div>
              <div><div style="color:var(--text-muted);">${metricLabel} (Opp)</div><div style="color:var(--accent-gold);font-weight:600;">${oppPaceDisplay} <span style="font-size:10px;opacity:0.7;">${oppRankDisplay}</span></div></div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 8px;background:rgba(255,255,255,0.04);border-radius:6px;">
              <span style="font-size:12px;color:var(--text-muted);">Matchup Edge</span>
              <span style="font-weight:700;color:${edgeClass};">${player.matchupEdge > 0 ? '+' : ''}${player.matchupEdge}% · ${edgeLabel}</span>
            </div>
            <div style="font-size:10px;color:var(--text-muted);text-align:right;">Source: ${player.dataSource}</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding-top:4px;border-top:1px solid var(--border-color);">
              <button onclick="openDraftKingsDirect()" style="background:rgba(138,43,226,0.18);color:#a82be7;border:1px solid rgba(138,43,226,0.35);padding:8px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;">🎲 DK</button>
              <button onclick="openFanDuelDirect({player:'${player.name.replace(/'/g,"\\'")}',league:'${lg}',line:0,direction:'OVER',edge:0})" style="background:rgba(74,143,255,0.18);color:var(--accent-blue);border:1px solid rgba(74,143,255,0.35);padding:8px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;">🎯 FD</button>
            </div>
          `;
          trendsContainer.appendChild(card);
        });

        if (trendData.length === 0) {
          trendsContainer.innerHTML = '<div class="empty-state"><div class="empty-icon">📊</div><div class="empty-title">No pace data yet</div><div class="empty-text">Load props first — pace data pulls from today\'s prop cards</div></div>';
        }

      } catch (error) {
        console.error('[PropEdge] loadPaceTrends error:', error);
      }
    }

    // ── LEGACY: kept so old references don't break ──
    // (was large hardcoded blob — replaced with live ESPN data above)
    // Original hardcoded fileData removed 2026-04-08
    // ── dummy to avoid any lingering refs ─────────────────────────────
    if (!window.fileData) { window.fileData = {"version":"1.0.0","lastSync":"","players":[],"paceData":[],"predictions":[]}; }
    if (!window.latestPredictions) { window.latestPredictions = []; }
    if (!window.sentAlerts) { window.sentAlerts = new Set(); }

    // ==========================================
    // LEAGUE NEWS & ANALYST SOURCE CONTEXT
    // ==========================================
    function setLeagueNewsFilter(league) {
      state.leagueNewsFilter = league || 'ALL';
      document.querySelectorAll('[data-league-news]').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.leagueNews === state.leagueNewsFilter);
      });
      refreshLeagueNews(true);  // Auto-load news context on startup
    }

    async function refreshLeagueNews(force) {
      const league = state.leagueNewsFilter || state.league || 'ALL';
      const meta = document.getElementById('leagueNewsMeta');
      const gamesOut = document.getElementById('leagueNewsGames');
      const articlesOut = document.getElementById('leagueNewsArticles');
      if (!force && state.leagueNews.loaded && state.leagueNews.league === league) {
        renderLeagueNews();
        return state.leagueNews;
      }
      if (meta) meta.textContent = `Loading ${league} context from ESPN, CBS Sports, and RotoWire...`;
      if (gamesOut) gamesOut.innerHTML = '<div class="league-news-empty">Loading game context...</div>';
      if (articlesOut) articlesOut.innerHTML = '<div class="league-news-empty">Loading news snippets...</div>';

      try {
        const response = await propEdgeNativeFetch(`/.netlify/functions/league-news?league=${encodeURIComponent(league)}`, { cache: 'no-store' });
        if (!response || !response.ok) throw new Error('unavailable');
        const data = await response.json();
        state.leagueNews = {
          league,
          games: Array.isArray(data.games) ? data.games : [],
          articles: Array.isArray(data.articles) ? data.articles : [],
          sources: Array.isArray(data.sources) ? data.sources : [],
          updated_at: data.updated_at || new Date().toISOString(),
          loaded: true
        };
      } catch (err) {
        // League news is optional context — silent fallback to empty state
        state.leagueNews = { league, games: [], articles: [], sources: [], updated_at: new Date().toISOString(), loaded: true };
      }
      renderLeagueNews();
      return state.leagueNews;
    }

    function renderLeagueNews() {
      const gamesOut = document.getElementById('leagueNewsGames');
      const articlesOut = document.getElementById('leagueNewsArticles');
      const meta = document.getElementById('leagueNewsMeta');
      const gameCount = document.getElementById('leagueNewsGameCount');
      const articleCount = document.getElementById('leagueNewsArticleCount');
      if (!gamesOut || !articlesOut) return;

      const news = state.leagueNews || {};
      const updated = news.updated_at ? new Date(news.updated_at).toLocaleString() : 'just now';
      const sourceOk = (news.sources || []).filter(s => s.status === 'ok').map(s => s.name).join(', ');
      if (meta) meta.textContent = `Updated ${updated}${sourceOk ? ` · Sources: ${sourceOk}` : ' · Source fetch limited'}`;
      if (gameCount) gameCount.textContent = `${(news.games || []).length}`;
      if (articleCount) articleCount.textContent = `${(news.articles || []).length}`;

      gamesOut.innerHTML = (news.games || []).length
        ? news.games.slice(0, 16).map(game => `
          <a class="league-game-card" href="${escapeHTML(game.url || '#')}" target="_blank" rel="noopener">
            <span class="league-news-source">${escapeHTML(game.league || '')} · ${escapeHTML(game.source || 'ESPN')}</span>
            <div class="league-game-matchup">${escapeHTML(game.matchup || 'Game context')}</div>
            <div class="league-game-status">${escapeHTML([game.score, game.status, game.venue].filter(Boolean).join(' · '))}</div>
            ${(game.headlines || []).slice(0, 2).map(h => `<div class="league-game-status">• ${escapeHTML(h)}</div>`).join('')}
          </a>
        `).join('')
        : '<div class="league-news-empty">No games returned for this league right now.</div>';

      articlesOut.innerHTML = (news.articles || []).length
        ? news.articles.slice(0, 24).map(article => `
          <a class="league-article-card" href="${escapeHTML(article.url || '#')}" target="_blank" rel="noopener">
            <span class="league-news-source">${escapeHTML(article.league || '')} · ${escapeHTML(article.source || 'Source')}</span>
            <div class="league-article-title">${escapeHTML(article.title || 'Latest league context')}</div>
            <div class="league-article-summary">${escapeHTML(article.summary || '')}</div>
          </a>
        `).join('')
        : '<div class="league-news-empty">No article snippets returned yet. Try Refresh News.</div>';
    }

    function getLeagueNewsAnalystContext(question, picks) {
      const news = state.leagueNews || {};
      if (!news.loaded) return [];
      const terms = new Set();
      String(question || '').toUpperCase().match(/\b[A-Z]{2,4}\b/g)?.forEach(t => terms.add(t));
      (picks || []).forEach(p => {
        if (p.team) terms.add(String(p.team).toUpperCase());
        String(p.game || '').toUpperCase().match(/\b[A-Z]{2,4}\b/g)?.forEach(t => terms.add(t));
        String(p.game_detail || '').toUpperCase().match(/\b[A-Z]{2,4}\b/g)?.forEach(t => terms.add(t));
      });
      const termList = [...terms];
      const scoreText = item => {
        const text = `${item.matchup || ''} ${item.title || ''} ${item.summary || ''} ${(item.teams || []).join(' ')}`.toUpperCase();
        return termList.reduce((sum, term) => sum + (text.includes(term) ? 1 : 0), 0);
      };
      const gameItems = (news.games || []).map(game => ({
        source: game.source || 'ESPN',
        url: game.url || '',
        status: 'ok',
        summary: `${game.league || ''} ${game.matchup || ''}: ${[game.score, game.status, game.venue, ...(game.headlines || []).slice(0, 2)].filter(Boolean).join(' · ')}`
      }));
      const articleItems = (news.articles || []).map(article => ({
        source: article.source || 'Source',
        url: article.url || '',
        status: 'ok',
        summary: `${article.league || ''} ${article.title || ''}: ${article.summary || ''}`.slice(0, 520)
      }));
      return [...gameItems, ...articleItems]
        .sort((a, b) => scoreText(b) - scoreText(a))
        .slice(0, 6);
    }

    function renderAIFastModeToggle() {
      const btn = document.getElementById('aiFastModeToggle');
      if (!btn) return;
      btn.classList.toggle('active', !!state.aiFastMode);
      btn.textContent = state.aiFastMode ? 'Fast Mode: On' : 'Fast Mode: Off';
      btn.title = state.aiFastMode
        ? 'Fast Mode skips fresh server-side source fetches for quicker PropEdge IQ answers.'
        : 'Standard mode can fetch fresh source context when cached News context is not loaded.';
    }

    function toggleAIFastMode() {
      state.aiFastMode = !state.aiFastMode;
      propEdgeStorage.setItem('propedge_aiFastMode', state.aiFastMode ? 'true' : 'false');
      renderAIFastModeToggle();
    }

    // TABS & FILTERS
    // ==========================================
    function applyViewVisibility() {
      const view = state.view || 'props';
      const isDesktop = window.innerWidth >= 1400;
      const setDisplay = (id, display) => {
        const el = document.getElementById(id);
        if (el) el.style.display = display;
      };

      setDisplay('propsContainer', view === 'props' ? 'block' : 'none');
      setDisplay('gamesContainer', view === 'games' ? 'block' : 'none');
      setDisplay('newsContainer', view === 'news' ? 'block' : 'none');
      setDisplay('injuriesContainer', view === 'injuries' ? 'block' : 'none');
      setDisplay('strategyContainer', view === 'strategy' ? 'block' : 'none');
      setDisplay('paceContainer', view === 'pace' ? 'block' : 'none');
      setDisplay('recommendationsContainer', view === 'recommendations' ? 'block' : 'none');
      setDisplay('portfolioContainer', view === 'portfolio' ? 'block' : 'none');
      setDisplay('filterSection', view === 'props' ? 'block' : 'none');
      setDisplay('sortBar', view === 'props' ? 'flex' : 'none');

      const parlayEl = document.getElementById('parlayContainer');
      if (parlayEl) {
        // Desktop keeps the parlay sidebar next to props, but it should not cover
        // Injuries, Games, or other full-width views.
        const showParlay = isDesktop
          ? (view === 'props' || view === 'parlay')
          : view === 'parlay';
        parlayEl.classList.toggle('view-force-hidden', !showParlay);
        parlayEl.style.display = showParlay ? 'block' : 'none';
      }
    }

    function initTabs() {
      let viewSwitchToken = 0;
      const runAfterPaint = (fn) => {
        const token = ++viewSwitchToken;
        requestAnimationFrame(() => {
          setTimeout(() => {
            if (token !== viewSwitchToken) return;
            try { fn(); } catch (err) { console.error('[Tabs] Deferred view work failed:', err); }
          }, 24);
        });
      };

      const navStrip = document.querySelector('.nav-tabs');
      if (navStrip) {
        let navPointerDown = false;
        let navStartX = 0;
        let navStartScroll = 0;
        let navDragged = false;
        let navLastDragEndAt = 0;

        navStrip.addEventListener('pointerdown', (e) => {
          navPointerDown = true;
          navDragged = false;
          navStartX = e.clientX;
          navStartScroll = navStrip.scrollLeft;
          navStrip.classList.add('is-dragging');
          try { navStrip.setPointerCapture(e.pointerId); } catch (err) {}
        }, { passive: true });

        navStrip.addEventListener('pointermove', (e) => {
          if (!navPointerDown) return;
          const dx = e.clientX - navStartX;
          if (Math.abs(dx) > 4) navDragged = true;
          navStrip.scrollLeft = navStartScroll - dx;
        }, { passive: true });

        const releaseNavDrag = (e) => {
          if (navDragged) {
            navLastDragEndAt = Date.now();
            setTimeout(() => { navDragged = false; }, 260);
          } else {
            const tappedEl = document.elementFromPoint(e.clientX, e.clientY);
            const tappedTab = tappedEl && tappedEl.closest ? tappedEl.closest('.nav-tab') : null;
            if (tappedTab && navStrip.contains(tappedTab)) {
              switchToNavView(tappedTab);
            }
          }
          navPointerDown = false;
          navStrip.classList.remove('is-dragging');
          try { navStrip.releasePointerCapture(e.pointerId); } catch (err) {}
        };

        navStrip.addEventListener('pointerup', releaseNavDrag, { passive: true });
        navStrip.addEventListener('pointercancel', releaseNavDrag, { passive: true });
        navStrip.addEventListener('pointerleave', releaseNavDrag, { passive: true });
        navStrip.addEventListener('click', (e) => {
          const suppressDragClick = navDragged && (Date.now() - navLastDragEndAt < 260);
          if (suppressDragClick) {
            e.preventDefault();
            e.stopPropagation();
            navDragged = false;
          }
        }, true);
      }

      // League tabs
      document.querySelectorAll('.sport-tab').forEach(tab => {
        tab.addEventListener('click', () => {
          const nextLeague = tab.dataset.league;
          if (state.league === nextLeague && tab.classList.contains('active')) return;
          document.querySelectorAll('.sport-tab').forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          state.league = nextLeague;
          state.propDisplayLimit = 100;

          if (state.gameFilter) {
            state.gameFilter = null;
            renderTicker([...state.games.NBA, ...state.games.NHL, ...state.games.MLB, ...state.games.NFL]);
          }

          runAfterPaint(() => {
            if (state.view === 'props') renderProps();
            if (state.view === 'recommendations') renderRecommendations();
          });
        });
      });

      function switchToNavView(tab) {
        if (!tab) return;
          const nextView = tab.dataset.view;
          if (!nextView) return;
          if (state.view === nextView && tab.classList.contains('active')) return;
          document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          try { tab.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' }); } catch (err) {}
          state.view = nextView;
          applyViewVisibility();

          runAfterPaint(() => {
            const view = state.view;
            if (view === 'props') { renderProps(); resumeTicker(); }
            if (view === 'games') { renderGames(); resumeTicker(); }
            if (view === 'news') { refreshLeagueNews(false); resumeTicker(); }
            if (view === 'injuries') { fetchAllInjuries(); resumeTicker(); }
            if (view === 'parlay') { renderParlay(); generateSuggestedParlays(); resumeTicker(); }
            if (view === 'strategy') { renderStrategy(); resumeTicker(); }
            if (view === 'pace') { loadPaceTrends(); displayPaceData(); resumeTicker(); }
            if (view === 'recommendations') { pauseTicker(); renderAIFastModeToggle(); renderRecommendations(); }
            if (view === 'portfolio') { renderPortfolio(); resumeTicker(); }
          });
      }

      if (navStrip) {
        navStrip.addEventListener('click', (e) => {
          const tab = e.target.closest('.nav-tab');
          if (!tab || !navStrip.contains(tab)) return;
          e.preventDefault();
          switchToNavView(tab);
        });
      }

      // View tabs — direct click listeners on each tab element
      document.querySelectorAll('.nav-tab').forEach(tab => {
        tab.addEventListener('click', (e) => {
          e.stopPropagation();  // Prevent bubbling to parent navStrip listener
          switchToNavView(tab);
        });
      });

      window.addEventListener('resize', applyViewVisibility);
    }

    function initFilters() {
      document.querySelectorAll('.filter-pill').forEach(chip => {
        chip.addEventListener('click', () => {
          document.querySelectorAll('.filter-pill').forEach(c => c.classList.remove('active'));
          chip.classList.add('active');
          state.filter = chip.dataset.filter;
          state.propDisplayLimit = 100;
          renderProps();
        });
      });
    }

    function sortProps() {
      state.sort = document.getElementById('sortSelect').value;
      state.propDisplayLimit = 100;
      renderProps();
    }

    // ==========================================
    // UTILITIES
    // ==========================================
    function toggleAutoRefresh() {
      state.autoRefresh = !state.autoRefresh;
      propEdgeStorage.setItem('propedge_autoRefresh', state.autoRefresh);
      document.getElementById('autoToggleDot').classList.toggle('off', !state.autoRefresh);
      
      if (state.autoRefresh) {
        startAutoRefresh();
        showToast('Auto-refresh ON (15 min)');
      } else {
        stopAutoRefresh();
        showToast('Auto-refresh OFF');
      }
    }

    function startAutoRefresh() {
      stopAutoRefresh();
      state.refreshInterval = setInterval(() => {
        loadData();
        fetchGames();
      }, 15 * 60 * 1000);
    }

    function stopAutoRefresh() {
      if (state.refreshInterval) {
        clearInterval(state.refreshInterval);
        state.refreshInterval = null;
      }
    }

    function toggleHideCompleted() {
      state.hideCompleted = document.getElementById('hideCompleted').checked;
      propEdgeStorage.setItem('propedge_hideCompleted', state.hideCompleted);
      renderTicker([...state.games.NBA, ...state.games.NHL, ...state.games.MLB, ...state.games.NFL]);
    }


    function updateStatus() {
      const now = new Date();
      const hour = now.getHours();
      const isLateNight = hour >= 23 || hour < 9;
      
      // Check if all ESPN games are final (no upcoming or live games)
      const allGames = [...state.games.NBA, ...state.games.NHL, ...state.games.MLB, ...state.games.NFL];
      const hasUpcomingOrLive = allGames.some(g => g.status === 'upcoming' || g.status === 'live');
      const allGamesFinished = allGames.length > 0 && !hasUpcomingOrLive;
      
      // Calculate next update
      let nextUpdate = '11:30 AM';
      if (hour >= 11 && hour < 18) {
        nextUpdate = '6:30 PM';
      } else if (hour >= 18 && hour < 23) {
        nextUpdate = '11:30 AM';
      }
      
      const indicator = document.querySelector('.live-indicator');
      const dot = document.querySelector('.live-dot');
      
      if (isLateNight || allGamesFinished) {
        // Late night or all games done — show next update time
        const statusLabel = window.innerWidth <= 390 ? nextUpdate : `NEXT: ${nextUpdate}`;
        document.getElementById('statusText').textContent = statusLabel;
        indicator.style.background = 'var(--accent-orange-dim)';
        indicator.style.color = 'var(--accent-orange)';
        dot.style.background = 'var(--accent-orange)';
        dot.style.animation = 'none';
      } else if (allGames.some(g => g.status === 'live') && state.props.length > 0) {
        document.getElementById('statusText').textContent = 'LIVE';
        indicator.style.background = 'var(--accent-green-dim)';
        indicator.style.color = 'var(--accent-green)';
        dot.style.background = 'var(--accent-green)';
        dot.style.animation = 'pulse 2s infinite';
      } else if (state.props.length > 0) {
        document.getElementById('statusText').textContent = 'READY';
        indicator.style.background = 'var(--accent-green-dim)';
        indicator.style.color = 'var(--accent-green)';
        dot.style.background = 'var(--accent-green)';
        dot.style.animation = 'pulse 2s infinite';
      } else {
        document.getElementById('statusText').textContent = 'OFFLINE';
        indicator.style.background = 'var(--accent-red-dim)';
        indicator.style.color = 'var(--accent-red)';
        dot.style.background = 'var(--accent-red)';
        dot.style.animation = 'none';
      }
      
      const updatedEl = document.getElementById('lastUpdated');
      if (updatedEl) {
        updatedEl.textContent = now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
      }
    }

    function updateStats() {
      document.getElementById('statTotal').textContent = state.props.length;
      
      const uniqueGames = new Set();
      state.props.forEach(p => uniqueGames.add(`${p.team}-${p.league}`));
      document.getElementById('statGames').textContent = uniqueGames.size;
      
      document.getElementById('statPrime').textContent = state.props.filter(p => p.tier === 'prime' || p.tier === 'ultimate').length;
      document.getElementById('statValue').textContent = state.props.filter(p => p.isValue).length;
    }

    function showLoading() {
      document.getElementById('propsContainer').innerHTML = `
        <div class="loading">
          <div class="spinner"></div>
          <span>Loading props...</span>
        </div>
      `;
    }

    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2500);
    }

    // ==========================================
    // SHARE PICKS
    // ==========================================
    function loadSharedPicks() {
      const urlParams = new URLSearchParams(window.location.search);
      const picksParam = urlParams.get('picks');
      
      if (picksParam) {
        try {
          const picksData = JSON.parse(atob(picksParam));
          if (Array.isArray(picksData) && picksData.length > 0) {
            showSharedPicksModal(picksData);
          }
        } catch (e) {
          console.error('Failed to parse shared picks:', e);
        }
        
        window.history.replaceState({}, '', window.location.pathname);
      }
    }

    function showSharedPicksModal(picksData) {
      const picksText = picksData.map(p => 
        `• ${p.player} ${p.direction} ${p.line} ${p.prop}`
      ).join('\n');
      
      const modal = document.createElement('div');
      modal.id = 'sharedPicksModal';
      modal.innerHTML = `
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:10000;display:flex;align-items:center;justify-content:center;padding:20px;">
          <div style="background:var(--bg-secondary);border-radius:16px;padding:24px;max-width:400px;width:100%;">
            <div style="font-size:18px;font-weight:600;margin-bottom:16px;color:var(--text-primary);">📥 Shared Picks</div>
            <div style="font-size:13px;color:var(--text-muted);margin-bottom:12px;">Someone shared these picks:</div>
            <div style="background:var(--bg-primary);border-radius:8px;padding:12px;font-size:12px;color:var(--text-primary);margin-bottom:16px;white-space:pre-wrap;font-family:monospace;">${picksText}</div>
            <button onclick="document.getElementById('sharedPicksModal').remove()" style="width:100%;padding:12px;border-radius:8px;border:none;background:var(--accent-green);color:var(--bg-primary);font-size:14px;font-weight:600;cursor:pointer;">Got it</button>
          </div>
        </div>
      `;
      document.body.appendChild(modal);
    }


    // =====================================================
    // PROPEDGE PLAYER DETAIL PANEL
    // =====================================================

    // Shared helpers — defined at top level so all detail functions can access them
    const barColor = (pct) => pct >= 60 ? 'var(--accent-green)' : pct < 40 ? 'var(--accent-red)' : 'var(--accent-gold)';

    /**
     * Build a radar (spider) chart SVG for defensive matchups.
     * Metrics: [PointsAllowedRank, PaceRank, SizeRank, DefEffRank, ReboundRank]
     */
    function buildRadarChartSVG(ranks) {
      const size = 100;
      const center = size / 2;
      const radius = 40;
      const points = [];
      const angles = [0, 72, 144, 216, 288].map(a => (a - 90) * Math.PI / 180);
      
      // Normalize ranks (1-32) to 0.2-1.0 scale (higher score = better for player)
      const scores = ranks.map(r => 0.2 + (Math.max(1, 32 - r) / 32) * 0.8);

      angles.forEach((angle, i) => {
        const val = scores[i] || 0.5;
        const x = center + radius * val * Math.cos(angle);
        const y = center + radius * val * Math.sin(angle);
        points.push(`${x},${y}`);
      });

      return `
        <svg viewBox="0 0 ${size} ${size}" style="width:100%; height:100%;">
          <!-- Background webs -->
          <circle cx="${center}" cy="${center}" r="${radius}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5" />
          <circle cx="${center}" cy="${center}" r="${radius * 0.5}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5" />
          ${angles.map(a => `<line x1="${center}" y1="${center}" x2="${center + radius * Math.cos(a)}" y2="${center + radius * Math.sin(a)}" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" />`).join('')}
          <!-- Data Polygon -->
          <polygon points="${points.join(' ')}" fill="rgba(0,230,118,0.15)" stroke="var(--accent-green)" stroke-width="1.5" stroke-linejoin="round" />
        </svg>
      `;
    }

    /**
     * Build a momentum gauge SVG.
     * Shows current pace vs the line.
     */
    /**
     * ── PROPEDGE WIN-PROBABILITY RADAR ENGINE ────────────────────────────────
     * Calculates Bayesian win probability based on pregame edge + current pace.
     */
    function calculateLiveWinProb(p, stat, elapsed, total) {
      if (!total || !p.line) return 50;
      
      const pregameProb = p.trueProb || (p.modelScore / 100) || 0.52;
      const currentPace = (stat / elapsed) * total;
      
      // Calculate Z-Score based on remaining time and typical volatility
      const remainingTimePct = (total - elapsed) / total;
      if (remainingTimePct <= 0) return stat > p.line ? 100 : 0;

      // ── Clutch & Blowout Multipliers ──
      let situationalMultiplier = 1.0;
      const game = getGameInfo(p.team, p.league, p.gameId);
      if (game && game.status === 'live') {
        const diff = Math.abs(game.homeScore - game.awayScore);
        const isLate = (p.league === 'NBA' && game.period >= 4) || (p.league === 'NHL' && game.period >= 3);
        
        if (isLate) {
          if (diff <= 5) {
            // CLUTCH: Superstars stay in, usage spikes
            situationalMultiplier = 1.15;
          } else if (diff >= 20) {
            // BLOWOUT: Benchings likely, pace slows
            situationalMultiplier = 0.65;
          }
        }
      }

      // Simple Bayesian update: we weight the current pace more as the game nears completion
      const paceWeight = 1 - remainingTimePct;
      const liveTrendProb = (currentPace * situationalMultiplier) > p.line ? 0.85 : 0.15;
      
      let winProb = (pregameProb * (1 - paceWeight)) + (liveTrendProb * paceWeight);
      if (p.direction === 'UNDER') winProb = 1 - winProb;
      
      return Math.min(99, Math.max(1, Math.round(winProb * 100)));
    }

    /**
     * ── CANNIBALIZATION ENGINE ──────────────────────────────────────────────
     * Detects negatively correlated overlap in the parlay slip.
     */
    function checkParlayCorrelation() {
      const container = document.getElementById('parlayCorrelationSection') || (() => {
        const div = document.createElement('div');
        div.id = 'parlayCorrelationSection';
        const pSummary = document.querySelector('.parlay-summary');
        if (pSummary) pSummary.insertBefore(div, pSummary.firstChild);
        return div;
      })();
      
      container.innerHTML = '';
      if (state.parlay.length < 2) return;

      const teamGroup = {};
      state.parlay.forEach(p => {
        if (!teamGroup[p.team]) teamGroup[p.team] = [];
        teamGroup[p.team].push(p);
      });

      let warnings = [];
      Object.entries(teamGroup).forEach(([team, props]) => {
        if (props.length >= 2) {
          const overPoints = props.filter(p => p.direction === 'OVER' && p.propType.toLowerCase().includes('pts'));
          if (overPoints.length >= 2) {
            warnings.push({
              title: 'Cannibalization Alert',
              msg: `${overPoints.map(p => p.player.split(' ').pop()).join(' & ')} are fighting for the same points on ${team}.`,
              type: 'warning'
            });
          }
        }
      });

      if (warnings.length > 0) {
        container.innerHTML = warnings.map(w => `
          <div style="background:rgba(255, 145, 0, 0.1); border:1px solid rgba(255, 145, 0, 0.3); border-radius:8px; padding:10px; margin-bottom:12px; display:flex; gap:10px; align-items:flex-start;">
            <span style="font-size:16px;">⚠️</span>
            <div>
              <div style="font-size:11px; font-weight:800; color:var(--accent-orange); text-transform:uppercase; letter-spacing:0.5px;">${w.title}</div>
              <div style="font-size:12px; color:#fff; margin-top:2px; line-height:1.4;">${w.msg}</div>
            </div>
          </div>
        `).join('');
      }
    }

    /**
     * Build momentum gauge SVG for live tracking
     */
    function buildMomentumGaugeSVG(liveStat, propLine, elapsed, total) {
      const predictedFinal = (liveStat / elapsed) * total;
      const pct = Math.min(100, Math.round((predictedFinal / propLine) * 100));
      const momentumColor = predictedFinal >= propLine ? 'var(--accent-green)' : predictedFinal >= propLine * 0.85 ? 'var(--accent-gold)' : 'var(--accent-red)';

      return `
        <svg viewBox="0 0 160 90" style="width:100%; height:100%;">
          <defs>
            <linearGradient id="momentumGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:var(--accent-red);stop-opacity:0.3" />
              <stop offset="50%" style="stop-color:var(--accent-gold);stop-opacity:0.3" />
              <stop offset="100%" style="stop-color:var(--accent-green);stop-opacity:0.3" />
            </linearGradient>
          </defs>
          <!-- Background bar -->
          <rect x="20" y="30" width="120" height="24" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
          <!-- Progress fill -->
          <rect x="20" y="30" width="${Math.max(2, (pct / 100) * 120)}" height="24" rx="4" fill="${momentumColor}" opacity="0.6" />
          <!-- Center line at propLine -->
          <line x1="${20 + (propLine / (propLine * 1.25)) * 120}" y1="25" x2="${20 + (propLine / (propLine * 1.25)) * 120}" y2="58" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-dasharray="2,2" />
          <!-- Text -->
          <text x="80" y="50" text-anchor="middle" font-family="JetBrains Mono" font-size="16" font-weight="800" fill="#fff">${liveStat}/${propLine}</text>
        </svg>
      `;
    }

    function buildLiveRadarGauge(p, stat, elapsed, total) {
      if (!total || !p.line) return '';
      const winProb = calculateLiveWinProb(p, stat, elapsed, total);
      const pace = (stat / elapsed) * total;
      const isOver = p.direction === 'OVER';
      
      // Calculate rotation for the needle (0 to 180 degrees)
      const rotation = (winProb / 100) * 180 - 90; 
      const color = winProb >= 70 ? 'var(--accent-green)' : winProb >= 40 ? 'var(--accent-gold)' : 'var(--accent-red)';
      
      return `
        <svg viewBox="0 0 140 80" style="width:100%; height:100%;">
          <defs>
            <linearGradient id="radarGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:var(--accent-red);stop-opacity:0.2" />
              <stop offset="50%" style="stop-color:var(--accent-gold);stop-opacity:0.2" />
              <stop offset="100%" style="stop-color:var(--accent-green);stop-opacity:0.2" />
            </linearGradient>
            <filter id="radarGlow">
              <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
              <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <!-- Background Radar Arc -->
          <path d="M20 70 A 50 50 0 0 1 120 70" fill="none" stroke="url(#radarGradient)" stroke-width="12" stroke-linecap="round" />
          <path d="M20 70 A 50 50 0 0 1 120 70" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="2" stroke-dasharray="2,4" />
          
          <!-- Win Probability Sweep -->
          <path d="M20 70 A 50 50 0 0 1 ${70 + 50 * Math.cos((rotation - 90) * Math.PI / 180)} ${70 + 50 * Math.sin((rotation - 90) * Math.PI / 180)}" 
                fill="none" stroke="${color}" stroke-width="12" stroke-linecap="round" opacity="0.3" filter="url(#radarGlow)" />

          <!-- Center Pivot -->
          <circle cx="70" cy="70" r="4" fill="#fff" />
          <circle cx="70" cy="70" r="8" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
          
          <!-- The Needle -->
          <line x1="70" y1="70" x2="${70 + 45 * Math.cos((rotation - 90) * Math.PI / 180)}" y2="${70 + 45 * Math.sin((rotation - 90) * Math.PI / 180)}" 
                stroke="#fff" stroke-width="3" stroke-linecap="round" filter="url(#radarGlow)" />
                
          <!-- Win Prob Text -->
          <text x="70" y="45" text-anchor="middle" font-family="JetBrains Mono" font-size="18" font-weight="800" fill="#fff">${winProb}%</text>
          <text x="70" y="62" text-anchor="middle" font-family="Outfit" font-size="9" font-weight="700" fill="${color}" style="text-transform:uppercase; letter-spacing:1px;">WIN PROB</text>
        </svg>
      `;
    }


    // ESPN_SPORT_MAP is declared above (shared constant)

    // Prop type → ESPN stat label mapping
    const PROP_STAT_MAP = {
      NBA: {
