    const TEAM_LOGO_SPORT_BY_LEAGUE = {
      NBA: 'nba',
      NFL: 'nfl',
      MLB: 'mlb',
      NHL: 'nhl',
    };

    const TEAM_LOGO_SLUG_OVERRIDES = {
      NBA: {
        NY: 'nyk',
        BRK: 'bkn',
        BKN: 'bkn',
        SAS: 'sa',
        NOP: 'no',
        NO: 'no',
        GSW: 'gsw',
        GS: 'gsw',
        UTA: 'utah',
        UTAH: 'utah',
        WSH: 'was',
      },
      MLB: {
        ATH: 'ath',
        OAK: 'oak',
        SFG: 'sf',
        SF: 'sf',
        SD: 'sd',
        CHW: 'chw',
        CWS: 'chw',
        WSH: 'wsh',
        WAS: 'wsh',
      },
      NHL: {
        VGK: 'vgk',
        VEG: 'vgk',
        TBL: 'tb',
        TB: 'tb',
        SJS: 'sj',
        SJ: 'sj',
        LAK: 'la',
        LA: 'la',
