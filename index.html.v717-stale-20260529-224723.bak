<meta name="theme-color" content="#ff6a00">
  <title>PropEdge</title>
  <meta name="app-version" content="v7.17-player-detail-card-tap">
  <script>
    // PropEdge storage adapter
    // Runs before all app code so stable features and newer features can share
    // one safe in-memory storage API inside sandboxed previews.
    var propEdgeStorage = window.propEdgeStorage = (function () {
      var memory = new Map();

      function keys() {
        return Array.from(memory.keys());
      }

      return {
        get length() { return memory.size; },
        key: function (index) {
          return keys()[index] || null;
        },
        getItem: function (key) {
          key = String(key);
          return memory.has(key) ? memory.get(key) : null;
        },
        setItem: function (key, value) {
          key = String(key);
          value = String(value);
          memory.set(key, value);
        },
        removeItem: function (key) {
          key = String(key);
          memory.delete(key);
        },
        clear: function () {
          memory.clear();
        }
      };
    })();

    // Static-preview compatibility layer.
    // The full app can still run from one HTML file without Netlify functions.
    // Remote AI endpoints fall back to in-page analysis so the board never throws
    // 404s or blocks props from rendering.
    var propEdgeNativeFetch = window.fetch ? window.fetch.bind(window) : null;

    // PropEdge Ollama / Gemma configuration.
    // Default model: gemma3:4b (Google Gemma 3, 4B params). Pull on the host with:
    //   ollama pull gemma3:4b
    // Override at runtime without editing the file:
    //   localStorage.setItem('propedge.ollamaBase', 'https://your-mac.your-tailnet.ts.net');
    //   localStorage.setItem('propedge.ollamaModel', 'gemma3:4b');
    // Or via URL: ?ollama=https://your-mac.ts.net&model=gemma3:4b
    //
    // "Serverless" caveat: Ollama itself is a long-running local server. To call it
    // from a deployed (HTTPS) Netlify site, use a Tailscale Serve / Funnel HTTPS URL
    // (mixed-content blocks plain http://100.x.x.x). See README/Ollama setup notes.
    function propEdgeReadConfig(key, fallback) {
      try {
        var qs = new URLSearchParams(window.location.search);
        var qv = qs.get(key === 'propedge.ollamaBase' ? 'ollama' : 'model');
        if (qv) return qv;
        var lv = window.localStorage && window.localStorage.getItem(key);
        if (lv) return lv;
      } catch (_) {}
      return fallback;
    }
    var PROPEDGE_OLLAMA_BASE = propEdgeReadConfig('propedge.ollamaBase', '');
    var PROPEDGE_OLLAMA_MODEL = propEdgeReadConfig('propedge.ollamaModel', 'gemma4:e4b');
    var PROPEDGE_OLLAMA_ENDPOINTS = (function () {
      var list = [];
      if (PROPEDGE_OLLAMA_BASE) {
        list.push(PROPEDGE_OLLAMA_BASE.replace(/\/$/, '') + '/api/chat');
      }
      // Local endpoints blocked by CORS in browser — only add if tunnel is configured
      // list.push('http://127.0.0.1:11434/api/chat');
      // list.push('http://localhost:11434/api/chat');
      return list;
    })();

    function propEdgeSafeJsonParse(value) {
      if (!value) return {};
      if (typeof value === 'object') return value;
      try { return JSON.parse(value); } catch (_) { return {}; }
    }

    function propEdgeBuildOllamaPrompt(prompt, context) {
      var safeContext = context || {};
      return [
        'User ask:',
        prompt || safeContext.prompt || 'Recommend the best available props.',
        '',
        'PropEdge context JSON:',
        JSON.stringify(safeContext).slice(0, 22000)
      ].join('\n');
    }

    async function propEdgeCallOllama(prompt, context) {
      if (!propEdgeNativeFetch) throw new Error('Fetch is unavailable in this browser.');

      var systemPrompt = [
        'You are PropEdge Ask an Analyst, a sharp sports props analyst.',
        'Use only the supplied PropEdge board data. Do not invent players, lines, odds, injuries, or games.',
        'Answer in a Linemaker-style format with these exact sections:',
        'PLUS EV ANALYSIS, BEST PLAYER PROPS, MATCHUP BREAKDOWN, NO-BET / RISK NOTES.',
        'For every recommended pick, include player, market, line, odds if supplied, model probability, implied probability, edge, action, and a short reason.',
        'If the data is weak or unavailable, say PASS or no-bet instead of forcing a play.',
        'Keep the tone direct, numbers-first, and concise. Never speculate beyond the supplied data.'
      ].join(' ');

      var body = {
        model: PROPEDGE_OLLAMA_MODEL,
        stream: false,
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: propEdgeBuildOllamaPrompt(prompt, context) }
        ],
        options: {
          temperature: 0.2,
          num_ctx: 8192,
          num_predict: 900
        }
      };

      var lastError = null;
      for (var i = 0; i < PROPEDGE_OLLAMA_ENDPOINTS.length; i++) {
        try {
          var response = await propEdgeNativeFetch(PROPEDGE_OLLAMA_ENDPOINTS[i], {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
          });
          if (!response.ok) throw new Error('Ollama HTTP ' + response.status);
          var data = await response.json();
          var content = data && data.message && data.message.content ? data.message.content : data.response;
          if (content && String(content).trim()) return String(content).trim();
          throw new Error('Ollama returned an empty response.');
        } catch (err) {
          lastError = err;
        }
      }
      throw lastError || new Error('Ollama unavailable.');
    }

    if (propEdgeNativeFetch) {
      window.fetch = function (input, init) {
        var url = typeof input === 'string' ? input : (input && input.url) || '';
        if (url.indexOf('/.netlify/functions/ai-recommendations') !== -1) {
          var requestBody = propEdgeSafeJsonParse(init && init.body);
          var context = requestBody.context || requestBody;
          var prompt = requestBody.prompt || context.prompt || 'Recommend the best available props from the current board.';
          return propEdgeCallOllama(prompt, context).then(function (analysis) {
            return new Response(JSON.stringify({
              recommendations: [],
              parlays: [],
              analysis: analysis,
              provider: 'ollama',
              model: PROPEDGE_OLLAMA_MODEL,
              disclaimer: 'Generated by local Ollama (' + PROPEDGE_OLLAMA_MODEL + ') from the supplied PropEdge board data.'
            }), { status: 200, headers: { 'Content-Type': 'application/json' } });
          }).catch(function (err) {
            console.warn('[Ollama] Falling back to in-page PropEdge analysis:', err && err.message ? err.message : err);
            return new Response(JSON.stringify({
              recommendations: [],
              parlays: [],
              analysis: null,
              provider: 'propedge-fallback',
              error: err && err.message ? err.message : 'Ollama unavailable',
              disclaimer: 'Static PropEdge fallback: recommendations are generated from the loaded prop board.'
            }), { status: 200, headers: { 'Content-Type': 'application/json' } });
          });
        }
        if (url.indexOf('/.netlify/functions/ai-feedback') !== -1) {
          return Promise.resolve(new Response(JSON.stringify({ ok: true }), {
            status: 200,
            headers: { 'Content-Type': 'application/json' }
          }));
        }
        if (url.indexOf('api.sportsgameodds.com') !== -1) {
          return Promise.resolve(new Response(JSON.stringify({
            sports: [],
            fallback: true,
            message: 'Static PropEdge fallback: using sheet lines instead of live SportsGameOdds API.'
          }), { status: 200, headers: { 'Content-Type': 'application/json' } }));
        }
        return propEdgeNativeFetch(input, init);
      };
    }
  </script>
