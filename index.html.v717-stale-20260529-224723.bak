        UTA: 'utah',
        UTAH: 'utah',
      },
      NFL: {
        WSH: 'wsh',
        WAS: 'wsh',
        JAX: 'jax',
        ARI: 'ari',
      },
    };

    function getDynamicTeamLogoUrl(teamAbbr, league) {
      const safeAbbr = (teamAbbr || '').toString().toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 4);
      const sport = TEAM_LOGO_SPORT_BY_LEAGUE[league];
      if (!safeAbbr || !sport) return '';
      const overrides = TEAM_LOGO_SLUG_OVERRIDES[league] || {};
      const slug = overrides[safeAbbr] || safeAbbr.toLowerCase();
      return `${ESPN_BASE}/${sport}/500/${slug}.png`;
    }

    function teamLogoFallbackHTML(teamAbbr) {
      const abbr = (teamAbbr || 'TEAM').toString().toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 4) || 'TEAM';
      return `<span class="team-logo-fallback" aria-label="${abbr} logo fallback">${abbr}</span>`;
    }

    function getTeamLogo(teamAbbr, league) {
      const abbr = teamAbbr ? teamAbbr.toString().toUpperCase() : '';
      const safeAbbr = abbr.replace(/[^A-Z0-9]/g, '').slice(0, 4) || 'TEAM';
      const fallback = teamLogoFallbackHTML(safeAbbr).replace(/"/g, '&quot;');
      const byLeague = league && TEAM_LOGOS_BY_LEAGUE[league] ? (TEAM_LOGOS_BY_LEAGUE[league][safeAbbr] || TEAM_LOGOS_BY_LEAGUE[league][abbr]) : '';
      const url = byLeague || TEAM_LOGOS[safeAbbr] || TEAM_LOGOS[abbr] || getDynamicTeamLogoUrl(safeAbbr, league);

      if (url) {
        return `<img src="${url}" alt="${safeAbbr} logo" loading="lazy" decoding="async" style="width:28px;height:28px;object-fit:contain;border-radius:4px;" onerror="this.outerHTML='${fallback}'" />`;
      }
      return teamLogoFallbackHTML(safeAbbr);
    }

