      if (!prop) return;
      const pick = `${prop.player} ${prop.direction} ${prop.line} ${prop.prop}`;
      navigator.clipboard.writeText(pick).then(() => {
        showToast('Pick copied — paste in Gambly to shop other books');
        window.open('https://gambly.com/gambly-bot', '_blank');
      }).catch(() => {
        window.open('https://gambly.com/', '_blank');
      });
    };

    function openGamblyBot() {
      if (state.parlay.length === 0) {
        showToast('Add props to your parlay first');
        return;
      }
      
      // Format picks for Gambly - natural language format works best
      const picks = state.parlay.map(p => 
        `${p.player} ${p.direction} ${p.line} ${p.prop}`
      ).join(', ');
      
      // Copy to clipboard first
      navigator.clipboard.writeText(picks).then(() => {
        showToast('Picks copied! Paste in Gambly chat');
        // Open Gambly bot page
        window.open('https://gambly.com/gambly-bot', '_blank');
      }).catch(() => {
        // If clipboard fails, just open Gambly
        window.open('https://gambly.com/', '_blank');
        showToast('Opening Gambly...');
      });
    }

    // Gambly bot numbers:
    //  iOS (iMessage):   646-567-9746
    //  Android (SMS):    305-857-2288
    const GAMBLY_IOS     = '16465679746';
    const GAMBLY_ANDROID = '13058572288';

    function textPicks(platform) {
      if (state.parlay.length === 0) {
        showToast('Add props to your parlay first');
        return;
      }

      const picks = state.parlay.map(p =>
        `${p.player} ${p.direction} ${p.line} ${p.prop}`
      ).join(', ');

      const message = `PropEdge picks: ${picks}`;

      // Auto-detect if no platform passed
      if (!platform) {
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
        platform = isIOS ? 'ios' : 'android';
      }

      const phoneNumber = platform === 'ios' ? GAMBLY_IOS : GAMBLY_ANDROID;
      const label       = platform === 'ios' ? 'iPhone (646-567-9746)' : 'Android (305-857-2288)';

      // iMessage uses & as separator, SMS uses ?
      const separator = platform === 'ios' ? '&' : '?';
      const smsUrl = `sms:+${phoneNumber}${separator}body=${encodeURIComponent(message)}`;
      window.location.href = smsUrl;
      showToast(`Opening Gambly Bot for ${label}...`);
    }

    function logParlay() {
      if (state.parlay.length === 0) {
        showToast('Add props to your parlay first');
        return;
      }

      // Pull wager from the UI input if available, fallback to 10
      const wagerEl = document.getElementById('wagerAmount');
      const wager = wagerEl ? parseFloat(wagerEl.value) : 10;

      // Create parlay bet object
      const parlayBet = {
        legs: state.parlay.map(p => ({
          player: p.player,
          league: p.league,
          prop: p.prop,
          direction: p.direction,
          line: p.line,
          edge: p.edge || 0
        })),
        wager: wager,
        timestamp: new Date().toISOString(),
        status: 'tracked',
        type: 'parlay',
        avgEdge: state.parlay.reduce((sum, p) => sum + (p.edge || 0), 0) / state.parlay.length
      };

      // Add to portfolio (same as individual props)
      const roiTracker = JSON.parse(propEdgeStorage.getItem('propEdgeROI') || '[]');
      roiTracker.push(parlayBet);
      saveROI(roiTracker);

      console.log('[PropEdge Parlay] Saved to propEdgeStorage:', parlayBet);
      showToast(`✅ ${state.parlay.length}-leg parlay logged - $${wager.toFixed(2)}`);

      // Clear parlay state and wager
      state.parlay = [];
      saveParlay();
      propEdgeStorage.removeItem('propEdgeParlaywager');

      // Switch to portfolio view and refresh
      setTimeout(() => {
        try {
          console.log('[PropEdge] Starting portfolio switch...');
          state.view = 'portfolio';

          // Update active tab
          document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
          const portfolioTab = document.querySelector('[data-view="portfolio"]');
          if (portfolioTab) {
            portfolioTab.classList.add('active');
            console.log('[PropEdge] Portfolio tab activated');
          } else {
            console.warn('[PropEdge] Portfolio tab not found');
          }

          // Hide only the other containers, show portfolio
          document.getElementById('propsContainer').style.display = 'none';
          document.getElementById('gamesContainer').style.display = 'none';
          document.getElementById('newsContainer').style.display = 'none';
          document.getElementById('injuriesContainer').style.display = 'none';
          document.getElementById('parlayContainer').style.display = 'none';
          document.getElementById('strategyContainer').style.display = 'none';
          document.getElementById('paceContainer').style.display = 'none';
          document.getElementById('recommendationsContainer').style.display = 'none';

          // Show portfolio container
          const portfolioContainer = document.getElementById('portfolioContainer');
          if (portfolioContainer) {
            portfolioContainer.style.display = 'block';
            console.log('[PropEdge] Portfolio container shown');
          } else {
            console.error('[PropEdge] Portfolio container not found!');
            return;
          }

          // Render portfolio
          console.log('[PropEdge] Calling renderPortfolio...');
          renderPortfolio();
          console.log('[PropEdge] renderPortfolio completed');
        } catch (err) {
          console.error('[PropEdge] Error switching to portfolio:', err.message, err.stack);
          showToast('Error displaying portfolio');
        }
      }, 200);

      console.log('[PropEdge Parlay] Logged parlay:', parlayBet);
    }


