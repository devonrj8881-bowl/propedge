// server.js
const express = require('express');
const fetch = require('node-fetch');
const bodyParser = require('body-parser');

const app = express();
app.use(bodyParser.json());

const OLLAMA_URL = 'http://localhost:11434/api/chat';
const MODEL_NAME = 'deepseek-coder'; // or another Ollama model you want

// Minimal Anthropic-compatible messages.create endpoint
app.post('/v1/messages', async (req, res) => {
  try {
    const { messages, model } = req.body;

    if (!messages || !Array.isArray(messages)) {
      return res.status(400).json({ error: 'Missing messages array in request body' });
    }

    // Convert Anthropic-style messages to Ollama format
    const ollamaMessages = messages.map(m => ({
      role: m.role === 'assistant' ? 'assistant' : 'user',
      content: typeof m.content === 'string'
        ? m.content
        : JSON.stringify(m.content),
    }));

    const ollamaBody = {
      model: MODEL_NAME,
      messages: ollamaMessages,
      stream: false,
    };

    const ollamaResp = await fetch(OLLAMA_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(ollamaBody),
    });

    if (!ollamaResp.ok) {
      const text = await ollamaResp.text();
      console.error('Ollama error:', text);
      return res.status(500).json({ error: 'Ollama request failed', details: text });
    }

    const data = await ollamaResp.json();
    const content = data.message?.content || '';

    // Wrap into Anthropic-style response
    const anthropicResponse = {
      id: 'msg_ollama_' + Date.now(),
      type: 'message',
      role: 'assistant',
      model: model || MODEL_NAME,
      content: [
        {
          type: 'text',
          text: content,
        },
      ],
      stop_reason: 'end_turn',
      usage: {
        input_tokens: 0,
        output_tokens: 0,
      },
    };

    res.json(anthropicResponse);
  } catch (err) {
    console.error('Proxy errclear
clear

